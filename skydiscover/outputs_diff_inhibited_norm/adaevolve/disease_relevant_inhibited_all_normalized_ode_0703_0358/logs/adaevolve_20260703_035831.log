 125 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 126 |     """Load paired inhibitor data.tsv and return X=[time, m0, M0, cd, c], y.
 127 | 
 128 |     The first three static features follow the non-inhibited benchmark
 129 |     convention. The additional cd feature is the inhibitor concentration parsed
 130 |     from each curve header. P0 is preserved in headers but not exposed as an ODE
 131 |     feature, matching the previous benchmark's use of M0 as the seed feature.
 132 |     """
 133 |     with data_file.open(newline="") as f:
 134 |         reader = csv.reader(f, delimiter="\t")
 135 |         header = next(reader)
 136 |         rows = [row for row in reader if row]
 137 | 
 138 |     features: list[list[float]] = []
 139 |     targets: list[float] = []
 140 |     curve_ids: list[int] = []
 141 |     curve_id = 0
 142 |     for col_idx in range(len(header) - 1):
 143 |         x_header = header[col_idx]
 144 |         y_header = header[col_idx + 1]
 145 |         if not (_is_x_column(x_header) and _is_y_column(y_header)):
 146 |             continue
 147 | 
 148 |         monomer = _parse_metadata_number(x_header, "m0")
 149 |         seed = _parse_metadata_number(x_header, "M0")
 150 |         inhibitor = _parse_metadata_number(x_header, "cd")
 151 |         if monomer is None or seed is None or inhibitor is None:
 152 |             continue
 153 | 
 154 |         for row in rows:
 155 |             if col_idx + 1 >= len(row):
 156 |                 continue
 157 |             time_value = row[col_idx].strip()
 158 |             response_value = row[col_idx + 1].strip()
 159 |             if (
 160 |                 not time_value
 161 |                 or not response_value
 162 |                 or time_value.lower() == "nan"
 163 |                 or response_value.lower() == "nan"
 164 |             ):
 165 |                 continue
 166 |             features.append([float(time_value), monomer, seed, inhibitor])
 167 |             targets.append(float(response_value))
 168 |             curve_ids.append(curve_id)
 169 |         curve_id += 1
 170 | 
 171 |     if not features:
 172 |         raise ValueError(f"No regression samples loaded from {data_file}")
 173 | 
 174 |     X = np.asarray(features, dtype=float)
 175 |     y = np.asarray(targets, dtype=float)
 176 |     time_norm = _base._minmax_normalize(X[:, 0])
 177 |     y_norm = _base._minmax_normalize(y)
 178 | 
 179 |     X_ode = np.column_stack([time_norm, X[:, 1], X[:, 2], X[:, 3], y_norm])
 180 |     curve_ids_array = np.asarray(curve_ids, dtype=int)
 181 |     X_ode, y_norm, curve_ids_array = _thin_curves(X_ode, y_norm, curve_ids_array)
 182 |     return _base._remember_curve_ids(X_ode, curve_ids_array), y_norm
