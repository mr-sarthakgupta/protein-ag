import numpy as np, re
p='disease_relevant_inhibited_clean/Abeta42/inhibition_constraints/data.tsv'
with open(p) as f:
    hdr=f.readline().rstrip('\n').split('\t')
data=np.genfromtxt(p,delimiter='\t',skip_header=1)
# pick cd=0 vs cd=2e-6 same m0=3e-6
for i in range(0,len(hdr),2):
    h=hdr[i]
    cd=re.search(r'cd:([0-9.eE+-]+)',h).group(1)
    m0=re.search(r'm0:([0-9.eE+-]+)',h).group(1)
    if m0=='3e-6' and 'rep:1' in h:
        y=data[:,i+1]; x=data[:,i]
        y=y[~np.isnan(y)]; x=x[~np.isnan(x)]
        # find half response time
        yn=(y-y.min())/(y.max()-y.min())
        idx=np.argmin(np.abs(yn-0.5))
        print(f'cd={cd} y0={y[0]:.3f} yend={y[-1]:.3f} t_half={x[idx]:.1f} n={len(y)}')
"
