import numpy as np, re
p='disease_relevant_inhibited_clean/Abeta42/inhibition_constraints/data.tsv'
data=np.genfromtxt(p,delimiter='\t',skip_header=1)
with open(p) as f:
    header=f.readline().rstrip('\n').split('\t')
def lead(s):
    m=re.search(r'[-+]?\d*\.?\d+(?:[eE][-+]?\d+)?',s)
    return float(m.group())
# global y range
ys=data[:,1::2]
print('y global min/max', np.nanmin(ys), np.nanmax(ys))
# for a few curves print y at start/end and normalized start
for i in range(0,192,2):
    h=header[i]
    d=dict(kv.split(':') for kv in h.replace(' X','').split('_') if ':' in kv)
    x=data[:,i]; y=data[:,i+1]
    m=~np.isnan(x)&~np.isnan(y)
    x=x[m];y=y[m]
    if len(y)<3: continue
    if i in (0,20,40,60,80,120,160,188):
        print(f'cd={d[\"cd\"]} M0={d[\"M0\"]} m0={d[\"m0\"]} y0={y[0]:.3f} yend={y[-1]:.3f} n={len(y)}')
"
