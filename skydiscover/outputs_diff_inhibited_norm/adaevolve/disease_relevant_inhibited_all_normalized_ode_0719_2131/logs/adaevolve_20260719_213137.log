 808 |     for curve_id in dict.fromkeys(np.asarray(curve_ids, dtype=int)):
 809 |         idx = np.flatnonzero(curve_ids == curve_id)
 810 |         if idx.size < 5:
 811 |             continue
 812 |         order = idx[np.argsort(X[idx, 0])]
 813 |         x = X[order, 0]
 814 |         true_curve = y_true[order]
 815 |         pred_curve = y_pred[order]
 816 |         dx = np.diff(x)
