t0=time.time()
r=ev.evaluate_ode_expression(expr,Xtr,ytr,Xval,yval,constants=c,
    initial_values=[0.3,0.5,0.1,1.0,0.5,1.0,0.0,0.0,0.01,1.0,0.5])
