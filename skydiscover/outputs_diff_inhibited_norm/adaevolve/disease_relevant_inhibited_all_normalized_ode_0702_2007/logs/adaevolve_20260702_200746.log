ds=ev.load_all_datasets(); name,Xtr,Xval,ytr,yval=ds[0]
x=feature_symbols(Xtr.shape[1]); t_,monomer,seed,inhibitor,concentration=x
c=constant_symbols(11)
inhibitor_scale=1+c[5]**2*inhibitor+c[6]**2*inhibitor*monomer
source_rate=(c[0]**2*monomer**c[1]+c[2]**2*seed)/inhibitor_scale
autocatalytic_rate=(c[3]**2*monomer**c[4]*(1+c[7]**2*seed)/inhibitor_scale)
baseline_flux=c[8]**2; plateau=c[9]; capacity=plateau-concentration
# replace time term with quadratic autocatalysis (secondary nucleation)
