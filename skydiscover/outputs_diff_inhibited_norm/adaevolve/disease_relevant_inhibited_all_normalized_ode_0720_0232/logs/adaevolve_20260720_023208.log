  31 |     inhibitor = x[3]
  32 |     concentration = x[4]
  33 | 
  34 |     plateau = 1 + c[0] ** 2
  35 |     capacity = plateau - concentration
  36 |     log_capacity = sp.log(1 + capacity ** 2 + c[1] ** 2)
  37 |     inhibitor_scale = 1 + c[2] ** 2 * inhibitor
  38 |     source = c[3] ** 2 + c[4] ** 2 * monomer + c[5] ** 2 * seed
  39 |     autocatalysis = c[6] ** 2 * concentration * (1 + c[7] ** 2 * seed)
  40 |     expression = capacity * log_capacity * (source + autocatalysis) / inhibitor_scale + c[8] * time * capacity
  41 | 
  42 |     return evaluate_expression(
