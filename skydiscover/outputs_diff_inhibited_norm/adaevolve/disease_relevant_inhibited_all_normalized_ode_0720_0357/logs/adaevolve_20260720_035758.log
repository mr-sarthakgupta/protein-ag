  24 |     """Single-equation inhibited aggregation ODE seed."""
  25 |     x = feature_symbols(X_train.shape[1])
  26 |     c = constant_symbols(8)
  27 | 
  28 |     time = x[0]
  29 |     monomer = x[1]
  30 |     seed = x[2]
  31 |     inhibitor = x[3]
  32 |     concentration = x[4]
  33 | 
  34 |     plateau = c[0]
  35 |     capacity = plateau - concentration
  36 |     free_monomer = monomer / (1 + c[1] ** 2 * inhibitor + c[2] ** 2 * inhibitor * monomer)
  37 |     source = c[3] ** 2 + c[4] ** 2 * free_monomer + c[5] ** 2 * seed
  38 |     secondary = c[6] ** 2 * free_monomer * concentration * (1 + concentration)
  39 |     expression = capacity * (source + secondary) + c[7] * time * capacity
  40 | 
  41 |     return evaluate_expression(
  42 |         expression,
