 824 |     for curve_id in dict.fromkeys(np.asarray(curve_ids, dtype=int)):
 825 |         idx = np.flatnonzero(curve_ids == curve_id)
 826 |         if idx.size < 5:
 827 |             continue
 828 |         order = idx[np.argsort(X[idx, 0])]
 829 |         x = X[order, 0]
 830 |         true_curve = y_true[order]
 831 |         pred_curve = y_pred[order]
 832 |         dx = np.diff(x)
