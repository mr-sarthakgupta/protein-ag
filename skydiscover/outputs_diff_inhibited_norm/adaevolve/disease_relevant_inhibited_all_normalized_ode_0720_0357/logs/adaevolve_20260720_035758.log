 837 |         pred_slope = np.diff(pred_curve)[valid_dx] / dx[valid_dx]
 838 |         slope_scale = float(np.mean(true_slope**2))
 839 |         slope_raw = float(np.mean((pred_slope - true_slope) ** 2))
 840 |         slope_loss = (
 841 |             _bounded_loss(slope_raw / slope_scale)
 842 |             if slope_scale > 0.0
