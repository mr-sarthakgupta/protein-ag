$ python3 -c "
import csv,collections
rows=collections.defaultdict(list)
with open('disease_relevant_inhibited_all_normalized_ode/repeat_variability_analysis_20260704_2021/average_curves_by_setting.csv') as f:
    for r in csv.DictReader(f):
        rows[r['setting']].append((float(r['time']),float(r['mean_y'])))
import numpy as np
def cross(ts,ys,frac):
    ys=np.array(ys);ts=np.array(ts)
    lo,hi=ys.min(),ys.max()
    tgt=lo+frac*(hi-lo)
    for i in range(1,len(ys)):
        if ys[i]>=tgt:
            return ts[i]
    return ts[-1]
for s in sorted(rows):
    if 'cd:0_' in s: continue
    d=sorted(rows[s])
    ts=[t for t,_ in d];ys=[y for _,y in d]
    print(s, 'ymax=%.2f'%max(ys),'t10=%.3f t50=%.3f t90=%.3f'%(cross(ts,ys,.1),cross(ts,ys,.5),cross(ts,ys,.9)))
"
