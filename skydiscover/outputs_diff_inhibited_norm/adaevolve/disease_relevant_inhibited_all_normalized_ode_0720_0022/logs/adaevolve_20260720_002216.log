  30 |     seed = x[2]
  31 |     inhibitor = x[3]
  32 |     concentration = x[4]
  33 | 
  34 |     plateau = c[0]
  35 |     capacity = plateau - concentration
  36 |     bound_fraction = 1 / (1 + c[1] ** 2 * inhibitor + c[2] ** 2 * inhibitor * concentration)
  37 |     source = c[3] ** 2 * monomer + c[4] ** 2 * seed + c[5] ** 2
  38 |     growth = c[6] ** 2 * concentration * (1 + concentration)
  39 |     expression = capacity * bound_fraction * (source + growth) + c[7] * seed * capacity
  40 | 
  41 |     return evaluate_expression(
  42 |         expression,
  43 |         X_train,
  44 |         y_train,
  45 |         X_val,
  46 |         y_val,
