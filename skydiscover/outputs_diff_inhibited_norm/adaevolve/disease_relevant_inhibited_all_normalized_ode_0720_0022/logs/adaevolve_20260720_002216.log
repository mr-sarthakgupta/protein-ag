$ python3 -c "
import csv
from collections import defaultdict
rows=defaultdict(list)
with open('disease_relevant_inhibited_all_normalized_ode/repeat_variability_analysis_20260704_2021/average_curves_by_setting.csv') as f:
    for r in csv.DictReader(f):
        rows[r['setting']].append((float(r['time']),float(r['mean_y'])))
# summarize distinct cd values and t50
import re
setts=sorted(rows)
print('n settings',len(setts))
for s in setts:
    pts=sorted(rows[s])
    ys=[y for t,y in pts]
    ymax=max(ys); ymin=min(ys)
    # t50 crossing
    half=ymin+0.5*(ymax-ymin)
    t50=None
    for i in range(1,len(pts)):
        if pts[i][1]>=half:
            t50=pts[i][0]; break
    m=re.search(r'cd:([0-9.e-]+)_m0:([0-9.e-]+)',s)
    print(s, 'ymax=%.2f'%ymax, 't50=%.3f'%(t50 or -1))
"
