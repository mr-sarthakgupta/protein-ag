 821 |         pred_slope = np.diff(pred_curve)[valid_dx] / dx[valid_dx]
 822 |         slope_scale = float(np.mean(true_slope**2))
 823 |         slope_raw = float(np.mean((pred_slope - true_slope) ** 2))
 824 |         slope_loss = (
 825 |             _bounded_loss(slope_raw / slope_scale)
 826 |             if slope_scale > 0.0
 827 |             else _bounded_loss(slope_raw)
 828 |         )
 829 | 
 830 |         timing_losses: list[float] = []
 831 |         for level in SHAPE_TIMING_LEVELS:
 832 |             if level <= 0.0 or level >= 1.0:
 833 |                 continue
 834 |             true_crossing = _half_response_time(x, true_curve, level=level)
 835 |             pred_crossing = _half_response_time(x, pred_curve, level=level)
 836 |             if true_crossing is None and pred_crossing is None:
 837 |                 timing_losses.append(0.0)
 838 |             elif true_crossing is None or pred_crossing is None:
 839 |                 timing_losses.append(1.0)
 840 |             else:
 841 |                 timing_losses.append(
 842 |                     min(abs(float(pred_crossing) - float(true_crossing)), 1.0)
 843 |                 )
 844 |         timing_loss = float(np.mean(timing_losses)) if timing_losses else 0.0
 845 | 
 846 |         # Each trajectory contributes one loss, regardless of how many plateau
 847 |         # points it contains, so easy dense curves cannot hide bad slow curves.
 848 |         curve_losses.append(0.5 * slope_loss + 0.5 * timing_loss)
 849 | 
 850 |     if not curve_losses:
 851 |         return 0.0
 852 |     mean_loss = float(np.mean(curve_losses))
 853 |     worst_curve_loss = float(np.quantile(curve_losses, 0.9))
 854 |     return float(
 855 |         (1.0 - SHAPE_WORST_CURVE_WEIGHT) * mean_loss
 856 |         + SHAPE_WORST_CURVE_WEIGHT * worst_curve_loss
 857 |     )
