  31 |     inhibitor = x[3]
  32 |     concentration = x[4]
  33 | 
  34 |     plateau = c[0]
  35 |     capacity = plateau - concentration
  36 |     time_decay = sp.exp(-c[1] ** 2 * inhibitor * time)
  37 |     inhibitor_scale = 1 + c[2] ** 2 * inhibitor * (1 + concentration)
