  18 | def evaluate_symbolic_candidate(
  19 |     X_train: NDArray,
  20 |     y_train: NDArray,
  21 |     X_val: NDArray,
  22 |     y_val: NDArray,
  23 | ) -> dict[str, Any]:
  24 |     """Single-equation inhibited aggregation ODE seed."""
  25 |     x = feature_symbols(X_train.shape[1])
  26 |     c = constant_symbols(8)
  27 | 
  28 |     time = x[0]
