    i90 = np.argmin(np.abs(y - 0.9))
    z10, z50, z90 = z[i10], z[i50], z[i90]
    if (z50 - z10) > 0:
        asym = (z90 - z50) / (z50 - z10)
    else:
        asym = np.nan
    print(f'nu={nu:.1f}: z10={z10:.2f} z50={z50:.2f} z90={z90:.2f} asym={asym:.2f}')
