# Load the sample dataset properly - as the evaluator does
data_file = 'alphasyn_gaspar2017_03um_seed_all/fit.tsv'
import csv
with open(data_file) as f:
    reader = csv.reader(f, delimiter='\t')
    header = next(reader)
    rows = list(reader)

# Parse like evaluator
params = [1.0, 2.0, 3.0, 5.0, 10.0, 20.0, 30.0, 50.0]
features, targets = [], []
for row in rows:
    if not row: continue
    t = float(row[0])
    for param, val in zip(params, row[1:]):
        if val and val.strip().lower() != 'nan':
            features.append([t, param])
            targets.append(float(val))

X = np.array(features)
y = np.array(targets)
print('X shape:', X.shape)
print('x0 (time) range:', X[:,0].min(), X[:,0].max())
print('x1 (param) range:', X[:,1].min(), X[:,1].max())
print('y range:', y.min(), y.max())
print('y mean:', y.mean(), 'y std:', y.std())

# Check if y is sigmoidal - look at low/high time points
low_t = X[:,0] < 5
high_t = X[:,0] > 20
print('y at low t:', y[low_t].mean())
print('y at high t:', y[high_t].mean())
"
