import numpy as np
import sympy as sp
import sys
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets
from pysr_harness.equation_session import feature_symbols, constant_symbols, fit_expression_constants

all_ds = load_all_datasets()

# Test Avrami/Weibull CDF: y = c0*(1 - exp(-((x0+c2)/c3)^c1)) + c4
# with x1 power-law coupling: c3 = exp(c5 + c6*log(x1))
# This is the stretched exponential / Avrami model for nucleation-growth

def test_avrami(all_ds):
    x = feature_symbols(2)
    c = constant_symbols(8)
    time = x[0]
    parameter = x[1]
    log_param = sp.log(parameter)
    # Avrami: y = c0*(1 - exp(-((x0-c2)/tau)^c1)) + c4
    # tau = c3*x1^c6 + c7*log(x1) (power-law + log coupling for tau)
    tau = c[3] * parameter**c[6] + c[7] * log_param
    # Use max(x0-c2, 0) via (x0-c2+|x0-c2|)/2 -- but we can't use abs
    # Instead use (x0-c2) and let c1 be fractional (not integer)
    # Problem: negative base with fractional exponent is complex
    # Use asinh-shifted time: u = asinh(x0 - c2), then (u/tau)^c1
    u = time - c[2]
    lt = sp.log(u + sp.sqrt(u**2 + 1))  # asinh(x0 - c2)
    expression = c[0] * (1 - sp.exp(-(lt / tau)**c[1])) + c[4]
    iv = [1.0, 2.0, 0.0, 3.0, 0.0, 0.0, 0.0, 0.0]

    results = []
    for name, Xtr, Xv, ytr, yv in all_ds:
        try:
            fitted = fit_expression_constants(expression, Xtr, ytr, Xv, constants=c, initial_values=iv)
            yp = fitted.y_pred_val
            var_y = np.var(yv)
            nmse = np.mean((yp - yv)**2) / var_y if var_y > 0 else float('inf')
            results.append((name, nmse))
        except Exception as e:
            results.append((name, float('inf')))
    return results

results6 = test_avrami(all_ds)
results6.sort(key=lambda x: x[1], reverse=True)
print('Avrami/Weibull - Top 10 worst:')
for name, nmse in results6[:10]:
    print(f'  {nmse:.4f}  {name[:55]}')
print(f'Mean NMSE: {np.mean([r[1] for r in results6 if np.isfinite(r[1])]):.4f}')
