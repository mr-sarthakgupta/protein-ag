import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
import sympy as sp

# Simulate the current best model on a few datasets to understand residuals
datasets = load_all_datasets()

# Current model: logistic in arcsinh-time with power-law x1
# y = c0 / (1 + exp(-c1*x1^c5 * (asinh(x0-c2) - c3*x1^c6))) + c4

def asinh_val(x0, c2):
    u = x0 - c2
    return np.log(u + np.sqrt(u**2 + 1))

def model(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4, c5, c6 = c
    lt = asinh_val(x0, c2)
    rate = c1 * x1**c5
    ht = c3 * x1**c6
    return c0 / (1 + np.exp(-rate * (lt - ht))) + c4

from scipy.optimize import least_squares

nmses = []
for name, X_train, X_val, y_train, y_val in datasets:
    def residuals(c):
        pred = model(X_train, c)
        return pred - y_train
    
    try:
        res = least_squares(residuals, [1.0, 2.0, 0.0, 3.0, 0.0, 0.0, 0.0], max_nfev=300)
        pred_val = model(X_val, res.x)
        var_y = np.var(y_val)
        nmse_v = np.mean((pred_val - y_val)**2) / (var_y if var_y > 0 else 1.0)
        nmses.append((nmse_v, name))
    except Exception as e:
        nmses.append((999.0, name + ' ERR:' + str(e)[:30]))

nmses.sort(reverse=True)
print('Top 10 hardest datasets (highest NMSE):')
for nmse_v, name in nmses[:10]:
    print(f'  {nmse_v:.4f}  {name}')
print(f'Mean NMSE: {np.mean([n for n,_ in nmses]):.4f}')
print(f'Median NMSE: {np.median([n for n,_ in nmses]):.4f}')
"
