import numpy as np, csv, os, re
from scipy.optimize import least_squares

def load_ds(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader); rows = list(reader)
    rh = header[1:]
    def pp(text):
        for pat,sc in [(r'(\d+(?:\.\d+)?)\s*uM',1),(r'(\d+(?:\.\d+)?)\s*mM',1000),
                       (r'pH\s+(\d+(?:\.\d+)?)',1),(r'(\d+(?:\.\d+)?)\s*%',1),
                       (r':\s*(\d+(?:\.\d+)?)\s*$',1)]:
            m = re.search(pat, text, re.IGNORECASE)
            if m: return float(m.group(1))*sc
        return None
    parsed = [pp(h) for h in rh]
    params = [float(p) for p in parsed] if all(p is not None for p in parsed) else [float(i+1) for i in range(len(rh))]
    feat, tgt = [], []
    for row in rows:
        if not row: continue
        t = float(row[0])
        for param, val in zip(params, row[1:]):
            if val and val.strip().lower() != 'nan':
                feat.append([t, param]); tgt.append(float(val))
    return np.array(feat), np.array(tgt)

test_files = ['alphasyn_gaspar2017_03um_seed_all/fit.tsv']
base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
if os.path.exists(base):
    for root, dirs, files in os.walk(base):
        if 'fit.tsv' in files: test_files.append(os.path.join(root, 'fit.tsv'))
        if len(test_files) >= 10: break

print('Checking t=0 presence and time ranges:')
for fpath in test_files:
    X, y = load_ds(fpath)
    name = os.path.basename(os.path.dirname(fpath))
    t_min = X[:,0].min()
    t_max = X[:,0].max()
    has_zero = (X[:,0] == 0).any()
    print(f'{name[:35]}: t=[{t_min:.1f},{t_max:.1f}], has_t0={has_zero}')

# Test Weibull/log-time model
# y = c0 * exp(-exp(-c1*(log(x0+c2) - c3))) + c4
# c3 = log(half_time), c2 = small offset to handle t=0
# init: c0=1, c1=2, c2=1, c3=7, c4=0
# exp(7)=1097 - midpoint between 28 and 57000 on log scale
# log(28)=3.3, log(57000)=10.9, midpoint=7.1 - perfect!
def pred_weibull(theta, X):
    c0,c1,c2,c3,c4 = theta
    x0 = X[:,0]
    lt = np.log(np.maximum(x0 + np.abs(c2), 1e-10))
    return c0*np.exp(-np.exp(np.clip(-c1*(lt-c3),-500,500))) + c4

def pred_weibull_x1(theta, X):
    c0,c1,c2,c3,c4,c5 = theta
    x0,x1 = X[:,0], X[:,1]
    lx1 = np.log(np.maximum(np.abs(x1), 1e-6))
    lt = np.log(np.maximum(x0 + np.abs(c2), 1e-10))
    rate = c1 + c4*lx1
    ht = c3 + c5*lx1
    return c0*np.exp(-np.exp(np.clip(-rate*(lt-ht),-500,500)))

print()
print('Testing Weibull/log-time templates:')
results = {'weibull5':[], 'weibull_x1_6':[]}
for fpath in test_files[:8]:
    try:
        X, y = load_ds(fpath)
        for name, pred, init in [
            ('weibull5', pred_weibull, [1.0, 2.0, 1.0, 7.0, 0.0]),
            ('weibull_x1_6', pred_weibull_x1, [1.0, 2.0, 1.0, 7.0, 0.0, 0.0]),
        ]:
            res = least_squares(lambda th: pred(th,X)-y, init, loss='soft_l1', max_nfev=300)
            yp = pred(res.x, X)
            nmse = np.var(y-yp)/np.var(y)
            results[name].append(nmse)
    except Exception as e:
        print(f'Error: {e}')

for name, vals in results.items():
    print(f'{name}: mean={np.mean(vals):.4f}, vals={[round(v,4) for v in vals]}')
