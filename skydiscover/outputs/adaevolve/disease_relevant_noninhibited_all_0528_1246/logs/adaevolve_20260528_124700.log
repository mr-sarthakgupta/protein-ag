 108 |         "command": "python3 -c \"\nimport numpy as np\nfrom scipy.optimize import brentq\n\n# Avrami/JMAK: y = 1 - exp(-(k*t)^n)\n# In asinh-time: lt = asinh(x0), so x0 ~ exp(lt)/2 for large t\n# We want: y = c0*(1 - exp(-(exp(lt - c2))^c3)) + c4\n# = c0*(1 - exp(-exp(c3*(lt - c2)))) + c4   [Gompertz-like when c3=1]\n# The term (exp(lt-c2))^c3 = exp(c3*(lt-c2))\n# So this IS a Gompertz in lt-space!\n\n# Check asymmetry of Gompertz in lt-space for various c3 (shape)\ndef asym_gompertz_lt(c3):\n    def f(lt):\n        return 1.0 - np.exp(-np.exp(c3*(lt - 0.0)))\n    def find_lt(level, lo=-50, hi=50):\n        return brentq(lambda lt: f(lt) - level, lo, hi)\n    lt10 = find_lt(0.1); lt50 = find_lt(0.5); lt90 = find_lt(0.9)\n    return (lt50 - lt10) / (lt90 - lt10)\n\nprint('Gompertz-in-lt-space asymmetry (all c3 give same shape):')\nfor c3 in [0.5, 1.0, 1.5, 2.0]:\n    print(f'  c3={c3}: {asym_gompertz_lt(c3):.3f}')\n\n# The Avrami in original time: y=1-exp(-(k*t)^n)\n# After asinh transform: t ~ sinh(lt), so (k*sinh(lt))^n\n# This is different from exp(n*lt)\n# Let's check: Avrami in asinh-time space\ndef asym_avrami_asinh(n, k=1.0):\n    def f(lt):\n        t = np.sinh(lt)\n        if t <= 0:\n            return 0.0\n        return 1.0 - np.exp(-(k*t)**n)\n    def find_lt(level, lo=-10, hi=20):\n        return brentq(lambda lt: f(lt) - level, lo, hi)\n    lt10 = find_lt(0.1); lt50 = find_lt(0.5); lt90 = find_lt(0.9)\n    return (lt50 - lt10) / (lt90 - lt10)\n\nprint('Avrami in asinh-time asymmetry:')\nfor n in [0.5, 1.0, 1.5, 2.0, 2.5, 3.0]:\n    try:\n        a = asym_avrami_asinh(n)\n        print(f'  n={n}: {a:.3f}')\n    except Exception as e:\n        print(f'  n={n}: error {e}')\n\"\n"
