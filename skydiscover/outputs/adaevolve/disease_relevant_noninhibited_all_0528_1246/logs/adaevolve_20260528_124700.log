import os, pandas as pd, numpy as np

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

all_fits = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            all_fits.append(os.path.join(root, f))

# Look at htt and insulin datasets
for p in all_fits:
    rel = p.replace(base, '')
    if 'htt' in rel.lower() or 'insulin' in rel.lower():
        df = pd.read_csv(p, sep='\t')
        cols = list(df.columns)
        x0_range = (df['X'].min(), df['X'].max())
        print(f'{rel}: shape={df.shape}, x0=[{x0_range[0]:.1f},{x0_range[1]:.1f}]')
        print(f'  cols: {cols[1:]}')
        # Show y range for each curve
        for col in cols[1:]:
            ymin, ymax = df[col].min(), df[col].max()
            print(f'    {col}: y=[{ymin:.4f},{ymax:.4f}]')
        print()
"
