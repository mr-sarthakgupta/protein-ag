import numpy as np

# Test (1/(1+exp(-z)))^nu shape - this is the Richards generalized logistic
# nu=1: standard logistic; nu>1: faster upper rise; nu<1: slower upper rise (right-skewed)
# But note: (1/(1+exp(-z)))^nu = exp(nu * log(1/(1+exp(-z))))
# Numerically: log(sigmoid(z)) = -log(1+exp(-z)) = -softplus(-z)
# This is numerically stable for all z

# The data shows asym ~2 (slow upper rise) needs nu < 1
for nu in [0.3, 0.5, 0.7, 1.0, 1.5, 2.0]:
    z = np.linspace(-10, 10, 10000)
    y = (1.0 / (1 + np.exp(-z)))**nu
    i10 = np.argmin(np.abs(y - 0.1))
    i50 = np.argmin(np.abs(y - 0.5))
    i90 = np.argmin(np.abs(y - 0.9))
    z10, z50, z90 = z[i10], z[i50], z[i90]
    if (z50 - z10) > 0:
        asym = (z90 - z50) / (z50 - z10)
    else:
        asym = np.nan
    print(f'nu={nu:.1f}: asym={asym:.2f}  z50={z50:.2f}')

# Numerical stability check: what happens at extremes?
print()
print('Stability check for nu=0.3:')
z_test = np.array([-100, -10, 0, 10, 100], dtype=float)
y_test = (1.0 / (1 + np.exp(-z_test)))**0.3
print(f'  y at z=[-100,-10,0,10,100]: {y_test}')
# Check if log form is needed
print('  All finite:', np.all(np.isfinite(y_test)))
