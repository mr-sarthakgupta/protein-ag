import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, _load_fit_table
from pathlib import Path
import sympy as sp
from pysr_harness.equation_session import constant_symbols, feature_symbols, fit_expression_constants
from pysr_harness.metrics import nmse

# Insulin seeded: x1=344 constant, 3 curves stacked (seeds 0.05%, 0.1%, no seeds)
# But x1=344 for ALL - so it's really 3 different curves with same x1!
# The 'no seeds' curve rises much slower -> bimodal shape in the combined data
fp = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/insulin/Fits/Nielsen2001_seeded_sec/fit.tsv')
X, y = _load_fit_table(fp)
print('Shape:', X.shape, 'x1 unique:', np.unique(X[:,1]))

# Sort by x0 and look at y values - are there multiple y values per x0?
x0_vals = np.unique(X[:,0])
print('Unique x0 count:', len(x0_vals))
# For a given x0, multiple y values (from different curves)
sample_x0 = x0_vals[20]
mask = X[:,0] == sample_x0
print(f'At x0={sample_x0:.1f}: y values = {y[mask]}')
sample_x0b = x0_vals[50]
mask2 = X[:,0] == sample_x0b
print(f'At x0={sample_x0b:.1f}: y values = {y[mask2]}')

# The problem: 3 curves all with x1=344, so the model can't distinguish them
# The model sees same (x0, x1) but different y -> irreducible noise
print()
print('This is the core problem: 3 different curves all mapped to x1=344')
print('A single sigmoid cannot fit 3 curves with identical x1 but different shapes')
