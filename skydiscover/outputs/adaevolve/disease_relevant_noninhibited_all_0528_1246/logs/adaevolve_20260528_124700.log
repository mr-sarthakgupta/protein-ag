for p in sorted(all_fits):
    rel = p.replace(base, '')
    df = pd.read_csv(p, sep='\t')
    cols = list(df.columns[1:])
    x0_all = df['X'].values
    params = [parse_param(c) for c in cols]
    if all(q is not None for q in params):
        params_v = [float(q) for q in params]
    else:
        params_v = [float(i+1) for i in range(len(cols))]
    
    # Build X, y with NaN filtering (like the evaluator)
    rows_X, rows_y = [], []
    for i, xi in enumerate(x0_all):
        for j, col in enumerate(cols):
