import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import sympy as sp
from pysr_harness.equation_session import constant_symbols, feature_symbols, fit_expression_constants
from pysr_harness.metrics import nmse

datasets = load_all_datasets()

# Try: separate rate and halftime, both with log-quadratic x1 dependence
# But use additive log form for rate too, initialized to zero (x1-independent start)
# rate = c1 + c9*log(x1) + c10*log(x1)^2   (11 constants total)
# vs P3 rate = c1*x1^c5

# Also try: rate = c1*x1^c5 + c9*log(x1)^2  (10 constants) - just quadratic log term on rate

results_p3 = []
results_10c = []

for name, X_tr, X_v, y_tr, y_v in datasets:
    x = feature_symbols(2)
    time, parameter = x[0], x[1]
    
    # P3 (9c)
    c9 = constant_symbols(9)
    u9 = time - c9[2]
    lt9 = sp.log(u9 + sp.sqrt(u9**2 + 1))
    lp = sp.log(parameter)
    ht9 = c9[3]*parameter**c9[6] + c9[7]*lp + c9[8]*lp**2
    expr_p3 = c9[0]/(1+sp.exp(-c9[1]*parameter**c9[5]*(lt9-ht9)))+c9[4]
    
    # 10c: add log-quadratic to rate only (c9 = log^2 coeff)
    c10 = constant_symbols(10)
    u10 = time - c10[2]
    lt10 = sp.log(u10 + sp.sqrt(u10**2 + 1))
    lp10 = sp.log(parameter)
    rate10 = c10[1]*parameter**c10[5] + c10[9]*lp10**2
    ht10 = c10[3]*parameter**c10[6] + c10[7]*lp10 + c10[8]*lp10**2
    expr_10c = c10[0]/(1+sp.exp(-rate10*(lt10-ht10)))+c10[4]
    
    try:
        f1 = fit_expression_constants(expr_p3, X_tr, y_tr, X_v, constants=c9, 
                                       initial_values=[1,2,0,3,0,0,0,0,0], max_nfev=1000)
        f2 = fit_expression_constants(expr_10c, X_tr, y_tr, X_v, constants=c10,
                                       initial_values=[1,2,0,3,0,0,0,0,0,0], max_nfev=1000)
        n1 = nmse(y_v, f1.y_pred_val)
        n2 = nmse(y_v, f2.y_pred_val)
        results_p3.append(n1)
        results_10c.append(n2)
    except Exception as e:
        results_p3.append(999); results_10c.append(999)

print(f'P3 (9c)  mean NMSE: {np.mean(results_p3):.4f}')
print(f'10c      mean NMSE: {np.mean(results_10c):.4f}')

pairs = sorted(zip(results_p3, results_10c, [d[0] for d in datasets]), reverse=True)
print('Top 8 worst:')
for n1, n2, nm in pairs[:8]:
    print(f'  {nm[-50:]}: p3={n1:.4f} 10c={n2:.4f} diff={n2-n1:+.4f}')
"
