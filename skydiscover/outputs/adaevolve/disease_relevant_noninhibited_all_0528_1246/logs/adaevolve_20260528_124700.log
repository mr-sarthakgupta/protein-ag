import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = load_all_datasets()

def asinh_val(x0, c2):
    u = x0 - c2
    return np.log(u + np.sqrt(u**2 + 1))

# Model A: current (7 constants)
def model_A(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0,c1,c2,c3,c4,c5,c6 = c
    lt = asinh_val(x0, c2)
    rate = c1*np.maximum(x1,1e-10)**c5
    ht = c3*np.maximum(x1,1e-10)**c6
    return c0/(1+np.exp(-np.clip(rate*(lt-ht),-500,500)))+c4

# Model B: 2-rate (9 constants) - rate = c1*x1^c5 + c7*x1^c8
def model_B(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0,c1,c2,c3,c4,c5,c6,c7,c8 = c
    lt = asinh_val(x0, c2)
    rate = c1*np.maximum(x1,1e-10)**c5 + c7*np.maximum(x1,1e-10)**c8
    ht = c3*np.maximum(x1,1e-10)**c6
    return c0/(1+np.exp(-np.clip(rate*(lt-ht),-500,500)))+c4

# Model C: log-linear halftime (8 constants)
# ht = c3 + c6*log(x1) -- additive log coupling
def model_C(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0,c1,c2,c3,c4,c5,c6,c7 = c
    lt = asinh_val(x0, c2)
    rate = c1*np.maximum(x1,1e-10)**c5
    ht = c3*np.maximum(x1,1e-10)**c6 + c7*np.log(np.maximum(x1,1e-10))
    return c0/(1+np.exp(-np.clip(rate*(lt-ht),-500,500)))+c4

# Model D: rate has additive log term (8 constants)
# rate = c1*x1^c5 + c7*log(x1)
def model_D(X, c):
