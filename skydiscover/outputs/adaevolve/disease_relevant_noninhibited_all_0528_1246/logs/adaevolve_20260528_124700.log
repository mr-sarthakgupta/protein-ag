import os, numpy as np, csv
base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
all_files = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            all_files.append(os.path.join(root, f))
all_files.sort()

single_col = []
multi_col = []
for p in all_files:
    with open(p) as f:
        header = f.readline().strip().split('\t')
    ncols = len(header) - 1
    rel = p.replace(base+'/', '')
    if ncols == 1:
        single_col.append(rel)
    else:
        multi_col.append((ncols, rel))

print(f'Single-column (x1=1.0): {len(single_col)}')
for r in single_col[:6]:
    print(' ', r)
