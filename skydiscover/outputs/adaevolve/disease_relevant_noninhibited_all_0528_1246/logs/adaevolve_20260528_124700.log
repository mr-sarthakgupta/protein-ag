import numpy as np
from scipy.optimize import least_squares
import pandas as pd, os, glob

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
files = sorted(glob.glob(os.path.join(base, '**', 'fit.tsv'), recursive=True))

def fit_dataset(path, c0_init):
    df = pd.read_csv(path, sep='\t')
    cols = df.columns.tolist()
