import numpy as np
import sys
from scipy.optimize import least_squares
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets
all_ds = load_all_datasets()
ds = {name: (Xtr, Xv, ytr, yv) for name, Xtr, Xv, ytr, yv in all_ds}

# For Kar2011 Q37 prim, what does the data look like per x1?
# x1 values are polyQ repeat lengths (3,4,6,8,9,22)
name = 'htt/Kar2011/Fits/Kar2011_Q37_prim'
Xtr, Xv, ytr, yv = ds[name]

# Try fitting a simple logistic per x1 to see if the issue is the x1 coupling
def logistic_fit(x0, y):
    def residual(theta):
        c0, c1, c2, c4 = theta
        u = x0 - c2
        lt = np.log(u + np.sqrt(u**2 + 1))  # asinh
        pred = c0 / (1 + np.exp(-c1 * lt)) + c4
        pred = np.where(np.isfinite(pred), pred, 1e6)
        return pred - y
    res = least_squares(residual, [1.0, 1.0, 50000, 0.0], loss='soft_l1', max_nfev=500)
    return res.x, res.cost

print('Per-x1 logistic fits (asinh time):')
for x1_val in sorted(np.unique(Xtr[:,1])):
    mask = Xtr[:,1] == x1_val
    x0_sub = Xtr[mask, 0]
    y_sub = ytr[mask]
    params, cost = logistic_fit(x0_sub, y_sub)
    c0, c1, c2, c4 = params
    pred = c0 / (1 + np.exp(-c1 * np.log(x0_sub - c2 + np.sqrt((x0_sub-c2)**2+1)))) + c4
    nmse = np.mean((pred-y_sub)**2)/np.var(y_sub) if np.var(y_sub)>0 else 0
    print(f'  x1={x1_val}: c0={c0:.3f}, c1={c1:.3f}, c2={c2:.0f}, c4={c4:.3f}, nmse={nmse:.4f}')
"
