# Show the data shape - sort by x0
idx = np.argsort(x0_2)
x0s = x0_2[idx]
ys = y_train2[idx]
# Print every 5th point
for i in range(0, min(len(x0s), 60), 5):
    print(f'  x0={x0s[i]:.0f} y={ys[i]:.4f}')
