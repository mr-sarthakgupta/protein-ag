import numpy as np, csv, os, re
from scipy.optimize import least_squares

def load_ds(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = list(reader)
    response_headers = header[1:]
    def parse_param(text):
        for pat, scale in [(r'(\d+(?:\.\d+)?)\s*uM',1),(r'(\d+(?:\.\d+)?)\s*mM',1000),
                           (r'pH\s+(\d+(?:\.\d+)?)',1),(r'(\d+(?:\.\d+)?)\s*%',1),
                           (r':\s*(\d+(?:\.\d+)?)\s*$',1)]:
            m = re.search(pat, text, re.IGNORECASE)
            if m: return float(m.group(1))*scale
        return None
    parsed = [parse_param(h) for h in response_headers]
    params = [float(p) for p in parsed] if all(p is not None for p in parsed) else [float(i+1) for i in range(len(response_headers))]
    features, targets = [], []
    for row in rows:
        if not row: continue
        t = float(row[0])
        for param, val in zip(params, row[1:]):
            if val and val.strip().lower() != 'nan':
                features.append([t, param])
                targets.append(float(val))
    return np.array(features), np.array(targets)

# Scale-invariant logistic: use x0/c_scale for half-time
# y = c0 / (1 + exp(-c1*(x0/c2 - 1))) + c3
# where c2 is the half-time (same units as x0), c1 is steepness
# Initial: c0=1, c1=5, c2=1 (half-time at x0=c2), c3=0
# This avoids scale issues because c2 adapts to any time scale

def pred_ratio(theta, X):
    c0,c1,c2,c3 = theta
    x0 = X[:,0]
    t_norm = x0 / np.maximum(np.abs(c2), 1e-10)
    return c0/(1+np.exp(np.clip(-c1*(t_norm-1), -500,500))) + c3

# With x1: y = c0/(1+exp(-c1*(x0/c2-1))) + c3 + c4*log(x1)  -- additive x1 effect
def pred_ratio_x1(theta, X):
    c0,c1,c2,c3,c4 = theta
    x0,x1 = X[:,0], X[:,1]
    lx1 = np.log(np.maximum(np.abs(x1), 1e-6))
    t_norm = x0 / np.maximum(np.abs(c2), 1e-10)
    return c0/(1+np.exp(np.clip(-c1*(t_norm-1), -500,500))) + c3 + c4*lx1

# Better: half-time scales with x1 too
# y = c0/(1+exp(-c1*(x0/(c2+c3*x1)-1))) + c4
def pred_ratio_ht(theta, X):
    c0,c1,c2,c3,c4 = theta
    x0,x1 = X[:,0], X[:,1]
    ht = c2 + c3*x1
    t_norm = x0 / np.maximum(np.abs(ht), 1e-10)
    return c0/(1+np.exp(np.clip(-c1*(t_norm-1), -500,500))) + c4

test_files = ['alphasyn_gaspar2017_03um_seed_all/fit.tsv']
base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
if os.path.exists(base):
    for root, dirs, files in os.walk(base):
        if 'fit.tsv' in files:
            test_files.append(os.path.join(root, 'fit.tsv'))
        if len(test_files) >= 8: break

print(f'Testing on {len(test_files)} datasets')
results = {'ratio4':[], 'ratio_x1_5':[], 'ratio_ht_5':[]}
for fpath in test_files:
    try:
        X, y = load_ds(fpath)
        for name, pred, init in [
            ('ratio4', pred_ratio, [1.0, 5.0, 1.0, 0.0]),
            ('ratio_x1_5', pred_ratio_x1, [1.0, 5.0, 1.0, 0.0, 0.0]),
            ('ratio_ht_5', pred_ratio_ht, [1.0, 5.0, 1.0, 0.0, 0.0]),
        ]:
            res = least_squares(lambda th: pred(th,X)-y, init, loss='soft_l1', max_nfev=300)
            yp = pred(res.x, X)
            nmse = np.var(y-yp)/np.var(y)
            results[name].append(nmse)
    except Exception as e:
        print(f'Error {e}')

for name, vals in results.items():
    print(f'{name}: mean={np.mean(vals):.4f}, vals={[round(v,4) for v in vals]}')
