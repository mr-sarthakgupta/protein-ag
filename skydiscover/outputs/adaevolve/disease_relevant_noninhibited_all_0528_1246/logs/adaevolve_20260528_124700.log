    x0, x1 = X[:,0], X[:,1]
    c0,c1,c2,c3,c4,c5,c6,c7 = c
    lt = asinh_val(x0, c2)
    lx1 = np.log(np.maximum(x1,1e-10))
    rate = c1*np.maximum(x1,1e-10)**c5
    ht = c3 + c6*lx1 + c7*lx1*lx1
    return c0/(1+np.exp(-np.clip(rate*(lt-ht),-500,500)))+c4

# Model F: quadratic in log(x1) for BOTH rate and halftime (9 constants)
def model_F(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0,c1,c2,c3,c4,c5,c6,c7,c8 = c
    lt = asinh_val(x0, c2)
    lx1 = np.log(np.maximum(x1,1e-10))
    rate = c1*np.exp(c5*lx1 + c8*lx1*lx1)  # log-quadratic rate
    ht = c3 + c6*lx1 + c7*lx1*lx1
    return c0/(1+np.exp(-np.clip(rate*(lt-ht),-500,500)))+c4

# Model G: power-law rate + log-quadratic halftime (9 constants)
def model_G(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0,c1,c2,c3,c4,c5,c6,c7,c8 = c
