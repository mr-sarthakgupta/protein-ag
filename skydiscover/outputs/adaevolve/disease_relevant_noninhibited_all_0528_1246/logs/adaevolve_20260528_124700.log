import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_dataset
from pathlib import Path
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'

# Test various halftime parameterizations on Kar2011 Q37
# The non-monotonic t50 vs x1 is the challenge
# x1 values: [3,4,6,8,9,22], t50: [111k, 130k, 374k, 308k, 252k, 186k]
# This is a peak at x1=6 then decreasing - a quadratic in x1 could capture this

hard = ['htt/Kar2011/Fits/Kar2011_Q37_prim/fit.tsv',
        'htt/Kar2011/Fits/Kar2011_Q37_sec/fit.tsv']

# Model A: halftime = c3 + c7*x1 + c8*x1^2 (quadratic in x1, no power law)
def model_A(t, p, c):
    u = t - c[2]; lt = np.log(u + np.sqrt(u**2+1))
    rate = c[1] * np.exp(c[5] * np.log(p+1))
    ht = c[3] + c[7]*p + c[8]*p**2
    return c[0] / (1 + np.exp(-rate*(lt - ht))) + c[4]

# Model B: halftime = c3*exp(c6*x1) + c7*x1 (exponential + linear in x1)
def model_B(t, p, c):
    u = t - c[2]; lt = np.log(u + np.sqrt(u**2+1))
    rate = c[1] * np.exp(c[5] * np.log(p+1))
    ht = c[3]*np.exp(c[6]*p) + c[7]*p
    return c[0] / (1 + np.exp(-rate*(lt - ht))) + c[4]

# Model C: rate*halftime coupling - rate=c1*exp(c5*lp), ht=c3*exp(c6*lp)+c7*lp+c8*lp^2 (current)
def model_C(t, p, c):
    lp = np.log(p)
    u = t - c[2]; lt = np.log(u + np.sqrt(u**2+1))
    rate = c[1] * p**c[5]
    ht = c[3]*p**c[6] + c[7]*lp + c[8]*lp**2
    return c[0] / (1 + np.exp(-rate*(lt - ht))) + c[4]

# Model D: tanh time transform instead of asinh
def model_D(t, p, c):
    lp = np.log(p)
    lt = np.log(t + c[2])  # log(t + offset)
    rate = c[1] * p**c[5]
    ht = c[3]*p**c[6] + c[7]*lp + c[8]*lp**2
    return c[0] / (1 + np.exp(-rate*(lt - ht))) + c[4]

models = [('A-quadratic', model_A, [1,2,0,3,0,0,0,0,0]),
          ('B-exp+lin', model_B, [1,2,0,3,0,0,0,0,0]),
          ('C-current', model_C, [1,2,0,3,0,0,0,0,0]),
          ('D-log_t', model_D, [1,2,1,3,0,0,0,0,0])]

for ds in hard:
    p = Path(base) / ds
    X_tr, X_v, y_tr, y_v = load_dataset(p)
    x0t, x1t = X_tr[:,0], X_tr[:,1]
    name = ds.split('/')[-2]
    for mname, mfn, init in models:
        def res(c, m=mfn):
            with np.errstate(all='ignore'):
                pred = m(x0t, x1t, c)
            if not np.all(np.isfinite(pred)): return np.full(len(y_tr), 1e6)
            return pred - y_tr
        r = least_squares(res, init, loss='soft_l1', max_nfev=2000)
        pv = mfn(X_v[:,0], X_v[:,1], r.x)
        nm = np.mean((pv-y_v)**2)/np.var(y_v)
        print(f'{name} {mname}: {nm:.4f}')
    print()
"
