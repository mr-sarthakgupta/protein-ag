import numpy as np
import pandas as pd
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
f = base + 'biofilm proteins/CsgA/CsgA_prim_IN_HOURS/fit.tsv'
df = pd.read_csv(f, sep='\t')
# Melt to long form
x0_all, x1_all, y_all = [], [], []
concs = [7,6,5,4,3,2]
for i, c in enumerate(concs):
    col = df.columns[i+1]
    x0_all.extend(df['X'].values)
    x1_all.extend([float(c)]*len(df))
    y_all.extend(df[col].values)
x0 = np.array(x0_all)
x1 = np.array(x1_all)
y = np.array(y_all)
print(f'x0: [{x0.min():.3g}, {x0.max():.3g}]')
print(f'x1: [{x1.min():.3g}, {x1.max():.3g}]')
print(f'y: [{y.min():.3g}, {y.max():.3g}]')

# Test power-law model: y = c0 * x0^c1 * x1^c2
def model_power(theta, x0, x1):
    c0,c1,c2 = theta
    return c0 * np.power(np.maximum(x0,1e-10), c1) * np.power(x1, c2)
res = least_squares(lambda t: model_power(t,x0,y_all) - y, [0.1,1,1], loss='soft_l1')
pred = model_power(res.x, x0, x1)
nmse = np.mean((pred-y)**2)/np.var(y)
print(f'Power-law NMSE: {nmse:.6f}, params: {res.x}')

# Test: y = c0*(1 - exp(-c1*x0^c2)) * x1^c3
def model_exp(theta, x0, x1):
    c0,c1,c2,c3 = theta
    return c0*(1 - np.exp(-np.abs(c1)*np.power(np.maximum(x0,1e-10),np.abs(c2)))) * np.power(x1,np.abs(c3))
res2 = least_squares(lambda t: model_exp(t,x0,x1) - y, [1,0.1,1.5,1], loss='soft_l1', max_nfev=2000)
pred2 = model_exp(res2.x, x0, x1)
nmse2 = np.mean((pred2-y)**2)/np.var(y)
print(f'Exp-growth NMSE: {nmse2:.6f}, params: {res2.x}')

# Check what the evaluator actually uses for x1 (from column headers)
print('Actual column headers:', list(df.columns[1:]))
"
