    try:
        res = least_squares(lambda c: gompertz_asinh(X[:,0], X[:,1], c) - y,
                           c0, loss='soft_l1', max_nfev=1000)
        y_pred = gompertz_asinh(X[:,0], X[:,1], res.x)
        nmse_v = np.mean((y_pred - y)**2) / max(np.var(y), 1e-12)
        results.append(nmse_v)
        if nmse_v > 0.03:
            hard.append((nmse_v, rel[:55]))
    except Exception as e:
        results.append(1.0)
        hard.append((1.0, rel[:55] + f' ERR'))

