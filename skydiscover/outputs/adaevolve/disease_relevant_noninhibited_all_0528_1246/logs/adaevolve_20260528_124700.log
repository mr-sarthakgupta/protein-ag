import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_dataset, _load_fit_table
from pathlib import Path
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'

# Look at Kar2011 Q37 structure
p = Path(base) / 'htt/Kar2011/Fits/Kar2011_Q37_prim/fit.tsv'
with open(p) as f:
    hdr = f.readline().strip().split('\t')
print('Columns:', hdr[1:])

X, y = _load_fit_table(p)
x0, x1 = X[:,0], X[:,1]
print(f'x1 unique values: {np.unique(x1)}')
print(f'x0 range: [{x0.min():.0f}, {x0.max():.0f}]')

# For each x1 value, show the y range and shape
for xi in np.unique(x1):
    mask = x1 == xi
    y_sub = y[mask]
    x0_sub = x0[mask]
    # Sort by x0
    idx = np.argsort(x0_sub)
    y_sub = y_sub[idx]; x0_sub = x0_sub[idx]
    # Find where sigmoid crosses 0.5
    cross = x0_sub[np.argmin(np.abs(y_sub - 0.5))] if len(y_sub) > 0 else None
    print(f'  x1={xi:.0f}: n={mask.sum()}, y=[{y_sub.min():.3f},{y_sub.max():.3f}], t50~{cross:.0f}')

# Try a model with x1 coupling via log1p
X_tr, X_v, y_tr, y_v = load_dataset(p)
x0t, x1t = X_tr[:,0], X_tr[:,1]

def model_lp(t, p, c):
    lp = np.log(p + 1)
    u = t - c[2]; lt = np.log(u + np.sqrt(u**2+1))
    rate = c[1] * np.exp(c[5] * lp)
    ht = c[3] * np.exp(c[6] * lp) + c[7]*lp + c[8]*lp**2
    return c[0] / (1 + np.exp(-rate*(lt - ht))) + c[4]

def res_lp(c):
    with np.errstate(all='ignore'):
        pred = model_lp(x0t, x1t, c)
    if not np.all(np.isfinite(pred)): return np.full(len(y_tr), 1e6)
    return pred - y_tr

rl = least_squares(res_lp, [1,2,0,3,0,0,0,0,0], loss='soft_l1', max_nfev=2000)
pv_l = model_lp(X_v[:,0], X_v[:,1], rl.x)
nm_l = np.mean((pv_l-y_v)**2)/np.var(y_v)
print(f'log1p model Kar2011_Q37_prim NMSE: {nm_l:.4f}')
"
