import pandas as pd
import numpy as np
import os, sys
sys.path.insert(0, '.')

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

# Check skewness of curves: for each dataset, measure rise time asymmetry
# A symmetric logistic has equal rise/fall. Gompertz rises fast, falls slow.
datasets = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            datasets.append(os.path.join(root, f))
datasets.sort()

results = []
for path in datasets:
    df = pd.read_csv(path, sep='\t')
    name = path.split(base)[1]
    for col in df.columns[1:]:
        y = df[col].dropna().values
        x0 = df.iloc[:len(y), 0].values
        if len(y) < 10:
            continue
        # Find 10%, 50%, 90% points
        try:
            i10 = np.argmin(np.abs(y - 0.1))
            i50 = np.argmin(np.abs(y - 0.5))
            i90 = np.argmin(np.abs(y - 0.9))
            t10, t50, t90 = x0[i10], x0[i50], x0[i90]
            if t90 > t50 > t10:
                # Asymmetry: (t90-t50)/(t50-t10) > 1 means slow rise (Gompertz-like)
                asym = (t90 - t50) / (t50 - t10) if (t50 - t10) > 0 else np.nan
                results.append((name, col, asym, y.min(), y.max()))
        except:
            pass

# Sort by asymmetry (most skewed first)
results.sort(key=lambda x: x[2] if np.isfinite(x[2]) else 0, reverse=True)
print('Most asymmetric curves (asym > 1 = slow upper rise):')
for name, col, asym, ymin, ymax in results[:10]:
    print(f'  {asym:.2f}  {name}  col={col[:20]}  y=[{ymin:.2f},{ymax:.2f}]')
print()
print('Most symmetric curves:')
for name, col, asym, ymin, ymax in results[-5:]:
    print(f'  {asym:.2f}  {name}  col={col[:20]}')
