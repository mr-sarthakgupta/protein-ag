import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = {name: (X_train, X_val, y_train, y_val) 
            for name, X_train, X_val, y_train, y_val in load_all_datasets()}

# The ACE_sec issue: optimizer gets stuck when c2 is free
# Try log(x0 + 1) fixed offset (c2 absorbed into c3)
# y = c0 / (1 + exp(-c1 * (log(x0+1) - c2))) + c3
# This is equivalent to: y = c0 / (1 + exp(-c1*log(x0+1) + c1*c2)) + c3
# = c0 / (1 + (x0+1)^(-c1) * exp(c1*c2)) + c3
# = c0 / (1 + c2' * (x0+1)^(-c1)) + c3  where c2' = exp(c1*c2)
# This is the Hill equation! y = c0 / (1 + (c2/(x0+1))^c1) + c3

def model_hill(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4, c5, c6 = c
    # Hill: y = c0 / (1 + (c2/x0)^c1) + c4
    # with x1 power-law scaling of c1 and c2
    hill_n = c1 * x1**c5  # Hill coefficient (rate analog)
    half = c2 * x1**c6    # half-saturation time
    denom = 1 + np.exp(-np.clip(hill_n * np.log(np.maximum(x0, 1e-10) / np.maximum(half, 1e-10)), -500, 500))
    return c0 / denom + c3 + c4*0  # c4 unused here

# Actually: Hill form is c0 / (1 + (c2/x0)^c1) + c3
def model_hill2(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4, c5 = c
    # y = c0 * x0^c1 / (x0^c1 + c2^c1) + c3
    # = c0 / (1 + (c2/x0)^c1) + c3
    # power-law x1: c1 -> c1*x1^c4, c2 -> c2*x1^c5
    hill_n = c1
    half = c2 * x1**c4
    safe_x0 = np.maximum(x0, 1e-10)
    safe_half = np.maximum(half, 1e-10)
    ratio = safe_half / safe_x0
    denom = 1 + ratio**hill_n
    return c0 / denom + c3

# Test on ACE_sec
name = 'beta-parvalbumin (Gadm1)/Sanchez2016/ACE_sec'
X_train, X_val, y_train, y_val = datasets[name]
var_y = np.var(y_val)

# x0 ranges from 0 to 247897, half-time around 100000
res = least_squares(lambda c: model_hill2(X_train, c) - y_train,
                   [1.0, 2.0, 100000.0, 0.0, 0.0, 0.0], max_nfev=500)
pred = model_hill2(X_val, res.x)
nmse_v = np.mean((pred - y_val)**2) / var_y
print(f'ACE_sec Hill2 NMSE: {nmse_v:.4f}, c: {res.x.round(3)}')

# Test Kar2011
name2 = 'htt/Kar2011/Fits/Kar2011_Q37_sec'
X_train2, X_val2, y_train2, y_val2 = datasets[name2]
var_y2 = np.var(y_val2)
res2 = least_squares(lambda c: model_hill2(X_train2, c) - y_train2,
                    [1.0, 2.0, 500000.0, 0.0, 0.0, 0.0], max_nfev=500)
pred2 = model_hill2(X_val2, res2.x)
nmse_v2 = np.mean((pred2 - y_val2)**2) / var_y2
print(f'Kar2011_Q37_sec Hill2 NMSE: {nmse_v2:.4f}, c: {res2.x.round(3)}')
