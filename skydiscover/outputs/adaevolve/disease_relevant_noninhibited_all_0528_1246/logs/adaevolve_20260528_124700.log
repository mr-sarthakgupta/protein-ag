import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_dataset
from pathlib import Path
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'

# Test double sigmoid on the hardest datasets except insulin
hard = [
    'htt/Kar2011/Fits/Kar2011_Q37_prim/fit.tsv',
    'htt/Kar2011/Fits/Kar2011_Q37_sec/fit.tsv',
    'htt/Kar2011/Fits/Temp/fit.tsv',
    'htt/Kakkar2016/FIts/Kakkar2016_14kDa_Ex45_polyQ_sec/fit.tsv',
]

def model2(t, p, c):
    # Double sigmoid with x1 coupling on rate and halftime
    lp1p = np.log(p + 1)
    u1 = t - c[2]; lt1 = np.log(u1 + np.sqrt(u1**2+1))
    u2 = t - c[6]; lt2 = np.log(u2 + np.sqrt(u2**2+1))
    rate1 = c[1] * np.exp(c[9] * lp1p)
    ht1 = c[3] * np.exp(c[10] * lp1p)
    rate2 = c[5] * np.exp(c[11] * lp1p)
    ht2 = c[7] * np.exp(c[12] * lp1p)  # too many constants
    s1 = c[0] / (1 + np.exp(-rate1*(lt1 - ht1)))
    s2 = c[4] / (1 + np.exp(-rate2*(lt2 - ht2)))
    return s1 + s2 + c[8]

def model_single(t, p, c):
    u = t - c[2]; lt = np.log(u + np.sqrt(u**2+1))
    lp = np.log(p)
    rate = c[1] * p**c[5]
    ht = c[3] * p**c[6] + c[7]*lp + c[8]*lp**2
    return c[0] / (1 + np.exp(-rate*(lt - ht))) + c[4]

for ds in hard:
    p = Path(base) / ds
    X_tr, X_v, y_tr, y_v = load_dataset(p)
    x0t, x1t = X_tr[:,0], X_tr[:,1]
    
    def res_s(c):
        with np.errstate(all='ignore'):
            pred = model_single(x0t, x1t, c)
        if not np.all(np.isfinite(pred)): return np.full(len(y_tr), 1e6)
        return pred - y_tr
    rs = least_squares(res_s, [1,2,0,3,0,0,0,0,0], loss='soft_l1', max_nfev=1000)
    pv_s = model_single(X_v[:,0], X_v[:,1], rs.x)
    nm_s = np.mean((pv_s-y_v)**2)/np.var(y_v)
    print(f'{ds.split(\"/\")[-2]}: single={nm_s:.4f}')
"
