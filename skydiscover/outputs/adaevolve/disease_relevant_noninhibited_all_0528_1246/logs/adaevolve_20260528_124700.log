 148 |         "command": "python3 -c \"\nimport numpy as np\nfrom scipy.optimize import brentq, curve_fit\nimport pandas as pd, os\n\n# Richards sigmoid: y = 1 / (1 + exp(-r*t))^(1/nu)\n# For nu > 1: 1/nu < 1 => exponent < 1 on denominator\n# Let's compute asymmetry correctly\n# At t->-inf: (1+exp(-r*t))^(1/nu) -> exp(-r*t/nu) -> inf, so y->0\n# At t->+inf: (1+exp(-r*t))^(1/nu) -> 1, so y->1\n# Inflection at t_inf where d^2y/dt^2 = 0\n# For standard form y = 1/(1+exp(-t))^(1/nu):\n# dy/dt = (1/nu)*exp(-t)/(1+exp(-t))^(1/nu+1)\n# d^2y/dt^2 = 0 when exp(-t) = nu (inflection at t_inf = -log(nu))\n# y_inf = 1/(1+nu)^(1/nu)\n\n# For nu=1: t_inf=0, y_inf=0.5 (standard logistic, symmetric)\n# For nu>1: t_inf = -log(nu) < 0, meaning inflection is LEFT of center\n# This means the curve rises FASTER initially then slows => right-skewed\n\n# Asymmetry = (t50 - t10)/(t90 - t10)\ndef asym_richards(nu):\n    def f(t):\n        return 1.0 / (1.0 + np.exp(-t))**(1.0/nu)\n    def find_t(level, lo=-200, hi=200):\n        return brentq(lambda t: f(t) - level, lo, hi)\n    t10 = find_t(0.1); t50 = find_t(0.5); t90 = find_t(0.9)\n    return (t50 - t10) / (t90 - t10)\n\nprint('Richards asymmetry vs nu:')\nfor nu in [0.1, 0.5, 1.0, 2.0, 3.0, 5.0, 10.0, 20.0, 50.0]:\n    try:\n        a = asym_richards(nu)\n        print(f'  nu={nu:5.1f}: asymmetry={a:.3f}  (right-skew if <0.5)')\n    except Exception as e:\n        print(f'  nu={nu}: {e}')\n\n# Target: mean=0.372\ntarget = 0.372\nnu_t = brentq(lambda nu: asym_richards(nu) - target, 1.01, 200)\nprint(f'nu for asymmetry=0.372: {nu_t:.2f}')\nprint(f'1/nu = {1/nu_t:.4f}')\n\"\n"
