import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = load_all_datasets()

def model_current(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4, c5, c6 = c
    u = x0 - c2
    lt = np.log(u + np.sqrt(u**2 + 1))
    rate = c1 * np.maximum(x1, 1e-10)**c5
    ht = c3 * np.maximum(x1, 1e-10)**c6
    return c0 / (1 + np.exp(-np.clip(rate * (lt - ht), -500, 500))) + c4

nmses = []
for name, X_train, X_val, y_train, y_val in datasets:
    var_y = np.var(y_val)
    if var_y < 1e-10: var_y = 1.0
    try:
        res = least_squares(lambda c: model_current(X_train, c) - y_train,
                           [1.0, 2.0, 0.0, 3.0, 0.0, 0.0, 0.0],
                           loss='soft_l1', max_nfev=300)
        pred = model_current(X_val, res.x)
        nmse_v = np.mean((pred - y_val)**2) / var_y
        nmses.append((nmse_v, name))
    except:
        nmses.append((999.0, name))

nmses.sort(reverse=True)
print('Current model (soft_l1) - top 10 + mean:')
for n,nm in nmses[:10]: print(f'  {n:.4f} {nm[-45:]}')
print(f'Mean: {np.mean([n for n,_ in nmses]):.4f}')
