import pandas as pd
import numpy as np
import os, sys
sys.path.insert(0, '.')

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

# Simulate what the best model does on lysozyme (the known hard case)
# Best model: logistic in asinh(x0-c2) space
# Hasecke dataset: x0 from 2050 to 350000, single curve (x1=70)
path = base + 'lysozyme/Fits/Hasecke2018_70uM_sec/fit.tsv'
df = pd.read_csv(path, sep='\t')
x0 = df.iloc[:,0].values
y = df.iloc[:,1].values

# Check the shape of the curve: where is the midpoint?
# y goes from 0 to ~0.97
mid_idx = np.argmin(np.abs(y - 0.5))
print(f'Lysozyme 70uM: x0_mid={x0[mid_idx]:.3g}, y_mid={y[mid_idx]:.3f}')
print(f'x0 range: {x0.min():.3g} to {x0.max():.3g}')
print(f'asinh(x0) range: {np.arcsinh(x0.min()):.3g} to {np.arcsinh(x0.max()):.3g}')
# Show asymmetry: how much of the rise is below vs above midpoint
below_mid = np.sum(y < 0.5)
above_mid = np.sum(y > 0.5)
print(f'Points below 0.5: {below_mid}, above 0.5: {above_mid}')

# Check 10% and 90% points
idx10 = np.argmin(np.abs(y - 0.1))
idx90 = np.argmin(np.abs(y - 0.9))
print(f'x0 at 10%: {x0[idx10]:.3g}, at 90%: {x0[idx90]:.3g}')
print(f'Ratio x0(90)/x0(10): {x0[idx90]/x0[idx10]:.3f}')
print()

# Also check serum amyloid ye2011
path2 = base + 'serum amyloid/Ye2011/Fits/Ye2011_sec/fit.tsv'
df2 = pd.read_csv(path2, sep='\t')
x0_2 = df2.iloc[:,0].values
y2 = df2.iloc[:,1].values
mid_idx2 = np.argmin(np.abs(y2 - 0.5))
print(f'Ye2011 col1: x0_mid={x0_2[mid_idx2]:.3g}, y_mid={y2[mid_idx2]:.3f}')
idx10_2 = np.argmin(np.abs(y2 - 0.1))
idx90_2 = np.argmin(np.abs(y2 - 0.9))
print(f'x0 at 10%: {x0_2[idx10_2]:.3g}, at 90%: {x0_2[idx90_2]:.3g}')
print(f'Ratio x0(90)/x0(10): {x0_2[idx90_2]/x0_2[idx10_2]:.3f}')
