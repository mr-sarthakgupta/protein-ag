root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')
datasets = []
for dirpath, _, filenames in os.walk(root):
    if 'fit.tsv' in filenames:
        datasets.append(Path(dirpath) / 'fit.tsv')
datasets.sort()

# Check x1 values across all datasets
single_curve = 0
multi_curve = 0
x1_vals_all = []
for p in datasets:
    with open(p) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [r for r in reader if r]
    n_curves = len(header) - 1
    if n_curves == 1:
        single_curve += 1
    else:
        multi_curve += 1
    # x1 values from header parsing
    import re
    params = []
    for h in header[1:]:
        m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.IGNORECASE)
        if m: params.append(float(m.group(1)))
    if params:
        x1_vals_all.extend(params)

print(f'Single-curve: {single_curve}, Multi-curve: {multi_curve}')
if x1_vals_all:
    print(f'x1 range across multi-curve: [{min(x1_vals_all):.2f}, {max(x1_vals_all):.2f}]')
    print(f'x1 zeros: {sum(1 for v in x1_vals_all if v==0)}')
"
