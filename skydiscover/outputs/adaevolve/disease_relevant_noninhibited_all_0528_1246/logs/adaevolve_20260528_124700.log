import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = {name: (X_train, X_val, y_train, y_val) 
            for name, X_train, X_val, y_train, y_val in load_all_datasets()}

# The ACE_sec problem: x0 goes from 0 to 247897
# log(x0+1) half-time at x0~100000 means log(100001) ~ 11.5
# Current init: c3=3.0, which corresponds to x0=exp(3)-1~19 -- way too small!
# Need c3~11.5 for this dataset
# 
# Key question: can we find ONE set of initial values that works for ALL datasets?
# Let's check what half-time value works for each hard dataset

def model_logoffset(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4, c5, c6 = c
    offset = np.exp(c2)
    lt = np.log(np.maximum(x0 + offset, 1e-10))
    rate = c1 * x1**c5
    ht = c3 * x1**c6
    return c0 / (1 + np.exp(-np.clip(rate * (lt - ht), -500, 500))) + c4

hard_datasets = [
    'beta-parvalbumin (Gadm1)/Sanchez2016/ACE_sec',
    'htt/Kar2011/Fits/Kar2011_Q37_sec',
    'insulin/Fits/Nielsen2001_seeded_sec',
    'Abeta/Cohen2013/Ab42_sec_IN_HOURS',
    'IAPP/Daval2010/Fits/Daval2010_prim',
]

for name in hard_datasets:
    X_train, X_val, y_train, y_val = datasets[name]
    x0 = X_train[:,0]
    var_y = np.var(y_val)
    if var_y < 1e-10: var_y = 1.0
    
    # Try multiple c3 inits to find best
    best_nmse = 999.0
    best_c3 = None
    best_c = None
    for c3_init in [1.0, 3.0, 5.0, 7.0, 9.0, 11.0, 13.0]:
        try:
            res = least_squares(lambda c: model_logoffset(X_train, c) - y_train,
                               [1.0, 2.0, 0.0, c3_init, 0.0, 0.0, 0.0], max_nfev=300)
            pred = model_logoffset(X_val, res.x)
            nmse_v = np.mean((pred - y_val)**2) / var_y
            if nmse_v < best_nmse:
                best_nmse = nmse_v
                best_c3 = c3_init
                best_c = res.x
        except: pass
    print(f'{name[-40:]:40s} best_c3_init={best_c3} NMSE={best_nmse:.4f} fitted_c3={best_c[3]:.2f}')
