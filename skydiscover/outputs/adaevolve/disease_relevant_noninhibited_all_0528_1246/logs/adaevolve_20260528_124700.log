import csv, numpy as np, sys, re, os
sys.path.insert(0, '.')
from pathlib import Path
from scipy.optimize import least_squares
root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def load_ds(p):
    with open(p) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [r for r in reader if r]
    parsed = []
    for h in header[1:]:
        text = h.strip()
        m = re.search(r'(\d+(?:\.\d+)?)\s*uM', text, re.IGNORECASE)
        if m: parsed.append(float(m.group(1))); continue
        m = re.search(r'(\d+(?:\.\d+)?)\s*mM', text, re.IGNORECASE)
        if m: parsed.append(float(m.group(1))*1000); continue
        m = re.search(r'(\d+(?:\.\d+)?)\s*%', text)
        if m: parsed.append(float(m.group(1))); continue
        parsed.append(None)
    if all(p is not None for p in parsed):
        params = [float(p) for p in parsed]
    else:
        params = [float(i+1) for i in range(len(header)-1)]
    X, y = [], []
    for row in rows:
        t = float(row[0])
        for i, pv in enumerate(params):
            if i+1 < len(row) and row[i+1].strip() and row[i+1].strip().lower() != 'nan':
                X.append([t, pv]); y.append(float(row[i+1]))
    return np.array(X), np.array(y)

# Test a Gompertz-in-log-time model: y = c0*exp(-exp(-c1*(lt - c2))) + c3
# where lt = asinh(t - c4), with x1 power-law scaling
def model_gompertz9(theta, X):
    c0,c1,c2,c3,c4,c5,c6,c7,c8 = theta
    t, x1 = X[:,0], X[:,1]
    u = t - c4
    lt = np.log(u + np.sqrt(u**2+1))
    lx1 = np.log(np.abs(x1)+1e-30)
    rate = c1 * np.abs(x1)**c5
    ht = c2*np.abs(x1)**c6 + c7*lx1 + c8*lx1**2
    inner = np.clip(-rate*(lt - ht), -500, 500)
    return c0*np.exp(-np.exp(inner)) + c3

datasets = []
for dirpath, _, filenames in os.walk(root):
    if 'fit.tsv' in filenames:
        rel = str(Path(dirpath).relative_to(root))
        datasets.append((rel, Path(dirpath) / 'fit.tsv'))
datasets.sort()

results_logistic = []
results_gompertz = []

for name, p in datasets:
    X, y = load_ds(p)
    v = np.var(y)
    if v <= 0: v = 1.0

    # Logistic model
    def model_log9(theta, X):
        c0,c1,c2,c3,c4,c5,c6,c7,c8 = theta
        t, x1 = X[:,0], X[:,1]
        u = t - c2
        lt = np.log(u + np.sqrt(u**2+1))
        lx1 = np.log(np.abs(x1)+1e-30)
        rate = c1 * np.abs(x1)**c5
        ht = c3*np.abs(x1)**c6 + c7*lx1 + c8*lx1**2
        arg = np.clip(-rate*(lt - ht), -500, 500)
        return c0/(1+np.exp(arg)) + c4
    def resid_log(theta):
        pred = model_log9(theta, X)
        if not np.all(np.isfinite(pred)): return np.full(len(y),1e6)
        return pred - y
    try:
        r = least_squares(resid_log, [1.,2.,0.,3.,0.,0.,0.,0.,0.], loss='soft_l1', max_nfev=1000)
        pred = model_log9(r.x, X)
        nmse_l = np.mean((pred-y)**2)/v
    except: nmse_l = float('inf')
    results_logistic.append((nmse_l, name))

    # Gompertz model
    def resid_gomp(theta):
        pred = model_gompertz9(theta, X)
        if not np.all(np.isfinite(pred)): return np.full(len(y),1e6)
        return pred - y
    try:
        r2 = least_squares(resid_gomp, [1.,2.,3.,0.,0.,0.,0.,0.,0.], loss='soft_l1', max_nfev=1000)
        pred2 = model_gompertz9(r2.x, X)
        nmse_g = np.mean((pred2-y)**2)/v
    except: nmse_g = float('inf')
    results_gompertz.append((nmse_g, name))

mean_l = np.mean([r[0] for r in results_logistic if np.isfinite(r[0])])
mean_g = np.mean([r[0] for r in results_gompertz if np.isfinite(r[0])])
print(f'Logistic mean NMSE: {mean_l:.4f}')
print(f'Gompertz mean NMSE: {mean_g:.4f}')
# Show top differences
diffs = [(results_gompertz[i][0]-results_logistic[i][0], results_logistic[i][1]) for i in range(len(datasets))]
diffs.sort(reverse=True)
print('Datasets where Gompertz is WORSE:')
for d, n in diffs[:5]: print(f'  {d:+.4f}  {n[-40:]}')
print('Datasets where Gompertz is BETTER:')
for d, n in diffs[-5:]: print(f'  {d:+.4f}  {n[-40:]}')
