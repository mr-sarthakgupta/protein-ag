    for name in hard_names:
        Xtr, Xv, ytr, yv = ds[name]
        fitted = fit_expression_constants(expression, Xtr, ytr, Xv, constants=c,
            initial_values=iv, max_nfev=nfev)
        yp = fitted.y_pred_val
        nmse = np.mean((yp - yv)**2) / np.var(yv)
        results.append((name[-35:], nmse))
    print(f'nfev={nfev}: mean={np.mean([r[1] for r in results]):.5f}')
    for n, s in results:
        print(f'  {s:.5f}  {n}')
