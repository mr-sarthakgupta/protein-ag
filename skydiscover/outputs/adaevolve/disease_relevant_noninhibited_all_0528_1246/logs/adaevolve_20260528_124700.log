 100 |         "command": "python3 -c \"\nimport csv, os, numpy as np, sys, re\nsys.path.insert(0, '.')\nfrom pathlib import Path\nroot = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')\ndatasets = []\nfor dirpath, _, filenames in os.walk(root):\n    if 'fit.tsv' in filenames:\n        rel = str(Path(dirpath).relative_to(root))\n        datasets.append((rel, Path(dirpath) / 'fit.tsv'))\ndatasets.sort()\n\n# Quick fit of current model on a few datasets to see residuals\n# Use the current best model: logistic in asinh(t-c2) \n# y = c0/(1+exp(-c1*(asinh(t-c2) - c3))) + c4\nfrom scipy.optimize import least_squares\n\ndef fit_dataset(p):\n    with open(p) as f:\n        reader = csv.reader(f, delimiter='\\t')\n        header = next(reader)\n        rows = [r for r in reader if r]\n    x0 = np.array([float(r[0]) for r in rows])\n    n_curves = len(header) - 1\n    \n    # Build X, y\n    params = []\n    for h in header[1:]:\n        m = re.search(r'(\\d+(?:\\.\\d+)?)\\s*uM', h, re.IGNORECASE)\n        if m: params.append(float(m.group(1)))\n        else: params.append(float(len(params)+1))\n    \n    X = []\n    y = []\n    for row in rows:\n        t = float(row[0])\n        for i, p_val in enumerate(params):\n            if i+1 < len(row) and row[i+1].strip() and row[i+1].strip().lower() != 'nan':\n                X.append([t, p_val])\n                y.append(float(row[i+1]))\n    X = np.array(X); y = np.array(y)\n    \n    # Fit simple logistic in asinh(t)\n    def model(theta, X):\n        c0,c1,c2,c3,c4 = theta\n        u = X[:,0] - c2\n        lt = np.log(u + np.sqrt(u**2+1))\n        return c0/(1+np.exp(-c1*(lt-c3))) + c4\n    \n    def resid(theta):\n        pred = model(theta, X)\n        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e6)\n        return pred - y\n    \n    try:\n        r = least_squares(resid, [1.0,2.0,0.0,3.0,0.0], loss='soft_l1', max_nfev=500)\n        pred = model(r.x, X)\n        nmse = np.mean((pred-y)**2)/np.var(y)\n        return nmse\n    except:\n        return float('inf')\n\n# Test on all datasets, find worst ones\nresults = []\nfor name, p in datasets:\n    nmse = fit_dataset(p)\n    results.append((nmse, name))\nresults.sort(reverse=True)\nprint('Worst 10 datasets (simple logistic NMSE):')\nfor nmse, name in results[:10]:\n    print(f'  {nmse:.4f}  {name}')\nprint('Mean NMSE:', np.mean([r[0] for r in results if np.isfinite(r[0])]))\n\"\n"
