import numpy as np

# Need asym ~2.3 for htt datasets
# (1/(1+exp(-z)))^nu - check larger nu
for nu in [1.0, 2.0, 3.0, 5.0, 8.0, 10.0, 15.0]:
    z = np.linspace(-20, 20, 100000)
    y = (1.0 / (1 + np.exp(-z)))**nu
    i10 = np.argmin(np.abs(y - 0.1))
    i50 = np.argmin(np.abs(y - 0.5))
    i90 = np.argmin(np.abs(y - 0.9))
    z10, z50, z90 = z[i10], z[i50], z[i90]
    if (z50 - z10) > 0:
        asym = (z90 - z50) / (z50 - z10)
    else:
        asym = np.nan
    print(f'nu={nu:.1f}: asym={asym:.2f}  z50={z50:.2f}')

# Also check: when nu is fitted and can be negative, what happens?
# (1/(1+exp(-z)))^(-1) = (1+exp(-z)) which grows without bound - bad
# So we need nu > 0 always. Can use exp(c9) or c9^2 or abs(c9) - but abs not smooth
# Better: use c9 initialized to 1.0, and the expression is numerically fine for c9>0
# For c9<0 it blows up. Need a softplus: log(1+exp(c9)) to ensure positivity.
# Or just initialize c9=1 and rely on optimizer staying positive.

# Actually the safest form: use sp.exp(c9) as the exponent (always positive)
# exp(c9) with c9=0 init gives nu=1 (standard logistic)
# c9 > 0 gives nu > 1 (asym > 1, right-skewed)
# c9 < 0 gives nu < 1 (asym < 1, left-skewed)
print()
print('Using exp(c9) as nu:')
for c9 in [-1, 0, 0.5, 1, 2]:
    nu = np.exp(c9)
    z = np.linspace(-20, 20, 100000)
    y = (1.0 / (1 + np.exp(-z)))**nu
    i10 = np.argmin(np.abs(y - 0.1))
    i50 = np.argmin(np.abs(y - 0.5))
    i90 = np.argmin(np.abs(y - 0.9))
    z10, z50, z90 = z[i10], z[i50], z[i90]
    if (z50 - z10) > 0:
        asym = (z90 - z50) / (z50 - z10)
    else:
        asym = np.nan
    print(f'c9={c9} -> nu={nu:.2f}: asym={asym:.2f}')
