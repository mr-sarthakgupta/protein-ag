sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import sympy as sp
from pysr_harness.equation_session import constant_symbols, feature_symbols, fit_expression_constants
from pysr_harness.metrics import nmse

datasets = load_all_datasets()

# Test P3 (9c) with nfev=300 vs nfev=1000 vs nfev=2000
# Focus on the worst datasets
hard_names = ['htt/Kar2011', 'htt/Kakkar2016', 'insulin/Fits/Nielsen2001_seeded']

res300, res1000, res2000 = [], [], []
for name, X_tr, X_v, y_tr, y_v in datasets:
    x = feature_symbols(2)
    time, parameter = x[0], x[1]
    c9 = constant_symbols(9)
    u9 = time - c9[2]
    lt9 = sp.log(u9 + sp.sqrt(u9**2 + 1))
    lp = sp.log(parameter)
    ht9 = c9[3]*parameter**c9[6] + c9[7]*lp + c9[8]*lp**2
    expr_p3 = c9[0]/(1+sp.exp(-c9[1]*parameter**c9[5]*(lt9-ht9)))+c9[4]
    iv = [1,2,0,3,0,0,0,0,0]
    
    try:
        f1 = fit_expression_constants(expr_p3, X_tr, y_tr, X_v, constants=c9, initial_values=iv, max_nfev=300)
        f2 = fit_expression_constants(expr_p3, X_tr, y_tr, X_v, constants=c9, initial_values=iv, max_nfev=1000)
        f3 = fit_expression_constants(expr_p3, X_tr, y_tr, X_v, constants=c9, initial_values=iv, max_nfev=2000)
        n1 = nmse(y_v, f1.y_pred_val)
        n2 = nmse(y_v, f2.y_pred_val)
        n3 = nmse(y_v, f3.y_pred_val)
        res300.append(n1); res1000.append(n2); res2000.append(n3)
        if any(h in name for h in hard_names):
            print(f'{name[-48:]}: 300={n1:.4f} 1000={n2:.4f} 2000={n3:.4f}')
    except Exception as e:
        res300.append(999); res1000.append(999); res2000.append(999)

print(f'Mean: 300={np.mean(res300):.4f} 1000={np.mean(res1000):.4f} 2000={np.mean(res2000):.4f}')
