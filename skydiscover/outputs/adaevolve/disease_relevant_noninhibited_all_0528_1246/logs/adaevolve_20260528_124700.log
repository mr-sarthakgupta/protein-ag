import numpy as np, pandas as pd, os

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
tsv_files = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            tsv_files.append(os.path.join(root, f))

# Test Avrami WITH x1 coupling on all 60 datasets
# y = c0*(1 - exp(-( (x0-c2) / (c3*x1^c6) )^c7)) + c4
# where x1 is the experimental parameter

from scipy.optimize import curve_fit

def fit_dataset_x1(path):
    df = pd.read_csv(path, sep='\t')
    cols = df.columns.tolist()
    x0_all = df[cols[0]].values.astype(float)
    y_cols = cols[1:]
    
    x1_vals = []
    for c in y_cols:
        try:
            x1_vals.append(float(c))
        except:
            x1_vals.append(None)
    if any(v is None for v in x1_vals):
        x1_vals = list(range(1, len(y_cols)+1))
    
    # Stack all (x0, x1, y) triples
    X0_list, X1_list, Y_list = [], [], []
    for i, yc in enumerate(y_cols):
        y = df[yc].values.astype(float)
        mask = np.isfinite(y) & np.isfinite(x0_all)
        if mask.sum() < 3: continue
        X0_list.append(x0_all[mask])
        X1_list.append(np.full(mask.sum(), float(x1_vals[i])))
        Y_list.append(y[mask])
    
    if not X0_list:
        return 1.0
    
    X0 = np.concatenate(X0_list)
    X1 = np.concatenate(X1_list)
    Y = np.concatenate(Y_list)
    
    # Model: y = c0*(1-exp(-((x0-c2)/(c3*x1^c6))^c7)) + c4
    def model(Xmat, c0, c2, c3, c6, c7, c4):
        x0, x1 = Xmat
        u = x0 - c2
        lt = np.log(u + np.sqrt(u**2 + 1))  # asinh
        scale = np.abs(c3) * np.abs(x1)**c6
        arg = np.maximum(lt / scale, 1e-10)
        return c0 * (1 - np.exp(-arg**np.abs(c7))) + c4
    
    try:
        xmin = X0.min()
        p0 = [1.0, xmin - 1.0, 3.0, 0.0, 1.0, 0.0]
        popt, _ = curve_fit(model, (X0, X1), Y, p0=p0, maxfev=3000)
        yp = model((X0, X1), *popt)
        nmse = np.mean((Y-yp)**2) / np.var(Y) if np.var(Y) > 0 else 0.0
        return nmse
    except:
        return 1.0

results = []
for path in tsv_files:
    nm = fit_dataset_x1(path)
    results.append(nm)

arr = np.array(results)
print(f'N={len(arr)}, Mean={arr.mean():.4f}, Median={np.median(arr):.4f}')
print(f'>0.1: {(arr>0.1).sum()}, >0.5: {(arr>0.5).sum()}')
worst = np.argsort(arr)[-5:]
for i in worst:
    print(f'  {arr[i]:.4f}  {tsv_files[i].split(\"non-inhibited/\")[-1]}')
"
