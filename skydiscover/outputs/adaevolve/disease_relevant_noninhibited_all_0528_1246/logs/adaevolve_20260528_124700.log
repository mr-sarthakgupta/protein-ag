import sympy as sp
import numpy as np
x1 = sp.Symbol('x1')
e1 = sp.log1p(x1)
e2 = sp.log(x1 + 1)
print('log1p srepr:', sp.srepr(e1))
print('log(x1+1) srepr:', sp.srepr(e2))
print('Are they equal?', e1 == e2)

# The evaluator allows sp.log1p but we use sp.log(x1+1) which only uses sp.log
# Both are safe, but sp.log(x1+1) uses only sp.log which is definitely allowed
# Let's check: what call name does sp.log1p produce?
import ast
code = 'sp.log1p(parameter + 1)'
tree = ast.parse(code, mode='eval')
