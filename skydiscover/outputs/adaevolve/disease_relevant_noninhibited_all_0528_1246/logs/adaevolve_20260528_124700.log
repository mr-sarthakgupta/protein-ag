import numpy as np, sys, os
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_dataset
from pathlib import Path
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
all_files = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            all_files.append(os.path.join(root, f))
all_files.sort()

# Double sigmoid: same rate structure but two halftimes
# y = c0/(1+exp(-rate*(lt-ht1))) + c4/(1+exp(-rate*(lt-ht2))) + c8
# where rate = c1*x1^c5, ht1=c3*x1^c6+c7*log(x1)+c9*log(x1)^2, ht2=ht1+c10*exp(c11*log(x1+1))
# This shares rate and x1 coupling, adds a second phase offset
# 12 constants total

def model_E(t, p, c):
    lp = np.log(p)
    lp1 = np.log(p+1)
    u = t - c[2]; lt = np.log(u + np.sqrt(u**2+1))
    rate = c[1] * p**c[5]
    ht1 = c[3]*p**c[6] + c[7]*lp + c[9]*lp**2
    # Second halftime = first + offset (so second phase is always after first)
    ht2 = ht1 + c[10] * np.exp(c[11] * lp1)
    s1 = c[0] / (1 + np.exp(-rate*(lt - ht1)))
    s2 = c[4] / (1 + np.exp(-rate*(lt - ht2)))
    return s1 + s2 + c[8]

# Also test: simpler double sigmoid - shared x1 coupling, independent halftimes
# y = c0/(1+exp(-c1*(lt-c3*x1^c6-c7*lp))) + c4/(1+exp(-c1*(lt-c3*x1^c6-c7*lp-c9))) + c8
# just 10 constants

def model_F(t, p, c):
    lp = np.log(p)
    u = t - c[2]; lt = np.log(u + np.sqrt(u**2+1))
    rate = c[1] * p**c[5]
    ht_base = c[3]*p**c[6] + c[7]*lp
    s1 = c[0] / (1 + np.exp(-rate*(lt - ht_base)))
    s2 = c[4] / (1 + np.exp(-rate*(lt - ht_base - c[9])))
    return s1 + s2 + c[8]

# Current best
def model_C(t, p, c):
    lp = np.log(p)
    u = t - c[2]; lt = np.log(u + np.sqrt(u**2+1))
    rate = c[1] * p**c[5]
    ht = c[3]*p**c[6] + c[7]*lp + c[8]*lp**2
    return c[0] / (1 + np.exp(-rate*(lt - ht))) + c[4]

models = [
    ('C-current-9c', model_C, [1,2,0,3,0,0,0,0,0]),
    ('E-double-12c', model_E, [0.8,2,0,3,0.2,0,0,0,0,0,1,0]),
    ('F-double-10c', model_F, [0.8,2,0,3,0.2,0,0,0,0,1]),
]

results = {n: [] for n,_,_ in models}
for fp in all_files:
    X_tr, X_v, y_tr, y_v = load_dataset(Path(fp))
    x0t, x1t = X_tr[:,0], X_tr[:,1]
    for mname, mfn, init in models:
        def resid(c, m=mfn):
            with np.errstate(all='ignore'):
                pred = m(x0t, x1t, c)
            if not np.all(np.isfinite(pred)): return np.full(len(y_tr), 1e6)
            return pred - y_tr
        r = least_squares(resid, init, loss='soft_l1', max_nfev=1000)
        pv = mfn(X_v[:,0], X_v[:,1], r.x)
        nm = np.mean((pv-y_v)**2)/np.var(y_v) if np.var(y_v)>0 else float('inf')
        results[mname].append(nm)

for mname, _, _ in models:
    vals = results[mname]
    print(f'{mname}: mean={np.mean(vals):.5f}, max={np.max(vals):.4f}')
"
