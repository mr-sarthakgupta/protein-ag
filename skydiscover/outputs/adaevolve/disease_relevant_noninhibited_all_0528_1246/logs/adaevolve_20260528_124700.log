import os, pandas as pd, numpy as np
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

# Check Kar2011 Q37 sec dataset
p = base + 'htt/Kar2011/Fits/Kar2011_Q37_sec/fit.tsv'
df = pd.read_csv(p, sep='\t')
cols = list(df.columns[1:])
x0 = df['X'].values
print(f'x0 range: [{x0.min():.3e}, {x0.max():.3e}]')
print(f'cols: {cols}')

# Parse x1 values
import re
params = []
for col in cols:
    m = re.search(r'(\d+(?:\.\d+)?)\s*uM', col)
    if m:
        params.append(float(m.group(1)))
    else:
        params.append(None)
print(f'params: {params}')

# Build X, y  
X = np.array([[xi, p] for xi in x0 for p in params if p is not None])
y_vals = []
for i in range(len(x0)):
    for j, col in enumerate(cols):
        if params[j] is not None:
