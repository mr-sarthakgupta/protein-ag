import numpy as np
import sys, pandas as pd
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import _load_fit_table
from scipy.optimize import least_squares
from pathlib import Path

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

# Examine htt Q37 - what's the x1 vs t50 relationship?
path = base + 'htt/Kar2011/Fits/Kar2011_Q37_prim/fit.tsv'
df = pd.read_csv(path, sep='\t')
X, y = _load_fit_table(Path(path))
print(f'Kar2011 Q37 prim: x1 unique={sorted(set(X[:,1]))}')
print(f'x0 range: {X[:,0].min():.3g} to {X[:,0].max():.3g}')

# For each x1 value, find the t50 from data
for x1_val in sorted(set(X[:,1])):
    mask = X[:,1] == x1_val
    x0_sub = X[mask, 0]
    y_sub = y[mask]
    # Sort by x0
    idx = np.argsort(x0_sub)
    x0_sub, y_sub = x0_sub[idx], y_sub[idx]
    i50 = np.argmin(np.abs(y_sub - 0.5))
    i10 = np.argmin(np.abs(y_sub - 0.1))
    i90 = np.argmin(np.abs(y_sub - 0.9))
    t50 = x0_sub[i50]
    t10, t90 = x0_sub[i10], x0_sub[i90]
    asym = (t90-t50)/(t50-t10) if (t50-t10) > 0 else np.nan
    print(f'  x1={x1_val:.1f}: t10={t10:.3g}, t50={t50:.3g}, t90={t90:.3g}, asym={asym:.2f}, ymax={y_sub.max():.3f}')

print()
# Check log(x1) vs log(t50) relationship
x1_vals = sorted(set(X[:,1]))
t50_vals = []
for x1_val in x1_vals:
    mask = X[:,1] == x1_val
    x0_sub = X[mask, 0]
    y_sub = y[mask]
    idx = np.argsort(x0_sub)
    x0_sub, y_sub = x0_sub[idx], y_sub[idx]
    i50 = np.argmin(np.abs(y_sub - 0.5))
    t50_vals.append(x0_sub[i50])

x1_arr = np.array(x1_vals)
t50_arr = np.array(t50_vals)
# Fit log(t50) ~ a + b*log(x1)
log_x1 = np.log(x1_arr)
log_t50 = np.log(t50_arr)
b = np.polyfit(log_x1, log_t50, 1)
print(f'Power law fit: log(t50) = {b[0]:.2f}*log(x1) + {b[1]:.2f}')
print(f'  => t50 ~ x1^{b[0]:.2f}')
