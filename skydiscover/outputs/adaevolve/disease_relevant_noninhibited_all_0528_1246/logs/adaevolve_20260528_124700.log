import numpy as np
from scipy.optimize import curve_fit
import pandas as pd, os

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'

tsv_files = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            tsv_files.append(os.path.join(root, f))

# Test combined Avrami+x1 model using asinh-time for stability
# y = c0*(1 - exp(-( c1*x1^c5 * asinh(x0-c2) / (c3*x1^c6) )^c7)) + c4
# = c0*(1 - exp(- (c1/c3 * x1^(c5-c6) * lt)^c7 )) + c4   where lt=asinh(x0-c2)
# Simplify: let A = c1/c3, B = c5-c6
# y = c0*(1 - exp(-(A * x1^B * lt)^c7)) + c4
# But we need lt > 0, so x0 > c2 (c2 initialized as min(x0)-1)

# Test on all 60 datasets
def fit_dataset(path):
    df = pd.read_csv(path, sep='\t')
    cols = df.columns.tolist()
    x0 = df[cols[0]].values.astype(float)
    y_cols = cols[1:]
    
    # Determine x1 values from column headers
    x1_vals = []
    for c in y_cols:
        try:
            x1_vals.append(float(c))
        except:
            x1_vals.append(None)
    
    # If non-numeric, use sequential index
    if any(v is None for v in x1_vals):
        x1_vals = list(range(1, len(y_cols)+1))
    
    nmses = []
    for i, yc in enumerate(y_cols):
        y = df[yc].values.astype(float)
        mask = np.isfinite(y) & np.isfinite(x0)
        if mask.sum() < 4: continue
        xv = x0[mask]; yv = y[mask]
        x1 = float(x1_vals[i])
        
        def model(x, c0, c2, c3, c7, c4):
            lt = np.log((x - c2) + np.sqrt((x-c2)**2 + 1))  # asinh
            arg = np.maximum(lt / np.abs(c3), 1e-10)
            return c0 * (1 - np.exp(-arg**np.abs(c7))) + c4
        
        try:
            xmin = xv.min()
            p0 = [1.0, xmin - 1.0, (xv.max()-xmin)/2 + 1, 1.0, 0.0]
            popt, _ = curve_fit(model, xv, yv, p0=p0, maxfev=2000)
            yp = model(xv, *popt)
            nmse = np.mean((yv-yp)**2) / np.var(yv) if np.var(yv) > 0 else 0.0
            nmses.append(nmse)
        except:
            nmses.append(1.0)
    return np.mean(nmses) if nmses else 1.0

results = []
for path in tsv_files:
    nm = fit_dataset(path)
    results.append(nm)

arr = np.array(results)
print(f'N={len(arr)}, Mean NMSE={arr.mean():.4f}, Median={np.median(arr):.4f}')
print(f'Max={arr.max():.4f}, >0.1: {(arr>0.1).sum()}')
# Show worst cases
worst_idx = np.argsort(arr)[-5:]
for i in worst_idx:
    name = tsv_files[i].split('non-inhibited/')[-1]
    print(f'  NMSE={arr[i]:.4f}  {name}')
"
