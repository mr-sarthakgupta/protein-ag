import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_dataset
from pathlib import Path
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'

hard = [
    'htt/Kar2011/Fits/Kar2011_Q37_prim/fit.tsv',
    'htt/Kar2011/Fits/Kar2011_Q37_sec/fit.tsv',
    'insulin/Fits/Nielsen2001_seeded_sec/fit.tsv',
]

# Test: single sigmoid with richer halftime: c3*x1^c6 + c7*x1 + c8*x1^2 (polynomial in x1)
def model_poly(t, p, c):
    u = t - c[2]; lt = np.log(u + np.sqrt(u**2+1))
    rate = c[1] * np.exp(c[5] * np.log(p+1))
    ht = c[3] * np.exp(c[6] * np.log(p+1)) + c[7]*p + c[8]*p**2
    return c[0] / (1 + np.exp(-rate*(lt - ht))) + c[4]

# Test: double sigmoid - no x1 coupling, just two phases
def model_double(t, p, c):
    lp = np.log(p+1)
    u1 = t - c[2]; lt1 = np.log(u1 + np.sqrt(u1**2+1))
    u2 = t - c[6]; lt2 = np.log(u2 + np.sqrt(u2**2+1))
    rate1 = c[1] * np.exp(c[9] * lp)
    ht1   = c[3] * np.exp(c[10] * lp)
    rate2 = c[5]
    ht2   = c[7] * np.exp(c[11] * lp)
    s1 = c[0] / (1 + np.exp(-rate1*(lt1 - ht1)))
    s2 = c[4] / (1 + np.exp(-rate2*(lt2 - ht2)))
    return s1 + s2 + c[8]

for ds in hard:
    p = Path(base) / ds
    X_tr, X_v, y_tr, y_v = load_dataset(p)
    x0t, x1t = X_tr[:,0], X_tr[:,1]

    def res_poly(c):
        with np.errstate(all='ignore'):
            pred = model_poly(x0t, x1t, c)
        if not np.all(np.isfinite(pred)): return np.full(len(y_tr), 1e6)
        return pred - y_tr

    rp = least_squares(res_poly, [1,2,0,3,0,0,0,0,0], loss='soft_l1', max_nfev=2000)
    pv_p = model_poly(X_v[:,0], X_v[:,1], rp.x)
    nm_p = np.mean((pv_p-y_v)**2)/np.var(y_v)

    def res_d(c):
        with np.errstate(all='ignore'):
            pred = model_double(x0t, x1t, c)
        if not np.all(np.isfinite(pred)): return np.full(len(y_tr), 1e6)
        return pred - y_tr

    rd = least_squares(res_d, [0.8,2,0,3,0.2,2,0,8,0,0,0,0], loss='soft_l1', max_nfev=2000)
    pv_d = model_double(X_v[:,0], X_v[:,1], rd.x)
    nm_d = np.mean((pv_d-y_v)**2)/np.var(y_v)

    name = ds.split('/')[-2]
    print(f'{name}: poly={nm_p:.4f}, double={nm_d:.4f}')
"
