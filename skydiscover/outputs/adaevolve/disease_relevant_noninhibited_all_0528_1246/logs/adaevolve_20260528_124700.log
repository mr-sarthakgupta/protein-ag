    lx1 = np.log(np.maximum(x1,1e-10))
    rate = c1*np.maximum(x1,1e-10)**c5
    ht = c3*np.maximum(x1,1e-10)**c6 + c7*lx1 + c8*lx1*lx1
    return c0/(1+np.exp(-np.clip(rate*(lt-ht),-500,500)))+c4

results = {}
for key, model, init in [
    ('A', lambda X,c: (lambda x0,x1,c0,c1,c2,c3,c4,c5,c6: c0/(1+np.exp(-np.clip(c1*np.maximum(x1,1e-10)**c5*(asinh_val(x0,c2)-c3*np.maximum(x1,1e-10)**c6),-500,500)))+c4)(X[:,0],X[:,1],*c),
