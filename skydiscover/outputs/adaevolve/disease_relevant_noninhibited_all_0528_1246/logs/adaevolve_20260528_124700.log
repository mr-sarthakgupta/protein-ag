for x1v in sorted(np.unique(x1)):
    mask = x1 == x1v
    idx = np.argsort(x0[mask])
    x0s = x0[mask][idx]
    ys = y_train[mask][idx]
    print(f'  x1={x1v}: first5={(list(zip(x0s[:5].round(0), ys[:5].round(3))))}')
    print(f'         last3={(list(zip(x0s[-3:].round(0), ys[-3:].round(3))))}')

print()
# The problem with asinh(c2*x0): when x0 has negative values (Ye2011 has x0=-256!)
# asinh handles negatives fine, but c2*x0 with c2>0 and x0<0 gives negative arg
# which is fine for asinh but may confuse the optimizer

# Test both models on Ye2011
def model_current(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4, c5, c6 = c
    u = x0 - c2
    lt = np.log(u + np.sqrt(u**2 + 1))
    rate = c1 * np.maximum(x1, 1e-10)**c5
    ht = c3 * np.maximum(x1, 1e-10)**c6
    return c0 / (1 + np.exp(-np.clip(rate * (lt - ht), -500, 500))) + c4

def model_asinh_scale(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4, c5, c6 = c
    t_arg = c2 * x0 * np.maximum(x1, 1e-10)**c6
    lt = np.log(t_arg + np.sqrt(t_arg**2 + 1))
    rate = c1 * np.maximum(x1, 1e-10)**c5
    return c0 / (1 + np.exp(-np.clip(rate * (lt - c3), -500, 500))) + c4

var_y = np.var(y_val)
res1 = least_squares(lambda c: model_current(X_train, c) - y_train,
