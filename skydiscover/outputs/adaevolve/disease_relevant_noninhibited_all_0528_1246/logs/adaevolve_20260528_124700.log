import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = {name: (X_train, X_val, y_train, y_val) 
            for name, X_train, X_val, y_train, y_val in load_all_datasets()}

# Kar2011: x0 in [7701, 937674], x1 in [3,4,6,8,9,22]
# What shape does each x1 curve have?
name = 'htt/Kar2011/Fits/Kar2011_Q37_sec'
X_train, X_val, y_train, y_val = datasets[name]
x0, x1 = X_train[:,0], X_train[:,1]

for x1v in sorted(np.unique(x1)):
    mask = x1 == x1v
    idx = np.argsort(x0[mask])
    x0s = x0[mask][idx]
    ys = y_train[mask][idx]
    # Find approximate half-time (where y~0.5)
    above_half = x0s[ys > 0.4]
    t_half = above_half[0] if len(above_half) > 0 else float('nan')
    print(f'  x1={x1v:4.0f}: n={mask.sum():3d}, y_range=[{ys.min():.3f},{ys.max():.3f}], t_half~{t_half:.0f}, log(t_half)={np.log(t_half):.2f}')

print()
