import numpy as np
import sympy as sp
import sys
from scipy.optimize import least_squares
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets
all_ds = load_all_datasets()
ds = {name: (Xtr, Xv, ytr, yv) for name, Xtr, Xv, ytr, yv in all_ds}

# Alphasyn - single x1, what does the data look like?
name = 'Alphasyn_Gaspar2017/03uM_seed all'
Xtr, Xv, ytr, yv = ds[name]
print(f'=== {name} ===')
print(f'n_train={len(ytr)}, n_val={len(yv)}')
print(f'x1={Xtr[:,1][0]}, x0=[{Xtr[:,0].min():.2f},{Xtr[:,0].max():.2f}]')
idx = np.argsort(Xtr[:,0])
print('Sample sorted points:')
for i in idx[::80][:12]:
    print(f'  x0={Xtr[i,0]:.3f}, y={ytr[i]:.4f}')

# Try direct logistic fit
def residual(theta):
    c0, c1, c2, c4 = theta
    u = Xtr[:,0] - c2
    lt = np.log(u + np.sqrt(u**2 + 1))
    pred = c0 / (1 + np.exp(-c1 * lt)) + c4
    pred = np.where(np.isfinite(pred), pred, 1e6)
    return pred - ytr
res = least_squares(residual, [1.0, 2.0, 0.0, 0.0], loss='soft_l1', max_nfev=1000)
c0, c1, c2, c4 = res.x
print(f'Best logistic: c0={c0:.4f}, c1={c1:.4f}, c2={c2:.4f}, c4={c4:.4f}')
u = Xv[:,0] - c2
lt = np.log(u + np.sqrt(u**2 + 1))
yp = c0 / (1 + np.exp(-c1 * lt)) + c4
nmse = np.mean((yp - yv)**2) / np.var(yv)
print(f'Val NMSE: {nmse:.5f}')
"
