-c1*(lt-c3))) + c9*exp(-exp(-c1*(lt-c3)))] + c4\n# This interpolates between logistic (c9=0) and Gompertz (c9=1)\n\ndef model_mix(theta, X):\n    c0,c1,c2,c3,c4,c5,c6,c7,c8,c9 = theta\n    t, x1 = X[:,0], X[:,1]\n    u = t - c2\n    lt = np.log(u + np.sqrt(u**2+1))\n    lx1 = np.log(np.abs(x1)+1e-30)\n    rate = c1 * np.abs(x1)**c5\n    ht = c3*np.abs(x1)**c6 + c7*lx1 + c8*lx1**2\n    z = np.clip(rate*(lt - ht), -500, 500)\n    # mixture: alpha*logistic + (1-alpha)*gompertz\n    alpha = 1.0/(1.0+np.exp(-c9))  # alpha in (0,1)\n    logistic = 1.0/(1.0+np.exp(-z))\n    gompertz = np.exp(-np.exp(-z))\n    return c0*(alpha*logistic + (1-alpha)*gompertz) + c4\n\ndatasets = []\nfor dirpath, _, filenames in os.walk(root):\n    if 'fit.tsv' in filenames:\n        rel = str(Path(dirpath).relative_to(root))\n        datasets.append((rel, Path(dirpath) / 'fit.tsv'))\ndatasets.sort()\n\nresults_mix = []\nfor name, p in datasets:\n    X, y = load_ds(p)\n    v = np.var(y)\n    if v <= 0: v = 1.0\n    def resid(theta):\n        pred = model_mix(theta, X)\n        if not np.all(np.isfinite(pred)): return np.full(len(y),1e6)\n        return pred - y\n    best = float('inf')\n    for init_c9 in [0.0, 2.0, -2.0]:\n        init = [1.,2.,0.,3.,0.,0.,0.,0.,0.,init_c9]\n        try:\n            r = least_squares(resid, init, loss='soft_l1', max_nfev=1000)\n            pred = model_mix(r.x, X)\n            nmse = np.mean((pred-y)**2)/v\n            if nmse < best: best = nmse\n        except: pass\n    results_mix.append((best, name))\n\nmean_mix = np.mean([r[0] for r in results_mix if np.isfinite(r[0])])\nprint(f'Mixture mean NMSE: {mean_mix:.4f}')\nresults_mix.sort(reverse=True)\nprint('Worst 5:')\nfor nmse, name in results_mix[:5]:\n    print(f'  {nmse:.4f}  {name[-40:]}')\n\" 2>/dev/null\n",
