 116 |         "command": "python3 -c \"\nimport numpy as np\nfrom scipy.optimize import brentq, curve_fit\nimport pandas as pd\n\nbase = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'\n\n# Test Avrami model: y = c0*(1 - exp(-((x0-c2)/c3)^c4)) + c5\n# on a few representative datasets\n\nimport os\ntsv_files = []\nfor root, dirs, files in os.walk(base):\n    for f in files:\n        if f == 'fit.tsv':\n            tsv_files.append(os.path.join(root, f))\n\ndef avrami_fit(path):\n    df = pd.read_csv(path, sep='\\t')\n    cols = df.columns.tolist()\n    x0 = df[cols[0]].values.astype(float)\n    y_cols = cols[1:]\n    nmses = []\n    for yc in y_cols:\n        y = df[yc].values.astype(float)\n        mask = np.isfinite(y) & np.isfinite(x0)\n        if mask.sum() < 5: continue\n        xv = x0[mask]; yv = y[mask]\n        # Avrami: y = c0*(1-exp(-((x-c2)/c3)^c4)) + c5\n        # Need x-c2 > 0, so c2 < min(x)\n        def model(x, c0, c2, c3, c4, c5):\n            arg = np.maximum((x - c2) / np.abs(c3), 1e-10)\n            return c0 * (1 - np.exp(-arg**np.abs(c4))) + c5\n        try:\n            p0 = [1.0, xv.min()-1, (xv.max()-xv.min())/2, 1.0, 0.0]\n            popt, _ = curve_fit(model, xv, yv, p0=p0, maxfev=2000)\n            yp = model(xv, *popt)\n            nmse = np.mean((yv-yp)**2) / np.var(yv)\n            nmses.append(nmse)\n        except:\n            nmses.append(1.0)\n    return np.mean(nmses) if nmses else 1.0\n\n# Test on first 10 datasets\nresults = []\nfor path in tsv_files[:10]:\n    nm = avrami_fit(path)\n    name = path.split('non-inhibited/')[-1]\n    results.append((name, nm))\n    \nfor name, nm in sorted(results, key=lambda x: x[1]):\n    print(f'{nm:.4f}  {name}')\nprint(f'Mean: {np.mean([r[1] for r in results]):.4f}')\n\"\n"
