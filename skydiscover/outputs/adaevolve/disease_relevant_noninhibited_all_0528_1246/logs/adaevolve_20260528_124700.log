    y_start = np.mean([df[c].values[0] for c in cols])
    y_end = np.mean([df[c].values[-1] for c in cols])
    print(f'{rel[:55]:55s} yS={y_start:.3f} yE={y_end:.3f} yMn={all_y.min():.3f} yMx={all_y.max():.3f} x0=[{x0.min():.1e},{x0.max():.1e}]')
"
