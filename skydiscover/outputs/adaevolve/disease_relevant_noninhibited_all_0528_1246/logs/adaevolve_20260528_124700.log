import numpy as np
import sympy as sp
import sys
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets
from pysr_harness.equation_session import feature_symbols, constant_symbols, fit_expression_constants

all_ds = load_all_datasets()

# Test: logistic in asinh(time) with rate = c1*x1^c5 and halftime = exp(c3 + c6*log(x1))
# This is equivalent to halftime = exp(c3) * x1^c6, but parameterized differently
# Key change: use exp(c3 + c6*log(x1)) for halftime - more numerically stable than c3*x1^c6
# when c3 can go negative

# Also test: adding a 'steepness' modifier to the logistic via a Hill-like approach
# y = c0 / (1 + (c2/x0)^c1) - Hill equation form

def test_hill(all_ds):
    x = feature_symbols(2)
    c = constant_symbols(7)
    time = x[0]
    parameter = x[1]
    # Hill-like: y = c0 / (1 + exp(-c1*x1^c5 * (log(x0+c2) - log(c3*x1^c6)))) + c4
    # Equivalent to logistic in log-time with power-law rate and halftime
    # But using log(x0 + c2) instead of asinh(x0 - c2)
    log_t = sp.log(time + c[2])
    rate = c[1] * parameter**c[5]
    log_halftime = sp.log(c[3] * parameter**c[6])
    expression = c[0] / (1 + sp.exp(-rate * (log_t - log_halftime))) + c[4]

    results = []
    for name, Xtr, Xv, ytr, yv in all_ds:
        try:
            fitted = fit_expression_constants(expression, Xtr, ytr, Xv, constants=c,
                initial_values=[1.0, 2.0, 1.0, 30000.0, 0.0, 0.0, 0.0])
            yp = fitted.y_pred_val
            var_y = np.var(yv)
            nmse = np.mean((yp - yv)**2) / var_y if var_y > 0 else float('inf')
            results.append((name, nmse))
        except Exception as e:
            results.append((name, float('inf')))
    return results

results3 = test_hill(all_ds)
results3.sort(key=lambda x: x[1], reverse=True)
print('Hill-like (log(x0+c2) time) - Top 10 worst:')
for name, nmse in results3[:10]:
    print(f'  {nmse:.4f}  {name[:55]}')
print(f'Mean NMSE: {np.mean([r[1] for r in results3 if np.isfinite(r[1])]):.4f}')
"
