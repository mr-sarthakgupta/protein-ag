import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = {name: (X_train, X_val, y_train, y_val) 
            for name, X_train, X_val, y_train, y_val in load_all_datasets()}

def asinh_val(x0, c2):
    u = x0 - c2
    return np.log(u + np.sqrt(u**2 + 1))

# Test on ACE_sec: the issue is very long lag + not reaching plateau
# Try adding a quadratic/power term to the logistic argument
# y = c0 / (1 + exp(-c1*(x0^c5 - c2))) + c4  -- direct power-law time
name = 'beta-parvalbumin (Gadm1)/Sanchez2016/ACE_sec'
X_train, X_val, y_train, y_val = datasets[name]
x0, x1 = X_train[:,0], X_train[:,1]

# Current model residuals
def model_current(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4, c5, c6 = c
    lt = asinh_val(x0, c2)
    rate = c1 * x1**c5
    ht = c3 * x1**c6
    return c0 / (1 + np.exp(-np.clip(rate * (lt - ht), -500, 500))) + c4

res = least_squares(lambda c: model_current(X_train, c) - y_train, 
                    [1.0, 2.0, 0.0, 3.0, 0.0, 0.0, 0.0], max_nfev=500)
pred_val = model_current(X_val, res.x)
var_y = np.var(y_val)
nmse_v = np.mean((pred_val - y_val)**2) / var_y
print(f'ACE_sec current model NMSE: {nmse_v:.4f}, constants: {res.x.round(3)}')

# Try: logistic with log(x0+1) time transform instead of asinh
def model_log(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4 = c
    lt = np.log(np.maximum(x0 + 1, 1e-10))
    return c0 / (1 + np.exp(-np.clip(c1 * (lt - c2), -500, 500))) + c4

res2 = least_squares(lambda c: model_log(X_train, c) - y_train,
                     [1.0, 2.0, 11.0, 0.0, 0.0], max_nfev=500)
pred_val2 = model_log(X_val, res2.x)
nmse_v2 = np.mean((pred_val2 - y_val)**2) / var_y
print(f'ACE_sec log model NMSE: {nmse_v2:.4f}, constants: {res2.x.round(3)}')
print()

# Check htt/Kar2011
name2 = 'htt/Kar2011/Fits/Kar2011_Q37_sec'
X_train2, X_val2, y_train2, y_val2 = datasets[name2]
res3 = least_squares(lambda c: model_current(X_train2, c) - y_train2,
                     [1.0, 2.0, 0.0, 3.0, 0.0, 0.0, 0.0], max_nfev=500)
pred_val3 = model_current(X_val2, res3.x)
var_y3 = np.var(y_val2)
nmse_v3 = np.mean((pred_val3 - y_val2)**2) / var_y3
print(f'Kar2011_Q37_sec current NMSE: {nmse_v3:.4f}, constants: {res3.x.round(3)}')
