import pandas as pd
import numpy as np
import os, re

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
datasets = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            datasets.append(os.path.join(root, f))
datasets.sort()

# Check datasets with x1=1 (single column, sequential index)
# and datasets with x0 near 0 or negative
special = []
for path in datasets:
    df = pd.read_csv(path, sep='\t')
    name = path.split(base)[1]
    x0 = df.iloc[:,0].values
    has_neg_x0 = (x0 < 0).any()
    has_zero_x0 = (x0 == 0).any()
    ncols = df.shape[1] - 1
    # Check if x1 would be 1 (single col or non-numeric)
    cols = df.columns[1:]
    params = []
    for c in cols:
        m = re.search(r'(\d+(?:\.\d+)?)\s*uM', c, re.IGNORECASE)
        if m:
            params.append(float(m.group(1)))
    x1_is_index = (len(params) == 0)
    if has_neg_x0 or has_zero_x0 or x1_is_index:
        print(f'{name}: neg_x0={has_neg_x0} zero_x0={has_zero_x0} x1_index={x1_is_index} ncols={ncols}')
