 124 |         "command": "python3 -c \"\nimport csv, numpy as np, sys, re\nsys.path.insert(0, '.')\nfrom pathlib import Path\nfrom scipy.optimize import least_squares\nroot = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')\n\ndef load_ds(p):\n    with open(p) as f:\n        reader = csv.reader(f, delimiter='\\t')\n        header = next(reader)\n        rows = [r for r in reader if r]\n    params = []\n    for h in header[1:]:\n        m = re.search(r'(\\d+(?:\\.\\d+)?)\\s*uM', h, re.IGNORECASE)\n        if m: params.append(float(m.group(1)))\n        else: params.append(float(len(params)+1))\n    X, y = [], []\n    for row in rows:\n        t = float(row[0])\n        for i, pv in enumerate(params):\n            if i+1 < len(row) and row[i+1].strip() and row[i+1].strip().lower() != 'nan':\n                X.append([t, pv]); y.append(float(row[i+1]))\n    return np.array(X), np.array(y)\n\n# 9-constant model: y = c0/(1+exp(-c1*x1^c5*(asinh(t-c2) - c3*x1^c6 - c7*log(x1) - c8*log(x1)^2))) + c4\ndef model9(theta, X):\n    c0,c1,c2,c3,c4,c5,c6,c7,c8 = theta\n    t, x1 = X[:,0], X[:,1]\n    u = t - c2\n    lt = np.log(u + np.sqrt(u**2+1))\n    lx1 = np.log(np.abs(x1)+1e-30)\n    rate = c1 * np.abs(x1)**c5\n    ht = c3 * np.abs(x1)**c6 + c7*lx1 + c8*lx1**2\n    arg = -rate*(lt - ht)\n    arg = np.clip(arg, -500, 500)\n    return c0/(1+np.exp(arg)) + c4\n\nworst_paths = [\n    'beta-parvalbumin (Gadm1)/Sanchez2016/ACE_sec',\n    'insulin/Fits/Nielsen2001_seeded_sec',\n    'serum amyloid/Ye2011/Fits/Ye2011_sec',\n    'Abeta/Meisl2014/Ab40_sec_IN_HOURS',\n    'prp/Stoehr2008/Stoehr2008_Fig4-seeded_sec_nuc',\n]\nfor name in worst_paths:\n    p = root / name / 'fit.tsv'\n    X, y = load_ds(p)\n    def resid(theta):\n        pred = model9(theta, X)\n        if not np.all(np.isfinite(pred)): return np.full(len(y),1e6)\n        return pred - y\n    best = float('inf')\n    for init in [[1.,2.,0.,3.,0.,0.,0.,0.,0.],[0.9,1.,X[:,0].mean(),2.,0.05,0.,0.,0.,0.]]:\n        try:\n            r = least_squares(resid, init, loss='soft_l1', max_nfev=1000)\n            pred = model9(r.x, X)\n            nmse = np.mean((pred-y)**2)/np.var(y)\n            if nmse < best: best = nmse\n        except: pass\n    print(f'{name[-20:]}: NMSE={best:.4f}, x1_range=[{X[:,1].min():.1f},{X[:,1].max():.1f}]')\n\"\n"
