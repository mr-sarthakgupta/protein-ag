import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = load_all_datasets()

# Hill/logistic-in-log(x0) model with power-law x1:
# y = c0 / (1 + exp(-c1*x1^c5 * log(x0 / (c3*x1^c6)))) + c4
# = c0 / (1 + (c3*x1^c6 / x0)^(c1*x1^c5)) + c4
# But x0 can be 0 or negative! Need offset.
# Use: log(x0 + c2) where c2 is fitted (must be > -min(x0))
# Or: log(|x0| + c2) -- but that's weird
# Safe version: log(x0 + c2) with c2 > 0 always via exp(c2) trick
# Better: use log(x0 + c2) with c2 initialized to max(1, |x0_min|+1)

# Actually the cleanest: logistic in log(x0+c2) space
# y = c0 / (1 + exp(-c1*x1^c5 * (log(x0+c2) - c3*x1^c6))) + c4
# This IS the current model but with log instead of asinh!
# The difference: log(x0+c2) vs asinh(x0-c2)

def model_logoffset(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4, c5, c6 = c
    # Ensure c2 > -min(x0) by using exp(c2) as the offset
    offset = np.exp(c2)  # always positive
    lt = np.log(np.maximum(x0 + offset, 1e-10))
    rate = c1 * np.abs(x1)**c5
    ht = c3 * np.abs(x1)**c6
    return c0 / (1 + np.exp(-np.clip(rate * (lt - ht), -500, 500))) + c4

nmses = []
for name, X_train, X_val, y_train, y_val in datasets:
    var_y = np.var(y_val)
    if var_y < 1e-10: var_y = 1.0
    try:
        res = least_squares(lambda c: model_logoffset(X_train, c) - y_train,
                           [1.0, 2.0, 0.0, 3.0, 0.0, 0.0, 0.0], max_nfev=300)
        pred = model_logoffset(X_val, res.x)
        nmse_v = np.mean((pred - y_val)**2) / var_y
        nmses.append((nmse_v, name))
    except Exception as e:
        nmses.append((999.0, name + ' ERR'))

nmses.sort(reverse=True)
print('Top 10 hardest:')
for n, nm in nmses[:10]: print(f'  {n:.4f}  {nm}')
print(f'Mean NMSE: {np.mean([n for n,_ in nmses]):.4f}')
print(f'Median NMSE: {np.median([n for n,_ in nmses]):.4f}')
