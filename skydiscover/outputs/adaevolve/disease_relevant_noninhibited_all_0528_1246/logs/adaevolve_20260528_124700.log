import numpy as np, csv, os, re
from scipy.optimize import least_squares

def load_ds(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader); rows = list(reader)
    rh = header[1:]
    def pp(text):
        for pat,sc in [(r'(\d+(?:\.\d+)?)\s*uM',1),(r'(\d+(?:\.\d+)?)\s*mM',1000),
                       (r'pH\s+(\d+(?:\.\d+)?)',1),(r'(\d+(?:\.\d+)?)\s*%',1),
                       (r':\s*(\d+(?:\.\d+)?)\s*$',1)]:
            m = re.search(pat, text, re.IGNORECASE)
            if m: return float(m.group(1))*sc
        return None
    parsed = [pp(h) for h in rh]
    params = [float(p) for p in parsed] if all(p is not None for p in parsed) else [float(i+1) for i in range(len(rh))]
    feat, tgt = [], []
    for row in rows:
        if not row: continue
        t = float(row[0])
        for param, val in zip(params, row[1:]):
            if val and val.strip().lower() != 'nan':
                feat.append([t, param]); tgt.append(float(val))
    return np.array(feat), np.array(tgt)

test_files = ['alphasyn_gaspar2017_03um_seed_all/fit.tsv']
base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
if os.path.exists(base):
    for root, dirs, files in os.walk(base):
        if 'fit.tsv' in files: test_files.append(os.path.join(root, 'fit.tsv'))
        if len(test_files) >= 10: break

# Examine datasets 1, 8, 9 closely
for i in [0, 7, 8, 9]:
    if i < len(test_files):
        fpath = test_files[i]
        X, y = load_ds(fpath)
        name = os.path.basename(os.path.dirname(fpath))
        print(f'Dataset {i}: {name[:40]}')
        print(f'  t=[{X[:,0].min():.2f},{X[:,0].max():.2f}], x1=[{X[:,1].min():.2f},{X[:,1].max():.2f}]')
        # Show y profile
        sort_idx = np.argsort(X[:,0])
        ts = X[sort_idx,0][:5]
        ys = y[sort_idx][:5]
        print(f'  First 5 (t,y): {list(zip(ts.round(2), ys.round(3)))}')
        ts2 = X[sort_idx,0][-5:]
        ys2 = y[sort_idx][-5:]
        print(f'  Last 5 (t,y): {list(zip(ts2.round(2), ys2.round(3)))}')

# Test Gompertz log1p with c2 as time-shift parameter
# Key: for dataset 8 (t=[0,16.8]), log1p(x0 - 0) = log1p(x0)
# log1p(16.8) = 2.88, log1p(8.4) = 2.23 - so c3=2 should work
# But what's the actual shape?
print()
print('Fitting dataset 8 closely:')
X8, y8 = load_ds(test_files[7])
def pred_gomp(theta, X):
    c0,c1,c2,c3,c4 = theta
    x0 = X[:,0]
    lt = np.log1p(np.maximum(x0 - c2, 0.0))
    return c0*np.exp(-np.exp(np.clip(-c1*(lt-c3),-500,500))) + c4

for init in [[1.0,2.0,0.0,2.0,0.0],[1.0,2.0,-5.0,2.0,0.0],[0.9,3.0,0.0,1.5,0.05]]:
    res = least_squares(lambda th: pred_gomp(th,X8)-y8, init, loss='soft_l1', max_nfev=500)
    yp = pred_gomp(res.x, X8)
    nmse = np.var(y8-yp)/np.var(y8)
    print(f'  init={init} -> nmse={nmse:.4f}, fitted={np.round(res.x,3)}')
