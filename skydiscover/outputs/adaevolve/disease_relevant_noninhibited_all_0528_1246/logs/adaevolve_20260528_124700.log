import numpy as np
import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import _load_fit_table
from scipy.optimize import least_squares
from pathlib import Path

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

# Kakkar2016 14kDa Ex45 - what's the issue?
path = base + 'htt/Kakkar2016/FIts/Kakkar2016_14kDa_Ex45_polyQ_prim/fit.tsv'
X, y = _load_fit_table(Path(path))
print(f'x1 unique: {sorted(set(X[:,1]))}')
print(f'x0 range: {X[:,0].min():.3g} to {X[:,0].max():.3g}')

# Show t50 vs x1
for x1_val in sorted(set(X[:,1])):
    mask = X[:,1] == x1_val
    x0_sub = X[mask, 0]
    y_sub = y[mask]
    idx = np.argsort(x0_sub)
    x0_sub, y_sub = x0_sub[idx], y_sub[idx]
    i50 = np.argmin(np.abs(y_sub - 0.5))
    i10 = np.argmin(np.abs(y_sub - 0.1))
    i90 = np.argmin(np.abs(y_sub - 0.9))
    t50 = x0_sub[i50]
    lt = np.arcsinh(x0_sub)
    lt10, lt50, lt90 = lt[i10], lt[i50], lt[i90]
    asym = (lt90-lt50)/(lt50-lt10) if (lt50-lt10) > 0 else np.nan
    print(f'  x1={x1_val:.1f}: t50={t50:.3g} asym_asinh={asym:.2f} ymax={y_sub.max():.3f}')

print()
# Also check the 'Temp' dataset
