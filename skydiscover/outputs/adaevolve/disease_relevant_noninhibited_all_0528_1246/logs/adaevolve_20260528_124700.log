import os, glob, numpy as np

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
files = glob.glob(os.path.join(base, '**', 'fit.tsv'), recursive=True)

# Analyze dataset shapes: check for biphasic vs monophasic
biphasic_count = 0
results = []
for path in sorted(files):
    try:
        import pandas as pd
        df = pd.read_csv(path, sep='\t')
        cols = df.columns.tolist()
        x0 = df[cols[0]].values
        y_cols = cols[1:]
        y_mean = df[y_cols].mean(axis=1).values
        sort_idx = np.argsort(x0)
        x0s = x0[sort_idx]; ys = y_mean[sort_idx]
        name = path.replace(base+'/', '')
        results.append((name, len(x0s), float(ys.min()), float(ys.max()), len(y_cols)))
    except Exception as e:
        pass

print(f'Total: {len(results)} datasets')
for name, n, ymin, ymax, ncols in results[:20]:
    print(f'  {name[:50]:50s} n={n:3d} ymin={ymin:.2f} ymax={ymax:.2f} ncols={ncols}')
"
