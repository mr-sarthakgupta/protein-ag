import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_dataset
from pathlib import Path
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
all_files = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            all_files.append(os.path.join(root, f))
import os
all_files = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            all_files.append(os.path.join(root, f))
all_files.sort()

def model_C(t, p, c):
    lp = np.log(p)
    u = t - c[2]; lt = np.log(u + np.sqrt(u**2+1))
    rate = c[1] * p**c[5]
    ht = c[3]*p**c[6] + c[7]*lp + c[8]*lp**2
    return c[0] / (1 + np.exp(-rate*(lt - ht))) + c[4]

def model_D(t, p, c):
    lp = np.log(p)
    lt = np.log(t + c[2])
    rate = c[1] * p**c[5]
    ht = c[3]*p**c[6] + c[7]*lp + c[8]*lp**2
    return c[0] / (1 + np.exp(-rate*(lt - ht))) + c[4]

res_C, res_D = [], []
for p in all_files:
    rel = p.replace(base+'/', '')
    X_tr, X_v, y_tr, y_v = load_dataset(Path(p))
    x0t, x1t = X_tr[:,0], X_tr[:,1]
    for mname, mfn, init, store in [
        ('C', model_C, [1,2,0,3,0,0,0,0,0], res_C),
        ('D', model_D, [1,2,1,3,0,0,0,0,0], res_D),
    ]:
        def resid(c, m=mfn):
            with np.errstate(all='ignore'):
                pred = m(x0t, x1t, c)
            if not np.all(np.isfinite(pred)): return np.full(len(y_tr), 1e6)
            return pred - y_tr
        r = least_squares(resid, init, loss='soft_l1', max_nfev=1000)
        pv = mfn(X_v[:,0], X_v[:,1], r.x)
        nm = np.mean((pv-y_v)**2)/np.var(y_v) if np.var(y_v)>0 else float('inf')
        store.append(nm)

print(f'Model C (asinh): mean={np.mean(res_C):.5f}, median={np.median(res_C):.5f}')
print(f'Model D (log_t): mean={np.mean(res_D):.5f}, median={np.median(res_D):.5f}')
# Show top differences
diffs = [(res_D[i]-res_C[i], all_files[i].replace(base+'/', '')) for i in range(len(all_files))]
diffs.sort(reverse=True)
print('Datasets where D is worse:')
for d, n in diffs[:5]: print(f'  {d:+.4f}  {n}')
print('Datasets where D is better:')
for d, n in diffs[-5:]: print(f'  {d:+.4f}  {n}')
"
