import numpy as np
from scipy.optimize import least_squares
import pandas as pd

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'

# Examine ACE_sec more carefully - what does the curve look like?
path = base + '/beta-parvalbumin (Gadm1)/Sanchez2016/ACE_sec/fit.tsv'
df = pd.read_csv(path, sep='\t')
cols = df.columns.tolist()
x0 = df[cols[0]].values.astype(float)
y = df[cols[1]].values.astype(float)
valid = np.isfinite(y)
xv = x0[valid]; yv = y[valid]

# Print every 10th point to see shape
print('ACE_sec curve (every 10th point):')
for i in range(0, len(xv), 10):
    print(f'  x={xv[i]:10.1f}  y={yv[i]:.4f}')

# Find where y first exceeds thresholds
for thresh in [0.05, 0.1, 0.2, 0.3, 0.5, 0.7, 0.9]:
    idx = np.where(yv >= thresh)[0]
    if len(idx) > 0:
        print(f'  y>={thresh}: first at x={xv[idx[0]]:.1f}')
    else:
        print(f'  y>={thresh}: never reached')

# Also check the other Sanchez2016 datasets for comparison
for name in ['WT_prim', 'CE_prim', 'C_prim', 'WT_sec']:
    p2 = base + f'/beta-parvalbumin (Gadm1)/Sanchez2016/{name}/fit.tsv'
    try:
        df2 = pd.read_csv(p2, sep='\t')
        c2 = df2.columns.tolist()
        x2 = df2[c2[0]].values.astype(float)
        y2 = df2[c2[1]].values.astype(float)
