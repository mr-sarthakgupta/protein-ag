    x0,x1 = X[:,0], X[:,1]
    lx1 = np.log(np.maximum(np.abs(x1), 1e-6))
    rate = c1 + c2*lx1
    ht = c3 + c4*lx1
    return c0*np.exp(-np.exp(np.clip(-rate*(x0-ht), -500, 500))) + c5

def pred_loglin_7(theta, X):
    # 7 constants: add x1 power-law correction to rate
    c0,c1,c2,c3,c4,c5,c6 = theta
    x0,x1 = X[:,0], X[:,1]
    lx1 = np.log(np.maximum(np.abs(x1), 1e-6))
    rate = c1 + c2*lx1
    ht = c3 + c4*lx1
    plateau = c0 + c5*lx1
    return plateau/(1+np.exp(np.clip(-rate*(x0-ht), -500, 500))) + c6

