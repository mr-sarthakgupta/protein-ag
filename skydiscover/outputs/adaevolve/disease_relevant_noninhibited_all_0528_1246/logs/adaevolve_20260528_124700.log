    c0,c1,c2,c3,c4,c5 = theta
    x0,x1 = X[:,0], X[:,1]
    rate = c1 + c2*x1
    ht = c3 + c4*x1
    return c0*np.exp(-np.exp(-rate*(x0-ht))) + c5

# Template C: logistic with log(x1) linear dependence
def pred_C(theta, X):
    c0,c1,c2,c3,c4,c5 = theta
    x0,x1 = X[:,0], X[:,1]
    lx1 = np.log(np.maximum(x1, 1e-6))
    rate = c1 + c2*lx1
    ht = c3 + c4*lx1
    return c0/(1+np.exp(-rate*(x0-ht))) + c5

init_A = [1.0, 0.5, 0.0, 10.0, 0.0, 0.0]
init_B = [1.0, 0.5, 0.0, 10.0, 0.0, 0.0]
init_C = [1.0, 0.5, 0.0, 10.0, 0.0, 0.0]

for name, pred, init in [('Logistic-linear', pred_A, init_A), 
