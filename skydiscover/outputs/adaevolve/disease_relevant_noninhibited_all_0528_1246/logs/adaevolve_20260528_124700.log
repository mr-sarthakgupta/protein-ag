import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np

datasets = {name: (X_train, X_val, y_train, y_val) 
            for name, X_train, X_val, y_train, y_val in load_all_datasets()}

# Examine the hardest datasets
hard = [
    'beta-parvalbumin (Gadm1)/Sanchez2016/ACE_sec',
    'insulin/Fits/Nielsen2001_seeded_sec',
    'htt/Kar2011/Fits/Kar2011_Q37_sec',
]

for name in hard:
    X_train, X_val, y_train, y_val = datasets[name]
    x0 = X_train[:,0]
    x1 = X_train[:,1]
    print(f'=== {name} ===')
    print(f'  x0 range: [{x0.min():.2f}, {x0.max():.2f}], x1 unique: {np.unique(x1)}')
    print(f'  y range: [{y_train.min():.4f}, {y_train.max():.4f}]')
    # Show sorted x0, y pairs for first x1 value
    x1_first = np.unique(x1)[0]
    mask = x1 == x1_first
    idx = np.argsort(x0[mask])
    x0s = x0[mask][idx]
    ys = y_train[mask][idx]
