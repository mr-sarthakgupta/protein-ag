import os, pandas as pd, numpy as np
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

def gompertz_asinh(x0v, x1v, c):
    u = x0v - c[2]
    lt = np.log(u + np.sqrt(u**2 + 1))
    lx1 = np.log(np.maximum(np.abs(x1v), 1e-10))
    rate = c[1] * np.maximum(np.abs(x1v), 1e-10)**c[5]
    halftime = c[3] * np.maximum(np.abs(x1v), 1e-10)**c[6] + c[7]*lx1 + c[8]*lx1**2
    arg = np.clip(-rate * (lt - halftime), -500, 500)
    return c[0] * np.exp(-np.exp(arg)) + c[4]

import re
def parse_param(col):
    for pat, scale in [(r'(\d+(?:\.\d+)?)\s*uM', 1.0),
                       (r'(\d+(?:\.\d+)?)\s*mM', 1000.0),
                       (r'(\d+(?:\.\d+)?)\s*mg/mL', 1.0),
                       (r'(\d+(?:\.\d+)?)\s*ng/ul', 1.0),
                       (r'pH\s+(\d+(?:\.\d+)?)', 1.0),
                       (r'(\d+(?:\.\d+)?)\s*%', 1.0)]:
        m = re.search(pat, col, re.IGNORECASE)
        if m: return float(m.group(1)) * scale
    return None

all_fits = []
