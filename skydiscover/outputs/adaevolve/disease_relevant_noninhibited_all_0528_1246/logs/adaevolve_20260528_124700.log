import numpy as np, pandas as pd, glob
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
fits = sorted(glob.glob(base + '**/fit.tsv', recursive=True))

def model_log1p(theta, x0, x1):
    c0,c1,c2,c3,c4,c5,c6,c7,c8 = theta
    u = x0 - c2
    lt = np.log(u + np.sqrt(u**2 + 1))
    lx1 = np.log1p(np.maximum(x1, 0.0))
    rate = c1 * np.exp(c5 * lx1)
    ht = c3 * np.exp(c6 * lx1) + c7*lx1 + c8*lx1**2
    return c0/(1+np.exp(-rate*(lt-ht))) + c4

results = []
for f in fits:
    df = pd.read_csv(f, sep='\t')
    X = df.iloc[:,:2].values.astype(float)
    y = df.iloc[:,-1].values.astype(float)
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    split = int(round(len(y)*0.75))
    Xtr,ytr = X[idx[:split]], y[idx[:split]]
    Xv,yv = X[idx[split:]], y[idx[split:]]
    def res(t):
        try:
            p=model_log1p(t,Xtr[:,0],Xtr[:,1])
            return p-ytr if np.all(np.isfinite(p)) else np.full(len(ytr),1e12)
        except: return np.full(len(ytr),1e12)
    r=least_squares(res,[1,2,0,3,0,0,0,0,0],loss='soft_l1',max_nfev=1000)
    pv=model_log1p(r.x,Xv[:,0],Xv[:,1])
    nv=np.mean((pv-yv)**2)/np.var(yv) if np.var(yv)>0 else np.inf
    name=f.replace(base,'').replace('/fit.tsv','')
    results.append((nv,name))

results.sort(reverse=True)
print('Top 10 hardest (log1p model):')
for nv,nm in results[:10]:
    print(f'  {nv:.5f}  {nm}')
mn=np.mean([r[0] for r in results])
print(f'Mean NMSE: {mn:.5f}, Score: {1/(1+mn):.5f}')
" 2>/dev/null
