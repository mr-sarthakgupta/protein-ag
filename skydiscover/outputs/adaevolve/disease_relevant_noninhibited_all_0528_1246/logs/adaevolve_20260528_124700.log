import numpy as np, csv, os, re
from scipy.optimize import least_squares

def load_ds(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader); rows = list(reader)
    rh = header[1:]
    def pp(text):
        for pat,sc in [(r'(\d+(?:\.\d+)?)\s*uM',1),(r'(\d+(?:\.\d+)?)\s*mM',1000),
                       (r'pH\s+(\d+(?:\.\d+)?)',1),(r'(\d+(?:\.\d+)?)\s*%',1),
                       (r':\s*(\d+(?:\.\d+)?)\s*$',1)]:
            m = re.search(pat, text, re.IGNORECASE)
            if m: return float(m.group(1))*sc
        return None
    parsed = [pp(h) for h in rh]
    params = [float(p) for p in parsed] if all(p is not None for p in parsed) else [float(i+1) for i in range(len(rh))]
    feat, tgt = [], []
    for row in rows:
        if not row: continue
        t = float(row[0])
        for param, val in zip(params, row[1:]):
            if val and val.strip().lower() != 'nan':
                feat.append([t, param]); tgt.append(float(val))
    return np.array(feat), np.array(tgt)

# Log-parameterized half-time: half_time = exp(c2)
# y = c0 / (1 + exp(-c1*(x0 - exp(c2)))) + c3
# With c2=0: half_time=1; c2=10: half_time=22026
# initial: c0=1, c1=0.5, c2=0, c3=0
def pred_log_ht(theta, X):
    c0,c1,c2,c3 = theta
    x0 = X[:,0]
    ht = np.exp(c2)
    return c0/(1+np.exp(np.clip(-c1*(x0-ht),-500,500))) + c3

# With x1 log-dependence on rate and half-time
# y = c0/(1+exp(-(c1+c2*log(x1))*(x0 - exp(c3+c4*log(x1))))) + c5
def pred_log_full(theta, X):
    c0,c1,c2,c3,c4,c5 = theta
    x0,x1 = X[:,0], X[:,1]
    lx1 = np.log(np.maximum(np.abs(x1), 1e-6))
    rate = c1 + c2*lx1
    ht = np.exp(np.clip(c3 + c4*lx1, -20, 20))
    return c0/(1+np.exp(np.clip(-rate*(x0-ht),-500,500))) + c5

# Gompertz with log half-time
def pred_gomp_log(theta, X):
    c0,c1,c2,c3 = theta
    x0 = X[:,0]
    ht = np.exp(c2)
    return c0*np.exp(-np.exp(np.clip(-c1*(x0-ht),-500,500))) + c3

test_files = ['alphasyn_gaspar2017_03um_seed_all/fit.tsv']
base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
if os.path.exists(base):
    for root, dirs, files in os.walk(base):
        if 'fit.tsv' in files: test_files.append(os.path.join(root, 'fit.tsv'))
        if len(test_files) >= 8: break

print(f'Testing {len(test_files)} datasets')
results = {'log_ht4':[], 'log_full6':[], 'gomp_log4':[]}
for fpath in test_files:
    try:
        X, y = load_ds(fpath)
        t_mid = np.median(X[:,0])
