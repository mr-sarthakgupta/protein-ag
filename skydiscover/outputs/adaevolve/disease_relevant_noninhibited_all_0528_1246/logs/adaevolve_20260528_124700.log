# Check if sp.log1p is in allowed calls
allowed = {'constant_symbols','evaluate_expression','feature_symbols',
           'sp.exp','sp.log','sp.log1p','sp.sqrt','sp.sin','sp.cos',
           'sp.tan','sp.tanh','sp.sinh','sp.cosh'}
