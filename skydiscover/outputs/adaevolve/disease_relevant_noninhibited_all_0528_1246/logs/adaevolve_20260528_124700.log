# For large x0 datasets (IAPP: x0 up to 57000), asinh(57000) ~ log(2*57000) ~ 11.6
# For small x0 (Abeta: x0 up to 11.5 hours), asinh(11.5) ~ 3.1
# The init c3=3 is roughly in the middle of these

# Try different initial values that better span the range
# Key: c2 shifts the time axis, c3 is the half-time in asinh space
# Better init: c3 should be ~asinh(median_x0_max/2) for typical datasets

# What are typical asinh values across datasets?
for name, Xtr, Xv, ytr, yv in all_ds[:10]:
    x0_max = Xtr[:,0].max()
    x0_min = max(0, Xtr[:,0].min())
    mid = (x0_max + x0_min) / 2
    asinh_mid = np.log(mid + np.sqrt(mid**2 + 1))
    asinh_max = np.log(x0_max + np.sqrt(x0_max**2 + 1))
    print(f'{name[-40:]:40s} x0_max={x0_max:.1e}, asinh(mid)={asinh_mid:.2f}, asinh(max)={asinh_max:.2f}')
