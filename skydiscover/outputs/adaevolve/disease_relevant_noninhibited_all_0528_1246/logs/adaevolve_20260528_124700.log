import os, pandas as pd, numpy as np
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

# New formulation: asinh((x0-c2)/c3) with c3 as time scale
def logistic_v2(x0v, x1v, c):
    # c = [plateau, rate, t_offset, t_scale, baseline, rate_exp, scale_exp, lx1_rate, lx1_halftime]
    t_scale = np.abs(c[3]) + 1e-8  # ensure positive
    u = (x0v - c[2]) / t_scale
    lt = np.log(u + np.sqrt(u**2 + 1))  # asinh((x0-c2)/c3)
    lx1 = np.log(np.maximum(np.abs(x1v), 1e-10))
    rate = c[1] * np.maximum(np.abs(x1v), 1e-10)**c[5]
    # halftime is now 0 (embedded in c2/c3), but we can add x1-dependent offset
    halftime = c[6] * lx1  # x1-dependent shift
    arg = np.clip(-rate * (lt - halftime), -500, 500)
    return c[0] / (1 + np.exp(arg)) + c[4]

import re
def parse_param(col):
    for pat, scale in [(r'(\d+(?:\.\d+)?)\s*uM', 1.0),
                       (r'(\d+(?:\.\d+)?)\s*mM', 1000.0),
                       (r'(\d+(?:\.\d+)?)\s*mg/mL', 1.0),
                       (r'(\d+(?:\.\d+)?)\s*ng/ul', 1.0),
                       (r'pH\s+(\d+(?:\.\d+)?)', 1.0),
                       (r'(\d+(?:\.\d+)?)\s*%', 1.0)]:
        m = re.search(pat, col, re.IGNORECASE)
        if m: return float(m.group(1)) * scale
    return None

all_fits = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            all_fits.append(os.path.join(root, f))

results = []
for p in sorted(all_fits):
    rel = p.replace(base, '')
    df = pd.read_csv(p, sep='\t')
    cols = list(df.columns[1:])
    x0 = df['X'].values
    params = [parse_param(c) for c in cols]
    if all(q is not None for q in params):
        params_v = [float(q) for q in params]
    else:
        params_v = [float(i+1) for i in range(len(cols))]
    X = np.array([[xi, q] for xi in x0 for q in params_v])
    y = np.array([df[c].values[i] for i in range(len(x0)) for c in cols])
    # init: c2=median(x0), c3=std(x0) or range/4
    x0_med = np.median(x0)
    x0_scale = max((x0.max() - x0.min()) / 4, 1.0)
    c0 = [1.0, 2.0, x0_med, x0_scale, 0.0, 0.0, 0.0]
    try:
        res = least_squares(lambda c: logistic_v2(X[:,0], X[:,1], c) - y,
                           c0, loss='soft_l1', max_nfev=1000)
        y_pred = logistic_v2(X[:,0], X[:,1], res.x)
        nmse_v = np.mean((y_pred - y)**2) / max(np.var(y), 1e-12)
        results.append((nmse_v, rel[:60]))
    except Exception as e:
        results.append((999.0, rel[:60] + f' ERR:{e}'))

results.sort(reverse=True)
print('Top 10 hardest:')
for nmse_v, name in results[:10]:
    print(f'  {nmse_v:.4f}  {name}')
print(f'Mean NMSE: {np.mean([r[0] for r in results]):.4f}')
"
