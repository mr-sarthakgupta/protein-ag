import os, numpy as np

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'

# Find all fit.tsv files
tsv_files = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            tsv_files.append(os.path.join(root, f))

# Analyze asymmetry: for each dataset, find t50 position relative to t10 and t90
# If t50 is closer to t10 => right-skewed (fast rise, slow plateau)
# If t50 is closer to t90 => left-skewed (slow rise, fast plateau)
asymmetries = []
for path in tsv_files:
    try:
        import pandas as pd
        df = pd.read_csv(path, sep='\t')
        cols = df.columns.tolist()
        x0 = df[cols[0]].values
        # average over all y columns
        y_cols = cols[1:]
        y_mean = df[y_cols].mean(axis=1).values
        # find t10, t50, t90 by interpolation
        from scipy.interpolate import interp1d
        if len(x0) < 4:
            continue
        sort_idx = np.argsort(x0)
        x0s = x0[sort_idx]; ys = y_mean[sort_idx]
        if ys.max() - ys.min() < 0.3:
            continue
        # normalize
        yn = (ys - ys.min()) / (ys.max() - ys.min())
        f = interp1d(yn, x0s, bounds_error=False, fill_value='extrapolate')
        t10 = float(f(0.1)); t50 = float(f(0.5)); t90 = float(f(0.9))
        if t90 > t10:
            asym = (t50 - t10) / (t90 - t10)  # 0.5 = symmetric, <0.5 = right-skew, >0.5 = left-skew
            asymmetries.append(asym)
    except:
        pass

asymmetries = np.array(asymmetries)
print(f'N datasets with asymmetry: {len(asymmetries)}')
print(f'Mean asymmetry: {asymmetries.mean():.3f} (0.5=symmetric)')
print(f'Std: {asymmetries.std():.3f}')
print(f'Min: {asymmetries.min():.3f}, Max: {asymmetries.max():.3f}')
print(f'Fraction right-skewed (<0.45): {(asymmetries < 0.45).mean():.2f}')
print(f'Fraction left-skewed (>0.55): {(asymmetries > 0.55).mean():.2f}')
print(f'Percentiles 10/25/50/75/90: {np.percentile(asymmetries, [10,25,50,75,90]).round(3)}')
"
