import numpy as np
import sympy as sp
import sys
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets
from pysr_harness.equation_session import feature_symbols, constant_symbols, fit_expression_constants

all_ds = load_all_datasets()

# Test alternative expressions on all datasets
# Alternative 1: logistic in log(x0 + c2) with additive x1 coupling in rate and halftime
def test_expr_v2(all_ds):
    x = feature_symbols(2)
    c = constant_symbols(8)
    time = x[0]
    parameter = x[1]
    # Use log(x0 + c2) - more natural for wide time ranges
    # rate = c1 * exp(c5 * log(x1)) = c1 * x1^c5
    # halftime = c3 + c6 * log(x1) + c7 * x1^c8  -- additive log coupling
    u = time - c[2]
    log_time = sp.log(u + sp.sqrt(u**2 + 1))
    rate = c[1] * sp.exp(c[5] * sp.log(parameter + 1))
    half_time = c[3] * sp.exp(c[6] * sp.log(parameter + 1))
    expression = c[0] / (1 + sp.exp(-rate * (log_time - half_time))) + c[4]

    results = []
    for name, Xtr, Xv, ytr, yv in all_ds:
        try:
            fitted = fit_expression_constants(expression, Xtr, ytr, Xv, constants=c,
                initial_values=[1.0, 2.0, 0.0, 3.0, 0.0, 0.0, 0.0, 0.0])
            yp = fitted.y_pred_val
            var_y = np.var(yv)
            nmse = np.mean((yp - yv)**2) / var_y if var_y > 0 else float('inf')
            results.append((name, nmse))
        except Exception as e:
            results.append((name, float('inf')))
    return results

results2 = test_expr_v2(all_ds)
results2.sort(key=lambda x: x[1], reverse=True)
print('Alternative (log(x1+1) coupling) - Top 10 worst:')
for name, nmse in results2[:10]:
    print(f'  {nmse:.4f}  {name[:55]}')
print(f'Mean NMSE: {np.mean([r[1] for r in results2 if np.isfinite(r[1])]):.4f}')
"
