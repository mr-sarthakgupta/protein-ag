import os, numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_dataset
from pathlib import Path
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
all_files = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            all_files.append(os.path.join(root, f))
all_files.sort()

# Fit the current best model to each dataset and report NMSE
# to identify which datasets are hardest
def fit_current(X_tr, y_tr, X_v, y_v):
    x0 = X_tr[:,0]; x1 = X_tr[:,1]
    def model(t, p, c):
        u = t - c[2]
        lt = np.log(u + np.sqrt(u**2 + 1))
        lp = np.log(p)
        rate = c[1] * p**c[5]
        ht = c[3] * p**c[6] + c[7]*lp + c[8]*lp**2
        return c[0] / (1 + np.exp(-rate*(lt - ht))) + c[4]
    def residual(c):
        with np.errstate(all='ignore'):
            pred = model(x0, x1, c)
        if not np.all(np.isfinite(pred)): return np.full(len(y_tr), 1e6)
        return pred - y_tr
    res = least_squares(residual, [1,2,0,3,0,0,0,0,0], loss='soft_l1', max_nfev=1000)
    xv0=X_v[:,0]; xv1=X_v[:,1]
    with np.errstate(all='ignore'):
        pv = model(xv0, xv1, res.x)
    nmse = np.mean((pv-y_v)**2)/np.var(y_v) if np.var(y_v)>0 else float('inf')
    return nmse

results = []
for p in all_files:
    rel = p.replace(base+'/', '')
    X_tr, X_v, y_tr, y_v = load_dataset(Path(p))
    try:
        nm = fit_current(X_tr, y_tr, X_v, y_v)
        results.append((nm, rel))
    except: pass

results.sort(reverse=True)
print('Top 10 hardest datasets (highest NMSE):')
for nm, r in results[:10]:
    print(f'  {nm:.4f}  {r}')
print('Mean NMSE:', np.mean([r[0] for r in results]))
"
