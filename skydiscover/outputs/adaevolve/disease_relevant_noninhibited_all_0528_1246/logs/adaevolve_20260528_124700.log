$ python3 -c "
import numpy as np
import sys
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets
from scipy.optimize import least_squares
all_ds = load_all_datasets()
ds = {name: (Xtr, Xv, ytr, yv) for name, Xtr, Xv, ytr, yv in all_ds}

# For insulin seeded, what's the irreducible noise?
name = 'insulin/Fits/Nielsen2001_seeded_sec'
Xtr, Xv, ytr, yv = ds[name]
x0_vals = np.unique(Xtr[:,0])
# Fit a simple logistic directly to mean per x0
means = []
for x0v in x0_vals:
    mask = np.abs(Xtr[:,0] - x0v) < 1
    means.append((x0v, ytr[mask].mean()))
means = np.array(means)

# Fit logistic to mean
def logistic(x0, c0, c1, c2, c4):
    return c0 / (1 + np.exp(-c1 * (x0 - c2))) + c4

def residual(theta):
    c0, c1, c2, c4 = theta
    pred = logistic(means[:,0], c0, c1, c2, c4)
    return pred - means[:,1]

res = least_squares(residual, [1.0, 0.0001, 30000, 0.0], loss='soft_l1')
c0, c1, c2, c4 = res.x
print(f'Best logistic fit to means: c0={c0:.3f}, c1={c1:.6f}, c2={c2:.1f}, c4={c4:.3f}')

# Now compute NMSE on full validation set using this fit
yp_val = logistic(Xv[:,0], c0, c1, c2, c4)
var_y = np.var(yv)
nmse_val = np.mean((yp_val - yv)**2) / var_y
print(f'Validation NMSE with logistic fit to means: {nmse_val:.4f}')
print(f'Var(y_val): {var_y:.4f}')

# What's the noise floor? Variance within each time point
within_var = []
for x0v in x0_vals:
    mask = np.abs(Xtr[:,0] - x0v) < 1
    if mask.sum() > 1:
        within_var.append(np.var(ytr[mask]))
print(f'Mean within-timepoint variance: {np.mean(within_var):.4f}')
print(f'This is the irreducible noise floor relative to var(y)={np.var(ytr):.4f}')
"
