import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = {name: (X_train, X_val, y_train, y_val) 
            for name, X_train, X_val, y_train, y_val in load_all_datasets()}

# For Kar2011: try fitting each x1 curve independently with simple logistic-in-log
# to understand the true rate/halftime per curve
name = 'htt/Kar2011/Fits/Kar2011_Q37_sec'
X_train, X_val, y_train, y_val = datasets[name]
x0, x1 = X_train[:,0], X_train[:,1]

print('Per-x1 fit for Kar2011_Q37_sec (logistic in log(x0)):')
for x1v in sorted(np.unique(x1)):
    mask = x1 == x1v
    x0m = x0[mask]
    ym = y_train[mask]
    def resid(c):
        lt = np.log(np.maximum(x0m, 1e-10))
        return c[0] / (1 + np.exp(-np.clip(c[1]*(lt - c[2]), -500, 500))) + c[3] - ym
    res = least_squares(resid, [1.0, 2.0, 11.0, 0.0], max_nfev=500)
    c = res.x
    print(f'  x1={x1v:4.0f}: plateau={c[0]:.3f}, rate={c[1]:.3f}, log_halftime={c[2]:.3f} (t_half={np.exp(c[2]):.0f}), baseline={c[3]:.3f}')

print()
# Now test: what if we use x0^c_exp instead of log(x0)?
# y = c0 / (1 + exp(-c1*(x0^c_exp - c2))) + c3
# This is the Boltzmann/Richards model with power-law time
name2 = 'htt/Kar2011/Fits/Kar2011_Q37_sec'
X_train2, X_val2, y_train2, y_val2 = datasets[name2]
var_y2 = np.var(y_val2)

def model_power_time(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4, c5, c6, c7 = c
    # time transform: x0^c7 (power law time)
    t_trans = np.maximum(x0, 1e-10)**c7
    rate = c1 * x1**c5
    ht = c2 * x1**c6
    return c0 / (1 + np.exp(-np.clip(rate * (t_trans - ht), -500, 500))) + c4

res3 = least_squares(lambda c: model_power_time(X_train2, c) - y_train2,
                    [1.0, 2.0, 1e8, 0.0, 0.0, 0.0, 0.0, 0.5], max_nfev=500)
pred3 = model_power_time(X_val2, res3.x)
nmse3 = np.mean((pred3 - y_val2)**2) / var_y2
print(f'Kar2011 power-time NMSE: {nmse3:.4f}, c7(time_exp)={res3.x[7]:.3f}')
