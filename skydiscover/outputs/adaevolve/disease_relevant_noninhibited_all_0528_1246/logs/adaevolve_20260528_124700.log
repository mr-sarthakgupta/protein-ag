import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import sympy as sp
from pysr_harness.equation_session import constant_symbols, feature_symbols, fit_expression_constants
from pysr_harness.metrics import nmse, combined_score_from_nmse

datasets = load_all_datasets()

# Test a variant: P3 but with log(x0) time transform instead of asinh
# This handles very wide x0 ranges (7k to 937k for Kar2011)
# Also test: P3 with extra c9*x1 linear term in halftime

res_p3 = []
res_logx0 = []
res_p3_linear = []

for name, X_tr, X_v, y_tr, y_v in datasets:
    x = feature_symbols(2)
    time, parameter = x[0], x[1]
    
    # P3 (9c) - asinh time
    c9 = constant_symbols(9)
    u9 = time - c9[2]
    lt9 = sp.log(u9 + sp.sqrt(u9**2 + 1))
    lp = sp.log(parameter)
    ht9 = c9[3]*parameter**c9[6] + c9[7]*lp + c9[8]*lp**2
    expr_p3 = c9[0]/(1+sp.exp(-c9[1]*parameter**c9[5]*(lt9-ht9)))+c9[4]
    
    # Variant: log(x0 + c2) time transform (10c: add c9 as x0 shift)
    c10 = constant_symbols(10)
    lp10 = sp.log(parameter)
    lt10 = sp.log(time + c10[9])  # log(x0 + c9) - needs c9 > 0
    ht10 = c10[3]*parameter**c10[6] + c10[7]*lp10 + c10[8]*lp10**2
    expr_log = c10[0]/(1+sp.exp(-c10[1]*parameter**c10[5]*(lt10-ht10)))+c10[4]
    
    try:
        f1 = fit_expression_constants(expr_p3, X_tr, y_tr, X_v, constants=c9, 
                                       initial_values=[1,2,0,3,0,0,0,0,0], max_nfev=1000)
        f2 = fit_expression_constants(expr_log, X_tr, y_tr, X_v, constants=c10,
                                       initial_values=[1,2,1,3,0,0,0,0,0,1], max_nfev=1000)
        n1 = nmse(y_v, f1.y_pred_val)
        n2 = nmse(y_v, f2.y_pred_val)
        res_p3.append(n1); res_logx0.append(n2)
    except Exception as e:
        res_p3.append(999); res_logx0.append(999)

print(f'P3 asinh (9c)     mean NMSE: {np.mean(res_p3):.4f}  score={combined_score_from_nmse(np.mean(res_p3)):.4f}')
print(f'log(x0+c9) (10c)  mean NMSE: {np.mean(res_logx0):.4f}  score={combined_score_from_nmse(np.mean(res_logx0)):.4f}')

pairs = sorted(zip(res_p3, res_logx0, [d[0] for d in datasets]), reverse=True)
for n1, n2, nm in pairs[:8]:
    print(f'  {nm[-50:]}: p3={n1:.4f} log={n2:.4f} diff={n2-n1:+.4f}')
