import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = load_all_datasets()

# Model A: log(x0 + c2) time - needs c2 > -min(x0) to stay positive
# y = c0 / (1 + exp(-c1*x1^c5 * (log(x0+c2) - c3*x1^c6))) + c4
def model_log(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4, c5, c6 = c
    lt = np.log(np.maximum(x0 + c2, 1e-10))
    rate = c1 * x1**c5
    ht = c3 * x1**c6
    return c0 / (1 + np.exp(-np.clip(rate * (lt - ht), -500, 500))) + c4

# Model B: asinh(c2*x0) - scale x0 directly, no shift
def model_asinh_scale(X, c):
    x0, x1 = X[:,0], X[:,1]
    c0, c1, c2, c3, c4, c5, c6 = c
    u = c2 * x0
    lt = np.log(u + np.sqrt(u**2 + 1))
    rate = c1 * x1**c5
    ht = c3 * x1**c6
    return c0 / (1 + np.exp(-np.clip(rate * (lt - ht), -500, 500))) + c4

nmses_log = []
nmses_asinh = []

for name, X_train, X_val, y_train, y_val in datasets:
    var_y = np.var(y_val)
    if var_y < 1e-10: var_y = 1.0
    
    # log model: init c2=1 (offset)
    try:
        res = least_squares(lambda c: model_log(X_train, c) - y_train,
                           [1.0, 2.0, 1.0, 3.0, 0.0, 0.0, 0.0], max_nfev=300)
        pred = model_log(X_val, res.x)
        nmse_v = np.mean((pred - y_val)**2) / var_y
        nmses_log.append((nmse_v, name))
    except Exception as e:
        nmses_log.append((999.0, name))
    
    # asinh scale model: init c2=1
    try:
        res2 = least_squares(lambda c: model_asinh_scale(X_train, c) - y_train,
                            [1.0, 2.0, 1.0, 3.0, 0.0, 0.0, 0.0], max_nfev=300)
        pred2 = model_asinh_scale(X_val, res2.x)
        nmse_v2 = np.mean((pred2 - y_val)**2) / var_y
        nmses_asinh.append((nmse_v2, name))
    except:
        nmses_asinh.append((999.0, name))

nmses_log.sort(reverse=True)
nmses_asinh.sort(reverse=True)
print('Log model - top 5 hardest:')
for n, nm in nmses_log[:5]: print(f'  {n:.4f}  {nm}')
print(f'  Mean: {np.mean([n for n,_ in nmses_log]):.4f}')

print('Asinh-scale model - top 5 hardest:')
for n, nm in nmses_asinh[:5]: print(f'  {n:.4f}  {nm}')
print(f'  Mean: {np.mean([n for n,_ in nmses_asinh]):.4f}')
