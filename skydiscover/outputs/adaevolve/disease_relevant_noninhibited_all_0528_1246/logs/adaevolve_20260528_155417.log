import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()

# Test a clean 7-constant model with additive x1 coupling in log-time space
# lt = asinh(x0 - c2)
# rate = c1 * x1^c5
# halftime = c3 + c6*log(x1)   <- simpler: just log coupling
# y = c0 / (1 + exp(-rate*(lt - halftime))) + c4

def model7_log(X, c):
    x0, x1 = X[:,0], X[:,1]
    u = x0 - c[2]
    lt = np.log(u + np.sqrt(u**2 + 1))
    lx1 = np.log(np.maximum(x1, 1e-10))
    rate = c[1] * np.power(np.maximum(x1, 1e-10), c[5])
    ht = c[3] + c[6]*lx1
    return c[0] / (1 + np.exp(-rate * (lt - ht))) + c[4]

init7 = [1.0, 2.0, 0.0, 3.0, 0.0, 0.0, 0.0]

results = []
for name, X_tr, X_val, y_tr, y_val in datasets:
    def res(c): return model7_log(X_tr, c) - y_tr
    sol = least_squares(res, init7, max_nfev=1000, method='trf', loss='soft_l1')
    yp = model7_log(X_val, sol.x)
    nv = np.mean((yp-y_val)**2)/(np.var(y_val)+1e-10)
    results.append((nv, name))

results.sort(reverse=True)
print('7-const log-coupling - top 8:')
for nv, n in results[:8]:
    print(f'  {nv:.5f}  {n}')
print(f'Mean NMSE: {np.mean([r[0] for r in results]):.6f}')
"
