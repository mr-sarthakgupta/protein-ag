import sys
sys.path.insert(0, '.')
import importlib.util
import numpy as np
from scipy.optimize import least_squares

spec = importlib.util.spec_from_file_location('ev', 'disease_relevant_noninhibited_all/evaluator.py')
ev = importlib.util.module_from_spec(spec)
spec.loader.exec_module(ev)
datasets = ev.load_all_datasets()

# FW model as described in breakthrough idea:
# rate = c5*x1^c6 (scales with concentration)
# halftime = c7/x1^c8 (INVERSE - higher conc = shorter halftime)
# Keep asinh time transform for stability
# y = c0 / (1 + exp(-rate*(lt - halftime))) + c4
# with c2 = time offset

def fit_fw_proper(X_train, y_train, X_val, y_val):
    x0_col = X_train[:,0]
    x1_col = X_train[:,1]
    x0v = X_val[:,0]
    x1v = X_val[:,1]
    
    def model(x0, x1, c):
        c0,c1,c2,c3,c4,c5,c6,c7,c8 = c
        u = x0 - c2
        lt = np.log(u + np.sqrt(u**2 + 1))
        x1s = np.maximum(x1, 1e-10)
        rate = c1 * x1s**c5
        # FW inverse halftime: c3/x1^c6 + log terms for non-monotonic
        ht = c3 / x1s**c6 + c7 * np.log(x1s) + c8 * np.log(x1s)**2
        return c0 / (1 + np.exp(-rate*(lt - ht))) + c4
    
    def residual(c):
        pred = model(x0_col, x1_col, c)
        if not np.all(np.isfinite(pred)):
            return np.full(len(y_train), 1e12)
        return pred - y_train
    
    # Try multiple initializations for robustness
    best_nmse = float('inf')
    for init in [[1,2,0,3,0,0,1,0,0], [1,2,0,10,0,0,0.5,0,0], [1,1,0,5,0,0,2,0,0]]:
        try:
            r = least_squares(residual, init, loss='soft_l1', max_nfev=1000)
            pred_val = model(x0v, x1v, r.x)
            var = np.var(y_val)
            n = np.mean((pred_val - y_val)**2) / var if var > 1e-12 else float('inf')
            if np.isfinite(n) and n < best_nmse:
                best_nmse = n
        except:
            pass
    return best_nmse

results_fw = []
for name, X_train, X_val, y_train, y_val in datasets:
    try:
        n = fit_fw_proper(X_train, y_train, X_val, y_val)
        results_fw.append((n, name))
    except Exception as e:
        results_fw.append((float('inf'), name))

results_fw.sort(reverse=True)
print('FW proper (inverse halftime) - hardest:')
for n, name in results_fw[:8]:
    print(f'  {n:.4f}  {name}')
print(f'Mean NMSE: {np.mean([r[0] for r in results_fw]):.4f}')
print(f'Datasets with NMSE > 0.05: {sum(1 for n,_ in results_fw if n > 0.05)}')
