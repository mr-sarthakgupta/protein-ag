import sys
sys.path.insert(0, '.')
import importlib.util
import numpy as np
from scipy.optimize import least_squares

spec = importlib.util.spec_from_file_location('ev', 'disease_relevant_noninhibited_all/evaluator.py')
ev = importlib.util.module_from_spec(spec)
spec.loader.exec_module(ev)
datasets = ev.load_all_datasets()

# The key insight: the current model uses c3*x1^c6 + c7*log(x1) + c8*log(x1)^2
# The FW idea: replace c3*x1^c6 with c3*x1^c6 + c7/x1^c8 (adds inverse term)
# But this causes instability. Instead, let's try:
# halftime = c3*(x1^c6 + c7/x1^c8) - a mixed forward+inverse power law
# This is what the breakthrough idea suggests for FW mechanism

# Actually let's try the simplest version: just current model with
# halftime = c3*x1^c6 + c7*log(x1) + c8*log(x1)^2 but with 
# RATE = c1 * (x1 + c9)^c5 - shifted power law for better stability

# Test: shifted power law rate (x1+c9)^c5 - avoids x1=0 issues
def fit_shifted(X_train, y_train, X_val, y_val):
    x0_col = X_train[:,0]
    x1_col = X_train[:,1]
    x0v = X_val[:,0]
    x1v = X_val[:,1]
    
    def model(x0, x1, c):
        c0,c1,c2,c3,c4,c5,c6,c7,c8,c9 = c
        u = x0 - c2
        lt = np.log(u + np.sqrt(u**2 + 1))
        lx1 = np.log(np.maximum(x1, 1e-10))
        # shifted power: (x1+c9)^c5 avoids x1=0 singularity
        x1s = np.maximum(x1 + c9, 1e-10)
        rate = c1 * x1s**c5
        ht = c3 * np.maximum(x1, 1e-10)**c6 + c7*lx1 + c8*lx1**2
        return c0 / (1 + np.exp(-rate*(lt - ht))) + c4
    
    def residual(c):
        pred = model(x0_col, x1_col, c)
        if not np.all(np.isfinite(pred)):
            return np.full(len(y_train), 1e12)
        return pred - y_train
    
    r = least_squares(residual, [1,2,0,3,0,0,0,0,0,0], loss='soft_l1', max_nfev=1000)
    pred_val = model(x0v, x1v, r.x)
    var = np.var(y_val)
    nmse = np.mean((pred_val - y_val)**2) / var if var > 1e-12 else float('inf')
    return nmse

# Test: FW-style: halftime = c3 + c7*log(x1) (simpler, no power law)
# rate = c1*x1^c5
def fit_fw_simple(X_train, y_train, X_val, y_val):
    x0_col = X_train[:,0]
    x1_col = X_train[:,1]
    x0v = X_val[:,0]
    x1v = X_val[:,1]
    
    def model(x0, x1, c):
        c0,c1,c2,c3,c4,c5,c6,c7,c8 = c
        u = x0 - c2
        lt = np.log(u + np.sqrt(u**2 + 1))
        lx1 = np.log(np.maximum(x1, 1e-10))
        rate = c1 * np.maximum(x1, 1e-10)**c5
        # Simplified halftime: just offset + log + log^2 (no power-law)
        ht = c3 + c6*lx1 + c7*lx1**2 + c8*lx1**3
        return c0 / (1 + np.exp(-rate*(lt - ht))) + c4
    
    def residual(c):
        pred = model(x0_col, x1_col, c)
        if not np.all(np.isfinite(pred)):
            return np.full(len(y_train), 1e12)
        return pred - y_train
    
    r = least_squares(residual, [1,2,0,3,0,0,0,0,0], loss='soft_l1', max_nfev=1000)
    pred_val = model(x0v, x1v, r.x)
    var = np.var(y_val)
    nmse = np.mean((pred_val - y_val)**2) / var if var > 1e-12 else float('inf')
    return nmse

rs, rf = [], []
for name, X_train, X_val, y_train, y_val in datasets:
    try:
        rs.append((fit_shifted(X_train, y_train, X_val, y_val), name))
    except:
        rs.append((float('inf'), name))
    try:
        rf.append((fit_fw_simple(X_train, y_train, X_val, y_val), name))
    except:
        rf.append((float('inf'), name))

rs.sort(reverse=True)
rf.sort(reverse=True)
print('Shifted power law (10c) - top 5:')
for n, name in rs[:5]: print(f'  {n:.4f}  {name}')
print(f'  Mean NMSE: {np.mean([r[0] for r in rs]):.4f}')
print('FW simple log-poly halftime (9c) - top 5:')
for n, name in rf[:5]: print(f'  {n:.4f}  {name}')
print(f'  Mean NMSE: {np.mean([r[0] for r in rf]):.4f}')
"
