import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()

# 8-constant model: drop c8*log(x1)^2 term
def model8(X, c):
    x0, x1 = X[:,0], X[:,1]
    x1p = np.maximum(x1, 1e-10)
    u = x0 - c[2]
    lt = np.log(u + np.sqrt(u**2 + 1))
    lx1 = np.log(x1p)
    rate = c[1] * np.power(x1p, c[5])
    ht = c[3] * np.power(x1p, c[6]) + c[7]*lx1
    return c[0] / (1 + np.exp(-rate * (lt - ht))) + c[4]

init8 = [1.0, 2.0, 0.0, 3.0, 0.0, 0.0, 0.0, 0.0]

results8 = []
for name, X_tr, X_val, y_tr, y_val in datasets:
    def res(c): return model8(X_tr, c) - y_tr
    sol = least_squares(res, init8, max_nfev=1000, method='trf', loss='soft_l1')
    yp = model8(X_val, sol.x)
    nv = np.mean((yp-y_val)**2)/(np.var(y_val)+1e-10)
    results8.append((nv, name))

results8.sort(reverse=True)
print('8-const (no log^2) - top 6:')
for nv, n in results8[:6]:
    print(f'  {nv:.5f}  {n}')
print(f'Mean NMSE: {np.mean([r[0] for r in results8]):.6f}')
print()

# Also test: what if we use tanh instead of logistic (mathematically equiv but different sympy complexity)?
# tanh form: c0 * (tanh(rate*(lt-ht)/2) + 1)/2 + c4  -- same as logistic but different nodes
# Actually logistic(x) = (tanh(x/2)+1)/2, so same function

# Test: use sp.tanh which might have fewer sympy nodes
import sympy as sp
x = [sp.Symbol('x0'), sp.Symbol('x1')]
c = [sp.Symbol(f'c{i}') for i in range(9)]
u = x[0] - c[2]
lt = sp.log(u + sp.sqrt(u**2 + 1))
lx1 = sp.log(x[1])
rate = c[1] * x[1]**c[5]
ht = c[3] * x[1]**c[6] + c[7]*lx1 + c[8]*lx1**2
# tanh form
expr_tanh = c[0] * (sp.tanh(rate*(lt-ht)/2) + 1)/2 + c[4]
expr_logistic = c[0] / (1 + sp.exp(-rate*(lt-ht))) + c[4]
n_tanh = sum(1 for _ in sp.preorder_traversal(expr_tanh))
n_logistic = sum(1 for _ in sp.preorder_traversal(expr_logistic))
print(f'Logistic nodes: {n_logistic}, Tanh nodes: {n_tanh}')

# 8-const model complexity
c8 = [sp.Symbol(f'c{i}') for i in range(8)]
u8 = x[0] - c8[2]
lt8 = sp.log(u8 + sp.sqrt(u8**2 + 1))
lx18 = sp.log(x[1])
rate8 = c8[1] * x[1]**c8[5]
ht8 = c8[3] * x[1]**c8[6] + c8[7]*lx18
expr8 = c8[0] / (1 + sp.exp(-rate8*(lt8-ht8))) + c8[4]
n8 = sum(1 for _ in sp.preorder_traversal(expr8))
print(f'8-const logistic nodes: {n8}')
"
