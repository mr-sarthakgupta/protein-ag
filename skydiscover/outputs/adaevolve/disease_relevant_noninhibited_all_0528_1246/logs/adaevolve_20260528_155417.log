import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()
dset = {name: (X_tr, X_val, y_tr, y_val) for name, X_tr, X_val, y_tr, y_val in datasets}

# Look at Kakkar2016_14kDa - what halftime does each x1 have?
name = 'htt/Kakkar2016/FIts/Kakkar2016_14kDa_Ex45_polyQ_sec'
X_tr, X_val, y_tr, y_val = dset[name]

# Fit a separate sigmoid per x1 to see what halftimes we need
def sig1(x0, c):
    u = x0 - c[2]
    lt = np.log(u + np.sqrt(u**2 + 1))
    return c[0] / (1 + np.exp(-c[1] * (lt - c[3]))) + c[4]

print('Per-x1 sigmoid fits for Kakkar2016_14kDa_sec:')
for x1v in np.unique(X_tr[:,1]):
    mask = X_tr[:,1] == x1v
    xs = X_tr[mask,0]; ys = y_tr[mask]
    idx = np.argsort(xs)
    xs, ys = xs[idx], ys[idx]
    def res(c): return sig1(xs, c) - ys
    sol = least_squares(res, [1.0, 2.0, 0.0, 8.0, 0.0], max_nfev=500, method='trf', loss='soft_l1')
    c = sol.x
    yp = sig1(xs, c)
    nmse_v = np.mean((yp-ys)**2)/(np.var(ys)+1e-10)
    print(f'  x1={x1v:.0f}: rate={c[1]:.3f}, shift={c[2]:.1f}, halftime_lt={c[3]:.3f}, plateau={c[0]:.3f}, nmse={nmse_v:.5f}')
    # halftime in x0 space: lt = halftime_lt => x0 = sinh(halftime_lt) + shift
    ht_x0 = np.sinh(c[3]) + c[2]
    print(f'         halftime_x0={ht_x0:.1f}')
"
