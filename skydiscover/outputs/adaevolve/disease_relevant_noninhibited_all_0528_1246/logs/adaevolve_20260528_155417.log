import sys
sys.path.insert(0, '.')
import importlib.util
import numpy as np
from scipy.optimize import least_squares

spec = importlib.util.spec_from_file_location('ev', 'disease_relevant_noninhibited_all/evaluator.py')
ev = importlib.util.module_from_spec(spec)
spec.loader.exec_module(ev)
datasets = ev.load_all_datasets()

# Test: rate also has log coupling: rate = c1*x1^c5 + c9*log(x1)
# This gives more flexibility for rate vs concentration
def fit_ratelog(X_train, y_train, X_val, y_val):
    x0_col = X_train[:,0]
    x1_col = X_train[:,1]
    x0v = X_val[:,0]
    x1v = X_val[:,1]
    
    def model(x0, x1, c):
        c0,c1,c2,c3,c4,c5,c6,c7,c8,c9 = c
        u = x0 - c2
        lt = np.log(u + np.sqrt(u**2 + 1))
        lx1 = np.log(np.maximum(x1, 1e-10))
        # rate with both power-law and log coupling
        rate = c1 * np.maximum(x1, 1e-10)**c5 + c9*lx1
        ht = c3 * np.maximum(x1, 1e-10)**c6 + c7*lx1 + c8*lx1**2
        return c0 / (1 + np.exp(-rate*(lt - ht))) + c4
    
    def residual(c):
        pred = model(x0_col, x1_col, c)
        if not np.all(np.isfinite(pred)):
            return np.full(len(y_train), 1e12)
        return pred - y_train
    
    r = least_squares(residual, [1,2,0,3,0,0,0,0,0,0], loss='soft_l1', max_nfev=1000)
    pred_val = model(x0v, x1v, r.x)
    var = np.var(y_val)
    nmse = np.mean((pred_val - y_val)**2) / var if var > 1e-12 else float('inf')
    return nmse

# Test: current model but with max_nfev=2000 - better convergence?
def fit_more_iters(X_train, y_train, X_val, y_val):
    x0_col = X_train[:,0]
    x1_col = X_train[:,1]
    x0v = X_val[:,0]
    x1v = X_val[:,1]
    
    def model(x0, x1, c):
        c0,c1,c2,c3,c4,c5,c6,c7,c8 = c
        u = x0 - c2
        lt = np.log(u + np.sqrt(u**2 + 1))
        lx1 = np.log(np.maximum(x1, 1e-10))
        rate = c1 * np.maximum(x1, 1e-10)**c5
        ht = c3 * np.maximum(x1, 1e-10)**c6 + c7*lx1 + c8*lx1**2
        return c0 / (1 + np.exp(-rate*(lt - ht))) + c4
    
    def residual(c):
        pred = model(x0_col, x1_col, c)
        if not np.all(np.isfinite(pred)):
            return np.full(len(y_train), 1e12)
        return pred - y_train
    
    r = least_squares(residual, [1,2,0,3,0,0,0,0,0], loss='soft_l1', max_nfev=3000)
    pred_val = model(x0v, x1v, r.x)
    var = np.var(y_val)
    nmse = np.mean((pred_val - y_val)**2) / var if var > 1e-12 else float('inf')
    return nmse

rl, rm = [], []
for name, X_train, X_val, y_train, y_val in datasets:
    try:
        rl.append((fit_ratelog(X_train, y_train, X_val, y_val), name))
    except:
        rl.append((float('inf'), name))
    try:
        rm.append((fit_more_iters(X_train, y_train, X_val, y_val), name))
    except:
        rm.append((float('inf'), name))

rl.sort(reverse=True)
rm.sort(reverse=True)
print('Rate+log coupling (10c) - top 5:')
for n, name in rl[:5]: print(f'  {n:.4f}  {name}')
print(f'  Mean NMSE: {np.mean([r[0] for r in rl]):.4f}')

print('More iters (3000) - top 5:')
for n, name in rm[:5]: print(f'  {n:.4f}  {name}')
print(f'  Mean NMSE: {np.mean([r[0] for r in rm]):.4f}')
"
