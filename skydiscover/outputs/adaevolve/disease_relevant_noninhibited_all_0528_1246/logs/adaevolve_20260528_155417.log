import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()
dset = {name: (X_tr, X_val, y_tr, y_val) for name, X_tr, X_val, y_tr, y_val in datasets}

# Kar2011 Q37: x1=3,4,6,8,9,22 (polyQ repeats), x0 range 7702-937675
# These are stochastic nucleation curves - each x1 has many replicates
# Let's see how many points per x1 and the spread
name = 'htt/Kar2011/Fits/Kar2011_Q37_prim'
X_tr, X_val, y_tr, y_val = dset[name]
print(f'Total train points: {len(X_tr)}')
for x1v in np.unique(X_tr[:,1]):
    mask = X_tr[:,1] == x1v
    ys = y_tr[mask]; xs = X_tr[mask,0]
    # What fraction are near 0 vs near 1?
    near0 = np.sum(ys < 0.1) / len(ys)
    near1 = np.sum(ys > 0.9) / len(ys)
    mid = 1 - near0 - near1
    print(f'  x1={x1v:.0f}: n={len(ys)}, near0={near0:.2f}, mid={mid:.2f}, near1={near1:.2f}')

# Now test: what if we use a simpler model (just 7 constants, no log-quadratic)
# but with better initialization for Kar2011?
def model7(X, c):
    x0, x1 = X[:,0], X[:,1]
    u = x0 - c[2]
    lt = np.log(u + np.sqrt(u**2 + 1))
    rate = c[1] * np.power(np.maximum(x1, 1e-10), c[5])
    ht = c[3] * np.power(np.maximum(x1, 1e-10), c[6])
    return c[0] / (1 + np.exp(-rate * (lt - ht))) + c[4]

# Try different inits for Kar2011
X_tr, X_val, y_tr, y_val = dset['htt/Kar2011/Fits/Kar2011_Q37_prim']
best_nmse = 999
for r1 in [0.5, 1.0, 2.0, 5.0]:
    for h1 in [5.0, 8.0, 10.0, 12.0]:
        for p5 in [-2.0, -1.0, 0.0, 1.0, 2.0]:
            init = [1.0, r1, 0.0, h1, 0.0, p5, p5]
            def res(c): return model7(X_tr, c) - y_tr
            try:
                sol = least_squares(res, init, max_nfev=500, method='trf', loss='soft_l1')
                yp = model7(X_val, sol.x)
                nv = np.mean((yp-y_val)**2)/(np.var(y_val)+1e-10)
                if nv < best_nmse:
                    best_nmse = nv
                    best_init = init[:]
            except: pass
print(f'Best NMSE for Kar2011 Q37 prim (7-const): {best_nmse:.4f}, init={best_init}')
"
