import os, glob
import numpy as np
import pandas as pd

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
tsv_files = glob.glob(os.path.join(base, '**', 'fit.tsv'), recursive=True)

# Check x1 min values across all datasets
x1_mins = []
for f in tsv_files:
    try:
        df = pd.read_csv(f, sep='\t')
        cols = df.columns.tolist()
        if len(cols) >= 2:
            x1_min = df[cols[1]].min()
            x1_mins.append((x1_min, '/'.join(f.split('/')[-3:-1])))
    except:
        pass

x1_mins.sort()
print('Datasets with smallest x1 min values:')
for v, n in x1_mins[:10]:
    print(f'  {v:.6g}  {n}')
print(f'Datasets with x1_min <= 0: {sum(1 for v,n in x1_mins if v <= 0)}')
print(f'Datasets with x1_min < 0.001: {sum(1 for v,n in x1_mins if v < 0.001)}')
print(f'Total: {len(x1_mins)}')
"
