import sys
sys.path.insert(0, '.')
import importlib.util
import numpy as np
from scipy.optimize import least_squares

spec = importlib.util.spec_from_file_location('ev', 'disease_relevant_noninhibited_all/evaluator.py')
ev = importlib.util.module_from_spec(spec)
spec.loader.exec_module(ev)
datasets = ev.load_all_datasets()

# Test: logistic with log(x0 + c2) time transform instead of asinh
# Also test: adding a linear x0 term to handle seeded datasets
# Model: y = c0 / (1 + exp(-c1*(log(x0+c2) - c3))) + c4
# This is simpler and may be more stable for seeded data

def fit_loglog(X_train, y_train, X_val, y_val):
    x0_col = X_train[:,0]
    x1_col = X_train[:,1]
    x0v = X_val[:,0]
    x1v = X_val[:,1]
    
    def model(x0, x1, c):
        c0,c1,c2,c3,c4,c5,c6,c7,c8 = c
        # log(x0 + c2) - safe log-time transform (c2 > 0 handles x0=0)
        lt = np.log(np.maximum(x0 + c2, 1e-10))
        lx1 = np.log(np.maximum(x1, 1e-10))
        rate = c1 * np.maximum(x1, 1e-10)**c5
        ht = c3 * np.maximum(x1, 1e-10)**c6 + c7*lx1 + c8*lx1**2
        return c0 / (1 + np.exp(-rate*(lt - ht))) + c4
    
    def residual(c):
        pred = model(x0_col, x1_col, c)
        if not np.all(np.isfinite(pred)):
            return np.full(len(y_train), 1e12)
        return pred - y_train
    
    r = least_squares(residual, [1,2,1,3,0,0,0,0,0], loss='soft_l1', max_nfev=1000)
    pred_val = model(x0v, x1v, r.x)
    var = np.var(y_val)
    nmse = np.mean((pred_val - y_val)**2) / var if var > 1e-12 else float('inf')
    return nmse

results_ll = []
for name, X_train, X_val, y_train, y_val in datasets:
    try:
        n = fit_loglog(X_train, y_train, X_val, y_val)
        results_ll.append((n, name))
    except Exception as e:
        results_ll.append((float('inf'), name))

results_ll.sort(reverse=True)
print('log(x0+c2) time transform - hardest datasets:')
for n, name in results_ll[:8]:
    print(f'  {n:.4f}  {name}')
print(f'Mean NMSE: {np.mean([r[0] for r in results_ll]):.4f}')
"
