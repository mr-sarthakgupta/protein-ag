import numpy as np, sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()
dset = {name: (X_tr, X_val, y_tr, y_val) for name, X_tr, X_val, y_tr, y_val in datasets}

# Look at Kar2011 Q37 - what does it look like per x1?
name = 'htt/Kar2011/Fits/Kar2011_Q37_prim'
X_tr, X_val, y_tr, y_val = dset[name]
print(f'x1 unique: {np.unique(X_tr[:,1])}')
print(f'x0 range: [{X_tr[:,0].min():.0f}, {X_tr[:,0].max():.0f}]')
for x1v in np.unique(X_tr[:,1]):
    mask = X_tr[:,1] == x1v
    ys = y_tr[mask]; xs = X_tr[mask,0]
    idx = np.argsort(xs)
    print(f'  x1={x1v}: y[0..5]={ys[idx[:5]].round(4)}, y[-5:]={ys[idx[-5:]].round(4)}')

# Also look at insulin high_conc
