import numpy as np
from scipy.optimize import curve_fit

# Test different functional forms on 1uM_sec data
t = np.array([601.2, 4404.7, 8208.3, 12011.8, 15815.3, 19618.9, 23422.4, 27225.9, 31029.5, 34833.0])
y = np.array([0.00002, 0.00188, 0.02974, 0.29167, 0.77634, 0.95145, 0.98986, 0.99789, 0.99956, 0.99991])

# Form 1: standard logistic
def logistic(t, k, t50):
    return 1 / (1 + np.exp(-k * (t - t50)))

# Form 2: Cohen/Knowles secondary nucleation approx: (1 - (1+B*exp(-lam*t))^-2)
# simplified: tanh-based with quadratic argument
def tanh_sq(t, k, t50):
    return np.tanh(k * (t - t50))**2

# Form 3: 1 - exp(-k*(t-t0)^2) for t>t0 (Avrami-like)
def avrami2(t, k, t0):
    return 1 - np.exp(-k * np.maximum(t - t0, 0)**2)

# Form 4: logistic with exponent (steeper)
def logistic_exp(t, k, t50, n):
    return 1 / (1 + np.exp(-k * (t - t50)))**n

# Fit each
from scipy.optimize import least_squares

def fit_and_nmse(func, p0, t, y):
    try:
        popt, _ = curve_fit(func, t, y, p0=p0, maxfev=5000)
        yp = func(t, *popt)
        nmse = np.mean((y - yp)**2) / np.var(y)
        return nmse, popt
    except:
        return float('inf'), None

nmse1, p1 = fit_and_nmse(logistic, [0.0003, 13000], t, y)
nmse2, p2 = fit_and_nmse(tanh_sq, [0.0003, 11000], t, y)
nmse3, p3 = fit_and_nmse(avrami2, [1e-8, 8000], t, y)
nmse4, p4 = fit_and_nmse(logistic_exp, [0.0003, 12000, 2.0], t, y)

print(f'logistic NMSE: {nmse1:.4f}, params={p1}')
print(f'tanh^2 NMSE: {nmse2:.4f}, params={p2}')
print(f'avrami2 NMSE: {nmse3:.4f}, params={p3}')
print(f'logistic_exp NMSE: {nmse4:.4f}, params={p4}')
"
