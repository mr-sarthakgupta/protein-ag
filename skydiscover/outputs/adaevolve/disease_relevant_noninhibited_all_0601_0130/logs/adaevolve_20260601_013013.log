    early = y[:10]
    late = y[-10:]
    print(f'{name}: t50={t50:.1f}, early_y={early.mean():.4f}, late_y={late.mean():.4f}')
    print(f'  first 5 y: {y[:5]}')
    print(f'  last 5 y: {y[-5:]}')
"
