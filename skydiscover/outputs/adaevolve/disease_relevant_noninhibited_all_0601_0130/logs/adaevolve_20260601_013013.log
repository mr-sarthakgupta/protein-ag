$ python3 -c "
import csv, os, numpy as np
from pathlib import Path
from scipy.optimize import least_squares

DATA_ROOT = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')
datasets = []
for dirpath, _, filenames in os.walk(DATA_ROOT):
    if 'fit.tsv' in filenames:
        datasets.append((Path(dirpath).name, Path(dirpath) / 'fit.tsv'))
datasets.sort()

import re
def parse_param(h):
    m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*mM', h, re.IGNORECASE)
    if m: return float(m.group(1)) * 1000
    return None

def load_dataset(p):
    with open(p) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [[float(v) if v.strip() else float('nan') for v in row] for row in reader if row]
    arr = np.array(rows)
    t = arr[:,0]
    response_headers = header[1:]
    parsed = [parse_param(h) for h in response_headers]
    if all(p is not None for p in parsed):
        params = [float(p) for p in parsed]
    else:
        params = [float(i+1) for i in range(len(response_headers))]
    X, y = [], []
    for col_i, param in enumerate(params):
        for row_i in range(len(t)):
            val = arr[row_i, col_i+1]
            if np.isfinite(val):
                X.append([t[row_i], param])
                y.append(val)
    return np.array(X), np.array(y)

# Test the current logistic model on several datasets
def logistic_model(X, c):
    t, x1 = X[:,0], X[:,1]
    rate = c[0] * x1**c[1]
    half_time = c[2] * x1**c[3]
    plateau = c[4]
    baseline = c[5]
    return plateau / (1 + np.exp(-rate * (t - half_time))) + baseline

def fit_nmse(X, y):
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    split = int(round(len(y) * 0.75))
    train_idx = np.sort(idx[:split])
    val_idx = np.sort(idx[split:])
    Xtr, ytr = X[train_idx], y[train_idx]
    Xval, yval = X[val_idx], y[val_idx]
    
    def residual(c):
        try:
            yp = logistic_model(Xtr, c)
            if not np.all(np.isfinite(yp)):
                return np.full(len(ytr), 1e6)
            return yp - ytr
        except:
            return np.full(len(ytr), 1e6)
    
    result = least_squares(residual, [0.1, 0.5, 10.0, -0.5, 1.0, 0.0], loss='soft_l1', max_nfev=300)
    yp_val = logistic_model(Xval, result.x)
    nmse = np.mean((yval - yp_val)**2) / np.var(yval) if np.var(yval) > 0 else float('inf')
    return nmse, result.x

print('Dataset NMSE for current logistic model:')
for name, p in datasets[:15]:
    X, y = load_dataset(p)
    nmse, params = fit_nmse(X, y)
    x1_unique = np.unique(X[:,1])
    print(f'  {name}: nmse={nmse:.4f}, x1={x1_unique[:3]}, n={len(y)}')
"
