        ph=c0*np.exp(-c4*log_base_v)+c5
        nmse_H=_nmse_with_gaussian_smoothed_target(y_v, ph)
    except Exception as e:
        nmse_H=results_A[-1]
    results_H.append(nmse_H)

print(f'Model A mean NMSE: {np.mean(results_A):.5f}')
print(f'Model H (Richards) mean NMSE: {np.mean(results_H):.5f}')
print()
print('Significant diffs (>0.005):')
