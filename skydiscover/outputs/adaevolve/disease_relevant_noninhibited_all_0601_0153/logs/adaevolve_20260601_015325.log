import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = load_all_datasets()
ds_dict = {name: (X_tr, X_v, y_tr, y_v) for name, X_tr, X_v, y_tr, y_v in datasets}

# Investigate htt/Kar2011 Q37 - what does the curve look like?
name = 'htt/Kar2011/Fits/Kar2011_Q37_prim'
X_tr, X_v, y_tr, y_v = ds_dict[name]
x0_tr, x1_tr = X_tr[:,0], X_tr[:,1]
print('=== htt Q37 prim ===')
print('x0 range:', x0_tr.min(), x0_tr.max())
print('x1 unique:', np.unique(x1_tr))
# For each x1 value, show the curve
for x1_val in np.unique(x1_tr):
    mask = x1_tr == x1_val
    x0_sub = x0_tr[mask]; y_sub = y_tr[mask]
    idx = np.argsort(x0_sub)
    x0_s = x0_sub[idx]; y_s = y_sub[idx]
    step = max(1, len(x0_s)//6)
    pts = [(int(x0_s[i]), round(y_s[i],3)) for i in range(0,len(x0_s),step)]
    print(f'  x1={x1_val}: {pts}')

print()
# Test log(1+c3*x0) with much better initial values for htt/Kar2011
# x0 range is 7701 to 937674 - log(1+c3*x0) needs c3 ~ 1/x0_mid ~ 1/100000
# So c3*x0_mid ~ 1, making log(1+1) ~ 0.7 - need c2 to compensate
# Try: c2=10, c3=1e-5 so c2*log(1+c3*x0_mid) ~ 10*log(2) ~ 7

name2 = 'htt/Kar2011/Fits/Kar2011_Q37_prim'
X_tr2, X_v2, y_tr2, y_v2 = ds_dict[name2]
x0_tr2, x1_tr2 = X_tr2[:,0], X_tr2[:,1]
x0_v2, x1_v2 = X_v2[:,0], X_v2[:,1]
var_v2 = np.var(y_v2)

def res_E2(theta):
    c0,c1,c2,c3,c4,c5 = theta
    c3_s = np.abs(c3)+1e-12
    z = np.clip(c1 - c2*np.log1p(c3_s*x0_tr2) - c4*x1_tr2,-500,500)
    pred = c0/(1+np.exp(z))+c5
    if not np.all(np.isfinite(pred)): return np.full_like(y_tr2,1e6)
    return pred - y_tr2

# Try multiple starting points
for init in [[1,14,1.0,1e-5,0.001,0],[1,7,1.0,1e-5,0.5,0],[1,10,2.0,1e-4,0.1,0]]:
    try:
        re = least_squares(res_E2, init, loss='soft_l1', max_nfev=500)
        c0,c1,c2,c3,c4,c5 = re.x
        c3_s=np.abs(c3)+1e-12
        z_v=np.clip(c1-c2*np.log1p(c3_s*x0_v2)-c4*x1_v2,-500,500)
        pv=c0/(1+np.exp(z_v))+c5
        nmse=np.mean((pv-y_v2)**2)/(var_v2+1e-10)
        print(f'  init={init[:3]}... -> nmse={nmse:.4f} c={np.round(re.x,4)}')
    except Exception as e:
        print(f'  init={init[:3]}... FAILED: {e}')
