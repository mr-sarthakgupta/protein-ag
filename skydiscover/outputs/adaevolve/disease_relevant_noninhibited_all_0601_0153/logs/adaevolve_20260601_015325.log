import numpy as np
import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()
ds_dict = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

def fit_nmse(model_fn, X_train, y_train, X_val, y_val, init):
    def residual(theta):
        pred = model_fn(theta, X_train)
        if not np.all(np.isfinite(pred)): return np.full(len(y_train), 1e12)
        return pred - y_train
    res = least_squares(residual, init, loss='soft_l1', max_nfev=300)
    pred_val = model_fn(res.x, X_val)
    var = np.var(y_val)
    if var <= 0: return np.mean((pred_val-y_val)**2), res.x
    return np.mean((pred_val - y_val)**2)/var, res.x

# Model A: c0/(1+exp(c1*(1 - x0/c2) - c3*x1)) + c4
# c2 = half-time (same scale as x0), c1 = steepness, c3*x1 shifts half-time
def model_A(theta, X):
    c0,c1,c2,c3,c4 = theta
    return c0/(1+np.exp(np.clip(c1*(1.0 - X[:,0]/c2) - c3*X[:,1], -500, 500))) + c4

# Model B: c0/(1+exp(c1 - c2*x0 - c3*x1)) + c4  [best known]
def model_B(theta, X):
    c0,c1,c2,c3,c4 = theta
    return c0/(1+np.exp(np.clip(c1 - c2*X[:,0] - c3*X[:,1], -500, 500))) + c4

# Test model A with init: c2=median x0 across datasets
# Typical x0 midpoints: IAPP~25000, lysozyme~180000, insulin~30000, htt~1e6
# Use c2=1e4 as a reasonable middle ground, c1=2 (steepness)
results_A = []
results_B = []
for name, X_train, X_val, y_train, y_val in datasets:
    # init c2 as median of x0
    x0_med = np.median(X_train[:,0])
    x0_med = max(x0_med, 1.0)
    nA, tA = fit_nmse(model_A, X_train, y_train, X_val, y_val, [1.0, 2.0, x0_med, 0.01, 0.0])
    nB, tB = fit_nmse(model_B, X_train, y_train, X_val, y_val, [1.0, 14.0, 9e-4, 0.001, 0.0])
    results_A.append((nA, name))
    results_B.append((nB, name))

print(f'Model A (half-time form): mean={np.nanmean([r[0] for r in results_A]):.5f}')
print(f'Model B (best known):     mean={np.nanmean([r[0] for r in results_B]):.5f}')
print('Worst A:')
for n,nm in sorted(results_A, reverse=True)[:5]:
    print(f'  {n:.4f} {nm}')
" 2>/dev/null
