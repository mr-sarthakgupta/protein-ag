import numpy as np, re, csv, os
from pathlib import Path
from scipy.optimize import least_squares

base = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def load_tsv(path):
    with open(path, newline='') as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rh = header[1:]
        parsed = [re.search(r'[-+]?\d*\.?\d+(?:[eE][-+]?\d+)?', h) for h in rh]
        params = [float(m.group()) for m in parsed] if all(m for m in parsed) else [float(i+1) for i in range(len(rh))]
        rows = [r for r in reader if r]
    feats, tgts = [], []
    for row in rows:
        for p, v in zip(params, row[1:]):
            if v.strip().lower() not in ('', 'nan'):
                feats.append([float(row[0]), p])
                tgts.append(float(v))
    arr = np.array(feats)
    return arr[:,0], arr[:,1], np.array(tgts)

# Product model: y = c0/(1+exp(c1 - (c2+c3*x1)*x0)) + c4
def model_prod(X, theta):
    c0,c1,c2,c3,c4 = theta
    x0, x1 = X[:,0], X[:,1]
    return c0 / (1 + np.exp(np.clip(c1 - (c2 + c3*x1)*x0, -500, 500))) + c4

def residual(theta, X, y):
    return model_prod(X, theta) - y

datasets = []
for root, dirs, files in os.walk(base):
    if 'fit.tsv' in files:
        datasets.append(Path(root)/'fit.tsv')
datasets.sort()

# Test with very small c3 init
p0 = [1.0, 14.0, 9e-4, 1e-7, 0.0]
results = []
for path in datasets:
    x0,x1,y = load_tsv(path)
    X = np.column_stack([x0,x1])
    try:
        res = least_squares(residual, p0, args=(X,y), max_nfev=300, method='trf')
        yp = model_prod(X, res.x)
        nmse = np.mean((y-yp)**2)/np.var(y)
        results.append((path.parent.name, nmse))
    except Exception as e:
        results.append((path.parent.name, float('nan')))

finite = [v for _,v in results if np.isfinite(v)]
print(f'p0={p0}')
print(f'n_ok={len(finite)}/42, mean={np.mean(finite):.4f}, max={np.max(finite):.4f}')
results.sort(key=lambda x: -x[1] if np.isfinite(x[1]) else 999)
print('Worst 8:')
for n,v in results[:8]:
    print(f'  {n}: {v:.4f}')
"
