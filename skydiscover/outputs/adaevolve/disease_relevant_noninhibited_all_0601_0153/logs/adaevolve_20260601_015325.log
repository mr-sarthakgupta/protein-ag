            ph=c0*np.exp(np.clip(-c4*log_base_v,-500,500))+c5
            nmse=_nmse_with_gaussian_smoothed_target(y_v, ph)
        except: nmse=results_A[-1]
        results_list.append(nmse)

print(f'Model A mean:      {np.mean(results_A):.5f}')
print(f'Model H c4=0.5:    {np.mean(results_H05):.5f}')
print(f'Model H c4=0.3:    {np.mean(results_H03):.5f}')
print()
print('Diffs vs A (>0.005):')
for i,(name,*_) in enumerate(datasets):
    d05=results_A[i]-results_H05[i]; d03=results_A[i]-results_H03[i]
    if abs(d05)>0.005 or abs(d03)>0.005:
        print(f'  {name[-38:]:38s}: A={results_A[i]:.4f} H05={results_H05[i]:.4f} H03={results_H03[i]:.4f}')
print()
for c4_init, results_list in [(0.5, results_H05), (0.3, results_H03)]:
    mn=np.mean(results_list)
    print(f'c4_init={c4_init}: fit={1/(1+mn):.4f} parsimony={1-0.2*22/160:.4f} combined={1/(1+mn)*(1-0.2*22/160):.4f}')
" 2>/dev/null
