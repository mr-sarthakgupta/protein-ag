import numpy as np, re, csv
from pathlib import Path
from scipy.optimize import curve_fit

base = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def load_tsv(path):
    with open(path, newline='') as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rh = header[1:]
        parsed = [re.search(r'[-+]?\d*\.?\d+(?:[eE][-+]?\d+)?', h) for h in rh]
        params = [float(m.group()) for m in parsed] if all(m for m in parsed) else [float(i+1) for i in range(len(rh))]
        rows = [r for r in reader if r]
    feats, tgts = [], []
    for row in rows:
        for p, v in zip(params, row[1:]):
            if v.strip().lower() not in ('', 'nan'):
                feats.append([float(row[0]), p])
                tgts.append(float(v))
    arr = np.array(feats)
    return arr[:,0], arr[:,1], np.array(tgts)

# product model: y = c0/(1+exp(c1 - (c2+c3*x1)*x0)) + c4
def model_prod(X, c0, c1, c2, c3, c4):
    x0, x1 = X[:,0], X[:,1]
    return c0 / (1 + np.exp(np.clip(c1 - (c2 + c3*x1)*x0, -500, 500))) + c4

datasets = []
for root, dirs, files in os.walk(base):
    if 'fit.tsv' in files:
        datasets.append(Path(root)/'fit.tsv')
datasets.sort()

results = []
for path in datasets:
    x0,x1,y = load_tsv(path)
    X = np.column_stack([x0,x1])
    name = path.parent.name
    # Use scaled initial values based on data
    x0med = np.median(x0[x0>0]) if np.any(x0>0) else 1.0
    x1med = np.median(x1)
    p0 = [1.0, 14.0, 9e-4/max(x1med,1), 1e-4/max(x1med,1), 0.0]
    try:
        p, _ = curve_fit(model_prod, X, y, p0=p0, maxfev=20000, method='trf')
        yp = model_prod(X, *p)
        nmse = np.mean((y-yp)**2)/np.var(y)
        results.append((name, nmse))
    except Exception as e:
        results.append((name, float('nan')))

nmses = [r[1] for r in results if np.isfinite(r[1])]
print(f'N successful: {len(nmses)}/{len(results)}')
print(f'Mean NMSE: {np.mean(nmses):.4f}')
print(f'Median NMSE: {np.median(nmses):.4f}')
# show worst 5
results_finite = [(n,v) for n,v in results if np.isfinite(v)]
results_finite.sort(key=lambda x: -x[1])
print('Worst 5:')
for n,v in results_finite[:5]:
    print(f'  {n}: {v:.4f}')
"
