import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
import sympy as sp
from scipy.optimize import least_squares

datasets = load_all_datasets()

# Test current model: y = c0/(1+exp(c1 - c2*x0 - c3*x1)) + c4
# on each dataset to find which ones have high NMSE
results = []
for name, X_train, X_val, y_train, y_val in datasets:
    x0_tr = X_train[:,0]
    x1_tr = X_train[:,1]
    x0_v = X_val[:,0]
    x1_v = X_val[:,1]
    
    def residual(theta):
        c0,c1,c2,c3,c4 = theta
        pred = c0/(1+np.exp(np.clip(c1 - c2*x0_tr - c3*x1_tr, -500, 500))) + c4
        if not np.all(np.isfinite(pred)):
            return np.full_like(y_train, 1e6)
        return pred - y_train
    
    try:
        res = least_squares(residual, [1.0, 14.0, 9e-4, 0.001, 0.0], loss='soft_l1', max_nfev=300)
        c0,c1,c2,c3,c4 = res.x
        pred_v = c0/(1+np.exp(np.clip(c1 - c2*x0_v - c3*x1_v, -500, 500))) + c4
        var_y = np.var(y_val)
        nmse = np.mean((pred_v - y_val)**2) / (var_y + 1e-10) if var_y > 0 else float('inf')
        results.append((nmse, name))
    except Exception as e:
        results.append((float('inf'), name + f' ERROR:{e}'))

results.sort(reverse=True)
print('Worst 15 datasets (high NMSE):')
for nmse, name in results[:15]:
    print(f'  {nmse:.4f}  {name}')
print()
print('Mean NMSE:', np.mean([r[0] for r in results if np.isfinite(r[0])]))
"
