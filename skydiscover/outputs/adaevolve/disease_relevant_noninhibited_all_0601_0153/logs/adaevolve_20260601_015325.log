    df = pd.read_csv(path, sep='\t')
    x0_col = df['X'].values
    resp_headers = [c for c in df.columns if c != 'X']
    parsed = [parse_param(h) for h in resp_headers]
    if all(p is not None for p in parsed):
        parameters = [float(p) for p in parsed]
    else:
        parameters = [float(i+1) for i in range(len(resp_headers))]
    rows_x0, rows_x1, rows_y = [], [], []
    for param, col in zip(parameters, resp_headers):
        y_vals = df[col].values
        valid = np.isfinite(y_vals)
        rows_x0.extend(x0_col[valid])
        rows_x1.extend([param]*valid.sum())
        rows_y.extend(y_vals[valid])
    X = np.column_stack([rows_x0, rows_x1])
    y = np.array(rows_y)
    # Use evaluator's exact split: rng seed=42, test_size=0.25
    rng = np.random.default_rng(42)
    indices = rng.permutation(len(y))
    split = int(round(len(y) * 0.75))
    tr = np.sort(indices[:split])
    va = np.sort(indices[split:])
    return X[tr], X[va], y[tr], y[va]

datasets = sorted(glob.glob(base + '**/fit.tsv', recursive=True))
all_data = [(load_dataset_split(d), d.split('/')[-2]) for d in datasets]

# Current Richards model
def model_A(X, c0, c1, c2, c3, c4, c5):
    z = c1 - c2*X[:,0] - c3*X[:,1]
    return c0 * np.exp(-c4 * np.log1p(np.exp(np.clip(z, -500, 500)))) + c5

# Log-time Richards model  
def model_C(X, c0, c1, c2, c3, c4, c5):
    z = c1 - c2*np.log1p(np.abs(X[:,0])) - c3*X[:,1]
    return c0 * np.exp(-c4 * np.log1p(np.exp(np.clip(z, -500, 500)))) + c5

def eval_model(model, p0, label):
