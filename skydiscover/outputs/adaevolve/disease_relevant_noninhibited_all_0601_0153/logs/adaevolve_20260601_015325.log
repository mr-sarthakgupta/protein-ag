import os

data_root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def load_dataset(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.IGNORECASE)
            if m: parsed.append(float(m.group(1)))
            else: parsed.append(None)
        if all(p is not None for p in parsed):
            params = [float(p) for p in parsed]
        else:
            params = [float(i+1) for i in range(len(response_headers))]
        rows = list(reader)
        X, y = [], []
        for row in rows:
            if not row: continue
            x0v = float(row[0])
            for param, val in zip(params, row[1:]):
                if val and val.strip().lower() != 'nan':
                    X.append([x0v, param])
                    y.append(float(val))
    return np.array(X), np.array(y)

def split(X, y):
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    sp2 = int(round(len(y)*0.75))
    ti, vi = np.sort(idx[:sp2]), np.sort(idx[sp2:])
    return X[ti], X[vi], y[ti], y[vi]

datasets = []
for dirpath, _, filenames in os.walk(data_root):
    if 'fit.tsv' in filenames:
        datasets.append(Path(dirpath) / 'fit.tsv')
datasets.sort()

# Model C: log(x0 + c2 + 1) - 5 params, c2 init=0 (safe for x0>=0), or higher for negative
# When c2=0: same as log(x0+1), when c2>0: shifts the curve
def modelC(th, X):
    c0v,c1v,c2v,c3v,c4v = th
    t = X[:,0]
    arg = t + c2v + 1.0
    with np.errstate(divide='ignore', invalid='ignore'):
        lt = np.where(arg > 0, np.log(arg), -1e10)
    return c0v/(1+np.exp(np.clip(-c1v*(lt-c3v), -500, 500)))+c4v

# Model C2: init c2=1 (safe for x0 >= -1)
# Model X2: log(x0^2 + 1) - always safe, 4 params
def modelX2(th, X):
    c0v,c1v,c2v,c3v = th
    t = X[:,0]
    lt = np.log(t**2 + 1)
    return c0v/(1+np.exp(np.clip(-c1v*(lt-c2v), -500, 500)))+c3v

results_C = []
results_X2 = []
bad_C = []
