import numpy as np
import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, _nmse_with_gaussian_smoothed_target
from scipy.optimize import least_squares

datasets = load_all_datasets()

def fit_eval(model_fn, X_train, y_train, X_val, y_val, init):
    def residual(theta):
        pred = model_fn(theta, X_train)
        if not np.all(np.isfinite(pred)): return np.full(len(y_train), 1e12)
        return pred - y_train
    res = least_squares(residual, init, loss='soft_l1', max_nfev=300)
    pred_val = model_fn(res.x, X_val)
    return _nmse_with_gaussian_smoothed_target(y_val, pred_val), res.x

def model_B(theta, X):
    c0,c1,c2,c3,c4 = theta
    return c0/(1+np.exp(np.clip(c1 - c2*X[:,0] - c3*X[:,1], -500, 500))) + c4

# The overflow issue: at init c2=9e-4, c1=14:
# exp(14 - 9e-4 * x0) overflows when x0 < (14-500)/9e-4 = -540000 (underflow)
# but exp(14 - 9e-4 * 353069) = exp(14 - 317.8) = exp(-303.8) -> 0 (fine!)
# Wait - the issue is exp(c1 - c2*x0) where c2 is negative after fitting?
# Let me check: what if c2 becomes negative? Then c1 - c2*x0 grows -> overflow

# Actually the issue is different: at init the residual is all positive
# (model gives ~1 everywhere since exp(14-0.9*0)=exp(14)>>1 -> 1/large -> 0)
# Wait: exp(14 - 9e-4 * 4620) = exp(14 - 4.16) = exp(9.84) = 18800 -> 1/18800 -> 0
# exp(14 - 9e-4 * 353069) = exp(14 - 317.8) = exp(-303.8) -> 0 -> 1/(1+0) = 1
# So at init, lysozyme sigmoid goes from 0 to 1 correctly!
# But then why does it fail?

# Let me trace the optimization for lysozyme
ds_dict = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}
X_train, X_val, y_train, y_val = ds_dict['lysozyme/Fits/Hasecke2018_7uM_sec']

# Check initial prediction
theta0 = [1.0, 14.0, 9e-4, 0.001, 0.0]
c0,c1,c2,c3,c4 = theta0
exponent = c1 - c2*X_train[:,0] - c3*X_train[:,1]
print('Exponent range at init:', exponent.min(), exponent.max())
pred0 = c0/(1+np.exp(np.clip(exponent, -500, 500))) + c4
print('Pred range at init:', pred0.min(), pred0.max())
print('y range:', y_train.min(), y_train.max())

# Check residuals at init
resid0 = pred0 - y_train
print('Residual range:', resid0.min(), resid0.max())
print('Sum sq residual at init:', np.sum(resid0**2))

# The sigmoid at init: c2*x0 goes from 9e-4*4620=4.16 to 9e-4*353069=317.8
# So exponent goes from 14-4.16-0.007=9.83 to 14-317.8-0.007=-303.8
# This is a VALID sigmoid at init! The optimizer should converge...
# But it doesn't. Why?

# Try with verbose
from scipy.optimize import least_squares
def residual(theta):
    c0,c1,c2,c3,c4 = theta
    exponent = c1 - c2*X_train[:,0] - c3*X_train[:,1]
    pred = c0/(1+np.exp(np.clip(exponent, -500, 500))) + c4
    if not np.all(np.isfinite(pred)): return np.full(len(y_train), 1e12)
    return pred - y_train

res = least_squares(residual, theta0, loss='soft_l1', max_nfev=300, verbose=0)
print('Fitted:', res.x)
print('Cost:', res.cost)
print('nfev:', res.nfev)
"
