import numpy as np, re, csv
from pathlib import Path
from scipy.optimize import curve_fit, differential_evolution

base = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def load_tsv(path):
    with open(path, newline='') as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rh = header[1:]
        parsed = [re.search(r'[-+]?\d*\.?\d+(?:[eE][-+]?\d+)?', h) for h in rh]
        params = [float(m.group()) for m in parsed] if all(m for m in parsed) else [float(i+1) for i in range(len(rh))]
        rows = [r for r in reader if r]
    feats, tgts = [], []
    for row in rows:
        for p, v in zip(params, row[1:]):
            if v.strip().lower() not in ('', 'nan'):
                feats.append([float(row[0]), p])
                tgts.append(float(v))
    arr = np.array(feats)
    return arr[:,0], arr[:,1], np.array(tgts)

def model_curr(X, c0, c1, c2, c3, c4):
    x0, x1 = X[:,0], X[:,1]
    return c0 / (1 + np.exp(np.clip(c1 - c2*x0 - c3*x1, -500, 500))) + c4

# Try a model with x0*x1 product term for half-time shift
def model_prod(X, c0, c1, c2, c3, c4):
    x0, x1 = X[:,0], X[:,1]
    # rate = c2 + c3*x1, half-time = c1/rate
    return c0 / (1 + np.exp(np.clip(c1 - (c2 + c3*x1)*x0, -500, 500))) + c4

paths = [
    (base/'Abeta/Cohen2013/Ab42_sec_IN_HOURS/fit.tsv', [1,5,0.5,0.1,0]),
    (base/'Abeta/Meisl2014/Ab40_sec_IN_HOURS/fit.tsv', [1,5,0.3,0.05,0]),
    (base/'prp/Stoehr2008/Stoehr2008_Fig4-seeded_sec_nuc/fit.tsv', [1,5,0.5,0.01,0]),
]

for path, p0 in paths:
    x0,x1,y = load_tsv(path)
    X = np.column_stack([x0,x1])
    name = path.parent.name
    for mname, mfn in [('curr',model_curr),('prod',model_prod)]:
        try:
