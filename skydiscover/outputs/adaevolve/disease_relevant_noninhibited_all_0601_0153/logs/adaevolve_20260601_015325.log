def form_a(x0, theta):
    c0,c1,c2,c3 = theta
    return c0/(1+np.exp(np.clip(c1-c2*x0,-500,500)))+c3

# c0/(1+exp(-c1*(x0-c2)))+c3 with init [1,1,1,0] 
def form_b(x0, theta):
    c0,c1,c2,c3 = theta
    return c0/(1+np.exp(np.clip(-c1*(x0-c2),-500,500)))+c3

