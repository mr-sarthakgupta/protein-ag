import numpy as np
import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()

def model_log(theta, X):
    c0,c1,c2,c3,c4 = theta
    return c0/(1+np.exp(np.clip(c1 - c2*np.log(X[:,0]+1) - c3*X[:,1], -500, 500))) + c4

def model_lin(theta, X):
    c0,c1,c2,c3,c4 = theta
    return c0/(1+np.exp(np.clip(c1 - c2*X[:,0] - c3*X[:,1], -500, 500))) + c4

def fit_nmse(model_fn, X_train, y_train, X_val, y_val, init):
    def residual(theta):
        pred = model_fn(theta, X_train)
        if not np.all(np.isfinite(pred)): return np.full(len(y_train), 1e12)
        return pred - y_train
    res = least_squares(residual, init, loss='soft_l1', max_nfev=300)
    pred_val = model_fn(res.x, X_val)
    var = np.var(y_val)
    if var <= 0: return np.mean((pred_val-y_val)**2)
    return np.mean((pred_val - y_val)**2)/var

results_log = []
results_lin = []
for name, X_train, X_val, y_train, y_val in datasets:
    nl = fit_nmse(model_log, X_train, y_train, X_val, y_val, [1.0, 10.0, 1.0, 0.1, 0.0])
    nlin = fit_nmse(model_lin, X_train, y_train, X_val, y_val, [1.0, 14.0, 9e-4, 0.001, 0.0])
    results_log.append((nl, name))
    results_lin.append((nlin, name))
    if not np.isfinite(nl):
        print(f'NaN log: {name}, x0=[{X_train[:,0].min():.1f},{X_train[:,0].max():.1f}], x1=[{X_train[:,1].min():.1f},{X_train[:,1].max():.1f}]')

print(f'Mean NMSE log: {np.nanmean([r[0] for r in results_log]):.5f}')
print(f'Mean NMSE lin: {np.nanmean([r[0] for r in results_lin]):.5f}')
print('Worst log datasets:')
for nmse, name in sorted(results_log, reverse=True)[:5]:
    print(f'  {nmse:.4f} {name}')
"
