import numpy as np
import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, _nmse_with_gaussian_smoothed_target
from scipy.optimize import least_squares

datasets = load_all_datasets()
ds_dict = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

def fit_eval(model_fn, X_train, y_train, X_val, y_val, init):
    def residual(theta):
        pred = model_fn(theta, X_train)
        if not np.all(np.isfinite(pred)): return np.full(len(y_train), 1e12)
        return pred - y_train
    res = least_squares(residual, init, loss='soft_l1', max_nfev=300)
    pred_val = model_fn(res.x, X_val)
    return _nmse_with_gaussian_smoothed_target(y_val, pred_val), res.x

# Boltzmann: c0/(1+exp((c1-x0)/c2 - c3*x1)) + c4
# c1 = half-time, c2 = width, c3 = x1 influence
# Init: c1=5000 (typical half-time in seconds), c2=5000 (width)
def model_bolt(theta, X):
    c0,c1,c2,c3,c4 = theta
    return c0/(1+np.exp(np.clip((c1-X[:,0])/c2 - c3*X[:,1], -500, 500))) + c4

# Test different inits for Boltzmann
for init in [
    [1.0, 5000.0, 5000.0, 0.01, 0.0],
    [1.0, 10000.0, 10000.0, 0.01, 0.0],
    [1.0, 1000.0, 1000.0, 0.001, 0.0],
]:
    nmses = []
    for name, X_train, X_val, y_train, y_val in datasets:
        n, _ = fit_eval(model_bolt, X_train, y_train, X_val, y_val, init)
        nmses.append((n, name))
    mean = np.mean([r[0] for r in nmses])
    worst = sorted(nmses, reverse=True)[:2]
    print(f'Boltzmann init={init[:3]}: mean={mean:.5f}, worst={[(f\"{n:.3f}\",nm.split(\"/\")[-1]) for n,nm in worst]}')

# Also test: what if we use x0-c1 form with c1 init at median x0?
# But we can't use data to set init...
# Try: c0/(1+exp(c1-c2*x0-c3*x1))+c4 with c1=2, c2=9e-4
# At init: half-time = 2/9e-4 = 2222 sec (reasonable for many datasets)
# Lysozyme half-time ~250000 - needs c2~8e-6, c1~2 -> 2/8e-6=250000 ✓
# But optimizer needs to reduce c2 by 112x from 9e-4 to 8e-6...

# Key insight: use c1=0 init! Then half-time=0 and model predicts 0.5 everywhere
# This is a NEUTRAL start - optimizer can go either direction
for init in [
    [1.0, 0.0, 9e-4, 0.001, 0.0],
    [1.0, 0.0, 1e-4, 0.001, 0.0],
    [1.0, 0.0, 1e-3, 0.001, 0.0],
]:
    nmses = []
    for name, X_train, X_val, y_train, y_val in datasets:
        n, _ = fit_eval(lambda t,X: t[0]/(1+np.exp(np.clip(t[1]-t[2]*X[:,0]-t[3]*X[:,1],-500,500)))+t[4],
                       X_train, y_train, X_val, y_val, init)
        nmses.append((n, name))
    mean = np.mean([r[0] for r in nmses])
    worst = sorted(nmses, reverse=True)[:2]
    print(f'c1=0 init={init[:3]}: mean={mean:.5f}, worst={[(f\"{n:.3f}\",nm.split(\"/\")[-1]) for n,nm in worst]}')
"
