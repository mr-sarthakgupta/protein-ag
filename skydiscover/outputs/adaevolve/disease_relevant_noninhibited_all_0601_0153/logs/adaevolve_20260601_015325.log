import pandas as pd, numpy as np, os
from scipy.optimize import curve_fit, minimize

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

# Investigate hnRNPA A1 sec dataset
fp = os.path.join(base, 'hnRNPA/Kim2013/Fits/Kim2013_A1_sec/fit.tsv')
df = pd.read_csv(fp, sep='\t')
X = df.iloc[:,:2].values.astype(float)
y = df.iloc[:,-1].values.astype(float)
print('Columns:', df.columns.tolist())
print('x0 range:', X[:,0].min(), X[:,0].max())
print('x1 unique:', np.unique(X[:,1]))
print('y sample:', y[::20].round(4))
print()

# Try with x1 ignored (pure time logistic)
def logistic_t(x0, c0, c1, c2, c4):
    z = c1 - c2*x0
    z = np.clip(z, -500, 500)
    return c0 / (1 + np.exp(z)) + c4

try:
    p0 = [1.0, 14.0, 9e-4, 0.0]
    pl, _ = curve_fit(logistic_t, X[:,0], y, p0=p0, maxfev=10000)
    yl = logistic_t(X[:,0], *pl)
    nmse = np.mean((y-yl)**2)/np.var(y)
    print(f'Pure time logistic: NMSE={nmse:.4f}, params={pl}')
except Exception as e:
    print(f'Pure time logistic failed: {e}')

# Try Gompertz: y = c0*exp(-exp(c1 - c2*x0)) + c4
def gompertz(X, c0, c1, c2, c3, c4):
    z = c1 - c2*X[:,0] - c3*X[:,1]
    z = np.clip(z, -500, 500)
    return c0 * np.exp(-np.exp(z)) + c4

try:
    p0g = [1.0, 3.0, 9e-4, 0.001, 0.0]
    pg, _ = curve_fit(gompertz, X, y, p0=p0g, maxfev=10000)
