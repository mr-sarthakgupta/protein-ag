    (form_b, [1.0, 0.001, 1000.0, 0.0], 'sigmoid init[1,0.001,1000,0]'),
    (form_c, [0.5, 1.0, 1.0, 0.5], 'tanh init[0.5,1,1,0.5]'),
]
for form, inits, label in tests:
    nmses = [fit_form(X_train, y_train, X_val, y_val, form, inits)
