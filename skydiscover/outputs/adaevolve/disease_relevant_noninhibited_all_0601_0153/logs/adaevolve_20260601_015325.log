import pandas as pd, numpy as np, os
from scipy.optimize import curve_fit

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

# For the htt/Kakkar dataset, x1 looks like it IS the secondary nucleation term
# Check correlation between x1 and y
for rel in ['htt/Kakkar2016/FIts/Kakkar2016_6kDa_polyQ_prim',
            'hnRNPA/Kim2013/Fits/Kim2013_A1_sec',
            'lysozyme/Fits/Hasecke2018_7uM_sec']:
    fp = os.path.join(base, rel, 'fit.tsv')
    if not os.path.exists(fp): continue
    df = pd.read_csv(fp, sep='\t')
    X = df.iloc[:,:2].values.astype(float)
    y = df.iloc[:,-1].values.astype(float)
    corr = np.corrcoef(X[:,1], y)[0,1]
    print(f'{rel[-40:]}: corr(x1,y)={corr:.4f}')
    print(f'  First 5: x1={X[:5,1].round(4)}, y={y[:5].round(4)}')

print()
# Try model that uses x0 only (ignoring x1) on all datasets
def logistic_t(X, c0, c1, c2, c4):
    z = c1 - c2*X[:,0]
    z = np.clip(z, -500, 500)
    return c0 / (1 + np.exp(z)) + c4

nmses = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            fp = os.path.join(root, f)
            df = pd.read_csv(fp, sep='\t')
            X = df.iloc[:,:2].values.astype(float)
            y = df.iloc[:,-1].values.astype(float)
            var_y = np.var(y)
            try:
                p0 = [1.0, 14.0, 9e-4, 0.0]
                pr, _ = curve_fit(logistic_t, X, y, p0=p0, maxfev=10000)
                yr = logistic_t(X, *pr)
                nmse = np.mean((y-yr)**2)/var_y if var_y > 0 else 0
                nmses.append(nmse)
            except:
                nmses.append(99)

good = [n for n in nmses if n < 99]
print(f'x0-only logistic: Mean NMSE={np.mean(good):.4f}, n_ok={len(good)}/{len(nmses)}')
"
