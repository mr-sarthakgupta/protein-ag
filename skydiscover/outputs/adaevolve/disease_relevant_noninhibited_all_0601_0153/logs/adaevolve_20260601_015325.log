 122 |         "command": "python3 -c \"\nimport pandas as pd\nimport numpy as np\nimport glob\n\nbase = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'\nfiles = glob.glob(base + '**/fit.tsv', recursive=True)\nfiles.sort()\n\n# Check asymmetry of sigmoidal curves - are they symmetric around midpoint?\n# Measure: time from 0.1->0.5 vs 0.5->0.9\nfor f in files[:4]:\n    df = pd.read_csv(f, sep='\\t')\n    x0 = df.iloc[:,0].values\n    col = df.columns[1]\n    y = df[col].values\n    \n    # interpolate crossing times\n    def crossing(y, x0, level):\n        idx = np.searchsorted(y, level)\n        if idx == 0 or idx >= len(y): return np.nan\n        t = x0[idx-1] + (level - y[idx-1]) / (y[idx] - y[idx-1]) * (x0[idx] - x0[idx-1])\n        return t\n    \n    t10 = crossing(y, x0, 0.1)\n    t50 = crossing(y, x0, 0.5)\n    t90 = crossing(y, x0, 0.9)\n    \n    name = f.replace(base,'')[:50]\n    if t10 and t50 and t90:\n        rise_low = t50 - t10\n        rise_high = t90 - t50\n        asymmetry = rise_high / rise_low if rise_low > 0 else np.nan\n        print(f'{name}: t10={t10:.2f}, t50={t50:.2f}, t90={t90:.2f}, asym={asymmetry:.2f}')\n    else:\n        print(f'{name}: could not compute crossings')\n\"\n"
