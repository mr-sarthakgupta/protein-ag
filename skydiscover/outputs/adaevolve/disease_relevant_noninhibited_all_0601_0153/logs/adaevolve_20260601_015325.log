print('Train residuals (first 10):', (pred_train - y_train)[:10].round(4))

# Show actual data shape - sort by x0
idx = np.argsort(X_train[:,0])
x0s = X_train[idx,0]
ys = y_train[idx]
preds = pred_train[idx]
# Print every 10th point
for i in range(0, len(x0s), 10):
    print(f'  x0={x0s[i]:.0f} y={ys[i]:.4f} pred={preds[i]:.4f} err={ys[i]-preds[i]:.4f}')

var = np.var(y_val)
nmse = np.mean((pred_val - y_val)**2)/var
print(f'NMSE val: {nmse:.4f}')
