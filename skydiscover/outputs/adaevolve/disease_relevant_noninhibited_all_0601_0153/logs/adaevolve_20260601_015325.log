import numpy as np
from scipy.optimize import least_squares
import csv, re
from pathlib import Path
import os

data_root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')
datasets = []
for dirpath, _, filenames in os.walk(data_root):
    if 'fit.tsv' in filenames:
        datasets.append(Path(dirpath) / 'fit.tsv')
datasets.sort()

def load_dataset(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.IGNORECASE)
            if m: parsed.append(float(m.group(1)))
            else: parsed.append(None)
        if all(p is not None for p in parsed):
            params = [float(p) for p in parsed]
        else:
            params = [float(i+1) for i in range(len(response_headers))]
        rows = list(reader)
        X, y = [], []
        for row in rows:
            if not row: continue
            x0 = float(row[0])
            for param, val in zip(params, row[1:]):
                if val and val.strip().lower() != 'nan':
                    X.append([x0, param])
                    y.append(float(val))
    return np.array(X), np.array(y)

def split(X, y):
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    split = int(round(len(y)*0.75))
    ti, vi = np.sort(idx[:split]), np.sort(idx[split:])
    return X[ti], X[vi], y[ti], y[vi]

# Model A: simple logistic, no x1 dependency
def modelA(th, X):
    c0,c1,c2,c3 = th
    t = X[:,0]
    return c0/(1+np.exp(-c1*(t-c2)))+c3

# Model B: logistic, rate = c1*x1, half_time = c2 (x1 linear in rate)
def modelB(th, X):
    c0,c1,c2,c3 = th
    t,p = X[:,0],X[:,1]
    return c0/(1+np.exp(-c1*p*(t-c2)))+c3

# Model C: logistic, rate=c1, half_time=c2+c3/x1 (half-time inversely depends on x1)
def modelC(th, X):
    c0,c1,c2,c3,c4 = th
    t,p = X[:,0],X[:,1]
    return c0/(1+np.exp(-c1*(t-(c2+c3/p))))+c4

# Model D: logistic, rate=c1*x1, half_time=c2/x1 (both scale with x1)
def modelD(th, X):
    c0,c1,c2,c3 = th
    t,p = X[:,0],X[:,1]
    return c0/(1+np.exp(-c1*p*(t-c2/p)))+c3

models = [
    ('A_simple4c', modelA, [1.0,0.5,5.0,0.0], 4),
    ('B_x1rate4c', modelB, [1.0,0.01,5.0,0.0], 4),
    ('C_invx1half5c', modelC, [1.0,0.5,5.0,1.0,0.0], 5),
    ('D_x1rate_invhalf4c', modelD, [1.0,0.01,50.0,0.0], 4),
]

results = {name: [] for name,_,_,_ in models}
for d in datasets:
    X, y = load_dataset(d)
    Xtr,Xval,ytr,yval = split(X,y)
    var = np.var(yval)
    for name, model, x0, nc in models:
        def res(th): return model(th, Xtr) - ytr
        r = least_squares(res, x0, loss='soft_l1', max_nfev=300)
        yp = model(r.x, Xval)
        nmse_v = np.mean((yval-yp)**2)/(var if var>1e-10 else 1)
        results[name].append(min(nmse_v, 10.0))

for name, vals in results.items():
    print(f'{name}: mean={np.mean(vals):.4f} median={np.median(vals):.4f} >1: {sum(v>1 for v in vals)}')
