import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = load_all_datasets()
results_A = []; results_F = []

for name, X_tr, X_v, y_tr, y_v in datasets:
    x0_tr, x1_tr = X_tr[:,0], X_tr[:,1]
    x0_v, x1_v = X_v[:,0], X_v[:,1]
    var_v = np.var(y_v)
    x0_mid = np.median(x0_tr)

    # Model A: current
    def res_A(theta):
        c0,c1,c2,c3,c4 = theta
        pred = c0/(1+np.exp(np.clip(c1-c2*x0_tr-c3*x1_tr,-500,500)))+c4
        if not np.all(np.isfinite(pred)): return np.full_like(y_tr,1e6)
        return pred - y_tr
    ra = least_squares(res_A,[1,14,9e-4,0.001,0],loss='soft_l1',max_nfev=300)
    c0,c1,c2,c3,c4=ra.x
    pa=c0/(1+np.exp(np.clip(c1-c2*x0_v-c3*x1_v,-500,500)))+c4
    results_A.append(np.mean((pa-y_v)**2)/(var_v+1e-10))

    # Model F: y = c0/(1+exp(c1 - c2*x0/x0_mid - c3*x1)) + c4
    # Normalize x0 by median to make c2 scale-invariant across datasets
    # This should help the optimizer find good solutions for all scales
    def res_F(theta):
        c0,c1,c2,c3,c4 = theta
        z = np.clip(c1 - c2*(x0_tr/x0_mid) - c3*x1_tr,-500,500)
        pred = c0/(1+np.exp(z))+c4
        if not np.all(np.isfinite(pred)): return np.full_like(y_tr,1e6)
        return pred - y_tr
    # BUT we can't use x0_mid in the expression (it's data-dependent!)
    # So this doesn't work as a fixed template. Skip.
    results_F.append(results_A[-1])

# Instead test: does the harness actually use Gaussian-smoothed NMSE?
# The evaluator uses _nmse_with_gaussian_smoothed_target which averages
# raw NMSE and smoothed NMSE. Let's check what this does to htt Q37
from disease_relevant_noninhibited_all.evaluator import _nmse_with_gaussian_smoothed_target, _gaussian_smooth_1d

name = 'htt/Kar2011/Fits/Kar2011_Q37_prim'
X_tr, X_v, y_tr, y_v = [(X_tr, X_v, y_tr, y_v) for n,X_tr,X_v,y_tr,y_v in datasets if n==name][0]
x0_tr, x1_tr = X_tr[:,0], X_tr[:,1]
x0_v, x1_v = X_v[:,0], X_v[:,1]

def res_A(theta):
    c0,c1,c2,c3,c4 = theta
    pred = c0/(1+np.exp(np.clip(c1-c2*x0_tr-c3*x1_tr,-500,500)))+c4
    return pred - y_tr
ra = least_squares(res_A,[1,14,9e-4,0.001,0],loss='soft_l1',max_nfev=300)
c0,c1,c2,c3,c4=ra.x
pa=c0/(1+np.exp(np.clip(c1-c2*x0_v-c3*x1_v,-500,500)))+c4
raw_nmse = np.mean((pa-y_v)**2)/(np.var(y_v)+1e-10)
gauss_nmse = _nmse_with_gaussian_smoothed_target(y_v, pa)
print(f'htt Q37 prim: raw_nmse={raw_nmse:.4f}, gaussian_nmse={gauss_nmse:.4f}')
print(f'  fitted c: {np.round(ra.x,6)}')

# What is the actual NMSE the harness sees?
# It uses (raw_loss + smooth_loss) / 2
# Let's check if the htt data is just inherently noisy
print(f'  y_val variance: {np.var(y_v):.4f}')
print(f'  y_val: min={y_v.min():.3f} max={y_v.max():.3f} mean={y_v.mean():.3f}')
