import pandas as pd
import numpy as np
import glob, re
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

def parse_param(text):
    text = text.strip()
    m = re.search(r'(\d+(?:\.\d+)?)\s*uM', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*mM', text, re.IGNORECASE)
    if m: return float(m.group(1)) * 1000.0
    m = re.search(r'(\d+(?:\.\d+)?)\s*mg/mL', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*ng/ul', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'pH\s+(\d+(?:\.\d+)?)', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*%', text)
    if m: return float(m.group(1))
    m = re.search(r':\s*(\d+(?:\.\d+)?)\s*$', text)
    if m: return float(m.group(1))
    return None

def load_split(path):
    df = pd.read_csv(path, sep='\t')
    x0_col = df['X'].values
    resp_headers = [c for c in df.columns if c != 'X']
    parsed = [parse_param(h) for h in resp_headers]
    parameters = [float(p) for p in parsed] if all(p is not None for p in parsed) else [float(i+1) for i in range(len(resp_headers))]
    rows_x0, rows_x1, rows_y = [], [], []
    for param, col in zip(parameters, resp_headers):
        y_vals = df[col].values
        valid = np.isfinite(y_vals)
        rows_x0.extend(x0_col[valid]); rows_x1.extend([param]*valid.sum()); rows_y.extend(y_vals[valid])
    X = np.column_stack([rows_x0, rows_x1]); y = np.array(rows_y)
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y)); split = int(round(len(y)*0.75))
    tr = np.sort(idx[:split]); va = np.sort(idx[split:])
    return X[tr], X[va], y[tr], y[va]

datasets = sorted(glob.glob(base + '**/fit.tsv', recursive=True))
all_data = [(load_split(d), d.split('/')[-2]) for d in datasets]

# Simple log-time logistic (complexity=22, 5 constants)
def model_D(X, c0, c1, c2, c3, c4):
    z = c1 - c2*np.log1p(np.abs(X[:,0])) - c3*X[:,1]
    return c0 / (1 + np.exp(np.clip(z, -500, 500))) + c4

# Log-time Richards (complexity=25, 6 constants)
def model_C(X, c0, c1, c2, c3, c4, c5):
    z = c1 - c2*np.log1p(np.abs(X[:,0])) - c3*X[:,1]
    return c0 * np.exp(-c4 * np.log1p(np.exp(np.clip(z, -500, 500)))) + c5

def eval_model(model, p0, label):
    nmses_val = []
    bad = []
    for (Xtr, Xva, ytr, yva), name in all_data:
        try:
            def resid(p): return model(Xtr, *p) - ytr
            r = least_squares(resid, p0, loss='soft_l1', max_nfev=300)
            yp = model(Xva, *r.x)
            n = np.mean((yp-yva)**2)/(np.var(yva)+1e-10)
            nmses_val.append(min(n, 10.0))
            if n > 0.15: bad.append(f'{name}:{n:.3f}')
        except:
            nmses_val.append(10.0); bad.append(f'{name}:ERR')
    mean_n = np.mean(nmses_val)
    # Compute combined score: fit_score * parsimony
    import sympy as sp
    x0s, x1s = sp.symbols('x0 x1')
    c = sp.symbols('c0:6')
    if '5 const' in label:
        expr = c[0]/(1+sp.exp(c[1]-c[2]*sp.log(1+x0s)-c[3]*x1s))+c[4]
    else:
        expr = c[0]*sp.exp(-c[4]*sp.log(1+sp.exp(c[1]-c[2]*sp.log(1+x0s)-c[3]*x1s)))+c[5]
    cplx = sum(1 for _ in sp.preorder_traversal(expr))
    parsimony = max(0, 1 - 0.20 * min(cplx/160, 1))
    fit_score = 1/(1+mean_n)
    combined = fit_score * parsimony
    print(f'{label}: nmse={mean_n:.4f} cplx={cplx} parsimony={parsimony:.4f} combined={combined:.4f}')
    print(f'  bad: {bad}')

eval_model(model_D, [1.0, 10.0, 1.5, 0.001, 0.0], 'Simple log-logistic (5 const)')
eval_model(model_C, [1.0, 10.0, 1.5, 0.001, 0.3, 0.0], 'Log-Richards (6 const)')
