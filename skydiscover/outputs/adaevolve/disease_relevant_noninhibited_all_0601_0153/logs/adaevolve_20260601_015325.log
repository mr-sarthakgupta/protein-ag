from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()

# The harness uses fixed initial values - test what happens with fixed inits
# for 4-param sigmoid: c0/(1+exp(-c1*(x0-c2)))+c3
# Initial: c0=1, c1=1, c2=1, c3=0 (harness default)
def fit_sigmoid4_fixed(X_train, y_train, X_val, y_val, inits):
    x0_t = X_train[:,0]
    x0_v = X_val[:,0]
    def residual(theta):
        c0,c1,c2,c3 = theta
        arg = np.clip(-c1*(x0_t-c2), -500, 500)
        pred = c0/(1+np.exp(arg))+c3
        return pred - y_train
    r = least_squares(residual, inits, loss='soft_l1', max_nfev=300)
    c0,c1,c2,c3 = r.x
    arg_v = np.clip(-c1*(x0_v-c2), -500, 500)
    pred_v = c0/(1+np.exp(arg_v))+c3
    var_y = np.var(y_val)
    return np.mean((pred_v - y_val)**2) / var_y if var_y>0 else 0

# Test different initial value sets
init_sets = [
