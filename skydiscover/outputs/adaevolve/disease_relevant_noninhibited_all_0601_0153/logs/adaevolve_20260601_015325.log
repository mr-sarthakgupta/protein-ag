var2 = np.var(y_val2)
nmse2 = np.mean((pred_val2 - y_val2)**2)/var2
print(f'insulin NMSE val: {nmse2:.4f}')
idx2 = np.argsort(X_train2[:,0])
x0s2 = X_train2[idx2,0]
ys2 = y_train2[idx2]
preds2 = model(res2.x, X_train2)[idx2]
for i in range(0, len(x0s2), 30):
    print(f'  x0={x0s2[i]:.0f} y={ys2[i]:.4f} pred={preds2[i]:.4f}')
