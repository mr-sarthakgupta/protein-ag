import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = load_all_datasets()
results_A = []; results_B = []

for name, X_tr, X_v, y_tr, y_v in datasets:
    x0_tr, x1_tr = X_tr[:,0], X_tr[:,1]
    x0_v, x1_v = X_v[:,0], X_v[:,1]
    var_v = np.var(y_v)
    x0_tr_s = np.maximum(x0_tr, 1e-6)
    x0_v_s = np.maximum(x0_v, 1e-6)

    # Model A: current
    def res_A(theta):
        c0,c1,c2,c3,c4 = theta
        pred = c0/(1+np.exp(np.clip(c1-c2*x0_tr-c3*x1_tr,-500,500)))+c4
        if not np.all(np.isfinite(pred)): return np.full_like(y_tr,1e6)
        return pred - y_tr
    ra = least_squares(res_A,[1,14,9e-4,0.001,0],loss='soft_l1',max_nfev=300)
    c0,c1,c2,c3,c4=ra.x
    pa=c0/(1+np.exp(np.clip(c1-c2*x0_v-c3*x1_v,-500,500)))+c4
    results_A.append(np.mean((pa-y_v)**2)/(var_v+1e-10))

    # Model B: y = c0/(1+exp(c1 - c2*x0 - c3*log(x0+1) - c4*x1)) + c5
    # combines linear and log time terms
    def res_B(theta):
        c0,c1,c2,c3,c4,c5 = theta
        z = np.clip(c1 - c2*x0_tr - c3*np.log(x0_tr_s) - c4*x1_tr,-500,500)
        pred = c0/(1+np.exp(z))+c5
        if not np.all(np.isfinite(pred)): return np.full_like(y_tr,1e6)
        return pred - y_tr
    try:
        rb = least_squares(res_B,[1,14,9e-4,1.0,0.001,0],loss='soft_l1',max_nfev=400)
        c0,c1,c2,c3,c4,c5=rb.x
        z_v=np.clip(c1-c2*x0_v-c3*np.log(x0_v_s)-c4*x1_v,-500,500)
        pb=c0/(1+np.exp(z_v))+c5
        nmse_B=np.mean((pb-y_v)**2)/(var_v+1e-10)
    except: nmse_B=results_A[-1]
    results_B.append(nmse_B)

print(f'Model A mean NMSE: {np.mean(results_A):.5f}')
print(f'Model B (lin+log) mean NMSE: {np.mean(results_B):.5f}')
print()
print('Significant differences (>0.005):')
for i,(name,*_) in enumerate(datasets):
    d=results_A[i]-results_B[i]
    if abs(d)>0.005:
        print(f'  {\"BETTER\" if d>0 else \"WORSE\":6s} {name[-38:]:38s}: A={results_A[i]:.4f} B={results_B[i]:.4f}')
