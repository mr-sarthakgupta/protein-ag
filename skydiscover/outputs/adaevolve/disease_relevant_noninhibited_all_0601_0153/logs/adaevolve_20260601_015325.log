import pandas as pd, numpy as np, os
from scipy.optimize import curve_fit

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

# Richards model: y = c0*exp(-c4*log(1+exp(c1-c2*x0-c3*x1))) + c5
# Equivalent to c0/(1+exp(z))^c4 + c5
def richards(X, c0, c1, c2, c3, c4, c5):
    z = c1 - c2*X[:,0] - c3*X[:,1]
    z = np.clip(z, -500, 500)
    lsp = np.where(z > 20, z, np.log1p(np.exp(z)))
    return c0 * np.exp(-c4 * lsp) + c5

nmses = []
hard = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            fp = os.path.join(root, f)
            df = pd.read_csv(fp, sep='\t')
            X = df.iloc[:,:2].values.astype(float)
            y = df.iloc[:,-1].values.astype(float)
            var_y = np.var(y)
            name = root.replace(base,'')
            try:
                p0 = [1.0, 14.0, 9e-4, 0.001, 0.3, 0.0]
                pr, _ = curve_fit(richards, X, y, p0=p0, maxfev=10000)
                yr = richards(X, *pr)
                nmse = np.mean((y-yr)**2)/var_y if var_y > 0 else 0
                nmses.append(nmse)
                if nmse > 0.05:
                    hard.append((nmse, name[:60]))
            except Exception as e:
                hard.append((99, name[:60] + ' ERR'))
                nmses.append(99)

good = [n for n in nmses if n < 99]
print(f'Mean NMSE (finite): {np.mean(good):.4f}, n={len(good)}/{len(nmses)}')
print('Hard (NMSE>0.05):')
for nmse, name in sorted(hard, reverse=True)[:8]:
    print(f'  {nmse:.4f} {name}')
"
