import numpy as np
import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, _nmse_with_gaussian_smoothed_target
from scipy.optimize import least_squares

datasets = load_all_datasets()
ds_dict = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

def fit_eval(model_fn, X_train, y_train, X_val, y_val, init):
    def residual(theta):
        pred = model_fn(theta, X_train)
        if not np.all(np.isfinite(pred)): return np.full(len(y_train), 1e12)
        return pred - y_train
    res = least_squares(residual, init, loss='soft_l1', max_nfev=300)
    pred_val = model_fn(res.x, X_val)
    return _nmse_with_gaussian_smoothed_target(y_val, pred_val), res.x

# Model B: best known
def model_B(theta, X):
    c0,c1,c2,c3,c4 = theta
    return c0/(1+np.exp(np.clip(c1 - c2*X[:,0] - c3*X[:,1], -500, 500))) + c4

# For lysozyme: x0~4620-353069, x1=7 constant
# The issue: c2*x0 with c2=9e-4 gives ~300 -> overflow
# What if we use a smaller init for c2? 
# c2=9e-4 works for datasets with x0~0-1000 (like hours-scale data)
# But lysozyme is in seconds with x0~1e5

# Try model B with init c2=1e-5 instead
ds = 'lysozyme/Fits/Hasecke2018_7uM_sec'
X_train, X_val, y_train, y_val = ds_dict[ds]
for c2_init in [9e-4, 1e-4, 1e-5, 1e-6]:
    n, theta = fit_eval(model_B, X_train, y_train, X_val, y_val, [1.0, 14.0, c2_init, 0.001, 0.0])
    print(f'lysozyme c2_init={c2_init}: nmse={n:.4f}, c2_fitted={theta[2]:.2e}')

# What about serum amyloid (x0 can be negative)?
ds2 = 'serum amyloid/Ye2011/Fits/Ye2011_sec'
X_train2, X_val2, y_train2, y_val2 = ds_dict[ds2]
print(f'serum amyloid x0: [{X_train2[:,0].min():.1f}, {X_train2[:,0].max():.1f}]')
print(f'serum amyloid x1: [{X_train2[:,1].min():.1f}, {X_train2[:,1].max():.1f}]')
n2, theta2 = fit_eval(model_B, X_train2, y_train2, X_val2, y_val2, [1.0, 14.0, 9e-4, 0.001, 0.0])
print(f'serum amyloid nmse={n2:.4f}, theta={theta2.round(6)}')

# insulin seeded
ds3 = 'insulin/Fits/Nielsen2001_seeded_sec'
X_train3, X_val3, y_train3, y_val3 = ds_dict[ds3]
print(f'insulin x0: [{X_train3[:,0].min():.1f}, {X_train3[:,0].max():.1f}]')
n3, theta3 = fit_eval(model_B, X_train3, y_train3, X_val3, y_val3, [1.0, 14.0, 9e-4, 0.001, 0.0])
print(f'insulin nmse={n3:.4f}, theta={theta3.round(6)}')
# Check what the data looks like
idx = np.argsort(X_train3[:,0])
x0s = X_train3[idx,0]; ys = y_train3[idx]
for i in range(0, len(x0s), 45):
    print(f'  x0={x0s[i]:.0f} y={ys[i]:.4f}')
