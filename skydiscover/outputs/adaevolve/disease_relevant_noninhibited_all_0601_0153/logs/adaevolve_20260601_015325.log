[:,1]\n    def res(theta):\n        c0,c1,c2,c3,c4 = theta\n        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):\n            pred = c3 * np.exp(-np.exp(c0 - c1 * x0 * x1**c2)) + c4\n        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)\n        return pred - y\n    return res\n\n# Model B: original Gompertz with better p0\ndef make_res_gomB(X, y):\n    x0, x1 = X[:,0], X[:,1]\n    def res(theta):\n        c0,c1,c2,c3,c4,c5 = theta\n        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):\n            rate = c0 * x1**c1\n            ht = c2 * x1**c3\n            pred = c4 * np.exp(-np.exp(-rate*(x0-ht))) + c5\n        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)\n        return pred - y\n    return res\n\np0A = [1.0, 0.01, 0.0, 1.0, 0.0]   # ModelA: c0,c1,c2,c3,c4\np0B = [0.1, 0.5, 10.0, -0.5, 1.0, 0.0]  # original\n\nnmse_A, nmse_B = [], []\nfor f in files:\n    X, y = load_fit(f)\n    rng = np.random.default_rng(42)\n    idx = rng.permutation(len(y))\n    split = int(round(len(y)*0.75))\n    Xtr, Xv = X[np.sort(idx[:split])], X[np.sort(idx[split:])]\n    ytr, yv = y[np.sort(idx[:split])], y[np.sort(idx[split:])]\n    \n    # Model A\n    try:\n        r = least_squares(make_res_gomA(Xtr, ytr), p0A, loss='soft_l1', max_nfev=300)\n        c = r.x\n        x0v, x1v = Xv[:,0], Xv[:,1]\n        pred = c[2]*np.exp(-np.exp(c[0] - c[1]*x0v*x1v**c[2])) + c[3]  # bug: reuse c[2]\n        # fix:\n        pred = c[2]*np.exp(-np.exp(c[0] - c[1]*x0v*x1v**c[2])) + c[3]\n        nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf\n        nmse_A.append(nm)\n    except: nmse_A.append(np.inf)\n    \n    # Model B (Gompertz original)\n    try:\n        r = least_squares(make_res_gomB(Xtr, ytr), p0B, loss='soft_l1', max_nfev=300)\n        c = r.x\n        x0v, x1v = Xv[:,0], Xv[:,1]\n        pred = c[4]*np.exp(-np.exp(-c[0]*x1v**c[1]*(x0v-c[2]*x1v**c[3])))+c[5]\n        nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf\n        nmse_B.append(nm)\n    except: nmse_B.append(np.inf)\n\nprint(f'ModelA(c0-c1*x0*x1^c2) mean={np.mean(nmse_A):.4f} >1:{sum(1 for v in nmse_A if v>1)}/{len(nmse_A)}')\nprint(f'ModelB(Gompertz orig)   mean={np.mean(nmse_B):.4f} >1:{sum(1 for v in nmse_B if v>1)}/{len(nmse_B)}')\n\" 2>/dev/null\n"
