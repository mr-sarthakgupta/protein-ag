 202 |         "command": "python3 -c \"\nimport numpy as np\nfrom scipy.optimize import least_squares\nimport csv, re\n\nbase = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'\n\ndef load_fit(path):\n    with open(path) as f:\n        reader = csv.reader(f, delimiter='\\t')\n        header = next(reader)\n        response_headers = header[1:]\n        parsed = []\n        for h in response_headers:\n            m = re.search(r'(\\d+(?:\\.\\d+)?)\\s*uM', h, re.I)\n            if m: parsed.append(float(m.group(1)))\n            else: parsed = None; break\n        if parsed is None:\n            params = [float(i+1) for i in range(len(response_headers))]\n        else:\n            params = parsed\n        feats, tgts = [], []\n        for row in reader:\n            if not row: continue\n            x0v = float(row[0])\n            for p, v in zip(params, row[1:]):\n                if v.strip() and v.strip().lower() != 'nan':\n                    feats.append([x0v, p])\n                    tgts.append(float(v))\n    return np.array(feats), np.array(tgts)\n\n# Check Kar2011 data\npath = base + 'htt/Kar2011/Fits/Kar2011_Q30_without_lowest_conc_rpim/fit.tsv'\nX, y = load_fit(path)\nx0, x1 = X[:,0], X[:,1]\nprint('x0 range:', x0.min(), x0.max())\nprint('x1 range:', x1.min(), x1.max())\nprint('x0*x1 range:', (x0*x1).min(), (x0*x1).max())\nprint('y range:', y.min(), y.max())\n\n# For the Gompertz: exp(c0 - c1*x0*x1^c2)\n# With c0=1, c1=0.001, c2=0: c0 - c1*x0 = 1 - 0.001*1718518 = -1716 -> exp(-1716) ~ 0 (good)\n# But during optimization, c1 might become negative -> exp(+1716) -> overflow\n# Solution: use x0*x1^c2 but clip or use log1p\n\n# Try: y = c3*exp(-exp(c0 - c1*log(1 + x0*x1^c2))) + c4\n# This maps x0 to log scale, making it robust to large x0\ndef make_res_gomLog(X, y):\n    x0, x1 = X[:,0], X[:,1]\n    def res(theta):\n        c0,c1,c2,c3,c4 = theta\n        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):\n            z = np.log1p(x0 * np.abs(x1)**c2)\n            pred = c3 * np.exp(-np.exp(c0 - c1 * z)) + c4\n        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)\n        return pred - y\n    return res\n\ndef eval_gomLog(c, Xv):\n    x0v, x1v = Xv[:,0], Xv[:,1]\n    z = np.log1p(x0v * np.abs(x1v)**c[2])\n    return c[3]*np.exp(-np.exp(c[0] - c[1]*z)) + c[4]\n\n# Also try: y = c3*exp(-exp(c0 - c1*x0^c2*x1^c3)) + c4  -- power of x0 too\ndef make_res_gomPow(X, y):\n    x0, x1 = X[:,0], X[:,1]\n    def res(theta):\n        c0,c1,c2,c3,c4,c5 = theta\n        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):\n            pred = c4 * np.exp(-np.exp(c0 - c1 * x0**c2 * x1**c3)) + c5\n        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)\n        return pred - y\n    return res\n\ndef eval_gomPow(c, Xv):\n    x0v, x1v = Xv[:,0], Xv[:,1]\n    return c[4]*np.exp(-np.exp(c[0] - c[1]*x0v**c[2]*x1v**c[3])) + c[5]\n\nimport glob\nfiles = glob.glob(base + '**/fit.tsv', recursive=True)\nfiles.sort()\n\np0L = [1.0, 1.0, 0.0, 1.0, 0.0]\np0P = [1.0, 0.001, 1.0, 0.0, 1.0, 0.0]\np0A = [1.0, 0.001, 0.0, 1.0, 0.0]\n\ndef make_res_gomA(X, y):\n    x0, x1 = X[:,0], X[:,1]\n    def res(theta):\n        c0,c1,c2,c3,c4 = theta\n        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):\n            pred = c3 * np.exp(-np.exp(c0 - c1 * x0 * x1**c2)) + c4\n        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)\n        return pred - y\n    return res\ndef eval_gomA(c, Xv):\n    x0v, x1v = Xv[:,0], Xv[:,1]\n    return c[3]*np.exp(-np.exp(c[0] - c[1]*x0v*x1v**c[2])) + c[4]\n\nresults = {'A':[], 'Log':[], 'Pow':[]}\nfor f in files:\n    X, y = load_fit(f)\n    rng = np.random.default_rng(42)\n    idx = rng.permutation(len(y))\n    split = int(round(len(y)*0.75))\n    Xtr, Xv = X[np.sort(idx[:split])], X[np.sort(idx[split:])]\n    ytr, yv = y[np.sort(idx[:split])], y[np.sort(idx[split:])]\n    for key, rfn, p0, efn in [\n        ('A', make_res_gomA, p0A, eval_gomA),\n        ('Log', make_res_gomLog, p0L, eval_gomLog),\n        ('Pow', make_res_gomPow, p0P, eval_gomPow),\n    ]:\n        try:\n            r = least_squares(rfn(Xtr,ytr), p0, loss='soft_l1', max_nfev=300)\n            pred = efn(r.x, Xv)\n            nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf\n            results[key].append(nm)\n        except: results[key].append(np.inf)\n\nfor k,v in results.items():\n    print(f'Model{k:4s} mean={np.mean(v):.4f} median={np.median(v):.4f} >1:{sum(1 for x in v if x>1)}/{len(v)}')\n\" 2>/dev/null\n"
