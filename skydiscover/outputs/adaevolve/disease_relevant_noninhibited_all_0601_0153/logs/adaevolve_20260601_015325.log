    x0, x1 = X[:,0], X[:,1]\n    def res(theta):\n        c0,c1,c2,c3,c4 = theta\n        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):\n            pred = c3 * np.exp(-np.exp(c0 - c1 * (x0+1) * x1**c2)) + c4\n        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)\n        return pred - y\n    return res\n\ndef eval_gomD(c, Xv):\n    x0v, x1v = Xv[:,0], Xv[:,1]\n    return c[3]*np.exp(-np.exp(c[0] - c[1]*(x0v+1)*x1v**c[2])) + c[4]\n\n# Model B: original Gompertz 6-param\ndef make_res_gomB(X, y):\n    x0, x1 = X[:,0], X[:,1]\n    def res(theta):\n        c0,c1,c2,c3,c4,c5 = theta\n        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):\n            rate = c0 * x1**c1\n            ht = c2 * x1**c3\n            pred = c4 * np.exp(-np.exp(-rate*(x0-ht))) + c5\n        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)\n        return pred - y\n    return res\n\ndef eval_gomB(c, Xv):\n    x0v, x1v = Xv[:,0], Xv[:,1]\n    return c[4]*np.exp(-np.exp(-c[0]*x1v**c[1]*(x0v-c[2]*x1v**c[3])))+c[5]\n\np0A = [1.0, 0.001, 0.0, 1.0, 0.0]\np0D = [1.0, 0.001, 0.0, 1.0, 0.0]\np0B = [0.1, 0.5, 10.0, -0.5, 1.0, 0.0]\n\nresults = {'A': [], 'D': [], 'B': []}\nfor f in files:\n    X, y = load_fit(f)\n    rng = np.random.default_rng(42)\n    idx = rng.permutation(len(y))\n    split = int(round(len(y)*0.75))\n    Xtr, Xv = X[np.sort(idx[:split])], X[np.sort(idx[split:])]\n    ytr, yv = y[np.sort(idx[:split])], y[np.sort(idx[split:])]\n    \n    for key, res_fn, p0, eval_fn in [\n        ('A', make_res_gomA, p0A, eval_gomA),\n        ('D', make_res_gomD, p0D, eval_gomD),\n        ('B', make_res_gomB, p0B, eval_gomB),\n    ]:\n        try:\n            r = least_squares(res_fn(Xtr, ytr), p0, loss='soft_l1', max_nfev=300)\n            pred = eval_fn(r.x, Xv)\n            nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf\n            results[key].append(nm)\n        except: results[key].append(np.inf)\n\nfor k, v in results.items():\n    print(f'Model{k} mean={np.mean(v):.4f} median={np.median(v):.4f} >1:{sum(1 for x in v if x>1)}/{len(v)}')\n\" 2>/dev/null\n"
