import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, _nmse_with_gaussian_smoothed_target
import numpy as np
from scipy.optimize import least_squares

datasets = load_all_datasets()
results_A = []; results_I = []

for name, X_tr, X_v, y_tr, y_v in datasets:
    x0_tr, x1_tr = X_tr[:,0], X_tr[:,1]
    x0_v, x1_v = X_v[:,0], X_v[:,1]

    # Model A
    def res_A(theta):
        c0,c1,c2,c3,c4 = theta
        pred = c0/(1+np.exp(np.clip(c1-c2*x0_tr-c3*x1_tr,-500,500)))+c4
        if not np.all(np.isfinite(pred)): return np.full_like(y_tr,1e6)
        return pred - y_tr
    ra = least_squares(res_A,[1,14,9e-4,0.001,0],loss='soft_l1',max_nfev=300)
    c0,c1,c2,c3,c4=ra.x
    pa=c0/(1+np.exp(np.clip(c1-c2*x0_v-c3*x1_v,-500,500)))+c4
    results_A.append(_nmse_with_gaussian_smoothed_target(y_v, pa))

    # Model I: y = c0 * exp(-exp(c4) * log(1+exp(c1-c2*x0-c3*x1))) + c5
    # exp(c4) is always positive, c4 free to vary -> naturally bounded shape
    # init c4=0 -> exp(0)=1 -> degrades to standard logistic
    def res_I(theta):
        c0,c1,c2,c3,c4,c5 = theta
        z = np.clip(c1-c2*x0_tr-c3*x1_tr,-500,500)
        log_base = np.log1p(np.exp(z))
        shape = np.exp(np.clip(c4, -10, 4))  # exp(c4) in (4.5e-5, 54.6)
        pred = c0 * np.exp(np.clip(-shape * log_base, -500, 500)) + c5
        if not np.all(np.isfinite(pred)): return np.full_like(y_tr,1e6)
        return pred - y_tr
    try:
        ri = least_squares(res_I,[1,14,9e-4,0.001,0.0,0],loss='soft_l1',max_nfev=300)
        c0,c1,c2,c3,c4,c5=ri.x
        z_v=np.clip(c1-c2*x0_v-c3*x1_v,-500,500)
        log_base_v=np.log1p(np.exp(z_v))
        shape=np.exp(np.clip(c4,-10,4))
        ph=c0*np.exp(np.clip(-shape*log_base_v,-500,500))+c5
        nmse_I=_nmse_with_gaussian_smoothed_target(y_v, ph)
    except: nmse_I=results_A[-1]
    results_I.append(nmse_I)

print(f'Model A mean NMSE: {np.mean(results_A):.5f}')
print(f'Model I (exp(c4) shape) mean NMSE: {np.mean(results_I):.5f}')
print()
for i,(name,*_) in enumerate(datasets):
    d=results_A[i]-results_I[i]
    if abs(d)>0.005:
        print(f'  {\"BETTER\" if d>0 else \"WORSE\":6s} {name[-42:]:42s}: A={results_A[i]:.4f} I={results_I[i]:.4f}')
mean_nmse=np.mean(results_I)
print(f'Expected combined: {1/(1+mean_nmse)*(1-0.2*25/160):.4f}')
