import pandas as pd, numpy as np, os
from scipy.optimize import curve_fit

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

# Test Richards model (Program 3): y = c0*exp(-c4*log(1+exp(c1-c2*x0-c3*x1))) + c5
def richards(X, c0, c1, c2, c3, c4, c5):
    z = c1 - c2*X[:,0] - c3*X[:,1]
    # clip for stability
    z = np.clip(z, -500, 500)
    return c0 * np.exp(-c4 * np.log1p(np.exp(z))) + c5

# Test standard logistic: y = c0/(1+exp(c1-c2*x0-c3*x1)) + c4
def logistic(X, c0, c1, c2, c3, c4):
    z = c1 - c2*X[:,0] - c3*X[:,1]
    z = np.clip(z, -500, 500)
    return c0 / (1 + np.exp(z)) + c4

hard_paths = [
    'lysozyme/Fits/Hasecke2018_7uM_sec',
    'hnRNPA/Kim2013/Fits/Kim2013_A1_sec',
    'biofilm proteins/CsgA/CsgA_sec_IN_HOURS',
    'prp/Stoehr2008/Stoehr2008_Fig4-seeded_sec_nuc',
    'htt/Kakkar2016/FIts/Kakkar2016_6kDa_polyQ_prim',
]

for rel in hard_paths:
    fp = os.path.join(base, rel, 'fit.tsv')
    if not os.path.exists(fp): continue
    df = pd.read_csv(fp, sep='\t')
    X = df.iloc[:,:2].values.astype(float)
    y = df.iloc[:,-1].values.astype(float)
    var_y = np.var(y)
    
    # Try Richards
    try:
        p0r = [1.0, 14.0, 9e-4, 0.001, 0.3, 0.0]
        pr, _ = curve_fit(richards, X, y, p0=p0r, maxfev=10000)
        yr = richards(X, *pr)
        nmse_r = np.mean((y-yr)**2)/var_y
    except Exception as e:
        nmse_r = 99; pr = [99]*6
    
    # Try logistic
    try:
        p0l = [1.0, 14.0, 9e-4, 0.001, 0.0]
        pl, _ = curve_fit(logistic, X, y, p0=p0l, maxfev=10000)
        yl = logistic(X, *pl)
        nmse_l = np.mean((y-yl)**2)/var_y
    except:
        nmse_l = 99
    
    print(f'{rel[-35:]}: logistic={nmse_l:.4f}, richards={nmse_r:.4f} (c4={pr[4]:.2f})')
"
