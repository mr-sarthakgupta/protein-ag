import numpy as np
import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()
ds_dict = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

def fit_nmse(model_fn, X_train, y_train, X_val, y_val, init):
    def residual(theta):
        pred = model_fn(theta, X_train)
        if not np.all(np.isfinite(pred)): return np.full(len(y_train), 1e12)
        return pred - y_train
    res = least_squares(residual, init, loss='soft_l1', max_nfev=300)
    pred_val = model_fn(res.x, X_val)
    var = np.var(y_val)
    if var <= 0: return np.mean((pred_val-y_val)**2), res.x
    return np.mean((pred_val - y_val)**2)/var, res.x

# Model: c0/(1+exp(c1 - x0/c2 - c3*x1)) + c4
# c2 is half-time scale, init=1e4 (middle of typical x0 range)
def model_div(theta, X):
    c0,c1,c2,c3,c4 = theta
    return c0/(1+np.exp(np.clip(c1 - X[:,0]/c2 - c3*X[:,1], -500, 500))) + c4

# Test on worst datasets
for ds_name in ['lysozyme/Fits/Hasecke2018_7uM_sec', 'insulin/Fits/Nielsen2001_seeded_sec',
                'htt/Kar2011/Fits/Kar2011_Q37_sec', 'Abeta/Meisl2014/Ab40_sec_IN_HOURS']:
    X_train, X_val, y_train, y_val = ds_dict[ds_name]
    nmse, theta = fit_nmse(model_div, X_train, y_train, X_val, y_val, [1.0, 2.0, 1e4, 0.01, 0.0])
    print(f'{ds_name}: nmse={nmse:.4f}, c={theta.round(4)}')

# Test all datasets
all_nmses = []
for name, X_train, X_val, y_train, y_val in datasets:
    nmse, _ = fit_nmse(model_div, X_train, y_train, X_val, y_val, [1.0, 2.0, 1e4, 0.01, 0.0])
    all_nmses.append(nmse)
    if not np.isfinite(nmse):
        print(f'  NaN: {name}')
print(f'Mean NMSE (div model, init=[1,2,1e4,0.01,0]): {np.nanmean(all_nmses):.5f}')
print(f'Max NMSE: {np.nanmax(all_nmses):.4f}')

# Also try with different inits
for init in [[1.0, 0.0, 1e3, 0.0, 0.0], [1.0, 1.0, 5e3, 0.01, 0.0], [1.0, 2.0, 2e4, 0.01, 0.0]]:
    nmses = []
    for name, X_train, X_val, y_train, y_val in datasets:
        nmse, _ = fit_nmse(model_div, X_train, y_train, X_val, y_val, init)
        nmses.append(nmse)
    print(f'init={init} -> mean={np.nanmean(nmses):.5f}')
