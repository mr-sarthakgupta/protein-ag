        pred_c = c0/np.maximum(1+np.exp(z_v),1e-10)**c4_clip + c5
        nmse_C = np.mean((pred_c-y_v)**2)/(var_v+1e-10)
    except:
        nmse_C = nmse_A
    results_C.append(nmse_C)

print(f'Model A mean NMSE: {np.mean(results_A):.5f}')
print(f'Model C mean NMSE: {np.mean(results_C):.5f}')
print()
# Show datasets where C improves over A by >0.01
print('Datasets where C improves A by >0.01:')
for i, (name, _, _, _, _) in enumerate(datasets):
    diff = results_A[i] - results_C[i]
    if diff > 0.01:
        print(f'  {name[-40:]:40s}: A={results_A[i]:.4f} C={results_C[i]:.4f} imp={diff:.4f}')
