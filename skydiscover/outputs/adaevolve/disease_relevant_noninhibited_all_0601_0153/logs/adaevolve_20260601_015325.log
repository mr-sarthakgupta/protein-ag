import numpy as np, re, csv
from pathlib import Path
from scipy.optimize import curve_fit

base = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def load_tsv(path):
    with open(path, newline='') as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rh = header[1:]
        parsed = [re.search(r'[-+]?\d*\.?\d+(?:[eE][-+]?\d+)?', h) for h in rh]
        params = [float(m.group()) for m in parsed] if all(m for m in parsed) else [float(i+1) for i in range(len(rh))]
        rows = [r for r in reader if r]
    feats, tgts = [], []
    for row in rows:
        for p, v in zip(params, row[1:]):
            if v.strip().lower() not in ('', 'nan'):
                feats.append([float(row[0]), p])
                tgts.append(float(v))
    arr = np.array(feats)
    return arr[:,0], arr[:,1], np.array(tgts)

# Current best model: y = c0/(1+exp(c1 - c2*x0 - c3*x1)) + c4
def model(X, c0, c1, c2, c3, c4):
    x0, x1 = X[:,0], X[:,1]
    return c0 / (1 + np.exp(c1 - c2*x0 - c3*x1)) + c4

# Test on multi-curve datasets
paths = [
    base/'Abeta/Cohen2013/Ab42_sec_IN_HOURS/fit.tsv',
    base/'Abeta/Meisl2014/Ab40_sec_IN_HOURS/fit.tsv',
    base/'biofilm proteins/CsgA/CsgA_prim_IN_HOURS/fit.tsv',
    base/'prp/Stoehr2008/Stoehr2008_Fig4-seeded_sec_nuc/fit.tsv',
]

for path in paths:
    x0,x1,y = load_tsv(path)
    X = np.column_stack([x0,x1])
    try:
        p0 = [1.0, 14.0, 9e-4, 0.001, 0.0]
        p, _ = curve_fit(model, X, y, p0=p0, maxfev=10000)
        yp = model(X, *p)
        nmse = np.mean((y-yp)**2)/np.var(y)
        print(f'{path.parent.name}: nmse={nmse:.4f}, c={[f\"{v:.3g}\" for v in p]}')
        # show per-unique-x1 nmse
        for ux1 in np.unique(x1)[:3]:
            mask = x1==ux1
            nm = np.mean((y[mask]-yp[mask])**2)/np.var(y[mask]) if np.var(y[mask])>0 else 0
            print(f'  x1={ux1:.2f}: nmse={nm:.4f}')
    except Exception as e:
        print(f'{path.parent.name}: FAILED {e}')
"
