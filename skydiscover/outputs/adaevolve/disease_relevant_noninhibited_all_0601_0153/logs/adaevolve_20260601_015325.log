import numpy as np
import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()
ds_dict = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

# Test: c0/(1+exp(c1 - c2*log(x0+1) - c3*x1)) + c4
# vs standard logistic
def model_log(theta, X):
    c0,c1,c2,c3,c4 = theta
    return c0/(1+np.exp(np.clip(c1 - c2*np.log(X[:,0]+1) - c3*X[:,1], -500, 500))) + c4

def fit_model(model_fn, X_train, y_train, X_val, y_val, init):
    def residual(theta):
        pred = model_fn(theta, X_train)
        if not np.all(np.isfinite(pred)): return np.full(len(y_train), 1e12)
        return pred - y_train
    res = least_squares(residual, init, loss='soft_l1', max_nfev=300)
    pred_val = model_fn(res.x, X_val)
    var = np.var(y_val)
    nmse = np.mean((pred_val - y_val)**2)/var if var > 0 else np.mean((pred_val-y_val)**2)
    return nmse, res.x

# Test on worst datasets
worst = ['lysozyme/Fits/Hasecke2018_7uM_sec', 'insulin/Fits/Nielsen2001_seeded_sec',
         'htt/Kar2011/Fits/Kar2011_Q37_sec', 'Abeta/Meisl2014/Ab40_sec_IN_HOURS']

for ds_name in worst:
    X_train, X_val, y_train, y_val = ds_dict[ds_name]
    # log(x0+1) model - init tuned for log scale
    nmse_log, theta = fit_model(model_log, X_train, y_train, X_val, y_val, [1.0, 10.0, 1.0, 0.1, 0.0])
    print(f'{ds_name}: log_nmse={nmse_log:.4f}, theta={theta.round(4)}')

# Also test all datasets with log model
all_nmses = []
for name, X_train, X_val, y_train, y_val in datasets:
    nmse_log, _ = fit_model(model_log, X_train, y_train, X_val, y_val, [1.0, 10.0, 1.0, 0.1, 0.0])
    all_nmses.append(nmse_log)
print(f'Mean NMSE (log model): {np.mean(all_nmses):.5f}')
"
