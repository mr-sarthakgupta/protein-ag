import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares

datasets = load_all_datasets()
ds_dict = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

# Examine lysozyme 7uM curve shape more carefully
name = 'lysozyme/Fits/Hasecke2018_7uM_sec'
X_train, X_val, y_train, y_val = ds_dict[name]
idx = np.argsort(X_train[:,0])
x0s = X_train[idx,0]
ys = y_train[idx]
# Print evenly spaced samples
step = max(1, len(x0s)//20)
print('lysozyme 7uM curve shape (every ~5th point):')
for i in range(0, len(x0s), step):
    print(f'  x0={x0s[i]:.0f}  y={ys[i]:.4f}')

print()
# Test: does a Hill function fit better?
# y = c0 * x0^n / (x0^n + c1^n) + c2  (Hill equation)
# vs logistic
# The lysozyme shows very slow rise - might need x0^n power
# Let's try fitting Hill: y = c0 * (x0-c1)^c2 / ((x0-c1)^c2 + c3^c2) + c4

# Test Gompertz: y = c0 * exp(-exp(-c1*(x0-c2))) + c3
def residual_gomp(theta):
    c0,c1,c2,c3 = theta
    arg = np.clip(-c1*(x0s - c2), -500, 500)
    pred = c0 * np.exp(-np.exp(arg)) + c3
    return pred - ys

res_g = least_squares(residual_gomp, [1.0, 1e-4, 200000, 0.0], loss='soft_l1', max_nfev=500)
pred_g = res_g.x[0]*np.exp(-np.exp(np.clip(-res_g.x[1]*(x0s-res_g.x[2]),-500,500)))+res_g.x[3]
nmse_g = np.mean((pred_g-ys)**2)/np.var(ys)
print(f'Gompertz NMSE on lysozyme 7uM train: {nmse_g:.4f}  params={np.round(res_g.x,4)}')

# Also test on htt/Kar2011/Q37 (2nd worst group)
name2 = 'htt/Kar2011/Fits/Kar2011_Q37_prim'
X2, X2v, y2, y2v = ds_dict[name2]
idx2 = np.argsort(X2[:,0])
x0s2 = X2[idx2,0]; x1s2 = X2[idx2,1]; ys2 = y2[idx2]
print()
print('htt Q37 prim - x1 unique values:', np.unique(x1s2))
step2 = max(1, len(x0s2)//15)
print('Sample curve (every ~7th):')
for i in range(0, min(60,len(x0s2)), step2):
    print(f'  x0={x0s2[i]:.0f} x1={x1s2[i]:.1f} y={ys2[i]:.4f}')
"
