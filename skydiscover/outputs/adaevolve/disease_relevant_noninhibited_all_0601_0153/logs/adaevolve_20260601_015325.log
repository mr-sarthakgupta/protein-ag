import numpy as np
import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, _nmse_with_gaussian_smoothed_target
from scipy.optimize import least_squares

datasets = load_all_datasets()
ds_dict = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

def fit_eval(model_fn, X_train, y_train, X_val, y_val, init):
    def residual(theta):
        pred = model_fn(theta, X_train)
        if not np.all(np.isfinite(pred)): return np.full(len(y_train), 1e12)
        return pred - y_train
    res = least_squares(residual, init, loss='soft_l1', max_nfev=300)
    pred_val = model_fn(res.x, X_val)
    return _nmse_with_gaussian_smoothed_target(y_val, pred_val), res.x

def model_B(theta, X):
    c0,c1,c2,c3,c4 = theta
    return c0/(1+np.exp(np.clip(c1 - c2*X[:,0] - c3*X[:,1], -500, 500))) + c4

# The key issue: for lysozyme, at init [1,14,9e-4,0.001,0]:
# sigmoid transitions at x0=14/9e-4=15556
# but actual transition at ~250000
# optimizer finds flat solution in 15 steps
# 
# What if we use c1 - c2*x0 but with c2 init such that c1/c2 is in the right range?
# We need c1/c2 to be a typical half-time. If c1=14 and typical half-time is 1e4:
# c2 = 14/1e4 = 1.4e-3
# For lysozyme half-time 2.5e5: c2 = 14/2.5e5 = 5.6e-5
# For IAPP half-time ~1e4: c2 = 14/1e4 = 1.4e-3

# The problem: IAPP needs c2~1e-3 but lysozyme needs c2~5e-5
# These differ by 20x - too much for a single init

# What if we use c2=1e-4 (geometric mean)?
# IAPP half-time: 14/1e-4 = 140000 sec (vs actual ~1e4) - 14x off
# Lysozyme half-time: 14/1e-4 = 140000 sec (vs actual 2.5e5) - 1.8x off - MUCH better!

# Let me check what datasets use what time scales
print('Dataset x0 ranges and medians:')
for name, X_train, X_val, y_train, y_val in datasets:
    x0 = X_train[:,0]
    print(f'  {name.split(\"/\")[-1]}: x0=[{x0.min():.0f},{x0.max():.0f}] med={np.median(x0):.0f}')
" 2>/dev/null
