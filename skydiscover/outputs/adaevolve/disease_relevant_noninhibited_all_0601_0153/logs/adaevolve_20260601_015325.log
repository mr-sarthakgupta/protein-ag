 130 |         "command": "python3 -c \"\nimport numpy as np\nfrom scipy.optimize import curve_fit\n\n# Test Gompertz vs logistic on IAPP data (asymmetry=1.97)\nimport pandas as pd\nbase = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'\ndf = pd.read_csv(base + 'IAPP/Daval2010/Fits/Daval2010_prim/fit.tsv', sep='\\t')\nx0 = df.iloc[:,0].values\ny = df.iloc[:,1].values\n\n# Logistic fit\ndef logistic(x, k, t0, A, b):\n    return A / (1 + np.exp(-k*(x - t0))) + b\n\n# Gompertz fit  \ndef gompertz(x, k, t0, A, b):\n    return A * np.exp(-np.exp(-k*(x - t0))) + b\n\ntry:\n    p1, _ = curve_fit(logistic, x0, y, p0=[0.0003, 10000, 1.0, 0.0], maxfev=5000)\n    y1 = logistic(x0, *p1)\n    nmse1 = np.mean((y - y1)**2) / np.var(y)\n    print(f'Logistic NMSE: {nmse1:.4f}')\nexcept Exception as e:\n    print(f'Logistic failed: {e}')\n\ntry:\n    p2, _ = curve_fit(gompertz, x0, y, p0=[0.0003, 10000, 1.0, 0.0], maxfev=5000)\n    y2 = gompertz(x0, *p2)\n    nmse2 = np.mean((y - y2)**2) / np.var(y)\n    print(f'Gompertz NMSE: {nmse2:.4f}')\nexcept Exception as e:\n    print(f'Gompertz failed: {e}')\n\n# Also test on Cohen2013 (asymmetry=1.27)\ndf2 = pd.read_csv(base + 'Abeta/Cohen2013/Ab42_sec_IN_HOURS/fit.tsv', sep='\\t')\nx2 = df2.iloc[:,0].values\ny2d = df2.iloc[:,1].values\ntry:\n    p3, _ = curve_fit(logistic, x2, y2d, p0=[5.0, 1.0, 1.0, 0.0], maxfev=5000)\n    nmse3 = np.mean((y2d - logistic(x2, *p3))**2) / np.var(y2d)\n    print(f'Cohen Logistic NMSE: {nmse3:.4f}')\n    p4, _ = curve_fit(gompertz, x2, y2d, p0=[5.0, 1.0, 1.0, 0.0], maxfev=5000)\n    nmse4 = np.mean((y2d - gompertz(x2, *p4))**2) / np.var(y2d)\n    print(f'Cohen Gompertz NMSE: {nmse4:.4f}')\nexcept Exception as e:\n    print(f'Cohen failed: {e}')\n\"\n"
