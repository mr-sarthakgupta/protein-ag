import numpy as np
import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()
ds_dict = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

# Test different init values for lysozyme with linear model
ds_name = 'lysozyme/Fits/Hasecke2018_7uM_sec'
X_train, X_val, y_train, y_val = ds_dict[ds_name]

def model_lin(theta, X):
    c0,c1,c2,c3,c4 = theta
    return c0/(1+np.exp(np.clip(c1 - c2*X[:,0] - c3*X[:,1], -500, 500))) + c4

def fit_nmse(model_fn, X_train, y_train, X_val, y_val, init):
    def residual(theta):
        pred = model_fn(theta, X_train)
        if not np.all(np.isfinite(pred)): return np.full(len(y_train), 1e12)
        return pred - y_train
    res = least_squares(residual, init, loss='soft_l1', max_nfev=300)
    pred_val = model_fn(res.x, X_val)
    var = np.var(y_val)
    return np.mean((pred_val - y_val)**2)/var, res.x

# Try various inits - x0 range is 4620 to 353069
# Midpoint ~180000, so c2*180000 ~ c1 => c2 ~ c1/180000
for init in [
    [1.0, 14.0, 9e-4, 0.001, 0.0],
    [1.0, 2.0, 1e-5, 0.001, 0.0],
    [1.0, 5.0, 2e-5, 0.0, 0.0],
    [1.0, 3.0, 1.5e-5, 0.0, 0.0],
    [1.0, 1.0, 5e-6, 0.0, 0.0],
]:
    nmse, theta = fit_nmse(model_lin, X_train, y_train, X_val, y_val, init)
    print(f'init={init[:3]} -> nmse={nmse:.4f}, c={theta.round(6)}')

# Now test: what if we use c2*x0 + c3*x1 but with better init?
# Key: for lysozyme x0~1e5, so c2~1e-5 is right scale
# The best-known model uses init c2=9e-4 which is 90x too large for this dataset
# This causes overflow and optimizer gets stuck

# Try 6-constant model: c0/(1+exp(c1 - c2*x0 - c3*x1)) + c4 with c2 init = 1e-5
print()
print('Testing all datasets with better init:')
def fit_all(init):
    nmses = []
    for name, X_train, X_val, y_train, y_val in datasets:
        nmse, _ = fit_nmse(model_lin, X_train, y_train, X_val, y_val, init)
        nmses.append(nmse)
    return np.mean(nmses)

for init in [
    [1.0, 14.0, 9e-4, 0.001, 0.0],
    [1.0, 5.0, 1e-4, 0.001, 0.0],
    [1.0, 8.0, 5e-5, 0.001, 0.0],
]:
    mean = fit_all(init)
    print(f'init={init} -> mean_nmse={mean:.5f}')
