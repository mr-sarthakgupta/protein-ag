import pandas as pd, numpy as np, os
from scipy.optimize import curve_fit

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

def model(X, c0, c1, c2, c3, c4):
    z = np.clip(c1 - c2*X[:,0], -500, 500)
    return c0/(1+np.exp(z)) + c3*X[:,1] + c4

# Load all datasets
datasets = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            fp = os.path.join(root, f)
            df = pd.read_csv(fp, sep='\t')
            X = df.iloc[:,:2].values.astype(float)
            y = df.iloc[:,-1].values.astype(float)
            name = root.replace(base, '')
            datasets.append((name, X, y))

# The harness uses scipy least_squares under the hood.
# Key: c1/c2 = half-time. For x0 in seconds (range 200-1e6), need c1/c2 ~ median(x0)
# For hours (range 0-22), need c1/c2 ~ 10 hours
# A good c2 init should be c1/median_x0. If c1=5, c2=5/median_x0
# But median_x0 varies enormously. 
# The trick: use c2 small enough that sigmoid is near flat at t=0 for most datasets
# c1=5, c2=1e-4 gives half-time=50000s ~ 14 hours -- works for both!

for p0 in [
    [1.0, 5.0, 1e-4, 0.0, 0.0],
    [1.0, 5.0, 5e-5, 0.0, 0.0],
    [1.0, 4.0, 5e-5, 0.0, 0.0],
    [1.0, 3.0, 5e-5, 0.0, 0.0],
    [1.0, 5.0, 2e-5, 0.0, 0.0],
    [1.0, 3.0, 2e-5, 0.0, 0.0],
]:
    nmses = []
    for name, X, y in datasets:
        var_y = np.var(y)
        try:
            pr, _ = curve_fit(model, X, y, p0=p0, maxfev=10000)
            yr = model(X, *pr)
            nmse = np.mean((y-yr)**2)/var_y if var_y > 0 else 0
            nmses.append(nmse)
        except:
            nmses.append(99)
    good = [n for n in nmses if n < 99]
    worst5 = sorted(good, reverse=True)[:3]
    print(f'p0={p0}: mean={np.mean(good):.4f} n_ok={len(good)}/{len(nmses)} worst3={[round(w,3) for w in worst5]}')
"
