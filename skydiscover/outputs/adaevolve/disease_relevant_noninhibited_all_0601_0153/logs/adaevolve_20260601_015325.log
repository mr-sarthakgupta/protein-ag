            yr = model(X, *pr)
            nmse = np.mean((y-yr)**2)/np.var(y)
            print(f'  p0={p0[:3]} -> NMSE={nmse:.4f} params={pr.round(3)}')
            break
        except Exception as e:
            print(f'  p0={p0[:3]} -> FAIL: {str(e)[:40]}')
    print()
