 162 |         "command": "python3 -c \"\nimport numpy as np\nfrom scipy.optimize import least_squares\nimport csv, re, glob\n\nbase = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'\nfiles = glob.glob(base + '**/fit.tsv', recursive=True)\nfiles.sort()\n\ndef load_fit(path):\n    with open(path) as f:\n        reader = csv.reader(f, delimiter='\\t')\n        header = next(reader)\n        response_headers = header[1:]\n        parsed = []\n        for h in response_headers:\n            m = re.search(r'(\\d+(?:\\.\\d+)?)\\s*uM', h, re.I)\n            if m: parsed.append(float(m.group(1)))\n            else: parsed = None; break\n        if parsed is None:\n            params = [float(i+1) for i in range(len(response_headers))]\n        else:\n            params = parsed\n        feats, tgts = [], []\n        for row in reader:\n            if not row: continue\n            x0v = float(row[0])\n            for p, v in zip(params, row[1:]):\n                if v.strip() and v.strip().lower() != 'nan':\n                    feats.append([x0v, p])\n                    tgts.append(float(v))\n    return np.array(feats), np.array(tgts)\n\ndef make_residual_log(X, y):\n    x0, x1 = X[:,0], X[:,1]\n    def res(theta):\n        c0,c1,c2,c3,c4,c5 = theta\n        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):\n            rate = c0 * x1**c1\n            ht = c2 * x1**c3\n            pred = c4 * np.exp(-np.exp(-rate*(x0-ht))) + c5\n        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)\n        return pred - y\n    return res\n\ndef make_residual_logistic(X, y):\n    x0, x1 = X[:,0], X[:,1]\n    def res(theta):\n        c0,c1,c2,c3,c4,c5 = theta\n        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):\n            rate = c0 * x1**c1\n            ht = c2 * x1**c3\n            pred = c4 / (1 + np.exp(-rate*(x0-ht))) + c5\n        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)\n        return pred - y\n    return res\n\np0 = [0.1, 0.5, 10.0, -0.5, 1.0, 0.0]\nnmse_gom, nmse_log = [], []\n\nfor f in files:\n    X, y = load_fit(f)\n    rng = np.random.default_rng(42)\n    idx = rng.permutation(len(y))\n    split = int(round(len(y)*0.75))\n    Xtr, Xv = X[np.sort(idx[:split])], X[np.sort(idx[split:])]\n    ytr, yv = y[np.sort(idx[:split])], y[np.sort(idx[split:])]\n    \n    for res_fn, lst in [(make_residual_log, nmse_gom), (make_residual_logistic, nmse_log)]:\n        try:\n            r = least_squares(res_fn(Xtr, ytr), p0, loss='soft_l1', max_nfev=300)\n            c = r.x\n            x0v, x1v = Xv[:,0], Xv[:,1]\n            if res_fn == make_residual_log:\n                pred = c[4]*np.exp(-np.exp(-c[0]*x1v**c[1]*(x0v-c[2]*x1v**c[3])))+c[5]\n            else:\n                pred = c[4]/(1+np.exp(-c[0]*x1v**c[1]*(x0v-c[2]*x1v**c[3])))+c[5]\n            nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf\n            lst.append(nm)\n        except: lst.append(np.inf)\n\nprint(f'Gompertz  mean NMSE: {np.mean(nmse_gom):.4f}, median: {np.median(nmse_gom):.4f}')\nprint(f'Logistic  mean NMSE: {np.mean(nmse_log):.4f}, median: {np.median(nmse_log):.4f}')\nprint(f'Gompertz  >1: {sum(1 for v in nmse_gom if v > 1.0)}/{len(nmse_gom)}')\nprint(f'Logistic  >1: {sum(1 for v in nmse_log if v > 1.0)}/{len(nmse_log)}')\n\" 2>/dev/null\n"
