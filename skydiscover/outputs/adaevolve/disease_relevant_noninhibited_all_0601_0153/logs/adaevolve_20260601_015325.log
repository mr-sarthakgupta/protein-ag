import pandas as pd, numpy as np, os
base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
# Fit simple logistic to each dataset and check residuals
from scipy.optimize import curve_fit
from scipy.special import expit

def logistic(X, c0, c1, c2, c3, c4):
    return c0 / (1 + np.exp(c1 - c2*X[:,0] - c3*X[:,1])) + c4

nmses = []
hard = []
for root, dirs, files in os.walk(base):
    for f in files:
        if f == 'fit.tsv':
            fp = os.path.join(root, f)
            df = pd.read_csv(fp, sep='\t')
            X = df.iloc[:,:2].values.astype(float)
            y = df.iloc[:,-1].values.astype(float)
            try:
                popt, _ = curve_fit(logistic, X, y, p0=[1.0, 14.0, 9e-4, 0.001, 0.0], maxfev=5000)
                yp = logistic(X, *popt)
                nmse = np.mean((y-yp)**2) / np.var(y) if np.var(y) > 0 else 0
                nmses.append(nmse)
                name = root.replace(base,'')
                if nmse > 0.05:
                    hard.append((nmse, name[:60]))
            except Exception as e:
                hard.append((99, root.replace(base,'')[:60] + ' ERR:' + str(e)[:20]))

print(f'Mean NMSE: {np.mean(nmses):.4f}, Median: {np.median(nmses):.4f}')
print(f'Hard datasets (NMSE>0.05):')
for nmse, name in sorted(hard, reverse=True)[:10]:
    print(f'  {nmse:.4f} {name}')
"
