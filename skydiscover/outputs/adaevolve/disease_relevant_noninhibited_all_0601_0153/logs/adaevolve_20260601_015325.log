import numpy as np
import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, _nmse_with_gaussian_smoothed_target
from scipy.optimize import least_squares

datasets = load_all_datasets()
ds_dict = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

def fit_eval_nfev(model_fn, X_train, y_train, X_val, y_val, init, max_nfev=300):
    def residual(theta):
        pred = model_fn(theta, X_train)
        if not np.all(np.isfinite(pred)): return np.full(len(y_train), 1e12)
        return pred - y_train
    res = least_squares(residual, init, loss='soft_l1', max_nfev=max_nfev)
    pred_val = model_fn(res.x, X_val)
    return _nmse_with_gaussian_smoothed_target(y_val, pred_val), res.x

def model_B(theta, X):
    c0,c1,c2,c3,c4 = theta
    return c0/(1+np.exp(np.clip(c1 - c2*X[:,0] - c3*X[:,1], -500, 500))) + c4

# Test with higher max_nfev on lysozyme
ds = 'lysozyme/Fits/Hasecke2018_7uM_sec'
X_train, X_val, y_train, y_val = ds_dict[ds]
for nfev in [300, 1000, 3000]:
    n, theta = fit_eval_nfev(model_B, X_train, y_train, X_val, y_val, [1.0, 14.0, 9e-4, 0.001, 0.0], nfev)
    print(f'nfev={nfev}: nmse={n:.4f}, theta={theta.round(6)}')

# Also check: what about using max_nfev=1000 across all datasets?
import time
t0 = time.time()
nmses_300 = []
nmses_1000 = []
for name, X_train, X_val, y_train, y_val in datasets:
    n300, _ = fit_eval_nfev(model_B, X_train, y_train, X_val, y_val, [1.0, 14.0, 9e-4, 0.001, 0.0], 300)
    n1000, _ = fit_eval_nfev(model_B, X_train, y_train, X_val, y_val, [1.0, 14.0, 9e-4, 0.001, 0.0], 1000)
    nmses_300.append(n300)
    nmses_1000.append(n1000)
t1 = time.time()
print(f'Time for all datasets (300+1000 nfev each): {t1-t0:.1f}s')
print(f'Mean NMSE nfev=300:  {np.mean(nmses_300):.5f}')
print(f'Mean NMSE nfev=1000: {np.mean(nmses_1000):.5f}')
"
