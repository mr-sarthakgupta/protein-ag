        c0,c1,c2,c3,c4 = theta
        pred = c0/(1+np.exp(np.clip(c1-c2*x0_tr-c3*x1_tr,-500,500)))+c4
        if not np.all(np.isfinite(pred)): return np.full_like(y_tr,1e6)
        return pred - y_tr
    ra = least_squares(res_A,[1,14,9e-4,0.001,0],loss='soft_l1',max_nfev=300)
    c0,c1,c2,c3,c4=ra.x
    pa=c0/(1+np.exp(np.clip(c1-c2*x0_v-c3*x1_v,-500,500)))+c4
    results_A.append(_nmse_with_gaussian_smoothed_target(y_v, pa))

    # Model G: y = c0/(1+exp(c1 - c2*x0 - c3*x1*x0)) + c4
    # multiplicative interaction x1*x0: concentration scales the rate
    # This is the physically correct nucleation model where rate ~ conc^n
    # For datasets with constant x1, c3*x1*x0 = const*x0 absorbed into c2
    def res_G(theta):
        c0,c1,c2,c3,c4 = theta
        z = np.clip(c1 - c2*x0_tr - c3*x1_tr*x0_tr,-500,500)
        pred = c0/(1+np.exp(z))+c4
        if not np.all(np.isfinite(pred)): return np.full_like(y_tr,1e6)
        return pred - y_tr
    try:
        rg = least_squares(res_G,[1,14,9e-4,1e-7,0],loss='soft_l1',max_nfev=300)
        c0,c1,c2,c3,c4=rg.x
        z_v=np.clip(c1-c2*x0_v-c3*x1_v*x0_v,-500,500)
        pg=c0/(1+np.exp(z_v))+c4
        nmse_G=_nmse_with_gaussian_smoothed_target(y_v, pg)
    except: nmse_G=results_A[-1]
    results_G.append(nmse_G)

print(f'Model A mean NMSE (gauss): {np.mean(results_A):.5f}')
print(f'Model G (x1*x0) mean NMSE: {np.mean(results_G):.5f}')
print()
print('Significant differences (>0.005):')
for i,(name,*_) in enumerate(datasets):
    d=results_A[i]-results_G[i]
    if abs(d)>0.005:
        print(f'  {\"BETTER\" if d>0 else \"WORSE\":6s} {name[-42:]:42s}: A={results_A[i]:.4f} G={results_G[i]:.4f}')
