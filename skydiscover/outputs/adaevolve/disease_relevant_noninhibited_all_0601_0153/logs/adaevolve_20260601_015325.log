    results_X2.append(v)
    if v > 0.3: bad_X2.append((d.parent.name, round(float(v),3)))

print(f'C log(x0+c2+1) 5p: mean={np.mean(results_C):.4f} >1:{sum(v>1 for v in results_C)} >0.5:{sum(v>0.5 for v in results_C)}')
