import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, _nmse_with_gaussian_smoothed_target
import numpy as np
from scipy.optimize import least_squares

datasets = load_all_datasets()
ds_dict = {n:(X_tr,X_v,y_tr,y_v) for n,X_tr,X_v,y_tr,y_v in datasets}

# Test Model H directly (c4 as shape, no exp wrapper)
# but with different initial values for c4
# The key: when c4=1, it's exactly the standard logistic
# When c4<1, it creates a sharper onset (good for lysozyme)
# When c4>1, it creates a more gradual onset

# Check which datasets diverge and why
problem_names = [
    'biofilm proteins/RdlB_Yang2017/Fits/20uM_prim',
    'htt/Kar2011/Fits/Kar2011_Q37_prim',
    'lysozyme/Fits/Hasecke2018_70uM_sec',
    'serum amyloid/Srinivasan2013/Fits/Srinivasan2013_Saa1.1_sec',
]

for name in problem_names:
    X_tr, X_v, y_tr, y_v = ds_dict[name]
    x0_tr, x1_tr = X_tr[:,0], X_tr[:,1]
    x0_v, x1_v = X_v[:,0], X_v[:,1]
    
    # Try Model H with different c4 inits
    best_nmse = float('inf')
    best_init = None
    for c4_init in [0.1, 0.3, 0.5, 1.0, 2.0]:
        def res_H(theta):
            c0,c1,c2,c3,c4,c5 = theta
            z = np.clip(c1-c2*x0_tr-c3*x1_tr,-500,500)
            log_base = np.log1p(np.exp(z))
            pred = c0 * np.exp(np.clip(-c4 * log_base, -500, 500)) + c5
            if not np.all(np.isfinite(pred)): return np.full_like(y_tr,1e6)
            return pred - y_tr
        try:
            rh = least_squares(res_H,[1,14,9e-4,0.001,c4_init,0],loss='soft_l1',max_nfev=300)
            c0,c1,c2,c3,c4,c5=rh.x
            z_v=np.clip(c1-c2*x0_v-c3*x1_v,-500,500)
            log_base_v=np.log1p(np.exp(z_v))
            ph=c0*np.exp(np.clip(-c4*log_base_v,-500,500))+c5
            nmse=_nmse_with_gaussian_smoothed_target(y_v, ph)
            if nmse < best_nmse:
                best_nmse = nmse
                best_init = c4_init
                best_c = rh.x
        except: pass
    print(f'{name[-35:]:35s}: best_nmse={best_nmse:.4f} c4_init={best_init} fitted_c4={best_c[4]:.3f}')
" 2>/dev/null
