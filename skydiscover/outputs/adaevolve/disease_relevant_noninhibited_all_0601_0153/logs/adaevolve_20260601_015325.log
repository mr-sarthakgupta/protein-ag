import numpy as np
from scipy.optimize import least_squares
import csv, re
from pathlib import Path
import os

data_root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')
datasets = []
for dirpath, _, filenames in os.walk(data_root):
    if 'fit.tsv' in filenames:
        datasets.append(Path(dirpath) / 'fit.tsv')
datasets.sort()

def load_dataset(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.IGNORECASE)
            if m: parsed.append(float(m.group(1)))
            else: parsed.append(None)
        if all(p is not None for p in parsed):
            params = [float(p) for p in parsed]
        else:
            params = [float(i+1) for i in range(len(response_headers))]
        rows = list(reader)
        X, y = [], []
        for row in rows:
            if not row: continue
            x0 = float(row[0])
            for param, val in zip(params, row[1:]):
                if val and val.strip().lower() != 'nan':
                    X.append([x0, param])
                    y.append(float(val))
    return np.array(X), np.array(y)

def split(X, y):
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    sp = int(round(len(y)*0.75))
    ti, vi = np.sort(idx[:sp]), np.sort(idx[sp:])
    return X[ti], X[vi], y[ti], y[vi]

# M1: log(t+c3) - handles x0=0 with time shift
def modelM1(th, X):
    c0,c1,c2,c3,c4 = th
    t = X[:,0]
    shift = np.abs(c3) + 1e-6  # ensure positive
    lt = np.log(t + shift)
    return c0/(1+np.exp(-c1*(lt-c2)))+c4

# M2: log(x0+c3) with x1 also shifting half-time
def modelM2(th, X):
    c0,c1,c2,c3,c4,c5 = th
    t,p = X[:,0],X[:,1]
    shift = np.abs(c3) + 1e-6
    lt = np.log(t + shift)
    lp = np.log(np.maximum(p, 1e-10))
    half = c2 + c4*lp
    return c0/(1+np.exp(-c1*(lt-half)))+c5

# M3: simple log(t+1) - no fitting of shift (log1p)
def modelM3(th, X):
    c0,c1,c2,c3 = th
    t = X[:,0]
    lt = np.log1p(np.maximum(t, -0.999))
    return c0/(1+np.exp(-c1*(lt-c2)))+c3

models = [
    ('M1_logshift5c', modelM1, [1.0,2.0,5.0,1.0,0.0], 5),
    ('M2_logshift_x1_6c', modelM2, [1.0,2.0,5.0,1.0,-0.5,0.0], 6),
    ('M3_log1p4c', modelM3, [1.0,2.0,5.0,0.0], 4),
]

results = {name: [] for name,_,_,_ in models}
bad = {name: [] for name,_,_,_ in models}
for d in datasets:
    X, y = load_dataset(d)
    Xtr,Xval,ytr,yval = split(X,y)
    var = np.var(yval)
    for name, model, x0, nc in models:
        def res(th): return model(th, Xtr) - ytr
        try:
            r = least_squares(res, x0, loss='soft_l1', max_nfev=300)
            yp = model(r.x, Xval)
            nmse_v = np.mean((yval-yp)**2)/(var if var>1e-10 else 1)
        except:
            nmse_v = 10.0
        v = min(nmse_v, 10.0)
        results[name].append(v)
        if v > 0.5:
            bad[name].append((d.parent.name, round(v,3)))

for name, vals in results.items():
    print(f'{name}: mean={np.mean(vals):.4f} median={np.median(vals):.4f} >1:{sum(v>1 for v in vals)} >0.5:{sum(v>0.5 for v in vals)}')
    if bad[name]:
        print(f'  bad: {bad[name][:4]}')
