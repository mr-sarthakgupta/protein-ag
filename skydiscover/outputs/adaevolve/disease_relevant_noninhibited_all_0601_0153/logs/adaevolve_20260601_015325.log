        if not np.all(np.isfinite(yp)):
            nmse_v = 10.0
        else:
            nmse_v = np.mean((yval-yp)**2)/(var if var>1e-10 else 1)
    except:
        nmse_v = 10.0
    v = min(nmse_v, 10.0)
