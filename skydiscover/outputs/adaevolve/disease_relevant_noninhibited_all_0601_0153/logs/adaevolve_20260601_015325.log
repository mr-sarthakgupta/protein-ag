import numpy as np, re, csv, os
from pathlib import Path
from scipy.optimize import curve_fit

base = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def load_tsv(path):
    with open(path, newline='') as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rh = header[1:]
        parsed = [re.search(r'[-+]?\d*\.?\d+(?:[eE][-+]?\d+)?', h) for h in rh]
        params = [float(m.group()) for m in parsed] if all(m for m in parsed) else [float(i+1) for i in range(len(rh))]
        rows = [r for r in reader if r]
    feats, tgts = [], []
    for row in rows:
        for p, v in zip(params, row[1:]):
            if v.strip().lower() not in ('', 'nan'):
                feats.append([float(row[0]), p])
                tgts.append(float(v))
    arr = np.array(feats)
    return arr[:,0], arr[:,1], np.array(tgts)

# Current model
def model_curr(X, c0, c1, c2, c3, c4):
    x0, x1 = X[:,0], X[:,1]
    return c0 / (1 + np.exp(np.clip(c1 - c2*x0 - c3*x1, -500, 500))) + c4

# Product model  
def model_prod(X, c0, c1, c2, c3, c4):
    x0, x1 = X[:,0], X[:,1]
    return c0 / (1 + np.exp(np.clip(c1 - (c2 + c3*x1)*x0, -500, 500))) + c4

datasets = []
for root, dirs, files in os.walk(base):
    if 'fit.tsv' in files:
        datasets.append(Path(root)/'fit.tsv')
datasets.sort()

p0 = [1.0, 14.0, 9e-4, 0.001, 0.0]

curr_nmses, prod_nmses = [], []
for path in datasets:
    x0,x1,y = load_tsv(path)
    X = np.column_stack([x0,x1])
    name = path.parent.name
    for nmse_list, mfn in [(curr_nmses, model_curr), (prod_nmses, model_prod)]:
        try:
            p, _ = curve_fit(mfn, X, y, p0=p0, maxfev=20000, method='trf')
            yp = mfn(X, *p)
            nmse = np.mean((y-yp)**2)/np.var(y)
            nmse_list.append(nmse)
        except:
            nmse_list.append(float('nan'))

c_fin = [v for v in curr_nmses if np.isfinite(v)]
p_fin = [v for v in prod_nmses if np.isfinite(v)]
print(f'Current: n={len(c_fin)}/42, mean={np.mean(c_fin):.4f}')
print(f'Product: n={len(p_fin)}/42, mean={np.mean(p_fin):.4f}')

# Show per-dataset comparison for worst cases
print('\\nDataset comparison (curr vs prod):')
for i, path in enumerate(datasets):
    name = path.parent.name
    c, pr = curr_nmses[i], prod_nmses[i]
    if np.isfinite(c) and np.isfinite(pr) and abs(c-pr) > 0.01:
        print(f'  {name}: curr={c:.4f} prod={pr:.4f} diff={pr-c:+.4f}')
"
