import pandas as pd
import numpy as np
import glob, re
from scipy.optimize import least_squares

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

def parse_param(text):
    text = text.strip()
    m = re.search(r'(\d+(?:\.\d+)?)\s*uM', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*mM', text, re.IGNORECASE)
    if m: return float(m.group(1)) * 1000.0
    m = re.search(r'(\d+(?:\.\d+)?)\s*mg/mL', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*ng/ul', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'pH\s+(\d+(?:\.\d+)?)', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*%', text)
    if m: return float(m.group(1))
    m = re.search(r':\s*(\d+(?:\.\d+)?)\s*$', text)
    if m: return float(m.group(1))
    return None

def load_dataset(path):
    df = pd.read_csv(path, sep='\t')
    x0_col = df['X'].values
    resp_headers = [c for c in df.columns if c != 'X']
    parsed = [parse_param(h) for h in resp_headers]
    if all(p is not None for p in parsed):
        parameters = [float(p) for p in parsed]
    else:
        parameters = [float(i+1) for i in range(len(resp_headers))]
    rows_x0, rows_x1, rows_y = [], [], []
    for param, col in zip(parameters, resp_headers):
        y_vals = df[col].values
        valid = np.isfinite(y_vals)
        rows_x0.extend(x0_col[valid])
        rows_x1.extend([param]*valid.sum())
        rows_y.extend(y_vals[valid])
    return np.column_stack([rows_x0, rows_x1]), np.array(rows_y)

datasets = sorted(glob.glob(base + '**/fit.tsv', recursive=True))
all_data = [(load_dataset(d), d.split('/')[-2]) for d in datasets]

# Model C: log-time Richards
def model_C(X, c0, c1, c2, c3, c4, c5):
    z = c1 - c2*np.log1p(np.abs(X[:,0])) - c3*X[:,1]
    return c0 * np.exp(-c4 * np.log1p(np.exp(np.clip(z, -500, 500)))) + c5

def eval_C(p0, nfev=300):
    nmses = []
    bad = []
    for (X, y), name in all_data:
        try:
            def resid(p): return model_C(X, *p) - y
            r = least_squares(resid, p0, loss='soft_l1', max_nfev=nfev)
            yp = model_C(X, *r.x)
            n = np.mean((yp-y)**2)/(np.var(y)+1e-10)
            nmses.append(min(n, 10.0))
            if n > 0.15: bad.append(f'{name}:{n:.3f}')
        except:
            nmses.append(10.0)
            bad.append(f'{name}:ERR')
    return np.mean(nmses), bad

# Best init from previous: c1=10, c2=1.5 or c1=12, c2=1.5
# Fine-tune around these
for c1, c2, c3, c4 in [
    (10.0, 1.5, 0.001, 0.3),
    (12.0, 1.5, 0.001, 0.3),
    (10.0, 1.5, 0.001, 1.0),
    (10.0, 1.5, 0.0, 0.3),
    (10.0, 1.5, 0.001, 0.5),
    (11.0, 1.5, 0.001, 0.3),
    (10.0, 1.3, 0.001, 0.3),
    (10.0, 1.7, 0.001, 0.3),
    (9.0, 1.5, 0.001, 0.3),
]:
    score, bad = eval_C([1.0, c1, c2, c3, c4, 0.0])
    print(f'c1={c1},c2={c2},c3={c3},c4={c4}: nmse={score:.4f} bad={bad}')
