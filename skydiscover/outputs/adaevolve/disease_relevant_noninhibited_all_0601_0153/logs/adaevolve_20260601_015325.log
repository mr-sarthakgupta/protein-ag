import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, _nmse_with_gaussian_smoothed_target
from scipy.optimize import least_squares

datasets = load_all_datasets()

def fit_5p(X_train, y_train, X_val, y_val, c2_init, c1_init=5.0):
    x0_t, x1_t = X_train[:,0], X_train[:,1]
    x0_v, x1_v = X_val[:,0], X_val[:,1]
    def residual(theta):
        c0,c1,c2,c3,c4 = theta
        arg = np.clip(c1-c2*x0_t-c3*x1_t, -500, 500)
        pred = c0/(1+np.exp(arg))+c4
        if not np.all(np.isfinite(pred)):
            return np.full_like(y_train, 1e12)
        return pred - y_train
    r = least_squares(residual, [1.0, c1_init, c2_init, 0.0, 0.0], loss='soft_l1', max_nfev=300)
    c0,c1,c2,c3,c4 = r.x
    arg_v = np.clip(c1-c2*x0_v-c3*x1_v, -500, 500)
    pred_v = c0/(1+np.exp(arg_v))+c4
    return _nmse_with_gaussian_smoothed_target(y_val, pred_v)

# Test different c2 inits
for c2_init in [1e-2, 1e-3, 5e-4, 1e-4, 1e-5, 1e-6]:
    nmses = [fit_5p(X_train, y_train, X_val, y_val, c2_init)
             for _, X_train, X_val, y_train, y_val in datasets]
    print(f'c2_init={c2_init:.0e}: mean={np.mean(nmses):.4f}, median={np.median(nmses):.4f}')

print()
# Try different c1 inits with best c2
for c1_init in [1.0, 2.0, 3.0, 5.0, 8.0, 10.0]:
    nmses = [fit_5p(X_train, y_train, X_val, y_val, 0.001, c1_init)
             for _, X_train, X_val, y_train, y_val in datasets]
    print(f'c1_init={c1_init}: mean={np.mean(nmses):.4f}, median={np.median(nmses):.4f}')
"
