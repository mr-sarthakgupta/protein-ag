import numpy as np, re, csv, os
from pathlib import Path
from scipy.optimize import curve_fit

base = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def load_tsv(path):
    with open(path, newline='') as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rh = header[1:]
        parsed = [re.search(r'[-+]?\d*\.?\d+(?:[eE][-+]?\d+)?', h) for h in rh]
        params = [float(m.group()) for m in parsed] if all(m for m in parsed) else [float(i+1) for i in range(len(rh))]
        rows = [r for r in reader if r]
    feats, tgts = [], []
    for row in rows:
        for p, v in zip(params, row[1:]):
            if v.strip().lower() not in ('', 'nan'):
                feats.append([float(row[0]), p])
                tgts.append(float(v))
    arr = np.array(feats)
    return arr[:,0], arr[:,1], np.array(tgts)

# Models to compare
def logistic(x0, c0, c1, c2, c4):
    return c0 / (1 + np.exp(np.clip(c1 - c2*x0, -500, 500))) + c4

# tanh model: y = c0*tanh(c2*(x0-c1)) + c3
def tanh_model(x0, c0, c1, c2, c3):
    return c0 * np.tanh(c2*(x0-c1)) + c3

# Gompertz: y = c0*exp(-exp(-c1*(x0-c2))) + c3
def gompertz(x0, c0, c1, c2, c3):
    return c0 * np.exp(-np.exp(np.clip(-c1*(x0-c2), -500, 500))) + c3

hard_paths = [
    base/'hnRNPA/Kim2013/Fits/Kim2013_A2_sec/fit.tsv',
    base/'htt/Kar2011/Fits/Kar2011_Q37_sec/fit.tsv',
    base/'insulin/Fits/Nielsen2001_seeded_sec/fit.tsv',
    base/'lysozyme/Fits/Hasecke2018_70uM_sec/fit.tsv',
]

for path in hard_paths:
    x0,x1,y = load_tsv(path)
    name = path.parent.name
    med = np.median(x0[x0>0]) if np.any(x0>0) else np.median(x0)
    
    results = {}
    for mname, mfn, p0 in [
        ('logistic', logistic, [1.0, 5.0, 1.0/med, 0.0]),
        ('tanh', tanh_model, [0.5, med, 1.0/med, 0.5]),
        ('gompertz', gompertz, [1.0, 1.0/med, med, 0.0]),
    ]:
        try:
            p, _ = curve_fit(mfn, x0, y, p0=p0, maxfev=50000, method='trf')
            yp = mfn(x0, *p)
            nmse = np.mean((y-yp)**2)/np.var(y)
            results[mname] = nmse
        except Exception as e:
            results[mname] = float('nan')
    
    print(f'{name}: ' + ', '.join(f'{k}={v:.4f}' for k,v in results.items()))
"
