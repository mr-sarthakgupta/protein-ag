  88 | def fit_expression_constants(
  89 |     expression: sp.Expr | str | float | int,
  90 |     X_train: NDArray,
  91 |     y_train: NDArray,
  92 |     X_val: NDArray,
  93 |     *,
  94 |     constants: Sequence[sp.Symbol] | None = None,
  95 |     initial_values: Sequence[float] | None = None,
  96 |     max_nfev: int = 300,
  97 | ) -> FittedExpression:
  98 |     """
  99 |     Fit free constants in a SkyDiscover-proposed expression template.
 100 | 
 101 |     The expression structure is supplied by the evolved program. This helper only
 102 |     performs the continuous inner fit and PySR-style export/evaluation.
 103 |     """
 104 |     X_train = np.asarray(X_train, dtype=float)
 105 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 106 |     X_val = np.asarray(X_val, dtype=float)
 107 |     feature_names = [f"x{i}" for i in range(X_train.shape[1])]
 108 |     template = _as_sympy_expr(expression, feature_names)
 109 | 
 110 |     if constants is None:
 111 |         feature_set = set(feature_symbols(X_train.shape[1]))
 112 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 113 |     constants = list(constants)
 114 | 
 115 |     if not constants:
 116 |         fitted_expr = sp.simplify(template)
 117 |         return FittedExpression(
 118 |             expression_template=template,
 119 |             expression=fitted_expr,
 120 |             constants={},
 121 |             y_pred_train=_predict(fitted_expr, X_train, feature_names),
 122 |             y_pred_val=_predict(fitted_expr, X_val, feature_names),
 123 |         )
 124 | 
 125 |     if initial_values is None:
 126 |         x0 = np.ones(len(constants), dtype=float)
 127 |     else:
 128 |         x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 129 |         if x0.size != len(constants):
 130 |             raise ValueError("initial_values must match the number of constants")
 131 | 
 132 |     def residual(theta: NDArray) -> NDArray:
 133 |         substitutions = {symbol: float(value) for symbol, value in zip(constants, theta)}
 134 |         candidate = template.subs(substitutions)
 135 |         try:
 136 |             prediction = _predict(candidate, X_train, feature_names)
 137 |         except Exception:
 138 |             return np.full_like(y_train, 1e12, dtype=float)
 139 |         if prediction.shape != y_train.shape or not np.all(np.isfinite(prediction)):
 140 |             return np.full_like(y_train, 1e12, dtype=float)
 141 |         return prediction - y_train
 142 | 
 143 |     result = least_squares(
 144 |         residual,
 145 |         x0,
 146 |         loss="soft_l1",
 147 |         max_nfev=max_nfev,
 148 |     )
 149 |     fitted_constants = {
 150 |         str(symbol): float(value) for symbol, value in zip(constants, result.x)
 151 |     }
 152 |     substitutions = dict(zip(constants, result.x))
 153 |     fitted_expr = sp.simplify(template.subs(substitutions))
 154 | 
 155 |     return FittedExpression(
 156 |         expression_template=template,
 157 |         expression=fitted_expr,
 158 |         constants=fitted_constants,
 159 |         y_pred_train=_predict(fitted_expr, X_train, feature_names),
 160 |         y_pred_val=_predict(fitted_expr, X_val, feature_names),
 161 |     )
