 164 | def evaluate_expression(
 165 |     expression: sp.Expr | str | float | int,
 166 |     X_train: NDArray,
 167 |     y_train: NDArray,
 168 |     X_val: NDArray,
 169 |     y_val: NDArray,
 170 |     *,
 171 |     constants: Sequence[sp.Symbol] | None = None,
 172 |     initial_values: Sequence[float] | None = None,
 173 |     max_nfev: int = 300,
 174 | ) -> dict[str, Any]:
 175 |     """Score a proposed equation template after fitting its constants."""
 176 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 177 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 178 |     fitted = fit_expression_constants(
 179 |         expression,
 180 |         X_train,
 181 |         y_train,
 182 |         X_val,
 183 |         constants=constants,
 184 |         initial_values=initial_values,
 185 |         max_nfev=max_nfev,
 186 |     )
 187 |     nmse_train = nmse(y_train, fitted.y_pred_train)
 188 |     nmse_val = nmse(y_val, fitted.y_pred_val)
 189 |     loss = float(np.mean((fitted.y_pred_train - y_train) ** 2))
 190 | 
 191 |     return {
 192 |         "equation_template": str(fitted.expression_template),
 193 |         "equation": str(fitted.expression),
 194 |         "constants": fitted.constants,
 195 |         "loss": loss,
 196 |         "complexity": _complexity(fitted.expression_template),
 197 |         "nmse_train": nmse_train,
 198 |         "nmse_val": nmse_val,
 199 |         "combined_score": combined_score_from_nmse(nmse_val),
 200 |     }
