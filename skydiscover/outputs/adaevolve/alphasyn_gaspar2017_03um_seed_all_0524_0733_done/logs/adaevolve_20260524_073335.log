  78 | def _predict(expression: sp.Expr, X: NDArray, feature_names: Sequence[str]) -> NDArray:
  79 |     symbols = create_sympy_symbols(feature_names)
  80 |     fn = sympy2numpy(expression, symbols)
  81 |     if isinstance(fn, CallableEquation):
  82 |         y_pred = fn(np.asarray(X, dtype=float))
  83 |     else:
  84 |         y_pred = fn(*[X[:, i] for i in range(X.shape[1])])
  85 |     return np.asarray(y_pred, dtype=float).reshape(-1)
