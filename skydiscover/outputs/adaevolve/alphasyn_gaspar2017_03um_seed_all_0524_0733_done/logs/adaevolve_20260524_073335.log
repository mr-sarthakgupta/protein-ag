   2 | 
   3 | from __future__ import annotations
   4 | 
   5 | from dataclasses import dataclass
   6 | from typing import Any, Sequence
   7 | 
   8 | import numpy as np
   9 | import sympy as sp
  10 | from numpy.typing import NDArray
  11 | from pysr.export_numpy import CallableEquation, sympy2numpy
  12 | from pysr.export_sympy import create_sympy_symbols, pysr2sympy, sympy_mappings
  13 | from scipy.optimize import least_squares
  14 | 
  15 | from pysr_harness.metrics import combined_score_from_nmse, nmse
  16 | from pysr_harness.operators import (
  17 |     GENERAL_BINARY_OPERATORS,
  18 |     GENERAL_TERNARY_OPERATORS,
  19 |     GENERAL_UNARY_OPERATORS,
  20 | )
  21 | 
  22 | 
  23 | @dataclass(frozen=True)
  24 | class FittedExpression:
  25 |     """A fitted symbolic expression and its validation predictions."""
  26 | 
  27 |     expression_template: sp.Expr
  28 |     expression: sp.Expr
  29 |     constants: dict[str, float]
  30 |     y_pred_train: NDArray
  31 |     y_pred_val: NDArray
  32 | 
  33 | 
  34 | def feature_symbols(n_features: int) -> list[sp.Symbol]:
  35 |     """Create PySR-compatible feature symbols x0, x1, ..."""
  36 |     return create_sympy_symbols([f"x{i}" for i in range(n_features)])
  37 | 
  38 | 
  39 | def constant_symbols(n_constants: int) -> list[sp.Symbol]:
  40 |     """Create tunable constant symbols c0, c1, ..."""
  41 |     return [sp.Symbol(f"c{i}", real=True) for i in range(n_constants)]
  42 | 
  43 | 
  44 | def pysr_operator_names() -> dict[str, list[str]]:
  45 |     """Return the PySR operator vocabulary exposed to evolved equation builders."""
  46 |     return {
  47 |         "unary": GENERAL_UNARY_OPERATORS.copy(),
  48 |         "binary": GENERAL_BINARY_OPERATORS.copy(),
  49 |         "ternary": GENERAL_TERNARY_OPERATORS.copy(),
  50 |     }
  51 | 
  52 | 
  53 | def pysr_operator_namespace() -> dict[str, Any]:
  54 |     """
  55 |     Return PySR-to-SymPy operator callables usable in expression templates.
  56 | 
  57 |     Operators like ``+``, ``-``, ``*``, and ``/`` should be written with normal
  58 |     Python syntax. Named PySR operators such as ``sin``, ``cos``, ``sqrt``,
  59 |     ``log1p``, ``max``, ``min``, ``muladd``, and ``clamp`` are exposed here.
  60 |     """
  61 |     return {
  62 |         **sympy_mappings,
  63 |         "pi": sp.pi,
  64 |         "E": sp.E,
  65 |     }
  66 | 
  67 | 
  68 | def _as_sympy_expr(expression: sp.Expr | str | float | int, feature_names: Sequence[str]) -> sp.Expr:
  69 |     if isinstance(expression, sp.Expr):
  70 |         return expression
  71 |     return pysr2sympy(expression, feature_names_in=list(feature_names))
  72 | 
  73 | 
  74 | def _complexity(expression: sp.Expr) -> float:
  75 |     return float(sum(1 for _ in sp.preorder_traversal(expression)))
  76 | 
  77 | 
  78 | def _predict(expression: sp.Expr, X: NDArray, feature_names: Sequence[str]) -> NDArray:
  79 |     symbols = create_sympy_symbols(feature_names)
  80 |     fn = sympy2numpy(expression, symbols)
  81 |     if isinstance(fn, CallableEquation):
  82 |         y_pred = fn(np.asarray(X, dtype=float))
  83 |     else:
  84 |         y_pred = fn(*[X[:, i] for i in range(X.shape[1])])
  85 |     return np.asarray(y_pred, dtype=float).reshape(-1)
  86 | 
  87 | 
  88 | def fit_expression_constants(
  89 |     expression: sp.Expr | str | float | int,
  90 |     X_train: NDArray,
  91 |     y_train: NDArray,
  92 |     X_val: NDArray,
  93 |     *,
  94 |     constants: Sequence[sp.Symbol] | None = None,
  95 |     initial_values: Sequence[float] | None = None,
  96 |     max_nfev: int = 300,
  97 | ) -> FittedExpression:
  98 |     """
  99 |     Fit free constants in a SkyDiscover-proposed expression template.
 100 | 
 101 |     The expression structure is supplied by the evolved program. This helper only
 102 |     performs the continuous inner fit and PySR-style export/evaluation.
 103 |     """
 104 |     X_train = np.asarray(X_train, dtype=float)
 105 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 106 |     X_val = np.asarray(X_val, dtype=float)
 107 |     feature_names = [f"x{i}" for i in range(X_train.shape[1])]
 108 |     template = _as_sympy_expr(expression, feature_names)
 109 | 
 110 |     if constants is None:
 111 |         feature_set = set(feature_symbols(X_train.shape[1]))
 112 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 113 |     constants = list(constants)
 114 | 
 115 |     if not constants:
 116 |         fitted_expr = sp.simplify(template)
 117 |         return FittedExpression(
 118 |             expression_template=template,
 119 |             expression=fitted_expr,
 120 |             constants={},
 121 |             y_pred_train=_predict(fitted_expr, X_train, feature_names),
 122 |             y_pred_val=_predict(fitted_expr, X_val, feature_names),
 123 |         )
 124 | 
 125 |     if initial_values is None:
 126 |         x0 = np.ones(len(constants), dtype=float)
 127 |     else:
 128 |         x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 129 |         if x0.size != len(constants):
 130 |             raise ValueError("initial_values must match the number of constants")
 131 | 
 132 |     def residual(theta: NDArray) -> NDArray:
 133 |         substitutions = {symbol: float(value) for symbol, value in zip(constants, theta)}
 134 |         candidate = template.subs(substitutions)
 135 |         try:
 136 |             prediction = _predict(candidate, X_train, feature_names)
 137 |         except Exception:
 138 |             return np.full_like(y_train, 1e12, dtype=float)
 139 |         if prediction.shape != y_train.shape or not np.all(np.isfinite(prediction)):
 140 |             return np.full_like(y_train, 1e12, dtype=float)
 141 |         return prediction - y_train
 142 | 
 143 |     result = least_squares(
 144 |         residual,
 145 |         x0,
 146 |         loss="soft_l1",
 147 |         max_nfev=max_nfev,
 148 |     )
 149 |     fitted_constants = {
 150 |         str(symbol): float(value) for symbol, value in zip(constants, result.x)
 151 |     }
 152 |     substitutions = dict(zip(constants, result.x))
 153 |     fitted_expr = sp.simplify(template.subs(substitutions))
 154 | 
 155 |     return FittedExpression(
 156 |         expression_template=template,
 157 |         expression=fitted_expr,
 158 |         constants=fitted_constants,
 159 |         y_pred_train=_predict(fitted_expr, X_train, feature_names),
 160 |         y_pred_val=_predict(fitted_expr, X_val, feature_names),
 161 |     )
 162 | 
 163 | 
 164 | def evaluate_expression(
 165 |     expression: sp.Expr | str | float | int,
 166 |     X_train: NDArray,
 167 |     y_train: NDArray,
 168 |     X_val: NDArray,
 169 |     y_val: NDArray,
 170 |     *,
 171 |     constants: Sequence[sp.Symbol] | None = None,
 172 |     initial_values: Sequence[float] | None = None,
 173 |     max_nfev: int = 300,
 174 | ) -> dict[str, Any]:
 175 |     """Score a proposed equation template after fitting its constants."""
 176 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 177 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 178 |     fitted = fit_expression_constants(
 179 |         expression,
 180 |         X_train,
 181 |         y_train,
 182 |         X_val,
 183 |         constants=constants,
 184 |         initial_values=initial_values,
 185 |         max_nfev=max_nfev,
 186 |     )
 187 |     nmse_train = nmse(y_train, fitted.y_pred_train)
 188 |     nmse_val = nmse(y_val, fitted.y_pred_val)
 189 |     loss = float(np.mean((fitted.y_pred_train - y_train) ** 2))
 190 | 
 191 |     return {
 192 |         "equation_template": str(fitted.expression_template),
 193 |         "equation": str(fitted.expression),
 194 |         "constants": fitted.constants,
 195 |         "loss": loss,
 196 |         "complexity": _complexity(fitted.expression_template),
 197 |         "nmse_train": nmse_train,
 198 |         "nmse_val": nmse_val,
 199 |         "combined_score": combined_score_from_nmse(nmse_val),
 200 |     }
