import sympy as sp
from pysr_harness.equation_session import constant_symbols, feature_symbols

datasets = load_all_datasets()
insulin_seeded = [(n,Xtr,Xv,ytr,yv) for n,Xtr,Xv,ytr,yv in datasets if 'seeded' in n][0]
name, Xtr, Xv, ytr, yv = insulin_seeded
print(f'{name}: train={Xtr.shape}, val={Xv.shape}')
print(f'x1 unique in val: {np.unique(Xv[:,1])}')
print(f'x1 log(344)={np.log(344):.3f}')

x = feature_symbols(2)
