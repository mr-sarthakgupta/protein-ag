  53 |         "Abeta/Cohen2013/Ab42_sec_IN_HOURS",  # 10 parameter curves
  54 |         "Abeta/Meisl2014/Ab40_sec_IN_HOURS",  # 11 parameter curves
  55 |         "htt/Kakkar2016/FIts/Kakkar2016_6kDa_polyQ_prim",  # 4 parameter curves
  56 |         "htt/Kar2011/Fits/Kar2011_Q30_without_lowest_conc_sec",  # 5 parameter curves
  57 |         "biofilm proteins/CsgA/CsgA_prim_IN_HOURS",  # 6 parameter curves
  58 |         "biofilm proteins/RdlB_Yang2017/Fits/5and20uM_prim",  # 2 parameter curves
  59 |         # Single-curve cross-protein holdouts
  60 |         "IAPP/Daval2010/Fits/Daval2010_prim",
  61 |         "IAPP/Daval2010/Fits/Daval2010_sec",
  62 |         "hnRNPA/Kim2013/Fits/Kim2013_A1_prim",
  63 |         "insulin/Fits/Nielsen2001_seeded_sec",
  64 |         "lysozyme/Fits/Hasecke2018_7uM_sec",
  65 |     }
  66 | )
  67 | GAUSSIAN_SMOOTH_SIGMA = float(os.environ.get("SKYDISCOVER_GAUSSIAN_SMOOTH_SIGMA", "1.0"))
  68 | SINGLE_EQUATION_ERROR_PREFIX = "Single-equation violation"
  69 | _ALLOWED_IMPORTS = {"sympy", "numpy"}
  70 | _ALLOWED_FROM_IMPORTS = {
  71 |     "__future__",
  72 |     "typing",
  73 |     "numpy.typing",
  74 |     "pysr_harness.equation_session",
  75 | }
  76 | _ALLOWED_HARNESS_IMPORTS = {
  77 |     "constant_symbols",
  78 |     "evaluate_expression",
  79 |     "feature_symbols",
  80 | }
  81 | _ALLOWED_EVALUATE_CALLS = {
  82 |     "constant_symbols",
  83 |     "evaluate_expression",
  84 |     "feature_symbols",
  85 |     "sp.exp",
  86 |     "sp.log",
  87 |     "sp.log1p",
  88 |     "sp.sqrt",
  89 |     "sp.sin",
  90 |     "sp.cos",
  91 |     "sp.tan",
  92 |     "sp.tanh",
  93 |     "sp.sinh",
  94 |     "sp.cosh",
  95 | }
  96 | _PROTECTED_NAMES = {
  97 |     "constant_symbols",
  98 |     "evaluate_expression",
  99 |     "feature_symbols",
 100 |     "single_equation_evaluation",
 101 |     "validate_single_equation_result",
 102 | }
 103 | _DISALLOWED_CONTROL_NODES = (
 104 |     ast.AsyncFunctionDef,
 105 |     ast.ClassDef,
 106 |     ast.For,
 107 |     ast.While,
 108 |     ast.If,
 109 |     ast.IfExp,
 110 |     ast.Try,
 111 |     ast.With,
 112 |     ast.AsyncWith,
 113 |     ast.Match,
 114 |     ast.Lambda,
 115 |     ast.ListComp,
 116 |     ast.SetComp,
 117 |     ast.DictComp,
 118 |     ast.GeneratorExp,
