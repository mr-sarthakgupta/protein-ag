import sys, tempfile, os, subprocess, pickle
sys.path.insert(0, '.')

# Minimal subprocess test to see what's happening
script = '''
import sys, os, pickle
sys.path.insert(0, '/home/mrsar/protein-ag/skydiscover')

results_path = '/tmp/test_results.pkl'

try:
    from disease_relevant_noninhibited_all.evaluator import (
        load_all_datasets, evaluate_symbolic_expression, _aggregate_per_dataset_results,
        _nmse_with_gaussian_smoothed_target
    )
    import pysr_harness.equation_session as equation_session
    equation_session.evaluate_expression = evaluate_symbolic_expression
    equation_session.nmse = _nmse_with_gaussian_smoothed_target
    from pysr_harness.equation_session import single_equation_evaluation, validate_single_equation_result
    import sympy as sp
    from pysr_harness.equation_session import constant_symbols, feature_symbols
    
    datasets = load_all_datasets()
    
    def fn(X_train, y_train, X_val, y_val):
        x = feature_symbols(X_train.shape[1])
        c = constant_symbols(4)
        time = x[0]
        expression = c[0] / (1 + sp.exp(-c[1] * (time - c[2]))) + c[3]
        return evaluate_symbolic_expression(expression, X_train, y_train, X_val, y_val,
            constants=c, initial_values=[1.0, 10.0, 0.5, 0.0])
    
    per_dataset_results = {}
    for name, X_train, X_val, y_train, y_val in datasets[:3]:
        try:
            with single_equation_evaluation():
                result = fn(X_train, y_train, X_val, y_val)
                validate_single_equation_result(result)
            per_dataset_results[name] = {
                \"nmse_val\": float(result.get(\"nmse_val\", float(\"inf\"))),
                \"n_val_points\": int(result.get(\"n_val_points\", 0)),
                \"evaluation_only\": bool(result.get(\"evaluation_only\", False)),
                \"combined_score\": float(result.get(\"combined_score\", 0.0)),
                \"complexity\": float(result.get(\"complexity\", 0.0)),
                \"equation_template\": str(result.get(\"equation_template\", \"\")),
                \"nmse_train\": float(result.get(\"nmse_train\", float(\"inf\"))),
                \"equation\": str(result.get(\"equation\", \"\")),
            }
        except Exception as e:
            per_dataset_results[name] = {\"error\": str(e), \"nmse_val\": float(\"inf\"), \"n_val_points\": 0}
    
    agg = _aggregate_per_dataset_results(per_dataset_results)
    with open(results_path, \"wb\") as f:
        pickle.dump({\"result\": agg, \"per\": per_dataset_results}, f)
    os._exit(0)
except Exception as e:
    import traceback
    with open(results_path, \"wb\") as f:
        pickle.dump({\"error\": str(e), \"tb\": traceback.format_exc()}, f)
    os._exit(1)
'''

with open('/tmp/test_sub.py', 'w') as f:
    f.write(script)

proc = subprocess.run([sys.executable, '/tmp/test_sub.py'], capture_output=True, timeout=30)
print('returncode:', proc.returncode)
print('stderr:', proc.stderr.decode()[:500] if proc.stderr else '')

if os.path.exists('/tmp/test_results.pkl'):
    with open('/tmp/test_results.pkl', 'rb') as f:
        data = pickle.load(f)
    if 'error' in data:
        print('error:', data['error'])
        print('tb:', data.get('tb','')[:300])
    else:
        agg = data['result']
        print(f'n_datasets={agg.get(\"n_datasets\")}, combined={agg.get(\"combined_score\")}')
        per = data['per']
        for name, r in list(per.items())[:3]:
            print(f'  {name}: n_val={r.get(\"n_val_points\")}, nmse={r.get(\"nmse_val\")}')
