import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, evaluate_symbolic_expression as eval_from_evaluator
from pysr_harness.equation_session import evaluate_expression as eval_from_session
import numpy as np
import sympy as sp
from pysr_harness.equation_session import constant_symbols, feature_symbols

datasets = load_all_datasets()
val_datasets = [(n, Xtr, Xv, ytr, yv) for n, Xtr, Xv, ytr, yv in datasets if Xv.shape[0] > 0 and Xtr.shape[0] > 0]

name, X_train, X_val, y_train, y_val = val_datasets[0]
print(f'Dataset: {name}')

x = feature_symbols(2)
c = constant_symbols(6)
time = x[0]
parameter = x[1]
rate = c[0] * parameter ** c[1]
half_time = c[2] * parameter ** c[3]
expression = c[4] / (1 + sp.exp(-rate * (time - half_time))) + c[5]

# Test evaluator version
r1 = eval_from_evaluator(expression, X_train, y_train, X_val, y_val, constants=c, initial_values=[0.1, 0.5, 10.0, -0.5, 1.0, 0.0])
print(f'evaluator version: nmse_train={r1[\"nmse_train\"]:.4f}, nmse_val={r1[\"nmse_val\"]:.4f}')
print(f'  n_val_points={r1.get(\"n_val_points\",\"missing\")}')
print(f'  keys: {list(r1.keys())}')

# Test session version  
r2 = eval_from_session(expression, X_train, y_train, X_val, y_val, constants=c, initial_values=[0.1, 0.5, 10.0, -0.5, 1.0, 0.0])
print(f'session version: nmse_train={r2[\"nmse_train\"]:.4f}, nmse_val={r2[\"nmse_val\"]:.4f}')
print(f'  n_val_points={r2.get(\"n_val_points\",\"missing\")}')
print(f'  keys: {list(r2.keys())}')
