# Log model
cB = constant_symbols(6)
rate_B = cB[0] + cB[1]*sp.log(param)
ht_B = cB[2] + cB[3]*sp.log(param)
exprB = cB[4]/(1+sp.exp(-rate_B*(time-ht_B)))+cB[5]
rB = evaluate_symbolic_expression(exprB, Xtr, ytr, Xv, yv, constants=cB, initial_values=[10.0, 0.0, 0.3, -0.05, 1.0, 0.0])
