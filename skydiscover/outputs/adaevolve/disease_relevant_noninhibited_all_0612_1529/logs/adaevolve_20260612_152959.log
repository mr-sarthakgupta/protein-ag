import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, evaluate_symbolic_expression
import sympy as sp
from pysr_harness.equation_session import constant_symbols, feature_symbols

datasets = load_all_datasets()
val_ds = [(n,Xtr,Xv,ytr,yv) for n,Xtr,Xv,ytr,yv in datasets if Xv.shape[0]>0]
wts = np.array([Xv.shape[0] for _,_,Xv,_,_ in val_ds])

x = feature_symbols(2)
time, param = x[0], x[1]

def test_expr(expr, c, init, label):
    nmses = []
    for name, Xtr, Xv, ytr, yv in val_ds:
        r = evaluate_symbolic_expression(expr, Xtr, ytr, Xv, yv, constants=c, initial_values=init)
        nmses.append(r['nmse_val'])
    wnmse = np.sum(np.array(nmses)*wts)/np.sum(wts)
    worst = sorted(zip(nmses,[n for n,*_ in val_ds]),reverse=True)[:3]
    print(f'{label}: weighted={wnmse:.4f}')
    for v,n in worst: print(f'  {v:.3f} {n[:40]}')

# Best so far: squared sigmoid
cH = constant_symbols(6)
rate_H = cH[0] + cH[1]*sp.log(param)
ht_H = cH[2] + cH[3]*sp.log(param)
exprH = cH[4]/(1+sp.exp(-rate_H*(time-ht_H)))**2+cH[5]
test_expr(exprH, cH, [10.0, 0.0, 0.3, -0.05, 1.0, 0.0], 'squared_sig_log')

# Hill function: c4 * x0^n / (x0^n + c2^n) where n depends on log(x1)
# This is naturally asymmetric - rises faster than sigmoid
cJ = constant_symbols(6)
n_J = cJ[0] + cJ[1]*sp.log(param)  # Hill coefficient
km_J = cJ[2] + cJ[3]*sp.log(param)  # half-max time
exprJ = cJ[4]*time**n_J/(time**n_J + km_J**n_J) + cJ[5]
test_expr(exprJ, cJ, [2.0, 0.0, 0.3, -0.05, 1.0, 0.0], 'hill_log')

# Squared sigmoid with power-law x1 dependence
cK = constant_symbols(6)
rate_K = cK[0]*param**cK[1]
ht_K = cK[2]*param**cK[3]
exprK = cK[4]/(1+sp.exp(-rate_K*(time-ht_K)))**2+cK[5]
test_expr(exprK, cK, [0.1, 0.3, 10.0, -0.5, 1.0, 0.0], 'squared_sig_power')

# Cubed sigmoid
cL = constant_symbols(6)
rate_L = cL[0] + cL[1]*sp.log(param)
ht_L = cL[2] + cL[3]*sp.log(param)
exprL = cL[4]/(1+sp.exp(-rate_L*(time-ht_L)))**3+cL[5]
test_expr(exprL, cL, [10.0, 0.0, 0.3, -0.05, 1.0, 0.0], 'cubed_sig_log')
" 2>&1 | grep -v Warning
