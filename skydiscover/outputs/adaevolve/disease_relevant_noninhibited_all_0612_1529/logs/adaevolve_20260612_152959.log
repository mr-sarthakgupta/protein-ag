    try:
        with single_equation_evaluation():
            result = fn(X_train, y_train, X_val, y_val)
            validate_single_equation_result(result)
        n_val = int(result.get('n_val_points', 0))
        print(f'  {name}: n_val_points={n_val}, nmse_val={result.get(\"nmse_val\")}')
    except Exception as e:
        print(f'  {name}: EXCEPTION {e}')

os.unlink(prog_path)
