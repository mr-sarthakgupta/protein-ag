print(f'Simple logistic: nmse={rD[\"nmse_val\"]:.4f}')

# Check the data shape - how many curves?
for x1 in np.unique(Xv[:,1]):
    mask = Xv[:,1] == x1
    print(f'  x1={x1}: {mask.sum()} points, y range [{yv[mask].min():.3f},{yv[mask].max():.3f}]')
