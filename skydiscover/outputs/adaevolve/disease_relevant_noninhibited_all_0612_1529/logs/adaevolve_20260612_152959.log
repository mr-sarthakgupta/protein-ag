import sys, tempfile, os, subprocess, pickle
sys.path.insert(0, '.')

prog_code = '''from __future__ import annotations
from typing import Any
import sympy as sp
from numpy.typing import NDArray
from pysr_harness.equation_session import constant_symbols, evaluate_expression, feature_symbols

def evaluate_symbolic_candidate(X_train: NDArray, y_train: NDArray, X_val: NDArray, y_val: NDArray) -> dict[str, Any]:
    x = feature_symbols(X_train.shape[1])
    c = constant_symbols(4)
    time = x[0]
    expression = c[0] / (1 + sp.exp(-c[1] * (time - c[2]))) + c[3]
    return evaluate_expression(expression, X_train, y_train, X_val, y_val, constants=c, initial_values=[1.0, 10.0, 0.5, 0.0])

def run_discovery(X_train: NDArray, y_train: NDArray, X_val: NDArray, y_val: NDArray) -> dict[str, Any]:
    return evaluate_symbolic_candidate(X_train, y_train, X_val, y_val)
'''

with tempfile.NamedTemporaryFile(mode='w', suffix='.py', delete=False) as f:
    f.write(prog_code)
    prog_path = f.name

from disease_relevant_noninhibited_all.evaluator import evaluate_candidate_with_timeout
result = evaluate_candidate_with_timeout(prog_path, timeout_seconds=120)
print(f'n_datasets={result.get(\"n_datasets\")}')
print(f'combined={result.get(\"combined_score\")}')
print(f'nmse_val={result.get(\"nmse_val\")}')
print(f'error={result.get(\"error\",\"none\")}')
per = result.get('per_dataset', {})
print(f'per_dataset count={len(per)}')
# Show first few
for name, r in list(per.items())[:3]:
    print(f'  {name}: n_val={r.get(\"n_val_points\",\"?\")} nmse={r.get(\"nmse_val\",\"?\")} err={r.get(\"error\",\"\")}')
os.unlink(prog_path)
