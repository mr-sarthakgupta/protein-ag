 158 | def _function_annotations(node: ast.FunctionDef) -> list[ast.AST]:
 159 |     annotations: list[ast.AST] = []
 160 |     args = node.args
 161 |     for arg in [*args.posonlyargs, *args.args, *args.kwonlyargs]:
 162 |         if arg.annotation is not None:
 163 |             annotations.append(arg.annotation)
 164 |     if args.vararg is not None and args.vararg.annotation is not None:
 165 |         annotations.append(args.vararg.annotation)
 166 |     if args.kwarg is not None and args.kwarg.annotation is not None:
 167 |         annotations.append(args.kwarg.annotation)
 168 |     if node.returns is not None:
 169 |         annotations.append(node.returns)
 170 |     return annotations
