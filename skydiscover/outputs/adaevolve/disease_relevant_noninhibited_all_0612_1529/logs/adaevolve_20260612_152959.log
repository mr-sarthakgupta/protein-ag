    half_time = c[2] * x[1]**c[3]
    expression = c[4] * sp.exp(-sp.exp(-rate * (x[0] - half_time)))
    return evaluate_expression(expression, X_train, y_train, X_val, y_val,
        constants=c, initial_values=[3.0, 0.3, 0.5, -0.3, 1.0])

def run_discovery(X_train, y_train, X_val, y_val):
    return evaluate_symbolic_candidate(X_train, y_train, X_val, y_val)
