import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, evaluate_symbolic_expression
import sympy as sp
from pysr_harness.equation_session import constant_symbols, feature_symbols, _complexity

datasets = load_all_datasets()
val_ds = [(n,Xtr,Xv,ytr,yv) for n,Xtr,Xv,ytr,yv in datasets if Xv.shape[0]>0]
wts = np.array([Xv.shape[0] for _,_,Xv,_,_ in val_ds])

x = feature_symbols(2)
time, param = x[0], x[1]

def test_expr(expr, c, init, label):
    nmses = []
    for name, Xtr, Xv, ytr, yv in val_ds:
        r = evaluate_symbolic_expression(expr, Xtr, ytr, Xv, yv, constants=c, initial_values=init)
        nmses.append(r['nmse_val'])
    wnmse = np.sum(np.array(nmses)*wts)/np.sum(wts)
    worst = sorted(zip(nmses,[n for n,*_ in val_ds]),reverse=True)[:2]
    cmplx = _complexity(expr)
    print(f'{label}: weighted={wnmse:.4f}, complexity={cmplx}')
    for v,n in worst: print(f'  {v:.3f} {n[:40]}')

# Best: cubed sigmoid
cL = constant_symbols(6)
rate_L = cL[0] + cL[1]*sp.log(param)
ht_L = cL[2] + cL[3]*sp.log(param)
exprL = cL[4]/(1+sp.exp(-rate_L*(time-ht_L)))**3+cL[5]
test_expr(exprL, cL, [10.0, 0.0, 0.3, -0.05, 1.0, 0.0], 'cubed_sig_log')

# 4th power
cM = constant_symbols(6)
rate_M = cM[0] + cM[1]*sp.log(param)
ht_M = cM[2] + cM[3]*sp.log(param)
exprM = cM[4]/(1+sp.exp(-rate_M*(time-ht_M)))**4+cM[5]
test_expr(exprM, cM, [10.0, 0.0, 0.3, -0.05, 1.0, 0.0], 'pow4_sig_log')

# Variable power: c4/(1+exp(...))**c5 + c6 - 7 constants but flexible
cN = constant_symbols(7)
rate_N = cN[0] + cN[1]*sp.log(param)
ht_N = cN[2] + cN[3]*sp.log(param)
exprN = cN[4]/(1+sp.exp(-rate_N*(time-ht_N)))**cN[5]+cN[6]
test_expr(exprN, cN, [10.0, 0.0, 0.3, -0.05, 1.0, 2.0, 0.0], 'var_pow_log')

# Cubed sigmoid with power-law x1
cO = constant_symbols(6)
rate_O = cO[0]*param**cO[1]
ht_O = cO[2] + cO[3]*sp.log(param)
exprO = cO[4]/(1+sp.exp(-rate_O*(time-ht_O)))**3+cO[5]
test_expr(exprO, cO, [5.0, 0.3, 0.5, -0.1, 1.0, 0.0], 'cubed_mixed')
