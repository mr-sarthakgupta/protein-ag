import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, _aggregate_per_dataset_results
import numpy as np

# Simulate what the evaluator does - build per_dataset_results
datasets = load_all_datasets()

# Simulate results for all datasets
per_dataset_results = {}
for name, X_train, X_val, y_train, y_val in datasets:
    n_val = X_val.shape[0]
    is_eval_only = X_train.shape[0] == 0 and n_val > 0
    per_dataset_results[name] = {
        'nmse_train': 0.005,
        'nmse_val': 0.005 if n_val > 0 else float('nan'),
        'n_val_points': n_val,
        'evaluation_only': is_eval_only,
        'combined_score': 0.99 if n_val > 0 else 0.0,
        'complexity': 23.0,
        'equation': 'test',
        'equation_template': 'c4/(1 + exp(-c0*x1**c1*(x0 - c2*x1**c3))) + c5',
    }

agg = _aggregate_per_dataset_results(per_dataset_results)
print(f'n_datasets={agg[\"n_datasets\"]}')
print(f'n_successful={agg[\"n_successful\"]}')
print(f'combined_score={agg[\"combined_score\"]}')
print(f'nmse_val={agg[\"nmse_val\"]}')
print(f'error={agg.get(\"error\",\"none\")}')
