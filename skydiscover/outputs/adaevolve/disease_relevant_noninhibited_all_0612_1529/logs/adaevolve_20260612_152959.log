import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, evaluate_symbolic_expression
import sympy as sp
from pysr_harness.equation_session import constant_symbols, feature_symbols

datasets = load_all_datasets()
val_ds = [(n,Xtr,Xv,ytr,yv) for n,Xtr,Xv,ytr,yv in datasets if Xv.shape[0]>0]
wA = np.array([Xv.shape[0] for _,_,Xv,_,_ in val_ds])

x = feature_symbols(2)
time, param = x[0], x[1]

def test_expr(expr, c, init, label):
    nmses = []
    for name, Xtr, Xv, ytr, yv in val_ds:
        r = evaluate_symbolic_expression(expr, Xtr, ytr, Xv, yv, constants=c, initial_values=init)
        nmses.append(r['nmse_val'])
    wnmse = np.sum(np.array(nmses)*wA)/np.sum(wA)
    worst = sorted(zip(nmses,[n for n,*_ in val_ds]),reverse=True)[:2]
    print(f'{label}: weighted={wnmse:.4f}, worst={[(f\"{v:.3f}\",n[:30]) for v,n in worst]}')

# C: log + power combined: rate=c0*x1^c1, half_time=c2+c3*log(x1)
cC = constant_symbols(6)
exprC = cC[4]/(1+sp.exp(-(cC[0]*param**cC[1])*(time-(cC[2]+cC[3]*sp.log(param)))))+cC[5]
test_expr(exprC, cC, [5.0, 0.3, 0.5, -0.1, 1.0, 0.0], 'power_rate+log_ht')

# D: simple logistic, no x1 dependence (baseline)
cD = constant_symbols(4)
exprD = cD[0]/(1+sp.exp(-cD[1]*(time-cD[2])))+cD[3]
test_expr(exprD, cD, [1.0, 10.0, 0.5, 0.0], 'simple_logistic')

# E: log-based with 5 constants (no plateau)
cE = constant_symbols(5)
rate_E = cE[0] + cE[1]*sp.log(param)
ht_E = cE[2] + cE[3]*sp.log(param)
exprE = 1/(1+sp.exp(-rate_E*(time-ht_E))) + cE[4]
test_expr(exprE, cE, [10.0, 0.0, 0.3, -0.05, 0.0], 'log5c')

# F: log-based with tanh instead of sigmoid
cF = constant_symbols(6)
rate_F = cF[0] + cF[1]*sp.log(param)
ht_F = cF[2] + cF[3]*sp.log(param)
exprF = cF[4]*sp.tanh(rate_F*(time-ht_F)) + cF[5]
test_expr(exprF, cF, [10.0, 0.0, 0.3, -0.05, 0.5, 0.5], 'tanh_log')
