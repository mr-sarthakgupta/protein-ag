 600 | 
 601 | def _parsimony_penalty_factor(complexity: float) -> float:
 602 |     """Bounded penalty factor for expression complexity."""
 603 |     if not np.isfinite(complexity) or PARSIMONY_COMPLEXITY_SCALE <= 0:
 604 |         return 1.0
 605 |     normalized = min(max(float(complexity), 0.0) / PARSIMONY_COMPLEXITY_SCALE, 1.0)
 606 |     return max(0.0, 1.0 - PARSIMONY_WEIGHT * normalized)
 607 | 
 608 | 
 609 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 610 |     values = np.asarray(values, dtype=float).ravel()
 611 |     if values.size < 3 or sigma <= 0.0:
 612 |         return values
 613 |     radius = max(1, int(round(3.0 * sigma)))
 614 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 615 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 616 |     kernel /= np.sum(kernel)
 617 |     padded = np.pad(values, (radius, radius), mode="edge")
 618 |     return np.convolve(padded, kernel, mode="valid")
 619 | 
 620 | 
 621 | def _curve_smoothed_target(X: np.ndarray, y_true: np.ndarray) -> np.ndarray:
 622 |     """Smooth targets independently for each parameter curve in time order."""
 623 |     X = np.asarray(X, dtype=float)
 624 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 625 |     if X.shape[0] != y_true.shape[0] or X.shape[1] < 2:
 626 |         return _gaussian_smooth_1d(y_true)
 627 | 
 628 |     smoothed = np.empty_like(y_true, dtype=float)
 629 |     for parameter in np.unique(X[:, 1]):
 630 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 631 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 632 |         smoothed_curve = _gaussian_smooth_1d(y_true[ordered_idx])
 633 |         smoothed[ordered_idx] = smoothed_curve
 634 |     return smoothed
 635 | 
 636 | 
 637 | def _normalized_mse_with_reference_variance(
 638 |     y_true: np.ndarray,
 639 |     y_pred: np.ndarray,
 640 |     reference_values: np.ndarray,
 641 | ) -> float:
 642 |     """MSE normalized by full dataset scale, not by a flat validation segment."""
 643 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 644 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 645 |     reference_values = np.asarray(reference_values, dtype=float).reshape(-1)
 646 |     if y_true.shape != y_pred.shape:
 647 |         return float("inf")
 648 |     if not np.all(np.isfinite(y_pred)):
 649 |         return float("inf")
 650 |     var = float(np.var(reference_values))
 651 |     if var <= 0.0:
 652 |         return float(np.mean((y_true - y_pred) ** 2))
 653 |     return float(np.mean((y_true - y_pred) ** 2) / var)
 654 | 
 655 | 
 656 | def _nmse_with_gaussian_smoothed_target(
 657 |     y_true: np.ndarray,
 658 |     y_pred: np.ndarray,
 659 |     X: np.ndarray | None = None,
 660 |     reference_values: np.ndarray | None = None,
 661 | ) -> float:
 662 |     reference = y_true if reference_values is None else reference_values
 663 |     return _normalized_mse_with_reference_variance(y_true, y_pred, reference)
 664 | 
 665 | 
 666 | def evaluate_symbolic_expression(
 667 |     expression: Any,
 668 |     X_train: np.ndarray,
 669 |     y_train: np.ndarray,
 670 |     X_val: np.ndarray,
 671 |     y_val: np.ndarray,
 672 |     *,
 673 |     constants: Any | None = None,
 674 |     initial_values: Any | None = None,
 675 |     max_nfev: int = 300,
 676 | ) -> dict[str, Any]:
 677 |     """Score a proposed expression by directly predicting normalized response."""
 678 |     import sympy as sp
 679 |     from pysr_harness import equation_session
 680 |     from scipy.optimize import least_squares
 681 | 
 682 |     X_train = np.asarray(X_train, dtype=float)
 683 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 684 |     X_val = np.asarray(X_val, dtype=float)
 685 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 686 |     evaluation_only = X_train.shape[0] == 0 and X_val.shape[0] > 0
 687 |     train_only = X_val.shape[0] == 0 and X_train.shape[0] > 0
 688 |     if evaluation_only:
 689 |         X_fit, y_fit = X_val, y_val
 690 |     else:
 691 |         X_fit, y_fit = X_train, y_train
 692 |     y_reference = np.concatenate([y_train, y_val]) if y_train.size else y_val
 693 |     n_features = X_fit.shape[1] if X_fit.shape[0] else X_val.shape[1]
 694 |     feature_names = [f"x{i}" for i in range(n_features)]
 695 |     template = equation_session._as_sympy_expr(expression, feature_names)
 696 |     equation_session._record_scored_template(template)
 697 | 
 698 |     if constants is None:
 699 |         feature_set = set(equation_session.feature_symbols(n_features))
 700 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 701 |     constants = list(constants)
 702 |     equation_session._validate_expression_template(template, constants)
 703 | 
 704 |     if initial_values is None:
 705 |         x0 = np.ones(len(constants), dtype=float)
 706 |     else:
 707 |         x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 708 |         if x0.size != len(constants):
 709 |             raise ValueError("initial_values must match the number of constants")
 710 | 
 711 |     if not constants:
 712 |         fitted_expr = template
 713 |         fitted_constants = {}
 714 |     else:
 715 |         feature_syms = equation_session.feature_symbols(n_features)
 716 |         X_cols = [X_fit[:, i] for i in range(n_features)]
 717 |         compiled = sp.lambdify(feature_syms + constants, template, modules=["numpy"])
 718 | 
 719 |         def residual(theta: np.ndarray) -> np.ndarray:
 720 |             try:
 721 |                 args = X_cols + [float(v) for v in theta]
 722 |                 prediction = np.asarray(compiled(*args), dtype=float).reshape(-1)
 723 |             except Exception:
 724 |                 return np.full_like(y_fit, 1e12, dtype=float)
 725 |             if prediction.shape != y_fit.shape or not np.all(np.isfinite(prediction)):
 726 |                 return np.full_like(y_fit, 1e12, dtype=float)
 727 |             return prediction - y_fit
 728 | 
 729 |         import warnings
 730 | 
 731 |         with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 732 |             warnings.simplefilter("ignore", RuntimeWarning)
 733 |             fit = least_squares(
 734 |                 residual,
 735 |                 x0,
 736 |                 loss="soft_l1",
 737 |                 max_nfev=max_nfev,
 738 |             )
 739 |         fitted_constants = {
 740 |             str(symbol): float(value) for symbol, value in zip(constants, fit.x)
 741 |         }
 742 |         fitted_expr = template.subs(dict(zip(constants, fit.x)))
 743 | 
 744 |     y_pred_fit = equation_session._predict(fitted_expr, X_fit, feature_names)
 745 |     y_pred_train = (
 746 |         np.empty(0, dtype=float)
 747 |         if evaluation_only
 748 |         else equation_session._predict(fitted_expr, X_train, feature_names)
 749 |     )
 750 |     y_pred_val = (
 751 |         np.empty(0, dtype=float)
 752 |         if train_only
 753 |         else equation_session._predict(fitted_expr, X_val, feature_names)
 754 |     )
 755 |     nmse_train = (
 756 |         float("nan")
 757 |         if evaluation_only
 758 |         else _nmse_with_gaussian_smoothed_target(
 759 |             y_train, y_pred_train, X_train, y_reference
 760 |         )
 761 |     )
 762 |     nmse_val = (
 763 |         float("nan")
 764 |         if train_only
 765 |         else _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 766 |     )
 767 |     loss = float(np.mean((y_pred_fit - y_fit) ** 2))
 768 | 
 769 |     result = {
 770 |         "equation_template": str(template),
 771 |         "equation": str(fitted_expr),
 772 |         "constants": fitted_constants,
 773 |         "loss": loss,
 774 |         "complexity": equation_session._complexity(template),
 775 |         "nmse_train": nmse_train,
 776 |         "nmse_val": nmse_val,
 777 |         "n_val_points": int(len(y_val)),
 778 |         "evaluation_only": evaluation_only,
 779 |         "train_only": train_only,
 780 |         "combined_score": (
 781 |             0.0
 782 |             if train_only or not np.isfinite(nmse_val)
 783 |             else combined_score_from_nmse(nmse_val)
 784 |         ),
 785 |     }
 786 |     equation_session._record_scorer_result(result)
 787 |     return result
 788 | 
 789 | 
 790 | def _point_weighted_mean(
 791 |     values: list[float],
 792 |     weights: list[int],
 793 | ) -> float:
 794 |     """Average values with one weight per evaluation point."""
 795 |     total_weight = sum(weights)
 796 |     if total_weight <= 0:
 797 |         return float("inf")
 798 |     weighted = sum(
 799 |         float(value) * float(weight)
 800 |         for value, weight in zip(values, weights)
 801 |         if np.isfinite(float(value))
 802 |     )
 803 |     if not np.isfinite(weighted):
 804 |         return float("inf")
 805 |     return float(weighted / total_weight)
 806 | 
 807 | 
 808 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 809 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 810 |     scoring_results = {
 811 |         name: result
 812 |         for name, result in per_dataset_results.items()
 813 |         if int(result.get("n_val_points", 0)) > 0
 814 |     }
 815 |     raw_nmse_vals = [float(r["nmse_val"]) for r in scoring_results.values()]
 816 |     nmse_vals = list(raw_nmse_vals)
 817 |     train_nmse_vals = [
 818 |         float(r["nmse_train"])
 819 |         for r in per_dataset_results.values()
 820 |         if np.isfinite(float(r.get("nmse_train", float("inf"))))
 821 |     ]
 822 |     complexity_vals = []
 823 |     for r in per_dataset_results.values():
 824 |         try:
 825 |             value = float(r.get("complexity", float("nan")))
 826 |         except (TypeError, ValueError):
 827 |             continue
 828 |         if np.isfinite(value):
 829 |             complexity_vals.append(value)
 830 |     aggregate_complexity = float(max(complexity_vals)) if complexity_vals else 0.0
 831 | 
 832 |     violation_errors = sorted(
 833 |         {
 834 |             str(r.get("error"))
 835 |             for r in per_dataset_results.values()
 836 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 837 |         }
 838 |     )
 839 |     failed_datasets = sorted(
 840 |         name
 841 |         for name, result in scoring_results.items()
 842 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 843 |     )
 844 |     templates = sorted(
 845 |         {
 846 |             str(r.get("equation_template"))
 847 |             for r in per_dataset_results.values()
 848 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 849 |         }
 850 |     )
 851 | 
 852 |     eq_template = ""
 853 |     for r in per_dataset_results.values():
 854 |         if r.get("equation"):
 855 |             eq_template = r["equation"]
 856 |             break
 857 | 
 858 |     hard_cases = [
 859 |         {"dataset": name, "nmse_val": float(result["nmse_val"])}
 860 |         for name, result in scoring_results.items()
 861 |         if np.isfinite(float(result.get("nmse_val", float("inf"))))
 862 |     ]
 863 |     hard_cases.sort(key=lambda item: item["nmse_val"], reverse=True)
 864 |     hard_cases = hard_cases[:5]
 865 |     hard_case_feedback = "; ".join(
 866 |         f"{case['dataset']} nmse={case['nmse_val']:.4g}" for case in hard_cases
 867 |     )
 868 | 
 869 |     violation_error = None
 870 |     if violation_errors:
 871 |         violation_error = violation_errors[0]
 872 |     elif failed_datasets:
 873 |         examples = ", ".join(failed_datasets[:3])
 874 |         violation_error = (
 875 |             "Single-equation violation: candidate failed on "
 876 |             f"{len(failed_datasets)}/{len(scoring_results)} validation datasets. "
 877 |             "Failed datasets are not dropped from the aggregate reward. "
 878 |             f"Examples: {examples}"
 879 |         )
 880 |     elif len(templates) > 1:
 881 |         examples = "; ".join(templates[:3])
