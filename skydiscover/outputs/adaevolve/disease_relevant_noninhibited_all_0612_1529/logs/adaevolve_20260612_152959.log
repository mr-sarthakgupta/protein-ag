import sys, csv
sys.path.insert(0, '.')

DATA_ROOT = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'

# Check a few datasets to understand x1 (parameter) values
import os, re
import numpy as np

def parse_param(col):
    text = col.strip().rsplit(':', 1)[-1].strip().strip(\"'\\\"\")
    m = re.search(r'(\d+(?:\.\d+)?)\s*uM', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*mM', text, re.IGNORECASE)
    if m: return float(m.group(1)) * 1000.0
    m = re.search(r'(\d+(?:\.\d+)?)\s*mg/mL', text, re.IGNORECASE)
    if m: return float(m.group(1))
    return None

datasets = []
for dirpath, _, filenames in os.walk(DATA_ROOT):
    if 'fit.tsv' in filenames:
        rel = os.path.relpath(dirpath, DATA_ROOT).replace(os.sep, '/')
        datasets.append((rel, os.path.join(dirpath, 'fit.tsv')))
datasets.sort()

for name, path in datasets[:10]:
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [r for r in reader if r]
    params = [parse_param(h) for h in header[1:]]
    params = [p for p in params if p is not None]
    print(f'{name}: {len(params)} curves, params={params[:5]}')
