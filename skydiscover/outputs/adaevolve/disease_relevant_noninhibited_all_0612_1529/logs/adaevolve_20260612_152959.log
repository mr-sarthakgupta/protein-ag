import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, evaluate_symbolic_expression
import sympy as sp
from pysr_harness.equation_session import constant_symbols, feature_symbols

datasets = load_all_datasets()
val_ds = [(n,Xtr,Xv,ytr,yv) for n,Xtr,Xv,ytr,yv in datasets if Xv.shape[0]>0]
wts = np.array([Xv.shape[0] for _,_,Xv,_,_ in val_ds])

x = feature_symbols(2)
time, param = x[0], x[1]

def test_expr(expr, c, init, label):
    nmses = []
    for name, Xtr, Xv, ytr, yv in val_ds:
        r = evaluate_symbolic_expression(expr, Xtr, ytr, Xv, yv, constants=c, initial_values=init)
        nmses.append(r['nmse_val'])
    wnmse = np.sum(np.array(nmses)*wts)/np.sum(wts)
    worst = sorted(zip(nmses,[n for n,*_ in val_ds]),reverse=True)[:3]
    print(f'{label}: weighted={wnmse:.4f}')
    for v,n in worst: print(f'  {v:.3f} {n[:40]}')

# Best so far: log model
cB = constant_symbols(6)
rate_B = cB[0] + cB[1]*sp.log(param)
ht_B = cB[2] + cB[3]*sp.log(param)
exprB = cB[4]/(1+sp.exp(-rate_B*(time-ht_B)))+cB[5]
test_expr(exprB, cB, [10.0, 0.0, 0.3, -0.05, 1.0, 0.0], 'log6c_baseline')

# G: log model + extra steepness term c5*x0^c6
cG = constant_symbols(7)
rate_G = cG[0] + cG[1]*sp.log(param)
ht_G = cG[2] + cG[3]*sp.log(param)
exprG = cG[4]/(1+sp.exp(-rate_G*(time-ht_G)))+cG[5]
test_expr(exprG, cG, [10.0, 0.0, 0.3, -0.05, 1.0, 0.0, 0.0], 'log7c')

# H: log model where rate also depends on x0 (time-varying rate)
cH = constant_symbols(6)
rate_H = cH[0] + cH[1]*sp.log(param)
ht_H = cH[2] + cH[3]*sp.log(param)
# Steeper sigmoid with exponent
exprH = cH[4]/(1+sp.exp(-rate_H*(time-ht_H)))**2+cH[5]
test_expr(exprH, cH, [10.0, 0.0, 0.3, -0.05, 1.0, 0.0], 'log_squared_sig')

# I: Gompertz-like: c4*exp(-exp(-rate*(x0-ht))) + c5
cI = constant_symbols(6)
rate_I = cI[0] + cI[1]*sp.log(param)
ht_I = cI[2] + cI[3]*sp.log(param)
exprI = cI[4]*sp.exp(-sp.exp(-rate_I*(time-ht_I)))+cI[5]
test_expr(exprI, cI, [10.0, 0.0, 0.3, -0.05, 1.0, 0.0], 'gompertz_log')
