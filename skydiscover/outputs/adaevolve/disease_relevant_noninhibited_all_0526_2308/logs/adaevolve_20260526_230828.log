 101 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 102 |     """Load a wide fit.tsv and return X=[measurement_x, parameter], y.
 103 | 
 104 |     The first column is always the time/measurement coordinate. Remaining
 105 |     columns are response curves. The varying parameter (concentration, pH,
 106 |     etc.) is extracted from the header; if extraction fails, sequential
 107 |     indices 1, 2, 3, ... are used.
 108 |     """
 109 |     with data_file.open(newline="") as f:
 110 |         reader = csv.reader(f, delimiter="\t")
 111 |         header = next(reader)
 112 | 
 113 |         response_headers = header[1:]
 114 |         parsed_params = [_parse_parameter_from_column(h) for h in response_headers]
 115 |         if all(p is not None for p in parsed_params):
 116 |             parameters = [float(p) for p in parsed_params]
 117 |         else:
 118 |             parameters = [float(i + 1) for i in range(len(response_headers))]
 119 | 
 120 |         features: list[list[float]] = []
 121 |         targets: list[float] = []
 122 |         for row in reader:
 123 |             if not row:
 124 |                 continue
 125 |             measurement_x = float(row[0])
 126 |             for param, value in zip(parameters, row[1:]):
 127 |                 if value == "" or value.strip().lower() == "nan":
 128 |                     continue
 129 |                 features.append([measurement_x, param])
 130 |                 targets.append(float(value))
 131 | 
 132 |     if not features:
 133 |         raise ValueError(f"No regression samples loaded from {data_file}")
 134 | 
 135 |     return np.asarray(features, dtype=float), np.asarray(targets, dtype=float)
 136 | 
 137 | 
 138 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 139 |     """Recursively find all fit.tsv files and return (dataset_name, path) pairs."""
 140 |     datasets: list[tuple[str, Path]] = []
 141 |     for dirpath, _dirnames, filenames in os.walk(root):
 142 |         if "fit.tsv" in filenames:
 143 |             fit_path = Path(dirpath) / "fit.tsv"
 144 |             rel = fit_path.parent.relative_to(root)
 145 |             name = str(rel).replace(os.sep, "/")
 146 |             datasets.append((name, fit_path))
 147 |     datasets.sort(key=lambda x: x[0])
 148 |     return datasets
 149 | 
 150 | 
 151 | def load_dataset(data_file: Path) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 152 |     """Load a single fit.tsv and return deterministic train/val split."""
 153 |     X, y = _load_fit_table(data_file)
 154 |     rng = np.random.default_rng(RANDOM_STATE)
 155 |     indices = rng.permutation(len(y))
 156 |     split = int(round(len(y) * (1.0 - TEST_SIZE)))
 157 |     train_idx = indices[:split]
 158 |     val_idx = indices[split:]
 159 |     return X[train_idx], X[val_idx], y[train_idx], y[val_idx]
 160 | 
 161 | 
 162 | def load_all_datasets(
 163 |     root: Path = DATA_ROOT,
 164 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 165 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 166 |     entries = discover_datasets(root)
 167 |     results = []
 168 |     for name, path in entries:
 169 |         try:
 170 |             X_train, X_val, y_train, y_val = load_dataset(path)
 171 |             results.append((name, X_train, X_val, y_train, y_val))
 172 |         except Exception as exc:
 173 |             print(f"Warning: skipping dataset {name}: {exc}")
 174 |     return results
