 101 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 102 |     """Load a wide fit.tsv and return X=[measurement_x, parameter], y.
 103 | 
 104 |     The first column is always the time/measurement coordinate. Remaining
 105 |     columns are response curves. The varying parameter (concentration, pH,
 106 |     etc.) is extracted from the header; if extraction fails, sequential
 107 |     indices 1, 2, 3, ... are used.
 108 |     """
 109 |     with data_file.open(newline="") as f:
 110 |         reader = csv.reader(f, delimiter="\t")
 111 |         header = next(reader)
 112 | 
 113 |         response_headers = header[1:]
 114 |         parsed_params = [_parse_parameter_from_column(h) for h in response_headers]
 115 |         if all(p is not None for p in parsed_params):
 116 |             parameters = [float(p) for p in parsed_params]
 117 |         else:
 118 |             parameters = [float(i + 1) for i in range(len(response_headers))]
 119 | 
 120 |         features: list[list[float]] = []
 121 |         targets: list[float] = []
 122 |         for row in reader:
 123 |             if not row:
 124 |                 continue
 125 |             measurement_x = float(row[0])
 126 |             for param, value in zip(parameters, row[1:]):
 127 |                 if value == "" or value.strip().lower() == "nan":
 128 |                     continue
 129 |                 features.append([measurement_x, param])
 130 |                 targets.append(float(value))
 131 | 
 132 |     if not features:
 133 |         raise ValueError(f"No regression samples loaded from {data_file}")
 134 | 
 135 |     return np.asarray(features, dtype=float), np.asarray(targets, dtype=float)
 136 | 
