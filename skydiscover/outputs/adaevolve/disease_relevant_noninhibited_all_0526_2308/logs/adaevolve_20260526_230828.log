 379 | def _eval_stage1_worker(args):
 380 |     """Module-level worker for stage 1 parallel evaluation."""
 381 |     name, X_train, X_val, y_train, y_val, program_path = args
 382 |     harness_root = str(BENCHMARK_ROOT)
 383 |     if harness_root not in sys.path:
 384 |         sys.path.insert(0, harness_root)
 385 |     spec = importlib.util.spec_from_file_location("program", program_path)
 386 |     program = importlib.util.module_from_spec(spec)
 387 |     spec.loader.exec_module(program)
 388 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
 389 |         program, "run_discovery", None
 390 |     )
 391 |     if fn is None:
 392 |         return 0.0
 393 |     n = min(200, len(X_train))
 394 |     m = min(80, len(X_val))
 395 |     try:
 396 |         result = fn(X_train[:n], y_train[:n], X_val[:m], y_val[:m])
 397 |         return float(result.get("combined_score", 0.0))
 398 |     except Exception:
 399 |         return 0.0
