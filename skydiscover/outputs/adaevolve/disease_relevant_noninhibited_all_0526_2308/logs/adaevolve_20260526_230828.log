 402 | def evaluate_stage1(program_path: str) -> dict:
 403 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
 404 |     try:
 405 |         harness_root = str(BENCHMARK_ROOT)
 406 |         if harness_root not in sys.path:
 407 |             sys.path.insert(0, harness_root)
 408 | 
 409 |         all_datasets = load_all_datasets()
 410 |         rng = np.random.default_rng(RANDOM_STATE)
 411 |         if len(all_datasets) > 8:
 412 |             indices = rng.choice(len(all_datasets), size=8, replace=False)
 413 |             subset = [all_datasets[i] for i in sorted(indices)]
 414 |         else:
 415 |             subset = all_datasets
 416 | 
 417 |         work_items = [
 418 |             (name, X_train, X_val, y_train, y_val, program_path)
 419 |             for name, X_train, X_val, y_train, y_val in subset
 420 |         ]
 421 | 
 422 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
 423 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
 424 |             combined_scores = [future.result() for future in concurrent.futures.as_completed(futures)]
 425 | 
 426 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
 427 |         return {"combined_score": agg_combined}
 428 |     except Exception as exc:
 429 |         print(f"Stage 1 evaluation failed: {exc}")
 430 |         return {"combined_score": 0.0, "error": str(exc)}
 431 | 
