 325 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
 326 |     nmse_val = float(result.get("nmse_val", float("inf")))
 327 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
 328 |     if not np.isfinite(combined):
