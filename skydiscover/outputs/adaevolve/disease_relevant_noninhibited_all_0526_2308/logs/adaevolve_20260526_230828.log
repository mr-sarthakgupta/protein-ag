 180 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 181 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 182 | 
 183 |     The subprocess loads every dataset, calls the candidate's
 184 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 185 |     constants each time) using parallel threads, and returns aggregated
 186 |     metrics.
 187 |     """
