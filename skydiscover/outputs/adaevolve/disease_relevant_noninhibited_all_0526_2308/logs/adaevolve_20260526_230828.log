 413 |             subset = [all_datasets[i] for i in sorted(indices)]
 414 |         else:
 415 |             subset = all_datasets
 416 | 
 417 |         work_items = [
 418 |             (name, X_train, X_val, y_train, y_val, program_path)
 419 |             for name, X_train, X_val, y_train, y_val in subset
 420 |         ]
 421 | 
 422 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
 423 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
