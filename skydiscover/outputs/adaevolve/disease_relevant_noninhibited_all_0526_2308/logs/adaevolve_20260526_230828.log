  48 | def _parse_parameter_from_column(column_name: str) -> float | None:
  49 |     """Extract a numeric parameter value from a fit.tsv column header.
  50 | 
  51 |     Handles diverse header formats found across disease-relevant datasets:
  52 |       - "... : 10uM"  or "10 uM"  → 10.0
  53 |       - "35uM" (bare, as in Abeta) → 35.0
  54 |       - "... : 3.95mM"             → 3950.0  (converted to uM)
  55 |       - "... : 0.3 mg/mL 22uM"    → 22.0    (prefer uM when both present)
  56 |       - "... : pH 2.7"             → 2.7
  57 |       - "... : 5% seeds"           → 5.0
  58 |       - "20 ng/ul"                 → 20.0
  59 |       - Non-numeric labels (WT, C19S, acid 10min, ...) → None
  60 |     """
  61 |     text = column_name.strip()
  62 | 
  63 |     # Prefer an explicit uM value
  64 |     m = re.search(r"(\d+(?:\.\d+)?)\s*uM", text, re.IGNORECASE)
  65 |     if m:
  66 |         return float(m.group(1))
  67 | 
  68 |     # mM → convert to uM
  69 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mM", text, re.IGNORECASE)
  70 |     if m:
  71 |         return float(m.group(1)) * 1000.0
  72 | 
  73 |     # mg/mL (take the number)
  74 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mg/mL", text, re.IGNORECASE)
  75 |     if m:
  76 |         return float(m.group(1))
  77 | 
  78 |     # ng/ul
  79 |     m = re.search(r"(\d+(?:\.\d+)?)\s*ng/ul", text, re.IGNORECASE)
  80 |     if m:
  81 |         return float(m.group(1))
  82 | 
  83 |     # pH value
  84 |     m = re.search(r"pH\s+(\d+(?:\.\d+)?)", text, re.IGNORECASE)
  85 |     if m:
  86 |         return float(m.group(1))
  87 | 
  88 |     # Percentage (e.g. "5% seeds")
  89 |     m = re.search(r"(\d+(?:\.\d+)?)\s*%", text)
  90 |     if m:
  91 |         return float(m.group(1))
  92 | 
  93 |     # Last resort: try to find any trailing number after colon/space
  94 |     m = re.search(r":\s*(\d+(?:\.\d+)?)\s*$", text)
  95 |     if m:
  96 |         return float(m.group(1))
  97 | 
  98 |     return None
