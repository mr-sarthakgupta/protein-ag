  25 | BENCHMARK_ROOT = Path(__file__).resolve().parents[1]
  26 | if str(BENCHMARK_ROOT) not in sys.path:
  27 |     sys.path.insert(0, str(BENCHMARK_ROOT))
  28 | 
  29 | import importlib.util as _ilu
  30 | 
  31 | import numpy as np
  32 | 
  33 | # Import metrics directly to avoid triggering pysr_harness.__init__'s
  34 | # heavy pysr/Julia imports (only needed at candidate evaluation time).
  35 | _metrics_spec = _ilu.spec_from_file_location(
  36 |     "pysr_harness.metrics",
  37 |     str(BENCHMARK_ROOT / "pysr_harness" / "metrics.py"),
  38 | )
  39 | _metrics_mod = _ilu.module_from_spec(_metrics_spec)
  40 | _metrics_spec.loader.exec_module(_metrics_mod)
  41 | combined_score_from_nmse = _metrics_mod.combined_score_from_nmse
