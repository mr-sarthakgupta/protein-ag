 180 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 181 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 182 | 
 183 |     The subprocess loads every dataset, calls the candidate's
 184 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 185 |     constants each time) using parallel threads, and returns aggregated
 186 |     metrics.
 187 |     """
 188 |     harness_root = str(BENCHMARK_ROOT)
 189 |     evaluator_path = str(Path(__file__).resolve())
 190 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
 191 |         script = f"""
 192 | import importlib.util
 193 | import os
 194 | import pickle
 195 | import sys
 196 | import traceback
 197 | from concurrent.futures import ThreadPoolExecutor, as_completed
 198 | 
 199 | os.environ.setdefault("OMP_NUM_THREADS", "1")
 200 | os.environ.setdefault("MKL_NUM_THREADS", "1")
 201 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
 202 | 
 203 | import numpy as np
 204 | 
 205 | sys.path.insert(0, {harness_root!r})
 206 | 
 207 | program_path = {program_path!r}
 208 | evaluator_path = {evaluator_path!r}
 209 | results_path = {temp_file.name + ".results"!r}
 210 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 211 | 
 212 | def _write_payload_and_exit(payload):
 213 |     with open(results_path, "wb") as f:
 214 |         pickle.dump(payload, f)
 215 |     sys.stdout.flush()
 216 |     sys.stderr.flush()
 217 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
 218 |     # interpreter shutdown. The parent only needs the pickle payload.
 219 |     os._exit(0)
 220 | 
 221 | try:
 222 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
 223 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
 224 |     evaluator_spec.loader.exec_module(evaluator)
 225 | 
 226 |     spec = importlib.util.spec_from_file_location("program", program_path)
 227 |     program = importlib.util.module_from_spec(spec)
 228 |     spec.loader.exec_module(program)
 229 | 
 230 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
 231 |         program, "run_discovery", None
 232 |     )
 233 |     if fn is None:
 234 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
 235 | 
 236 |     datasets = evaluator.load_all_datasets()
 237 | 
 238 |     def _eval_one(args):
 239 |         ds_name, X_train, X_val, y_train, y_val = args
 240 |         try:
 241 |             result = fn(X_train, y_train, X_val, y_val)
 242 |             ds_nmse = float(result.get("nmse_val", float("inf")))
 243 |             ds_combined = float(result.get("combined_score", 0.0))
 244 |             return ds_name, {{
 245 |                 "nmse_val": ds_nmse,
 246 |                 "combined_score": ds_combined,
 247 |                 "equation": str(result.get("equation", "")),
 248 |                 "constants": result.get("constants", {{}}),
 249 |             }}
 250 |         except Exception as exc:
 251 |             return ds_name, {{
 252 |                 "nmse_val": float("inf"),
 253 |                 "combined_score": 0.0,
 254 |                 "error": str(exc),
 255 |             }}
 256 | 
 257 |     per_dataset_results = {{}}
 258 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
 259 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
 260 |         for future in as_completed(futures):
 261 |             ds_name, ds_result = future.result()
 262 |             per_dataset_results[ds_name] = ds_result
 263 | 
 264 |     combined_scores = [r["combined_score"] for r in per_dataset_results.values()]
 265 |     nmse_vals = [r["nmse_val"] for r in per_dataset_results.values()]
 266 |     finite_nmse = [v for v in nmse_vals if np.isfinite(v)]
 267 |     agg_nmse = float(np.mean(finite_nmse)) if finite_nmse else float("inf")
 268 |     agg_combined = float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
 269 | 
 270 |     eq_template = ""
 271 |     for r in per_dataset_results.values():
 272 |         if r.get("equation"):
 273 |             eq_template = r["equation"]
 274 |             break
 275 | 
 276 |     aggregated = {{
 277 |         "equation": eq_template,
 278 |         "nmse_val": agg_nmse,
 279 |         "combined_score": agg_combined,
 280 |         "n_datasets": len(datasets),
 281 |         "n_successful": sum(1 for s in combined_scores if s > 0),
 282 |         "per_dataset": per_dataset_results,
 283 |     }}
 284 | 
 285 |     _write_payload_and_exit({{"result": aggregated}})
 286 | except Exception as exc:
 287 |     traceback.print_exc()
 288 |     _write_payload_and_exit({{"error": str(exc)}})
 289 | """
 290 |         temp_file.write(script.encode())
 291 |         temp_path = temp_file.name
 292 | 
 293 |     results_path = f"{temp_path}.results"
 294 |     try:
 295 |         process = subprocess.Popen(
 296 |             [sys.executable, temp_path],
 297 |             stdout=subprocess.PIPE,
 298 |             stderr=subprocess.PIPE,
 299 |         )
 300 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
 301 |         if stdout:
 302 |             print(stdout.decode())
 303 |         if stderr:
 304 |             print(stderr.decode())
 305 |         if process.returncode != 0:
 306 |             raise RuntimeError(f"Subprocess exited with code {process.returncode}")
 307 |         if not os.path.exists(results_path):
 308 |             raise RuntimeError("Results file not found")
 309 |         with open(results_path, "rb") as f:
 310 |             payload = pickle.load(f)
 311 |         if "error" in payload:
 312 |             raise RuntimeError(payload["error"])
 313 |         return payload["result"]
 314 |     except subprocess.TimeoutExpired:
 315 |         process.kill()
 316 |         process.wait()
 317 |         raise TimeoutError(f"Program execution timed out after {timeout_seconds}s")
 318 |     finally:
 319 |         for path in (temp_path, results_path):
 320 |             if os.path.exists(path):
 321 |                 os.unlink(path)
 322 | 
 323 | 
 324 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
 325 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
 326 |     nmse_val = float(result.get("nmse_val", float("inf")))
 327 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
 328 |     if not np.isfinite(combined):
 329 |         combined = 0.0
 330 | 
 331 |     return {
 332 |         "equation": str(result.get("equation", "")),
 333 |         "loss": nmse_val,
 334 |         "complexity": 0.0,
 335 |         "nmse_train": float("inf"),
 336 |         "nmse_val": nmse_val,
 337 |         "combined_score": combined,
 338 |         "eval_time": float(eval_time),
 339 |         "n_datasets": result.get("n_datasets", 0),
 340 |         "n_successful": result.get("n_successful", 0),
 341 |         "per_dataset": result.get("per_dataset", {}),
 342 |     }
 343 | 
 344 | 
 345 | def evaluate(program_path: str) -> dict:
 346 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
 347 |     try:
 348 |         start = time.time()
 349 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=3000)
 350 |         metrics = _metrics_from_result(result, time.time() - start)
 351 |         print(
 352 |             "Evaluation: "
 353 |             f"nmse_val={metrics['nmse_val']:.6f}, "
 354 |             f"combined_score={metrics['combined_score']:.6f}, "
 355 |             f"n_datasets={metrics['n_datasets']}, "
 356 |             f"n_successful={metrics['n_successful']}, "
 357 |             f"time={metrics['eval_time']:.2f}s"
 358 |         )
 359 |         print(f"Equation template: {metrics['equation']}")
 360 |         return metrics
 361 |     except Exception as exc:
 362 |         print(f"Evaluation failed: {exc}")
 363 |         traceback.print_exc()
 364 |         return {
 365 |             "equation": "",
 366 |             "loss": float("inf"),
 367 |             "complexity": 0.0,
 368 |             "nmse_train": float("inf"),
 369 |             "nmse_val": float("inf"),
 370 |             "combined_score": 0.0,
 371 |             "eval_time": 0.0,
 372 |             "n_datasets": 0,
 373 |             "n_successful": 0,
 374 |             "per_dataset": {},
 375 |             "error": str(exc),
 376 |         }
 377 | 
 378 | 
 379 | def _eval_stage1_worker(args):
 380 |     """Module-level worker for stage 1 parallel evaluation."""
 381 |     name, X_train, X_val, y_train, y_val, program_path = args
 382 |     harness_root = str(BENCHMARK_ROOT)
 383 |     if harness_root not in sys.path:
 384 |         sys.path.insert(0, harness_root)
 385 |     spec = importlib.util.spec_from_file_location("program", program_path)
 386 |     program = importlib.util.module_from_spec(spec)
 387 |     spec.loader.exec_module(program)
 388 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
 389 |         program, "run_discovery", None
 390 |     )
 391 |     if fn is None:
 392 |         return 0.0
 393 |     n = min(200, len(X_train))
 394 |     m = min(80, len(X_val))
 395 |     try:
 396 |         result = fn(X_train[:n], y_train[:n], X_val[:m], y_val[:m])
 397 |         return float(result.get("combined_score", 0.0))
 398 |     except Exception:
 399 |         return 0.0
 400 | 
 401 | 
 402 | def evaluate_stage1(program_path: str) -> dict:
 403 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
 404 |     try:
 405 |         harness_root = str(BENCHMARK_ROOT)
 406 |         if harness_root not in sys.path:
 407 |             sys.path.insert(0, harness_root)
 408 | 
 409 |         all_datasets = load_all_datasets()
 410 |         rng = np.random.default_rng(RANDOM_STATE)
 411 |         if len(all_datasets) > 8:
 412 |             indices = rng.choice(len(all_datasets), size=8, replace=False)
 413 |             subset = [all_datasets[i] for i in sorted(indices)]
 414 |         else:
 415 |             subset = all_datasets
 416 | 
 417 |         work_items = [
 418 |             (name, X_train, X_val, y_train, y_val, program_path)
 419 |             for name, X_train, X_val, y_train, y_val in subset
 420 |         ]
 421 | 
 422 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
 423 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
 424 |             combined_scores = [future.result() for future in concurrent.futures.as_completed(futures)]
 425 | 
 426 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
 427 |         return {"combined_score": agg_combined}
 428 |     except Exception as exc:
 429 |         print(f"Stage 1 evaluation failed: {exc}")
 430 |         return {"combined_score": 0.0, "error": str(exc)}
 431 | 
 432 | 
 433 | def evaluate_stage2(program_path: str) -> dict:
 434 |     """Full evaluation for cascade stage 2."""
 435 |     return evaluate(program_path)
