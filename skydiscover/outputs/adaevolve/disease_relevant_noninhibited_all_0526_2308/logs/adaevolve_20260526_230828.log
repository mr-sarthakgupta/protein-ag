 285 |     _write_payload_and_exit({{"result": aggregated}})
 286 | except Exception as exc:
 287 |     traceback.print_exc()
 288 |     _write_payload_and_exit({{"error": str(exc)}})
 289 | """
 290 |         temp_file.write(script.encode())
 291 |         temp_path = temp_file.name
 292 | 
 293 |     results_path = f"{temp_path}.results"
 294 |     try:
 295 |         process = subprocess.Popen(
 296 |             [sys.executable, temp_path],
 297 |             stdout=subprocess.PIPE,
 298 |             stderr=subprocess.PIPE,
 299 |         )
 300 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
 301 |         if stdout:
 302 |             print(stdout.decode())
 303 |         if stderr:
 304 |             print(stderr.decode())
