 402 | def evaluate_stage1(program_path: str) -> dict:
 403 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
 404 |     try:
 405 |         harness_root = str(BENCHMARK_ROOT)
 406 |         if harness_root not in sys.path:
