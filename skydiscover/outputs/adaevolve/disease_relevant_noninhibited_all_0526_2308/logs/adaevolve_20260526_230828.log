 138 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 139 |     """Recursively find all fit.tsv files and return (dataset_name, path) pairs."""
 140 |     datasets: list[tuple[str, Path]] = []
 141 |     for dirpath, _dirnames, filenames in os.walk(root):
 142 |         if "fit.tsv" in filenames:
 143 |             fit_path = Path(dirpath) / "fit.tsv"
 144 |             rel = fit_path.parent.relative_to(root)
 145 |             name = str(rel).replace(os.sep, "/")
 146 |             datasets.append((name, fit_path))
 147 |     datasets.sort(key=lambda x: x[0])
 148 |     return datasets
 149 | 
