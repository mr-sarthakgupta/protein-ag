import os, csv, numpy as np, sys
sys.path.insert(0, '.')

path = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited'
all_files = []
for dirpath, dirnames, filenames in os.walk(path):
    if 'fit.tsv' in filenames:
        all_files.append(os.path.join(dirpath, 'fit.tsv'))
all_files.sort()

# Load a few datasets and look at y-value shapes to understand the data
for f in all_files[:3]:
    rel = f.replace(path+'/', '')
    with open(f) as fh:
        reader = csv.reader(fh, delimiter='\t')
        header = next(reader)
        rows = [[float(v) if v and v.strip().lower() != 'nan' else None for v in r] for r in reader if r]
    
    # Show x0 and y for first curve
    x0 = [r[0] for r in rows if r[0] is not None]
    y1 = [r[1] for r in rows if len(r) > 1 and r[1] is not None]
    print(f'{rel}:')
    print(f'  x0 range: [{min(x0):.2f}, {max(x0):.2f}], n={len(x0)}')
    print(f'  y range: [{min(y1):.4f}, {max(y1):.4f}]')
    # Show a few y values to see sigmoidal shape
    step = max(1, len(y1)//10)
    print(f'  y sample: {[round(y1[i],3) for i in range(0,len(y1),step)[:10]]}')
    print()
"
