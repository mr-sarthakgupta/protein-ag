$ python3 -c "
import csv, os, numpy as np
from pathlib import Path

root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

# Look at a few representative datasets to understand curve shapes
test_paths = [
    'Abeta/Cohen2013/Ab42_sec_IN_HOURS',
    'htt/Kar2011/Fits/Kar2011_Q37_sec',
    'IAPP/Daval2010/Fits/Daval2010_sec',
    'biofilm proteins/CsgA/CsgA_sec_IN_HOURS',
]

for rel in test_paths:
    p = root / rel / 'fit.tsv'
    with open(p) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [[float(v) if v.strip() and v.strip().lower()!='nan' else float('nan') for v in r] for r in reader if r]
    arr = np.array(rows)
    t = arr[:,0]
    y_cols = arr[:,1:]
    print(f'Dataset: {rel}')
    print(f'  headers: {header[1:4]}')
    print(f'  t: [{t[0]:.3g}, {t[-1]:.3g}], n={len(t)}')
    # Check shape: look at first curve
    y0 = y_cols[:,0]
    valid = np.isfinite(y0)
    tv = t[valid]; yv = y0[valid]
    # Find where curve rises above 10% and 90%
    t10 = tv[np.searchsorted(yv, 0.1)] if np.any(yv > 0.1) else float('nan')
    t90 = tv[np.searchsorted(yv, 0.9)] if np.any(yv > 0.9) else float('nan')
    print(f'  curve0: y[0]={yv[0]:.3f}, y[-1]={yv[-1]:.3f}, t10%={t10:.3g}, t90%={t90:.3g}')
    print()
"
