import csv, os, numpy as np, re
from pathlib import Path
from scipy.optimize import least_squares

root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def parse_param(col):
    for pat, scale in [(r'(\d+(?:\.\d+)?)\s*uM', 1.0), (r'(\d+(?:\.\d+)?)\s*mM', 1000.0),
                       (r'(\d+(?:\.\d+)?)\s*mg/mL', 1.0), (r'(\d+(?:\.\d+)?)\s*ng/ul', 1.0),
                       (r'pH\s+(\d+(?:\.\d+)?)', 1.0), (r'(\d+(?:\.\d+)?)\s*%', 1.0),
                       (r':\s*(\d+(?:\.\d+)?)\s*$', 1.0)]:
        m = re.search(pat, col, re.IGNORECASE)
        if m: return float(m.group(1)) * scale
    return None

def load_ds(p):
    with open(p) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [[float(v) if v.strip() and v.strip().lower()!='nan' else float('nan') for v in r] for r in reader if r]
    arr = np.array(rows)
    t = arr[:,0]; y_cols = arr[:,1:]
    resp_hdrs = header[1:]
    parsed = [parse_param(h) for h in resp_hdrs]
    params = [float(pp) for pp in parsed] if all(pp is not None for pp in parsed) else [float(i+1) for i in range(len(resp_hdrs))]
    X, y = [], []
    for i, param in enumerate(params):
        for j in range(len(t)):
            val = y_cols[j, i]
            if np.isfinite(val):
                X.append([t[j], param]); y.append(val)
    return np.array(X), np.array(y)

def logistic_thalf(X, c):
    t, x1 = X[:,0], X[:,1]
    with np.errstate(over='ignore', invalid='ignore'):
        t_half = c[2] * np.abs(x1)**c[3]
        inner = np.clip(-c[0] * (t - t_half), -500, 500)
        return c[4] / (1 + np.exp(inner)) + c[5]

# Also try: logistic with tanh for smoother fitting
# y = c4 * (1 + tanh(c0*(t - c2*x1^c3)))/2 + c5
def logistic_tanh(X, c):
    t, x1 = X[:,0], X[:,1]
    with np.errstate(over='ignore', invalid='ignore'):
        t_half = c[2] * np.abs(x1)**c[3]
        inner = np.clip(c[0] * (t - t_half), -500, 500)
        return c[4] * (1 + np.tanh(inner)) / 2 + c[5]

# Kar2011 Q37 - look at what the logistic fits
p = root / 'htt/Kar2011/Fits/Kar2011_Q37_prim/fit.tsv'
X, y = load_ds(p)
t = X[:,0]; t_range = max(t.max()-t.min(), 1e-12); t_mid = t.min()+t_range*0.5; rate = 4/t_range
c0 = [rate, 0.5, t_mid, -0.5, 1.0, 0.0]
def res(c): 
    pred = logistic_thalf(X, c)
    if not np.all(np.isfinite(pred)): return np.full(len(y), 1e6)
    return pred - y
r = least_squares(res, c0, loss='soft_l1', max_nfev=500)
pred = logistic_thalf(X, r.x)
nmse = np.mean((pred-y)**2)/np.var(y)
print(f'Kar2011 Q37 prim: nmse={nmse:.4f}, fitted c={[f\"{v:.4g}\" for v in r.x]}')
# Show unique x1 values
print(f'  unique x1 values: {sorted(set(X[:,1]))}')

# Lysozyme - single curve
p = root / 'lysozyme/Fits/Hasecke2018_70uM_sec/fit.tsv'
X, y = load_ds(p)
t = X[:,0]; t_range = max(t.max()-t.min(), 1e-12); t_mid = t.min()+t_range*0.5; rate = 4/t_range
c0 = [rate, 0.5, t_mid, -0.5, 1.0, 0.0]
def res(c): 
    pred = logistic_thalf(X, c)
    if not np.all(np.isfinite(pred)): return np.full(len(y), 1e6)
    return pred - y
r = least_squares(res, c0, loss='soft_l1', max_nfev=500)
pred = logistic_thalf(X, r.x)
nmse = np.mean((pred-y)**2)/np.var(y)
print(f'Lysozyme 70uM: nmse={nmse:.4f}, fitted c={[f\"{v:.4g}\" for v in r.x]}')
# What does the curve look like?
print(f'  t: [{X[:,0].min():.4g}, {X[:,0].max():.4g}], y: [{y.min():.3f}, {y.max():.3f}]')
# Show some y values
idx = np.linspace(0, len(y)-1, 10, dtype=int)
print(f'  t sample: {[f\"{X[i,0]:.3g}\" for i in idx]}')
print(f'  y sample: {[f\"{y[i]:.3f}\" for i in idx]}')
print(f'  pred sample: {[f\"{pred[i]:.3f}\" for i in idx]}')
"
