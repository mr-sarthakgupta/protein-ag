    t, y_cols, hdrs, params = load_ds_raw(p)
    print(f'Dataset: {rel}')
    print(f'  params: {params}')
    print(f'  t: [{t[0]:.4g}, {t[-1]:.4g}]')
    for i in range(min(3, y_cols.shape[1])):
