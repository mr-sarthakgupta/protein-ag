import csv, os, numpy as np, re
from pathlib import Path

root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def parse_param(col):
    for pat, scale in [(r'(\d+(?:\.\d+)?)\s*uM', 1.0), (r'(\d+(?:\.\d+)?)\s*mM', 1000.0),
                       (r'(\d+(?:\.\d+)?)\s*mg/mL', 1.0), (r'(\d+(?:\.\d+)?)\s*ng/ul', 1.0),
                       (r'pH\s+(\d+(?:\.\d+)?)', 1.0), (r'(\d+(?:\.\d+)?)\s*%', 1.0),
                       (r':\s*(\d+(?:\.\d+)?)\s*$', 1.0)]:
        m = re.search(pat, col, re.IGNORECASE)
        if m: return float(m.group(1)) * scale
    return None

# Inspect hard datasets
hard_datasets = [
    'IAPP/Daval2010/Fits/Daval2010_sec',
    'htt/Kar2011/Fits/Kar2011_Q37_sec',
    'htt/Kakkar2016/FIts/Kakkar2016_14kDa_Ex45_polyQ_sec',
    'biofilm proteins/RdlB_Yang2017/Fits/5uM_sec',
    'insulin/Fits/Nielsen2001_high_conc_sec',
    'serum amyloid/Ye2011/Fits/Ye2011_sec',
]

for rel in hard_datasets:
    p = root / rel / 'fit.tsv'
    with open(p) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [[float(v) if v.strip() and v.strip().lower()!='nan' else float('nan') for v in r] for r in reader if r]
    arr = np.array(rows)
    t = arr[:,0]; y_cols = arr[:,1:]
    resp_hdrs = header[1:]
    parsed = [parse_param(h) for h in resp_hdrs]
    print(f'Dataset: {rel}')
    print(f'  headers: {resp_hdrs[:3]}')
    print(f'  parsed params: {parsed[:3]}')
    print(f'  t range: [{t[0]:.4g}, {t[-1]:.4g}], n={len(t)}')
    # Show first curve
    y0 = y_cols[:,0]
    valid = np.isfinite(y0)
    tv = t[valid]; yv = y0[valid]
    print(f'  curve0 y: [{yv[0]:.3f}, {yv[len(yv)//4]:.3f}, {yv[len(yv)//2]:.3f}, {yv[-1]:.3f}]')
    print()
"
