import sympy as sp
import numpy as np

# Final expression: logistic_loglin_full
# rate = exp(c0 + c1*log(x1))  
# t_half = exp(c2 + c3*log(x1))
# y = c4 / (1 + exp(-rate*(x0 - t_half))) + c5

x0, x1 = sp.symbols('x0 x1')
c = [sp.Symbol(f'c{i}') for i in range(6)]

log_x1 = sp.log(x1)
rate = sp.exp(c[0] + c[1] * log_x1)
t_half = sp.exp(c[2] + c[3] * log_x1)
expression = c[4] / (1 + sp.exp(-rate * (x0 - t_half))) + c[5]

print('Expression:', expression)
complexity = sum(1 for _ in sp.preorder_traversal(expression))
print('Complexity:', complexity)

# Parsimony: 1 - 0.2*(29/160) = 1 - 0.03625 = 0.96375
parsimony = 1 - 0.2 * (complexity / 160)
print(f'Parsimony factor: {parsimony:.4f}')

# Expected combined score if mean_nmse = 0.053:
fit_score = 1/(1+0.053)
combined = fit_score * parsimony
print(f'Expected combined_score (nmse=0.053): {combined:.4f}')

# vs current score 0.6447 with nmse=0.5064
fit_current = 1/(1+0.5064)
combined_current = fit_current * (1 - 0.2*23/160)
print(f'Current combined_score estimate: {combined_current:.4f}')

# What about nmse=0.043 (data-informed)?
fit_opt = 1/(1+0.043)
combined_opt = fit_opt * parsimony
print(f'Optimistic combined_score (nmse=0.043): {combined_opt:.4f}')
"
