 206 |         "command": "python3 -c \"\nimport csv, os, numpy as np, re\nfrom pathlib import Path\nfrom scipy.optimize import least_squares\n\nroot = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')\n\ndef parse_param(col):\n    for pat, scale in [(r'(\\d+(?:\\.\\d+)?)\\s*uM', 1.0), (r'(\\d+(?:\\.\\d+)?)\\s*mM', 1000.0),\n                       (r'(\\d+(?:\\.\\d+)?)\\s*mg/mL', 1.0), (r'(\\d+(?:\\.\\d+)?)\\s*ng/ul', 1.0),\n                       (r'pH\\s+(\\d+(?:\\.\\d+)?)', 1.0), (r'(\\d+(?:\\.\\d+)?)\\s*%', 1.0),\n                       (r':\\s*(\\d+(?:\\.\\d+)?)\\s*$', 1.0)]:\n        m = re.search(pat, col, re.IGNORECASE)\n        if m: return float(m.group(1)) * scale\n    return None\n\ndef load_ds(p):\n    with open(p) as f:\n        reader = csv.reader(f, delimiter='\\t')\n        header = next(reader)\n        rows = [[float(v) if v.strip() and v.strip().lower()!='nan' else float('nan') for v in r] for r in reader if r]\n    arr = np.array(rows)\n    t = arr[:,0]; y_cols = arr[:,1:]\n    resp_hdrs = header[1:]\n    parsed = [parse_param(h) for h in resp_hdrs]\n    params = [float(pp) for pp in parsed] if all(pp is not None for pp in parsed) else [float(i+1) for i in range(len(resp_hdrs))]\n    X, y = [], []\n    for i, param in enumerate(params):\n        for j in range(len(t)):\n            val = y_cols[j, i]\n            if np.isfinite(val):\n                X.append([t[j], param]); y.append(val)\n    return np.array(X), np.array(y)\n\n# Current best\ndef logistic_thalf(X, c):\n    t, x1 = X[:,0], X[:,1]\n    with np.errstate(over='ignore', invalid='ignore'):\n        t_half = c[2] * np.abs(x1)**c[3]\n        inner = np.clip(-c[0] * (t - t_half), -500, 500)\n        return c[4] / (1 + np.exp(inner)) + c[5]\n\n# Variant: t_half uses log(x1) -> more stable, physically motivated\n# t_half = exp(c2 + c3*log(x1)) = exp(c2) * x1^c3 -- same as power law\n# but: t_half = c2 * exp(c3 * x1) -- exponential in x1\ndef logistic_exp_thalf(X, c):\n    t, x1 = X[:,0], X[:,1]\n    with np.errstate(over='ignore', invalid='ignore'):\n        t_half = c[2] * np.exp(c[3] * x1)\n        inner = np.clip(-c[0] * (t - t_half), -500, 500)\n        return c[4] / (1 + np.exp(inner)) + c[5]\n\n# Variant: both rate and t_half scale with x1 via exp\ndef logistic_exp_full(X, c):\n    t, x1 = X[:,0], X[:,1]\n    with np.errstate(over='ignore', invalid='ignore'):\n        rate = c[0] * np.exp(c[1] * x1)\n        t_half = c[2] * np.exp(c[3] * x1)\n        inner = np.clip(-rate * (t - t_half), -500, 500)\n        return c[4] / (1 + np.exp(inner)) + c[5]\n\n# Variant: logistic where t_half = c2 + c3/x1 (inverse concentration)\ndef logistic_inv_thalf(X, c):\n    t, x1 = X[:,0], X[:,1]\n    with np.errstate(over='ignore', invalid='ignore'):\n        t_half = c[2] + c[3] / np.maximum(np.abs(x1), 1e-12)\n        inner = np.clip(-c[0] * (t - t_half), -500, 500)\n        return c[4] / (1 + np.exp(inner)) + c[5]\n\n# Variant: logistic where t_half = c2 * x1^c3, rate = c0 * x1^c1\n# but use log-space: log(t_half) = log(c2) + c3*log(x1)\n# Equivalent to power law but numerically: t_half = exp(c2 + c3*log(x1+1))\ndef logistic_loglin_thalf(X, c):\n    t, x1 = X[:,0], X[:,1]\n    with np.errstate(over='ignore', invalid='ignore'):\n        log_x1 = np.log(np.maximum(np.abs(x1), 1e-12))\n        t_half = np.exp(c[2] + c[3] * log_x1)\n        inner = np.clip(-c[0] * (t - t_half), -500, 500)\n        return c[4] / (1 + np.exp(inner)) + c[5]\n\ndatasets = []\nfor dirpath, _, filenames in os.walk(root):\n    if 'fit.tsv' in filenames:\n        datasets.append((str(Path(dirpath).relative_to(root)), Path(dirpath) / 'fit.tsv'))\ndatasets.sort()\n\nmodels = {\n    'logistic_thalf': (logistic_thalf, [4e-5, 0.5, 5e4, -0.5, 1.0, 0.0]),\n    'logistic_loglin': (logistic_loglin_thalf, [4e-5, 0.5, 10.0, -0.5, 1.0, 0.0]),\n    'logistic_inv': (logistic_inv_thalf, [4e-5, 0.5, 5e4, 1e4, 1.0, 0.0]),\n}\n\nresults = {k: [] for k in models}\nfor name, p in datasets:\n    X, y = load_ds(p)\n    t = X[:,0]\n    t_range = max(t.max() - t.min(), 1e-12)\n    t_mid = t.min() + t_range * 0.5\n    rate_init = 4.0 / t_range\n    \n    for mname, (fn, c0_tmpl) in models.items():\n        if mname == 'logistic_loglin':\n            c0 = [rate_init, 0.5, np.log(max(t_mid, 1.0)), -0.5, 1.0, 0.0]\n        else:\n            c0 = [rate_init, 0.5, t_mid, -0.5, 1.0, 0.0]\n        def res(c, fn=fn, X=X, y=y):\n            pred = fn(X, c)\n            if not np.all(np.isfinite(pred)): return np.full(len(y), 1e6)\n            return pred - y\n        try:\n            r = least_squares(res, c0, loss='soft_l1', max_nfev=500)\n            pred = fn(X, r.x)\n            nmse_v = np.mean((pred-y)**2)/np.var(y) if np.var(y)>0 else float('inf')\n        except:\n            nmse_v = float('inf')\n        results[mname].append(nmse_v)\n\nfor mname, vals in results.items():\n    finite = [v for v in vals if np.isfinite(v)]\n    print(f'{mname}: mean={np.mean(finite):.4f}, median={np.median(finite):.4f}, n_good={sum(1 for v in vals if v < 0.1)}/42')\n\"\n"
