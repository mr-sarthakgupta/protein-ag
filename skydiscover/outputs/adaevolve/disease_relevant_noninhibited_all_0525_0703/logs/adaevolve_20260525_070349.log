import numpy as np
import sys
sys.path.insert(0, '.')

from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import sympy as sp
from pysr_harness.equation_session import constant_symbols, evaluate_expression, feature_symbols

datasets = load_all_datasets()

# Check the IAPP dataset that fails
name, X_train, X_val, y_train, y_val = datasets[3]
print('Name:', name)
print('x0 range:', X_train[:, 0].min(), X_train[:, 0].max())
print('x1 range:', X_train[:, 1].min(), X_train[:, 1].max())
print('y range:', y_train.min(), y_train.max())

x = feature_symbols(X_train.shape[1])
time = x[0]
parameter = x[1]

# Try different initial values for logistic
c = constant_symbols(6)
rate = c[0] + c[1] * parameter
t_half = c[2] + c[3] * parameter
expr = c[4] / (1 + sp.exp(-rate * (time - t_half))) + c[5]

# Normalize time
t_scale = X_train[:, 0].max()
