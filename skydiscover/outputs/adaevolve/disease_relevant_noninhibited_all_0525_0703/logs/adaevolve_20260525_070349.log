 312 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
 313 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
 314 |     nmse_val = float(result.get("nmse_val", float("inf")))
 315 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
 316 |     if not np.isfinite(combined):
 317 |         combined = 0.0
 318 | 
 319 |     return {
 320 |         "equation": str(result.get("equation", "")),
 321 |         "loss": nmse_val,
 322 |         "complexity": 0.0,
 323 |         "nmse_train": float("inf"),
 324 |         "nmse_val": nmse_val,
 325 |         "combined_score": combined,
 326 |         "eval_time": float(eval_time),
 327 |         "n_datasets": result.get("n_datasets", 0),
 328 |         "n_successful": result.get("n_successful", 0),
 329 |         "per_dataset": result.get("per_dataset", {}),
 330 |     }
 331 | 
 332 | 
 333 | def evaluate(program_path: str) -> dict:
 334 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
 335 |     try:
 336 |         start = time.time()
 337 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=3000)
 338 |         metrics = _metrics_from_result(result, time.time() - start)
 339 |         print(
 340 |             "Evaluation: "
 341 |             f"nmse_val={metrics['nmse_val']:.6f}, "
 342 |             f"combined_score={metrics['combined_score']:.6f}, "
 343 |             f"n_datasets={metrics['n_datasets']}, "
 344 |             f"n_successful={metrics['n_successful']}, "
 345 |             f"time={metrics['eval_time']:.2f}s"
 346 |         )
 347 |         print(f"Equation template: {metrics['equation']}")
 348 |         return metrics
 349 |     except Exception as exc:
 350 |         print(f"Evaluation failed: {exc}")
 351 |         traceback.print_exc()
 352 |         return {
 353 |             "equation": "",
 354 |             "loss": float("inf"),
 355 |             "complexity": 0.0,
 356 |             "nmse_train": float("inf"),
 357 |             "nmse_val": float("inf"),
 358 |             "combined_score": 0.0,
 359 |             "eval_time": 0.0,
 360 |             "n_datasets": 0,
 361 |             "n_successful": 0,
 362 |             "per_dataset": {},
 363 |             "error": str(exc),
 364 |         }
