import numpy as np
import csv
from pathlib import Path
import sys
sys.path.insert(0, '.')

# Load all datasets and check their characteristics
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, discover_datasets

datasets = load_all_datasets()
print(f'Total datasets: {len(datasets)}')
for name, X_train, X_val, y_train, y_val in datasets[:10]:
    n_unique_x1 = len(np.unique(X_train[:, 1]))
