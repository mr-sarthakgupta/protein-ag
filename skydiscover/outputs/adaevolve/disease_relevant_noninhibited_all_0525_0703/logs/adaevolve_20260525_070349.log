 179 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 180 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 181 | 
 182 |     The subprocess loads every dataset, calls the candidate's
 183 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 184 |     constants each time) using parallel threads, and returns aggregated
 185 |     metrics.
 186 |     """
 187 |     harness_root = str(BENCHMARK_ROOT)
 188 |     evaluator_path = str(Path(__file__).resolve())
 189 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
 190 |         script = f"""
 191 | import importlib.util
 192 | import os
 193 | import pickle
 194 | import sys
 195 | import traceback
 196 | from concurrent.futures import ThreadPoolExecutor, as_completed
 197 | 
 198 | import numpy as np
 199 | 
 200 | sys.path.insert(0, {harness_root!r})
 201 | 
 202 | program_path = {program_path!r}
 203 | evaluator_path = {evaluator_path!r}
 204 | results_path = {temp_file.name + ".results"!r}
 205 | NUM_WORKERS = min(8, os.cpu_count() or 4)
 206 | 
 207 | try:
 208 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
 209 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
 210 |     evaluator_spec.loader.exec_module(evaluator)
 211 | 
 212 |     spec = importlib.util.spec_from_file_location("program", program_path)
 213 |     program = importlib.util.module_from_spec(spec)
 214 |     spec.loader.exec_module(program)
 215 | 
 216 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
 217 |         program, "run_discovery", None
 218 |     )
 219 |     if fn is None:
 220 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
 221 | 
 222 |     datasets = evaluator.load_all_datasets()
 223 | 
 224 |     def _eval_one(args):
 225 |         ds_name, X_train, X_val, y_train, y_val = args
 226 |         try:
 227 |             result = fn(X_train, y_train, X_val, y_val)
 228 |             ds_nmse = float(result.get("nmse_val", float("inf")))
 229 |             ds_combined = float(result.get("combined_score", 0.0))
 230 |             return ds_name, {{
 231 |                 "nmse_val": ds_nmse,
 232 |                 "combined_score": ds_combined,
 233 |                 "equation": str(result.get("equation", "")),
 234 |                 "constants": result.get("constants", {{}}),
 235 |             }}
 236 |         except Exception as exc:
 237 |             return ds_name, {{
 238 |                 "nmse_val": float("inf"),
 239 |                 "combined_score": 0.0,
 240 |                 "error": str(exc),
 241 |             }}
 242 | 
 243 |     per_dataset_results = {{}}
 244 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as pool:
 245 |         futures = {{pool.submit(_eval_one, ds): ds[0] for ds in datasets}}
 246 |         for future in as_completed(futures):
 247 |             ds_name, ds_result = future.result()
 248 |             per_dataset_results[ds_name] = ds_result
 249 | 
 250 |     combined_scores = [r["combined_score"] for r in per_dataset_results.values()]
 251 |     nmse_vals = [r["nmse_val"] for r in per_dataset_results.values()]
 252 |     finite_nmse = [v for v in nmse_vals if np.isfinite(v)]
 253 |     agg_nmse = float(np.mean(finite_nmse)) if finite_nmse else float("inf")
 254 |     agg_combined = float(np.mean(combined_scores))
 255 | 
 256 |     eq_template = ""
 257 |     for r in per_dataset_results.values():
 258 |         if r.get("equation"):
 259 |             eq_template = r["equation"]
 260 |             break
 261 | 
 262 |     aggregated = {{
 263 |         "equation": eq_template,
 264 |         "nmse_val": agg_nmse,
 265 |         "combined_score": agg_combined,
 266 |         "n_datasets": len(datasets),
 267 |         "n_successful": sum(1 for s in combined_scores if s > 0),
 268 |         "per_dataset": per_dataset_results,
 269 |     }}
 270 | 
 271 |     with open(results_path, "wb") as f:
 272 |         pickle.dump({{"result": aggregated}}, f)
 273 | except Exception as exc:
 274 |     traceback.print_exc()
 275 |     with open(results_path, "wb") as f:
 276 |         pickle.dump({{"error": str(exc)}}, f)
 277 | """
 278 |         temp_file.write(script.encode())
 279 |         temp_path = temp_file.name
 280 | 
 281 |     results_path = f"{temp_path}.results"
 282 |     try:
 283 |         process = subprocess.Popen(
 284 |             [sys.executable, temp_path],
 285 |             stdout=subprocess.PIPE,
 286 |             stderr=subprocess.PIPE,
 287 |         )
 288 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
 289 |         if stdout:
 290 |             print(stdout.decode())
 291 |         if stderr:
 292 |             print(stderr.decode())
 293 |         if process.returncode != 0:
 294 |             raise RuntimeError(f"Subprocess exited with code {process.returncode}")
 295 |         if not os.path.exists(results_path):
 296 |             raise RuntimeError("Results file not found")
 297 |         with open(results_path, "rb") as f:
 298 |             payload = pickle.load(f)
 299 |         if "error" in payload:
 300 |             raise RuntimeError(payload["error"])
 301 |         return payload["result"]
 302 |     except subprocess.TimeoutExpired:
 303 |         process.kill()
 304 |         process.wait()
 305 |         raise TimeoutError(f"Program execution timed out after {timeout_seconds}s")
 306 |     finally:
 307 |         for path in (temp_path, results_path):
 308 |             if os.path.exists(path):
 309 |                 os.unlink(path)
