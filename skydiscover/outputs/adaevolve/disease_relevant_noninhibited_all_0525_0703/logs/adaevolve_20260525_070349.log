 367 | def evaluate_stage1(program_path: str) -> dict:
 368 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
 369 |     try:
 370 |         harness_root = str(BENCHMARK_ROOT)
 371 |         if harness_root not in sys.path:
 372 |             sys.path.insert(0, harness_root)
 373 | 
 374 |         spec = importlib.util.spec_from_file_location("program", program_path)
 375 |         program = importlib.util.module_from_spec(spec)
 376 |         spec.loader.exec_module(program)
 377 | 
 378 |         fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
 379 |             program, "run_discovery", None
 380 |         )
 381 |         if fn is None:
 382 |             return {"combined_score": 0.0, "error": "missing evaluate_symbolic_candidate()"}
 383 | 
 384 |         all_datasets = load_all_datasets()
 385 |         # Stage 1: sample up to 8 datasets for a quick check
 386 |         rng = np.random.default_rng(RANDOM_STATE)
 387 |         if len(all_datasets) > 8:
 388 |             indices = rng.choice(len(all_datasets), size=8, replace=False)
 389 |             subset = [all_datasets[i] for i in sorted(indices)]
 390 |         else:
 391 |             subset = all_datasets
 392 | 
 393 |         from concurrent.futures import ThreadPoolExecutor, as_completed
 394 | 
 395 |         def _eval_stage1(args):
 396 |             name, X_train, X_val, y_train, y_val = args
 397 |             n = min(200, len(X_train))
 398 |             m = min(80, len(X_val))
 399 |             try:
 400 |                 result = fn(X_train[:n], y_train[:n], X_val[:m], y_val[:m])
 401 |                 return float(result.get("combined_score", 0.0))
 402 |             except Exception:
 403 |                 return 0.0
 404 | 
 405 |         combined_scores = []
 406 |         with ThreadPoolExecutor(max_workers=NUM_WORKERS) as pool:
 407 |             futures = [pool.submit(_eval_stage1, ds) for ds in subset]
 408 |             for future in as_completed(futures):
 409 |                 combined_scores.append(future.result())
 410 | 
 411 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
 412 |         return {"combined_score": agg_combined}
 413 |     except Exception as exc:
 414 |         print(f"Stage 1 evaluation failed: {exc}")
 415 |         return {"combined_score": 0.0, "error": str(exc)}
 416 | 
