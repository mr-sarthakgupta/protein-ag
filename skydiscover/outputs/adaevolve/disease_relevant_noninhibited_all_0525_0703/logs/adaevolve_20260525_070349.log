 100 |     Fit free constants in a SkyDiscover-proposed expression template.
 101 | 
 102 |     The expression structure is supplied by the evolved program. This helper only
 103 |     performs the continuous inner fit and PySR-style export/evaluation.
 104 |     """
 105 |     X_train = np.asarray(X_train, dtype=float)
 106 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 107 |     X_val = np.asarray(X_val, dtype=float)
 108 |     feature_names = [f"x{i}" for i in range(X_train.shape[1])]
 109 |     template = _as_sympy_expr(expression, feature_names)
 110 | 
 111 |     if constants is None:
 112 |         feature_set = set(feature_symbols(X_train.shape[1]))
 113 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 114 |     constants = list(constants)
 115 | 
 116 |     if not constants:
 117 |         return FittedExpression(
 118 |             expression_template=template,
 119 |             expression=template,
 120 |             constants={},
 121 |             y_pred_train=_predict(template, X_train, feature_names),
 122 |             y_pred_val=_predict(template, X_val, feature_names),
 123 |         )
 124 | 
 125 |     if initial_values is None:
 126 |         x0 = np.ones(len(constants), dtype=float)
 127 |     else:
 128 |         x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 129 |         if x0.size != len(constants):
 130 |             raise ValueError("initial_values must match the number of constants")
 131 | 
 132 |     feature_syms = create_sympy_symbols(feature_names)
 133 |     X_cols = [X_train[:, i] for i in range(X_train.shape[1])]
 134 | 
 135 |     # Compile expression and its Jacobian once upfront so the residual
 136 |     # avoids repeated SymPy subs() + sympy2numpy() calls (the main
 137 |     # bottleneck). The analytical Jacobian also eliminates finite-difference
 138 |     # sensitivity that causes different local minima across compilation methods.
 139 |     all_syms = feature_syms + constants
 140 |     try:
 141 |         _compiled = sp.lambdify(all_syms, template, modules=["numpy"])
 142 |         _partials = [sp.diff(template, ci) for ci in constants]
 143 |         _compiled_jac = [sp.lambdify(all_syms, pd, modules=["numpy"]) for pd in _partials]
 144 |         _test_args = X_cols + [float(v) for v in x0]
 145 |         _test_out = np.asarray(_compiled(*_test_args), dtype=float).reshape(-1)
 146 |         if _test_out.shape != y_train.shape:
 147 |             raise ValueError("shape mismatch")
 148 |         _use_compiled = True
 149 |     except Exception:
 150 |         _use_compiled = False
 151 | 
 152 |     if _use_compiled:
 153 |         def residual(theta: NDArray) -> NDArray:
 154 |             try:
 155 |                 args = X_cols + [float(v) for v in theta]
 156 |                 prediction = np.asarray(_compiled(*args), dtype=float).reshape(-1)
 157 |             except Exception:
 158 |                 return np.full_like(y_train, 1e12, dtype=float)
 159 |             if prediction.shape != y_train.shape or not np.all(np.isfinite(prediction)):
 160 |                 return np.full_like(y_train, 1e12, dtype=float)
 161 |             return prediction - y_train
 162 | 
 163 |         def jacobian(theta: NDArray) -> NDArray:
 164 |             try:
 165 |                 args = X_cols + [float(v) for v in theta]
 166 |                 cols = []
 167 |                 for jfn in _compiled_jac:
 168 |                     col = np.asarray(jfn(*args), dtype=float).reshape(-1)
 169 |                     col = np.nan_to_num(col, nan=0.0, posinf=1e12, neginf=-1e12)
 170 |                     cols.append(col)
 171 |                 return np.column_stack(cols)
 172 |             except Exception:
 173 |                 return np.zeros((len(y_train), len(theta)), dtype=float)
 174 |     else:
 175 |         def residual(theta: NDArray) -> NDArray:
 176 |             substitutions = {symbol: float(value) for symbol, value in zip(constants, theta)}
 177 |             candidate = template.subs(substitutions)
 178 |             try:
 179 |                 prediction = _predict(candidate, X_train, feature_names)
 180 |             except Exception:
 181 |                 return np.full_like(y_train, 1e12, dtype=float)
 182 |             if prediction.shape != y_train.shape or not np.all(np.isfinite(prediction)):
 183 |                 return np.full_like(y_train, 1e12, dtype=float)
 184 |             return prediction - y_train
 185 |         jacobian = "2-point"
 186 | 
 187 |     import warnings
 188 | 
 189 |     with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 190 |         warnings.simplefilter("ignore", RuntimeWarning)
 191 |         result = least_squares(
 192 |             residual,
 193 |             x0,
 194 |             jac=jacobian,
 195 |             loss="soft_l1",
 196 |             max_nfev=max_nfev,
 197 |         )
 198 |     fitted_constants = {
 199 |         str(symbol): float(value) for symbol, value in zip(constants, result.x)
 200 |     }
 201 |     substitutions = dict(zip(constants, result.x))
 202 |     fitted_expr = template.subs(substitutions)
 203 | 
 204 |     return FittedExpression(
 205 |         expression_template=template,
 206 |         expression=fitted_expr,
 207 |         constants=fitted_constants,
 208 |         y_pred_train=_predict(fitted_expr, X_train, feature_names),
 209 |         y_pred_val=_predict(fitted_expr, X_val, feature_names),
 210 |     )
 211 | 
 212 | 
 213 | def evaluate_expression(
 214 |     expression: sp.Expr | str | float | int,
 215 |     X_train: NDArray,
 216 |     y_train: NDArray,
 217 |     X_val: NDArray,
 218 |     y_val: NDArray,
 219 |     *,
 220 |     constants: Sequence[sp.Symbol] | None = None,
 221 |     initial_values: Sequence[float] | None = None,
 222 |     max_nfev: int = 300,
 223 | ) -> dict[str, Any]:
 224 |     """Score a proposed equation template after fitting its constants."""
 225 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 226 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 227 |     fitted = fit_expression_constants(
 228 |         expression,
 229 |         X_train,
 230 |         y_train,
 231 |         X_val,
 232 |         constants=constants,
 233 |         initial_values=initial_values,
 234 |         max_nfev=max_nfev,
 235 |     )
 236 |     nmse_train = nmse(y_train, fitted.y_pred_train)
 237 |     nmse_val = nmse(y_val, fitted.y_pred_val)
 238 |     loss = float(np.mean((fitted.y_pred_train - y_train) ** 2))
 239 | 
 240 |     return {
 241 |         "equation_template": str(fitted.expression_template),
 242 |         "equation": str(fitted.expression),
 243 |         "constants": fitted.constants,
 244 |         "loss": loss,
 245 |         "complexity": _complexity(fitted.expression_template),
 246 |         "nmse_train": nmse_train,
 247 |         "nmse_val": nmse_val,
 248 |         "combined_score": combined_score_from_nmse(nmse_val),
 249 |     }
