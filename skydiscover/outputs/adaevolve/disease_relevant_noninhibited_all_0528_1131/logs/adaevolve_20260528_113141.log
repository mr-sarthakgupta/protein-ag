 395 | def _parse_parameter_from_column(column_name: str) -> float | None:
 396 |     """Extract a numeric parameter value from a fit.tsv column header.
 397 | 
 398 |     Handles diverse header formats found across disease-relevant datasets:
 399 |       - "... : 10uM"  or "10 uM"  → 10.0
 400 |       - "35uM" (bare, as in Abeta) → 35.0
 401 |       - "... : 3.95mM"             → 3950.0  (converted to uM)
 402 |       - "... : 0.3 mg/mL 22uM"    → 22.0    (prefer uM when both present)
 403 |       - "... : pH 2.7"             → 2.7
 404 |       - "... : 5% seeds"           → 5.0
 405 |       - "20 ng/ul"                 → 20.0
 406 |       - Non-numeric labels (WT, C19S, acid 10min, ...) → None
 407 |     """
 408 |     text = column_name.strip()
 409 | 
 410 |     # Prefer an explicit uM value
 411 |     m = re.search(r"(\d+(?:\.\d+)?)\s*uM", text, re.IGNORECASE)
 412 |     if m:
 413 |         return float(m.group(1))
 414 | 
 415 |     # mM → convert to uM
 416 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mM", text, re.IGNORECASE)
 417 |     if m:
 418 |         return float(m.group(1)) * 1000.0
 419 | 
 420 |     # mg/mL (take the number)
 421 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mg/mL", text, re.IGNORECASE)
 422 |     if m:
 423 |         return float(m.group(1))
 424 | 
 425 |     # ng/ul
 426 |     m = re.search(r"(\d+(?:\.\d+)?)\s*ng/ul", text, re.IGNORECASE)
 427 |     if m:
 428 |         return float(m.group(1))
 429 | 
 430 |     # pH value
 431 |     m = re.search(r"pH\s+(\d+(?:\.\d+)?)", text, re.IGNORECASE)
 432 |     if m:
 433 |         return float(m.group(1))
 434 | 
 435 |     # Percentage (e.g. "5% seeds")
 436 |     m = re.search(r"(\d+(?:\.\d+)?)\s*%", text)
 437 |     if m:
 438 |         return float(m.group(1))
 439 | 
 440 |     # Last resort: try to find any trailing number after colon/space
 441 |     m = re.search(r":\s*(\d+(?:\.\d+)?)\s*$", text)
 442 |     if m:
 443 |         return float(m.group(1))
 444 | 
 445 |     return None
 446 | 
 447 | 
 448 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 449 |     """Load a wide fit.tsv and return X=[measurement_x, parameter], y.
 450 | 
 451 |     The first column is always the time/measurement coordinate. Remaining
 452 |     columns are response curves. The varying parameter (concentration, pH,
 453 |     etc.) is extracted from the header; if extraction fails, sequential
 454 |     indices 1, 2, 3, ... are used.
 455 |     """
 456 |     with data_file.open(newline="") as f:
 457 |         reader = csv.reader(f, delimiter="\t")
 458 |         header = next(reader)
 459 | 
 460 |         response_headers = header[1:]
 461 |         parsed_params = [_parse_parameter_from_column(h) for h in response_headers]
 462 |         if all(p is not None for p in parsed_params):
 463 |             parameters = [float(p) for p in parsed_params]
 464 |         else:
 465 |             parameters = [float(i + 1) for i in range(len(response_headers))]
 466 | 
 467 |         features: list[list[float]] = []
 468 |         targets: list[float] = []
 469 |         for row in reader:
 470 |             if not row:
 471 |                 continue
 472 |             measurement_x = float(row[0])
 473 |             for param, value in zip(parameters, row[1:]):
 474 |                 if value == "" or value.strip().lower() == "nan":
 475 |                     continue
 476 |                 features.append([measurement_x, param])
 477 |                 targets.append(float(value))
 478 | 
 479 |     if not features:
 480 |         raise ValueError(f"No regression samples loaded from {data_file}")
 481 | 
 482 |     return np.asarray(features, dtype=float), np.asarray(targets, dtype=float)
 483 | 
 484 | 
 485 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 486 |     """Recursively find all fit.tsv files and return (dataset_name, path) pairs."""
 487 |     datasets: list[tuple[str, Path]] = []
 488 |     for dirpath, _dirnames, filenames in os.walk(root):
 489 |         if "fit.tsv" in filenames:
 490 |             fit_path = Path(dirpath) / "fit.tsv"
 491 |             rel = fit_path.parent.relative_to(root)
 492 |             name = str(rel).replace(os.sep, "/")
 493 |             datasets.append((name, fit_path))
 494 |     datasets.sort(key=lambda x: x[0])
 495 |     return datasets
 496 | 
 497 | 
 498 | def load_dataset(data_file: Path) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 499 |     """Load a single fit.tsv and return deterministic train/val split."""
 500 |     X, y = _load_fit_table(data_file)
 501 |     rng = np.random.default_rng(RANDOM_STATE)
 502 |     indices = rng.permutation(len(y))
 503 |     split = int(round(len(y) * (1.0 - TEST_SIZE)))
 504 |     train_idx = indices[:split]
 505 |     val_idx = indices[split:]
 506 |     return X[train_idx], X[val_idx], y[train_idx], y[val_idx]
 507 | 
 508 | 
 509 | def load_all_datasets(
 510 |     root: Path = DATA_ROOT,
 511 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 512 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 513 |     entries = discover_datasets(root)
 514 |     results = []
 515 |     for name, path in entries:
 516 |         try:
 517 |             X_train, X_val, y_train, y_val = load_dataset(path)
 518 |             results.append((name, X_train, X_val, y_train, y_val))
 519 |         except Exception as exc:
 520 |             print(f"Warning: skipping dataset {name}: {exc}")
 521 |     return results
 522 | 
 523 | 
 524 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 525 | 
 526 | 
 527 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 528 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 529 |     nmse_vals = [r["nmse_val"] for r in per_dataset_results.values()]
 530 | 
 531 |     violation_errors = sorted(
 532 |         {
 533 |             str(r.get("error"))
 534 |             for r in per_dataset_results.values()
 535 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 536 |         }
 537 |     )
 538 |     failed_datasets = sorted(
 539 |         name
 540 |         for name, result in per_dataset_results.items()
 541 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 542 |     )
 543 |     templates = sorted(
 544 |         {
 545 |             str(r.get("equation_template"))
 546 |             for r in per_dataset_results.values()
 547 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 548 |         }
 549 |     )
 550 | 
 551 |     eq_template = ""
 552 |     for r in per_dataset_results.values():
 553 |         if r.get("equation"):
 554 |             eq_template = r["equation"]
 555 |             break
 556 | 
 557 |     violation_error = None
 558 |     if violation_errors:
 559 |         violation_error = violation_errors[0]
 560 |     elif failed_datasets:
 561 |         examples = ", ".join(failed_datasets[:3])
 562 |         violation_error = (
 563 |             "Single-equation violation: candidate failed on "
 564 |             f"{len(failed_datasets)}/{len(per_dataset_results)} datasets. "
 565 |             "Failed datasets are not dropped from the aggregate reward. "
 566 |             f"Examples: {examples}"
 567 |         )
 568 |     elif len(templates) > 1:
 569 |         examples = "; ".join(templates[:3])
 570 |         violation_error = (
 571 |             "Single-equation violation: evaluate_symbolic_candidate() produced "
 572 |             f"{len(templates)} distinct equation templates across datasets. "
 573 |             "The base equation must be identical for all datasets; only fitted "
 574 |             f"constants may vary. Example templates: {examples}"
 575 |         )
 576 | 
 577 |     if violation_error:
 578 |         agg_nmse = float("inf")
 579 |         agg_combined = 0.0
 580 |         n_successful = 0
 581 |     else:
 582 |         agg_nmse = float(np.mean(nmse_vals)) if nmse_vals else float("inf")
 583 |         agg_combined = (
 584 |             float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
 585 |         )
 586 |         n_successful = sum(1 for value in nmse_vals if np.isfinite(value))
 587 | 
 588 |     aggregated = {
 589 |         "equation": eq_template,
 590 |         "nmse_val": agg_nmse,
 591 |         "combined_score": agg_combined,
 592 |         "n_datasets": len(per_dataset_results),
 593 |         "n_successful": n_successful,
 594 |         "per_dataset": per_dataset_results,
 595 |     }
 596 |     if violation_error:
 597 |         aggregated["error"] = violation_error
 598 |     return aggregated
 599 | 
 600 | 
 601 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 602 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 603 | 
 604 |     The subprocess loads every dataset, calls the candidate's
 605 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 606 |     constants each time) using parallel threads, and returns aggregated
 607 |     metrics.
 608 |     """
 609 |     validate_candidate_source(program_path)
 610 |     harness_root = str(BENCHMARK_ROOT)
 611 |     evaluator_path = str(Path(__file__).resolve())
 612 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
 613 |         script = f"""
 614 | import importlib.util
 615 | import os
 616 | import pickle
 617 | import sys
 618 | import traceback
 619 | from concurrent.futures import ThreadPoolExecutor, as_completed
 620 | 
 621 | os.environ.setdefault("OMP_NUM_THREADS", "1")
 622 | os.environ.setdefault("MKL_NUM_THREADS", "1")
 623 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
 624 | 
 625 | import numpy as np
 626 | 
 627 | sys.path.insert(0, {harness_root!r})
 628 | 
 629 | program_path = {program_path!r}
 630 | evaluator_path = {evaluator_path!r}
 631 | results_path = {temp_file.name + ".results"!r}
 632 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 633 | 
 634 | def _write_payload_and_exit(payload):
 635 |     with open(results_path, "wb") as f:
 636 |         pickle.dump(payload, f)
 637 |     sys.stdout.flush()
 638 |     sys.stderr.flush()
 639 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
 640 |     # interpreter shutdown. The parent only needs the pickle payload.
 641 |     os._exit(0)
 642 | 
 643 | try:
 644 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
 645 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
 646 |     evaluator_spec.loader.exec_module(evaluator)
 647 |     evaluator.validate_candidate_source(program_path)
 648 | 
 649 |     spec = importlib.util.spec_from_file_location("program", program_path)
 650 |     program = importlib.util.module_from_spec(spec)
 651 |     spec.loader.exec_module(program)
 652 |     from pysr_harness.equation_session import (
 653 |         single_equation_evaluation,
 654 |         validate_single_equation_result,
 655 |     )
 656 | 
 657 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
 658 |         program, "run_discovery", None
 659 |     )
 660 |     if fn is None:
 661 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
 662 | 
 663 |     datasets = evaluator.load_all_datasets()
 664 | 
 665 |     def _eval_one(args):
 666 |         ds_name, X_train, X_val, y_train, y_val = args
 667 |         try:
 668 |             with single_equation_evaluation():
 669 |                 result = fn(X_train, y_train, X_val, y_val)
 670 |                 validate_single_equation_result(result)
 671 |             ds_nmse = float(result.get("nmse_val", float("inf")))
 672 |             ds_combined = float(result.get("combined_score", 0.0))
 673 |             return ds_name, {{
 674 |                 "nmse_val": ds_nmse,
 675 |                 "combined_score": ds_combined,
 676 |                 "equation": str(result.get("equation", "")),
 677 |                 "equation_template": str(result.get("equation_template", "")),
 678 |                 "constants": result.get("constants", {{}}),
 679 |             }}
 680 |         except Exception as exc:
 681 |             return ds_name, {{
 682 |                 "nmse_val": float("inf"),
 683 |                 "combined_score": 0.0,
 684 |                 "error": str(exc),
 685 |             }}
 686 | 
 687 |     per_dataset_results = {{}}
 688 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
 689 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
 690 |         for future in as_completed(futures):
 691 |             ds_name, ds_result = future.result()
 692 |             per_dataset_results[ds_name] = ds_result
 693 | 
 694 |     aggregated = evaluator._aggregate_per_dataset_results(per_dataset_results)
 695 | 
 696 |     _write_payload_and_exit({{"result": aggregated}})
 697 | except Exception as exc:
 698 |     traceback.print_exc()
 699 |     _write_payload_and_exit({{"error": str(exc)}})
 700 | """
 701 |         temp_file.write(script.encode())
 702 |         temp_path = temp_file.name
 703 | 
 704 |     results_path = f"{temp_path}.results"
 705 |     try:
 706 |         process = subprocess.Popen(
 707 |             [sys.executable, temp_path],
 708 |             stdout=subprocess.PIPE,
 709 |             stderr=subprocess.PIPE,
 710 |         )
 711 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
 712 |         if stdout:
 713 |             print(stdout.decode())
 714 |         if stderr:
 715 |             print(stderr.decode())
 716 |         if process.returncode != 0:
 717 |             raise RuntimeError(f"Subprocess exited with code {process.returncode}")
 718 |         if not os.path.exists(results_path):
 719 |             raise RuntimeError("Results file not found")
 720 |         with open(results_path, "rb") as f:
 721 |             payload = pickle.load(f)
 722 |         if "error" in payload:
 723 |             raise RuntimeError(payload["error"])
 724 |         return payload["result"]
 725 |     except subprocess.TimeoutExpired:
 726 |         process.kill()
 727 |         process.wait()
 728 |         raise TimeoutError(f"Program execution timed out after {timeout_seconds}s")
 729 |     finally:
 730 |         for path in (temp_path, results_path):
 731 |             if os.path.exists(path):
 732 |                 os.unlink(path)
 733 | 
 734 | 
 735 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
 736 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
 737 |     nmse_val = float(result.get("nmse_val", float("inf")))
 738 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
 739 |     if not np.isfinite(combined):
 740 |         combined = 0.0
 741 | 
 742 |     return {
 743 |         "equation": str(result.get("equation", "")),
 744 |         "loss": nmse_val,
 745 |         "complexity": 0.0,
 746 |         "nmse_train": float("inf"),
 747 |         "nmse_val": nmse_val,
 748 |         "combined_score": combined,
 749 |         "eval_time": float(eval_time),
 750 |         "n_datasets": result.get("n_datasets", 0),
 751 |         "n_successful": result.get("n_successful", 0),
 752 |         "per_dataset": result.get("per_dataset", {}),
 753 |         "error": str(result.get("error", "")),
 754 |     }
 755 | 
 756 | 
 757 | def evaluate(program_path: str) -> dict:
 758 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
 759 |     try:
 760 |         start = time.time()
 761 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=3000)
 762 |         metrics = _metrics_from_result(result, time.time() - start)
 763 |         print(
 764 |             "Evaluation: "
 765 |             f"nmse_val={metrics['nmse_val']:.6f}, "
 766 |             f"combined_score={metrics['combined_score']:.6f}, "
 767 |             f"n_datasets={metrics['n_datasets']}, "
 768 |             f"n_successful={metrics['n_successful']}, "
 769 |             f"time={metrics['eval_time']:.2f}s"
 770 |         )
 771 |         print(f"Equation template: {metrics['equation']}")
 772 |         if metrics.get("error"):
 773 |             print(f"Evaluator feedback: {metrics['error']}")
 774 |         return metrics
 775 |     except Exception as exc:
 776 |         print(f"Evaluation failed: {exc}")
 777 |         traceback.print_exc()
 778 |         return {
 779 |             "equation": "",
 780 |             "loss": float("inf"),
 781 |             "complexity": 0.0,
 782 |             "nmse_train": float("inf"),
 783 |             "nmse_val": float("inf"),
 784 |             "combined_score": 0.0,
 785 |             "eval_time": 0.0,
 786 |             "n_datasets": 0,
 787 |             "n_successful": 0,
 788 |             "per_dataset": {},
 789 |             "error": str(exc),
 790 |         }
 791 | 
 792 | 
 793 | def _eval_stage1_worker(args):
 794 |     """Module-level worker for stage 1 parallel evaluation."""
 795 |     name, X_train, X_val, y_train, y_val, program_path = args
 796 |     harness_root = str(BENCHMARK_ROOT)
 797 |     if harness_root not in sys.path:
 798 |         sys.path.insert(0, harness_root)
 799 |     validate_candidate_source(program_path)
 800 |     spec = importlib.util.spec_from_file_location("program", program_path)
 801 |     program = importlib.util.module_from_spec(spec)
 802 |     spec.loader.exec_module(program)
 803 |     from pysr_harness.equation_session import (
 804 |         single_equation_evaluation,
 805 |         validate_single_equation_result,
 806 |     )
 807 | 
 808 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
 809 |         program, "run_discovery", None
 810 |     )
 811 |     if fn is None:
 812 |         return 0.0, "missing evaluate_symbolic_candidate()", ""
 813 |     n = min(200, len(X_train))
 814 |     m = min(80, len(X_val))
 815 |     try:
 816 |         with single_equation_evaluation():
 817 |             result = fn(X_train[:n], y_train[:n], X_val[:m], y_val[:m])
 818 |             validate_single_equation_result(result)
 819 |         return float(result.get("combined_score", 0.0)), None, str(
 820 |             result.get("equation_template", "")
 821 |         )
 822 |     except Exception as exc:
 823 |         return 0.0, str(exc), ""
