 601 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 602 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 603 | 
 604 |     The subprocess loads every dataset, calls the candidate's
 605 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 606 |     constants each time) using parallel threads, and returns aggregated
 607 |     metrics.
 608 |     """
 609 |     validate_candidate_source(program_path)
 610 |     harness_root = str(BENCHMARK_ROOT)
 611 |     evaluator_path = str(Path(__file__).resolve())
 612 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
 613 |         script = f"""
 614 | import importlib.util
 615 | import os
 616 | import pickle
 617 | import sys
 618 | import traceback
 619 | from concurrent.futures import ThreadPoolExecutor, as_completed
 620 | 
 621 | os.environ.setdefault("OMP_NUM_THREADS", "1")
 622 | os.environ.setdefault("MKL_NUM_THREADS", "1")
 623 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
 624 | 
 625 | import numpy as np
 626 | 
 627 | sys.path.insert(0, {harness_root!r})
 628 | 
 629 | program_path = {program_path!r}
 630 | evaluator_path = {evaluator_path!r}
 631 | results_path = {temp_file.name + ".results"!r}
 632 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 633 | 
 634 | def _write_payload_and_exit(payload):
 635 |     with open(results_path, "wb") as f:
 636 |         pickle.dump(payload, f)
 637 |     sys.stdout.flush()
 638 |     sys.stderr.flush()
 639 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
 640 |     # interpreter shutdown. The parent only needs the pickle payload.
 641 |     os._exit(0)
 642 | 
 643 | try:
 644 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
 645 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
 646 |     evaluator_spec.loader.exec_module(evaluator)
 647 |     evaluator.validate_candidate_source(program_path)
 648 | 
 649 |     spec = importlib.util.spec_from_file_location("program", program_path)
 650 |     program = importlib.util.module_from_spec(spec)
 651 |     spec.loader.exec_module(program)
 652 |     from pysr_harness.equation_session import (
 653 |         single_equation_evaluation,
 654 |         validate_single_equation_result,
 655 |     )
 656 | 
 657 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
 658 |         program, "run_discovery", None
 659 |     )
 660 |     if fn is None:
 661 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
 662 | 
 663 |     datasets = evaluator.load_all_datasets()
 664 | 
 665 |     def _eval_one(args):
 666 |         ds_name, X_train, X_val, y_train, y_val = args
 667 |         try:
 668 |             with single_equation_evaluation():
 669 |                 result = fn(X_train, y_train, X_val, y_val)
 670 |                 validate_single_equation_result(result)
 671 |             ds_nmse = float(result.get("nmse_val", float("inf")))
 672 |             ds_combined = float(result.get("combined_score", 0.0))
 673 |             return ds_name, {{
 674 |                 "nmse_val": ds_nmse,
 675 |                 "combined_score": ds_combined,
 676 |                 "equation": str(result.get("equation", "")),
 677 |                 "equation_template": str(result.get("equation_template", "")),
 678 |                 "constants": result.get("constants", {{}}),
 679 |             }}
 680 |         except Exception as exc:
 681 |             return ds_name, {{
 682 |                 "nmse_val": float("inf"),
 683 |                 "combined_score": 0.0,
 684 |                 "error": str(exc),
 685 |             }}
 686 | 
 687 |     per_dataset_results = {{}}
 688 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
 689 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
 690 |         for future in as_completed(futures):
 691 |             ds_name, ds_result = future.result()
 692 |             per_dataset_results[ds_name] = ds_result
 693 | 
 694 |     aggregated = evaluator._aggregate_per_dataset_results(per_dataset_results)
 695 | 
 696 |     _write_payload_and_exit({{"result": aggregated}})
 697 | except Exception as exc:
 698 |     traceback.print_exc()
 699 |     _write_payload_and_exit({{"error": str(exc)}})
 700 | """
 701 |         temp_file.write(script.encode())
 702 |         temp_path = temp_file.name
 703 | 
 704 |     results_path = f"{temp_path}.results"
 705 |     try:
 706 |         process = subprocess.Popen(
 707 |             [sys.executable, temp_path],
 708 |             stdout=subprocess.PIPE,
 709 |             stderr=subprocess.PIPE,
 710 |         )
 711 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
 712 |         if stdout:
 713 |             print(stdout.decode())
 714 |         if stderr:
 715 |             print(stderr.decode())
 716 |         if process.returncode != 0:
 717 |             raise RuntimeError(f"Subprocess exited with code {process.returncode}")
 718 |         if not os.path.exists(results_path):
 719 |             raise RuntimeError("Results file not found")
 720 |         with open(results_path, "rb") as f:
 721 |             payload = pickle.load(f)
 722 |         if "error" in payload:
 723 |             raise RuntimeError(payload["error"])
 724 |         return payload["result"]
 725 |     except subprocess.TimeoutExpired:
 726 |         process.kill()
 727 |         process.wait()
 728 |         raise TimeoutError(f"Program execution timed out after {timeout_seconds}s")
 729 |     finally:
 730 |         for path in (temp_path, results_path):
 731 |             if os.path.exists(path):
 732 |                 os.unlink(path)
 733 | 
