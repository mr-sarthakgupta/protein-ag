 757 | def evaluate(program_path: str) -> dict:
 758 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
 759 |     try:
 760 |         start = time.time()
 761 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=3000)
 762 |         metrics = _metrics_from_result(result, time.time() - start)
 763 |         print(
 764 |             "Evaluation: "
 765 |             f"nmse_val={metrics['nmse_val']:.6f}, "
 766 |             f"combined_score={metrics['combined_score']:.6f}, "
 767 |             f"n_datasets={metrics['n_datasets']}, "
 768 |             f"n_successful={metrics['n_successful']}, "
 769 |             f"time={metrics['eval_time']:.2f}s"
 770 |         )
 771 |         print(f"Equation template: {metrics['equation']}")
 772 |         if metrics.get("error"):
 773 |             print(f"Evaluator feedback: {metrics['error']}")
 774 |         return metrics
 775 |     except Exception as exc:
 776 |         print(f"Evaluation failed: {exc}")
 777 |         traceback.print_exc()
 778 |         return {
 779 |             "equation": "",
 780 |             "loss": float("inf"),
 781 |             "complexity": 0.0,
 782 |             "nmse_train": float("inf"),
 783 |             "nmse_val": float("inf"),
 784 |             "combined_score": 0.0,
 785 |             "eval_time": 0.0,
 786 |             "n_datasets": 0,
 787 |             "n_successful": 0,
 788 |             "per_dataset": {},
 789 |             "error": str(exc),
 790 |         }
