import numpy as np
import csv
import re
from pathlib import Path
from scipy.optimize import least_squares

def parse_param(col):
    text = col.strip()
    m = re.search(r'(\d+(?:\.\d+)?)\s*uM', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*mM', text, re.IGNORECASE)
    if m: return float(m.group(1)) * 1000.0
    m = re.search(r'(\d+(?:\.\d+)?)\s*mg/mL', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*ng/ul', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'pH\s+(\d+(?:\.\d+)?)', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*%', text)
    if m: return float(m.group(1))
    m = re.search(r':\s*(\d+(?:\.\d+)?)\s*$', text)
    if m: return float(m.group(1))
    return None

def load_tsv(path):
    with open(path, newline='') as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed_params = [parse_param(h) for h in response_headers]
        if all(p is not None for p in parsed_params):
            parameters = [float(p) for p in parsed_params]
        else:
            parameters = [float(i+1) for i in range(len(response_headers))]
        features, targets = [], []
        for row in reader:
            if not row: continue
            meas_x = float(row[0])
            for param, value in zip(parameters, row[1:]):
                if value == '' or value.strip().lower() == 'nan': continue
                features.append([meas_x, param])
                targets.append(float(value))
    return np.array(features), np.array(targets)

def nmse(y_true, y_pred):
    if not np.all(np.isfinite(y_pred)):
        return float('inf')
    var = float(np.var(y_true))
    if var <= 0.0:
        return float(np.mean((y_true - y_pred)**2))
    return float(np.mean((y_true - y_pred)**2) / var)

# Focus on the Alphasyn dataset - x1=0.3 for all 8 curves
# and the Kakkar2016 datasets with some duplicate x1 values

# Let's look at Kakkar2016_14kDa_Ex45_polyQ_sec
path = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/htt/Kakkar2016/FIts/Kakkar2016_14kDa_Ex45_polyQ_sec/fit.tsv'
with open(path, newline='') as f:
    reader = csv.reader(f, delimiter='\t')
    header = next(reader)
    rows = list(reader)
print('Header:', header)
print('Parsed x1:', [parse_param(h) for h in header[1:]])
print()

# Alphasyn
path_alphasyn = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/Alphasyn_Gaspar2017/03uM_seed all/fit.tsv'
with open(path_alphasyn, newline='') as f:
    reader = csv.reader(f, delimiter='\t')
    header = next(reader)
    rows = list(reader)
print('Alphasyn header:', header[:4])
print('Parsed x1:', [parse_param(h) for h in header[1:]])
print()

# The Alphasyn dataset has x1=0.3 for all 8 curves (seeding experiment)
# Let's look at the curve shapes
t = np.array([float(r[0]) for r in rows if r])
cols = [np.array([float(r[i+1]) for r in rows if r]) for i in range(8)]
y_all = np.column_stack(cols)
print('Alphasyn t range:', t.min(), t.max())
print('Alphasyn y range:', y_all.min(), y_all.max())
print()

# For each curve, what's the t50?
for i in range(8):
    y = cols[i]
    idx50 = np.argmin(np.abs(y - 0.5))
    idx10 = np.argmin(np.abs(y - 0.1))
    idx90 = np.argmin(np.abs(y - 0.9))
    print(f'Curve {i}: t10={t[idx10]:.1f}, t50={t[idx50]:.1f}, t90={t[idx90]:.1f}')
