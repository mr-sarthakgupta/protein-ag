import numpy as np

# The seeded insulin dataset has non-numeric x1 values (no seeds, 0.05%, 0.1%)
# Let's verify what x1 becomes
import re
headers = ['Nielsen2001_Fig6_344uMtotal_0-05pcseeds_43deg.txt: \"344 uM total, 0.05% seeds\"',
           'Nielsen2001_Fig6_344uMtotal_0-1pcseeds_43deg.txt: \"344 uM total, 0.1% seeds\"', 
           'Nielsen2001_Fig6_344uMtotal_noseeds_43deg.txt: \"344 uM total, no seeds\"']

def parse_param(col):
    text = col.strip()
    m = re.search(r'(\d+(?:\.\d+)?)\s*uM', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*mM', text, re.IGNORECASE)
    if m: return float(m.group(1)) * 1000.0
    m = re.search(r'(\d+(?:\.\d+)?)\s*mg/mL', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*ng/ul', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'pH\s+(\d+(?:\.\d+)?)', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*%', text)
    if m: return float(m.group(1))
    m = re.search(r':\s*(\d+(?:\.\d+)?)\s*$', text)
    if m: return float(m.group(1))
    return None

for h in headers:
    print(f'{h[:50]}: {parse_param(h)}')
print()
# The 344uM matches first, so x1 = 344 for all 3 columns? That would mean x1 is constant
# Actually wait - the first uM match is 344 for all 3 columns
# So x1=344 for all -> effectively single-concentration

# What about the SH3 pH dataset?
headers_sh3 = ['Zurdo2001_Fig8_pH2.txt: pH 1.5',
               'Zurdo2001_Fig8_pH2.4.txt: pH 2.4',
               'Zurdo2001_Fig8_pH2.7.txt: pH 2.7']
for h in headers_sh3:
    print(f'{h}: {parse_param(h)}')
"
