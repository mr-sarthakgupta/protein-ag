rng = np.random.default_rng(42)
indices = rng.permutation(len(y))
split = int(round(len(y) * 0.75))
X_train, X_val = X[indices[:split]], X[indices[split:]]
y_train, y_val = y[indices[:split]], y[indices[split:]]

# The best possible NMSE for this dataset is limited by the variance
# within curves at the same x1 value
print()
print('y variance analysis:')
print(f'Overall y variance: {np.var(y):.4f}')
# y at each time point varies across the 3 curves
y_all = np.column_stack([y1, y2, y3])
within_variance = np.mean(np.var(y_all, axis=1))
between_variance = np.var(np.mean(y_all, axis=1))
print(f'Within-curve variance: {within_variance:.4f}')
print(f'Between-curve variance: {between_variance:.4f}')
print(f'Theoretical min NMSE: {within_variance/np.var(y):.4f}')
