import numpy as np

# Let's look at some difficult datasets to understand the shape
import csv
from pathlib import Path

def load_tsv(path):
    with open(path, newline='') as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [[float(v) for v in row if v.strip()] for row in reader if row]
    return header, np.array(rows)

# Haemoglobin - single concentration, very steep
path = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/haemoglobin/Ferrone1985a/data and fits/sec_nuc_assuming_nc_n2_5/fit.tsv'
h, d = load_tsv(path)
print('Haemoglobin shape:', d.shape)
print('t range:', d[:,0].min(), d[:,0].max())
print('y range:', d[:,1].min(), d[:,1].max())
print('First 5 rows:', d[:5])
print()

# Alpha-syn - multi-concentration
path = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/Alphasyn_Gaspar2017/03uM_seed all/fit.tsv'
h, d = load_tsv(path)
print('AlphaSyn shape:', d.shape)
print('headers:', h[:4])
print('t range:', d[:,0].min(), d[:,0].max())
print()
"
