import sys
sys.path.insert(0, '.')
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, evaluate_expression
from pathlib import Path
import re, csv

DATA_ROOT = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def load_dataset(path):
    with open(path, newline='') as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [r for r in reader if r]
    resp = header[1:]
    parsed = []
    for h in resp:
        text = h.strip()
        done = False
        for pat, mult in [(r'(\d+(?:\.\d+)?)\s*uM', 1), (r'(\d+(?:\.\d+)?)\s*mM', 1000), (r'(\d+(?:\.\d+)?)\s*mg/mL', 1), (r'(\d+(?:\.\d+)?)\s*ng/ul', 1)]:
            m = re.search(pat, text, re.IGNORECASE)
            if m: parsed.append(float(m.group(1)) * mult); done=True; break
        if done: continue
        m = re.search(r'pH\s+(\d+(?:\.\d+)?)', text, re.IGNORECASE)
        if m: parsed.append(float(m.group(1))); continue
        m = re.search(r'(\d+(?:\.\d+)?)\s*%', text)
        if m: parsed.append(float(m.group(1))); continue
        m = re.search(r':\s*(\d+(?:\.\d+)?)\s*$', text)
        if m: parsed.append(float(m.group(1))); continue
        parsed.append(None)
    if all(p is not None for p in parsed):
        params = [float(p) for p in parsed]
    else:
        params = [float(i+1) for i in range(len(resp))]
    features, targets = [], []
    for row in rows:
        if not row: continue
        t = float(row[0])
        for p, v in zip(params, row[1:]):
            if v and v.strip().lower() != 'nan':
                features.append([t, p])
                targets.append(float(v))
    return np.array(features), np.array(targets)

x = feature_symbols(2)
c = constant_symbols(8)
time, parameter = x[0], x[1]

# Strategy: try both logistic and Gompertz with data-adaptive initial values
# Pick the best result

def estimate_params(X_train, y_train):
    times = X_train[:, 0]
    t_min, t_max = times.min(), times.max()
    t_range = t_max - t_min
    
    # Estimate half-time: find time where y is closest to 0.5
    # Sort by time and interpolate
    sort_idx = np.argsort(times)
    t_sorted = times[sort_idx]
    y_sorted = y_train[sort_idx]
    
    # Find approximate half-time
    y_min, y_max = y_sorted.min(), y_sorted.max()
    y_half = (y_min + y_max) / 2
    
    # Find where y crosses y_half
    idx_cross = np.argmin(np.abs(y_sorted - y_half))
    t_half = t_sorted[idx_cross]
    
    # Estimate rate from transition width (10-90% range)
    idx_10 = np.argmin(np.abs(y_sorted - (y_min + 0.1*(y_max-y_min))))
    idx_90 = np.argmin(np.abs(y_sorted - (y_min + 0.9*(y_max-y_min))))
    t_10 = t_sorted[idx_10]
    t_90 = t_sorted[idx_90]
    t_trans = abs(t_90 - t_10)
    rate = 4.4 / t_trans if t_trans > 0 else 4.4 / t_range
    
    return t_half, rate, y_min, y_max

# Test on a few datasets
test_paths = [
    'IAPP/Daval2010/Fits/Daval2010_sec',
    'biofilm proteins/TasA/Romero2010/Fits/Temp',
    'haemoglobin/Ferrone1985a/data and fits/sec_nuc_assuming_nc_n2_5',
    'Abeta/Meisl2014/Ab40_sec_IN_HOURS',
    'Alphasyn_Gaspar2017/03uM_seed all',
    'SH3/Fits/Zurdo2001_pH2_sec',
]

for rel in test_paths:
    path = DATA_ROOT / rel / 'fit.tsv'
    X, y = load_dataset(path)
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    split = int(round(len(y) * 0.75))
    X_train, X_val = X[idx[:split]], X[idx[split:]]
    y_train, y_val = y[idx[:split]], y[idx[split:]]
    
    t_half, rate, y_min, y_max = estimate_params(X_train, y_train)
    x1_mean = np.mean(X_train[:, 1])
    print(f'{Path(rel).name}: t_half={t_half:.1f}, rate={rate:.2e}, x1={x1_mean:.2f}')
    
    # Logistic model
    expr_log = c[4] / (1 + sp.exp(-c[0]*parameter**c[1] * (time - c[2]*parameter**c[3]))) + c[5]
    r_log = evaluate_expression(expr_log, X_train, y_train, X_val, y_val,
        constants=c[:6], initial_values=[rate, 0.0, t_half, 0.0, y_max-y_min, y_min])
    
    # Gompertz model with concentration dependence
    expr_gomp = c[4] * sp.exp(-c[1] * sp.exp(-c[0]*parameter**c[6] * (time - c[2]*parameter**c[3]))) + c[5]
    r_gomp = evaluate_expression(expr_gomp, X_train, y_train, X_val, y_val,
        constants=[c[0], c[1], c[2], c[3], c[4], c[5], c[6]],
        initial_values=[rate, 2.0, t_half, 0.0, y_max-y_min, y_min, 0.0])
    
    best = min(r_log['nmse_val'], r_gomp['nmse_val'])
    print(f'  logistic={r_log[\"nmse_val\"]:.4f}, gompertz={r_gomp[\"nmse_val\"]:.4f}, best={best:.4f}')
