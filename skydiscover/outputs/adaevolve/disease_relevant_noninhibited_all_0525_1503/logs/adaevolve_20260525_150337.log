nan_count = 0
for row in rows:
    for v in row[1:]:
        if v.strip().lower() == 'nan' or v.strip() == '':
            nan_count += 1
print(f'NaN count: {nan_count}')
print(f'Total values: {len(rows) * (len(rows[0])-1)}')
print()

# Load the dataset properly
X, y = load_tsv(path)
print(f'Loaded: {X.shape}, y range: {y.min():.4f} to {y.max():.4f}')
print(f'NaN in y: {np.isnan(y).sum()}')
print(f'x1 values: {np.unique(X[:,1])}')
print(f't range: {X[:,0].min():.1f} to {X[:,0].max():.1f}')

# Now test models on Alphasyn
rng = np.random.default_rng(42)
indices = rng.permutation(len(y))
