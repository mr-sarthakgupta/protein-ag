 208 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 209 |     fitted = fit_expression_constants(
 210 |         expression,
 211 |         X_train,
 212 |         y_train,
 213 |         X_val,
 214 |         constants=constants,
 215 |         initial_values=initial_values,
 216 |         max_nfev=max_nfev,
 217 |     )
 218 |     nmse_train = nmse(y_train, fitted.y_pred_train)
 219 |     nmse_val = nmse(y_val, fitted.y_pred_val)
 220 |     loss = float(np.mean((fitted.y_pred_train - y_train) ** 2))
 221 | 
 222 |     return {
 223 |         "equation_template": str(fitted.expression_template),
 224 |         "equation": str(fitted.expression),
 225 |         "constants": fitted.constants,
 226 |         "loss": loss,
 227 |         "complexity": _complexity(fitted.expression_template),
 228 |         "nmse_train": nmse_train,
 229 |         "nmse_val": nmse_val,
 230 |         "combined_score": combined_score_from_nmse(nmse_val),
 231 |     }
