 336 | def evaluate(program_path: str) -> dict:
 337 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
 338 |     try:
 339 |         start = time.time()
 340 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=3000)
 341 |         metrics = _metrics_from_result(result, time.time() - start)
 342 |         print(
 343 |             "Evaluation: "
 344 |             f"nmse_val={metrics['nmse_val']:.6f}, "
 345 |             f"combined_score={metrics['combined_score']:.6f}, "
 346 |             f"n_datasets={metrics['n_datasets']}, "
 347 |             f"n_successful={metrics['n_successful']}, "
 348 |             f"time={metrics['eval_time']:.2f}s"
 349 |         )
 350 |         print(f"Equation template: {metrics['equation']}")
 351 |         return metrics
 352 |     except Exception as exc:
 353 |         print(f"Evaluation failed: {exc}")
 354 |         traceback.print_exc()
 355 |         return {
 356 |             "equation": "",
 357 |             "loss": float("inf"),
 358 |             "complexity": 0.0,
 359 |             "nmse_train": float("inf"),
 360 |             "nmse_val": float("inf"),
 361 |             "combined_score": 0.0,
 362 |             "eval_time": 0.0,
 363 |             "n_datasets": 0,
 364 |             "n_successful": 0,
 365 |             "per_dataset": {},
