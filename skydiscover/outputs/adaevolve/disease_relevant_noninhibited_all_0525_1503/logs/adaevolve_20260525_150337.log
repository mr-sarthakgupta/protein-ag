import sys
sys.path.insert(0, '/home/mrsar/protein-ag')
sys.path.insert(0, '.')

import numpy as np
import sympy as sp

# Try to reproduce the current model failure on haemoglobin
from pysr_harness.equation_session import feature_symbols, constant_symbols, evaluate_expression
import csv
from pathlib import Path

DATA_ROOT = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def load_dataset(path):
    import re
    with open(path, newline='') as f:
        import csv
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [r for r in reader if r]
    resp = header[1:]
    parsed = []
    for h in resp:
        text = h.strip()
        m = re.search(r'(\d+(?:\.\d+)?)\s*uM', text, re.IGNORECASE)
        if m: parsed.append(float(m.group(1))); continue
        m = re.search(r'(\d+(?:\.\d+)?)\s*mM', text, re.IGNORECASE)
        if m: parsed.append(float(m.group(1)) * 1000); continue
        m = re.search(r'(\d+(?:\.\d+)?)\s*mg/mL', text, re.IGNORECASE)
        if m: parsed.append(float(m.group(1))); continue
        m = re.search(r'(\d+(?:\.\d+)?)\s*ng/ul', text, re.IGNORECASE)
        if m: parsed.append(float(m.group(1))); continue
        m = re.search(r'pH\s+(\d+(?:\.\d+)?)', text, re.IGNORECASE)
        if m: parsed.append(float(m.group(1))); continue
        m = re.search(r'(\d+(?:\.\d+)?)\s*%', text)
        if m: parsed.append(float(m.group(1))); continue
        m = re.search(r':\s*(\d+(?:\.\d+)?)\s*$', text)
        if m: parsed.append(float(m.group(1))); continue
        parsed.append(None)
    if all(p is not None for p in parsed):
        params = [float(p) for p in parsed]
    else:
        params = [float(i+1) for i in range(len(resp))]
    
    features, targets = [], []
    for row in rows:
        if not row: continue
        t = float(row[0])
        for p, v in zip(params, row[1:]):
            if v and v.strip().lower() != 'nan':
                features.append([t, p])
                targets.append(float(v))
    return np.array(features), np.array(targets)

# Test on haemoglobin
X, y = load_dataset(DATA_ROOT / 'haemoglobin/Ferrone1985a/data and fits/sec_nuc_assuming_nc_n2_5/fit.tsv')
rng = np.random.default_rng(42)
idx = rng.permutation(len(y))
split = int(round(len(y) * 0.75))
X_train, X_val = X[idx[:split]], X[idx[split:]]
y_train, y_val = y[idx[:split]], y[idx[split:]]

print('Haemoglobin: X_train shape', X_train.shape, 'x1 unique:', np.unique(X_train[:, 1]))
print('y range:', y_train.min(), y_train.max())

x = feature_symbols(2)
c = constant_symbols(6)
time, parameter = x[0], x[1]
rate = c[0] * parameter ** c[1]
half_time = c[2] * parameter ** c[3]
plateau = c[4]
baseline = c[5]
expression = plateau / (1 + sp.exp(-rate * (time - half_time))) + baseline

result = evaluate_expression(expression, X_train, y_train, X_val, y_val,
    constants=c, initial_values=[0.1, 0.5, 10.0, -0.5, 1.0, 0.0])
print('NMSE val:', result['nmse_val'])
print('Equation:', result['equation'])
" 2>&1
