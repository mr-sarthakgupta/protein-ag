 312 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
 313 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
 314 |     nmse_val = float(result.get("nmse_val", float("inf")))
 315 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
 316 |     if not np.isfinite(combined):
 317 |         combined = 0.0
 318 | 
 319 |     return {
 320 |         "equation": str(result.get("equation", "")),
 321 |         "loss": nmse_val,
 322 |         "complexity": 0.0,
 323 |         "nmse_train": float("inf"),
 324 |         "nmse_val": nmse_val,
 325 |         "combined_score": combined,
 326 |         "eval_time": float(eval_time),
 327 |         "n_datasets": result.get("n_datasets", 0),
 328 |         "n_successful": result.get("n_successful", 0),
 329 |         "per_dataset": result.get("per_dataset", {}),
 330 |     }
 331 | 
