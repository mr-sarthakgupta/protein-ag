 370 | def evaluate_stage1(program_path: str) -> dict:
 371 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
 372 |     try:
 373 |         harness_root = str(BENCHMARK_ROOT)
 374 |         if harness_root not in sys.path:
 375 |             sys.path.insert(0, harness_root)
 376 | 
 377 |         spec = importlib.util.spec_from_file_location("program", program_path)
 378 |         program = importlib.util.module_from_spec(spec)
 379 |         spec.loader.exec_module(program)
 380 | 
 381 |         fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
 382 |             program, "run_discovery", None
 383 |         )
 384 |         if fn is None:
 385 |             return {"combined_score": 0.0, "error": "missing evaluate_symbolic_candidate()"}
 386 | 
 387 |         all_datasets = load_all_datasets()
 388 |         # Stage 1: sample up to 8 datasets for a quick check
 389 |         rng = np.random.default_rng(RANDOM_STATE)
 390 |         if len(all_datasets) > 8:
 391 |             indices = rng.choice(len(all_datasets), size=8, replace=False)
 392 |             subset = [all_datasets[i] for i in sorted(indices)]
 393 |         else:
 394 |             subset = all_datasets
 395 | 
 396 |         import multiprocessing
 397 | 
 398 |         def _eval_stage1(args):
 399 |             name, X_train, X_val, y_train, y_val = args
 400 |             n = min(200, len(X_train))
 401 |             m = min(80, len(X_val))
 402 |             try:
 403 |                 result = fn(X_train[:n], y_train[:n], X_val[:m], y_val[:m])
 404 |                 return float(result.get("combined_score", 0.0))
 405 |             except Exception:
 406 |                 return 0.0
 407 | 
 408 |         fork_ctx = multiprocessing.get_context("fork")
 409 |         with fork_ctx.Pool(processes=NUM_WORKERS) as pool:
 410 |             combined_scores = list(pool.imap_unordered(_eval_stage1, subset))
 411 | 
 412 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
 413 |         return {"combined_score": agg_combined}
 414 |     except Exception as exc:
 415 |         print(f"Stage 1 evaluation failed: {exc}")
 416 |         return {"combined_score": 0.0, "error": str(exc)}
