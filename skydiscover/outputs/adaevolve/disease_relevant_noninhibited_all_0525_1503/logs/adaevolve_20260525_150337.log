t = np.array([float(r[0]) for r in rows if r])
cols = []
for i in range(8):
    col = []
    for r in rows:
        if r:
            v = r[i+1]
            if v.strip().lower() != 'nan' and v.strip() != '':
                col.append(float(v))
            else:
                col.append(np.nan)
