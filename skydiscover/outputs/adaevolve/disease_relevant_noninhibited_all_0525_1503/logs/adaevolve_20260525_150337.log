import sys
sys.path.insert(0, '.')
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, evaluate_expression
from pathlib import Path
import re, csv

DATA_ROOT = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def load_dataset(path):
    with open(path, newline='') as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [r for r in reader if r]
    resp = header[1:]
    parsed = []
    for h in resp:
        text = h.strip()
        done = False
        for pat, mult in [(r'(\d+(?:\.\d+)?)\s*uM', 1), (r'(\d+(?:\.\d+)?)\s*mM', 1000), (r'(\d+(?:\.\d+)?)\s*mg/mL', 1), (r'(\d+(?:\.\d+)?)\s*ng/ul', 1)]:
            m = re.search(pat, text, re.IGNORECASE)
            if m: parsed.append(float(m.group(1)) * mult); done=True; break
        if done: continue
        m = re.search(r'pH\s+(\d+(?:\.\d+)?)', text, re.IGNORECASE)
        if m: parsed.append(float(m.group(1))); continue
        m = re.search(r'(\d+(?:\.\d+)?)\s*%', text)
        if m: parsed.append(float(m.group(1))); continue
        m = re.search(r':\s*(\d+(?:\.\d+)?)\s*$', text)
        if m: parsed.append(float(m.group(1))); continue
        parsed.append(None)
    if all(p is not None for p in parsed):
        params = [float(p) for p in parsed]
    else:
        params = [float(i+1) for i in range(len(resp))]
    features, targets = [], []
    for row in rows:
        if not row: continue
        t = float(row[0])
        for p, v in zip(params, row[1:]):
            if v and v.strip().lower() != 'nan':
                features.append([t, p])
                targets.append(float(v))
    return np.array(features), np.array(targets)

x = feature_symbols(2)
c = constant_symbols(8)
time, parameter = x[0], x[1]

# TasA Temp: t=[-302, 129479], x1=1, y=[0.0001, 0.9987]
# The curve is NOT sigmoidal - it's more like a gradual rise
# y at midpoint (t~65000) is 0.93 - so the half-time is much earlier, ~t=15000
# Let's estimate: y=0.5 at around t=?
# From the data: t=11495 -> y=0.115, t=52134 -> y=0.842
# y=0.5 is around t=30000 approximately

path = DATA_ROOT / 'biofilm proteins/TasA/Romero2010/Fits/Temp/fit.tsv'
X, y = load_dataset(path)
rng = np.random.default_rng(42)
idx = rng.permutation(len(y))
split = int(round(len(y) * 0.75))
X_train, X_val = X[idx[:split]], X[idx[split:]]
y_train, y_val = y[idx[:split]], y[idx[split:]]

# This curve is NOT standard logistic - it's more like Gompertz (asymmetric)
# Or it could be Hill function: y = t^n / (t50^n + t^n)

# Try Gompertz with data-adaptive init
expr_gomp = c[4] * sp.exp(-c[1] * sp.exp(-c[0] * (time - c[2]))) + c[5]
for init in [
    [1e-4, 5.0, 30000.0, 0.0, 1.0],
    [1e-4, 3.0, 15000.0, 0.0, 1.0],
    [5e-5, 5.0, 20000.0, 0.0, 1.0],
]:
    r = evaluate_expression(expr_gomp, X_train, y_train, X_val, y_val,
        constants=[c[0], c[1], c[2], c[4], c[5]], initial_values=init)
    print(f'Gompertz init={init[:3]}: nmse={r[\"nmse_val\"]:.4f}')

# Try Hill function: y = t^n / (t50^n + t^n)
# But t can be negative...
# Try: y = (t - t0)^n / (t50^n + (t - t0)^n) where t0 is the start time
# Or: y = 1 / (1 + (t50/t)^n) - Hill

# Try Avrami: y = 1 - exp(-k * t^n)
# But t can be negative, so use t - t_min
expr_avrami = c[4] * (1 - sp.exp(-c[0] * (time - c[2])**c[1])) + c[5]
for init in [
    [1e-10, 3.0, -302.0, 1.0, 0.0],
    [1e-12, 4.0, -302.0, 1.0, 0.0],
]:
    r = evaluate_expression(expr_avrami, X_train, y_train, X_val, y_val,
        constants=[c[0], c[1], c[2], c[4], c[5]], initial_values=init)
    print(f'Avrami init={init[:3]}: nmse={r[\"nmse_val\"]:.4f}')
