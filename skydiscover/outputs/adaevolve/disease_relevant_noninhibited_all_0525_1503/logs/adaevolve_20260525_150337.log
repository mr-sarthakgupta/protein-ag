 194 | 
 195 | def evaluate_expression(
 196 |     expression: sp.Expr | str | float | int,
 197 |     X_train: NDArray,
 198 |     y_train: NDArray,
 199 |     X_val: NDArray,
 200 |     y_val: NDArray,
 201 |     *,
 202 |     constants: Sequence[sp.Symbol] | None = None,
 203 |     initial_values: Sequence[float] | None = None,
 204 |     max_nfev: int = 300,
 205 | ) -> dict[str, Any]:
 206 |     """Score a proposed equation template after fitting its constants."""
