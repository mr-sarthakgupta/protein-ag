import numpy as np
import csv
import re
from pathlib import Path
from scipy.optimize import least_squares

def parse_param(col):
    text = col.strip()
    m = re.search(r'(\d+(?:\.\d+)?)\s*uM', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*mM', text, re.IGNORECASE)
    if m: return float(m.group(1)) * 1000.0
    m = re.search(r'(\d+(?:\.\d+)?)\s*mg/mL', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*ng/ul', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'pH\s+(\d+(?:\.\d+)?)', text, re.IGNORECASE)
    if m: return float(m.group(1))
    m = re.search(r'(\d+(?:\.\d+)?)\s*%', text)
    if m: return float(m.group(1))
    m = re.search(r':\s*(\d+(?:\.\d+)?)\s*$', text)
    if m: return float(m.group(1))
    return None

def load_tsv(path):
    with open(path, newline='') as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed_params = [parse_param(h) for h in response_headers]
        if all(p is not None for p in parsed_params):
            parameters = [float(p) for p in parsed_params]
        else:
            parameters = [float(i+1) for i in range(len(response_headers))]
        features, targets = [], []
        for row in reader:
            if not row: continue
            meas_x = float(row[0])
            for param, value in zip(parameters, row[1:]):
                if value == '' or value.strip().lower() == 'nan': continue
                features.append([meas_x, param])
                targets.append(float(value))
    return np.array(features), np.array(targets)

def nmse(y_true, y_pred):
    if not np.all(np.isfinite(y_pred)):
        return float('inf')
    var = float(np.var(y_true))
    if var <= 0.0:
        return float(np.mean((y_true - y_pred)**2))
    return float(np.mean((y_true - y_pred)**2) / var)

# Test on seeded insulin - the 3 curves have x1=344 but different t50
# We need a model that can fit them all
# The key is that x1 is the same for all 3 curves
# So we can only fit the 'average' behavior

# Let's look at the actual data
path = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/insulin/Fits/Nielsen2001_seeded_sec/fit.tsv'
with open(path, newline='') as f:
    reader = csv.reader(f, delimiter='\t')
    header = next(reader)
    rows = list(reader)

t = np.array([float(r[0]) for r in rows if r])
y1 = np.array([float(r[1]) for r in rows if r])
y2 = np.array([float(r[2]) for r in rows if r])
y3 = np.array([float(r[3]) for r in rows if r])

# Find t50 for each
for name, yv in [('0.05%', y1), ('0.1%', y2), ('no seeds', y3)]:
    idx50 = np.argmin(np.abs(yv - 0.5))
    idx10 = np.argmin(np.abs(yv - 0.1))
    idx90 = np.argmin(np.abs(yv - 0.9))
    print(f'{name}: t10={t[idx10]:.0f}, t50={t[idx50]:.0f}, t90={t[idx90]:.0f}')

# The 3 curves have very different t50 values (6888, 8767, 42583)
# and they all have x1=344 so the model can't distinguish them
# Best we can do is fit the average

# Let's look at what happens if we try a model with a wide range of t50 values
# The 'best' single-curve fit would be for the middle curve

