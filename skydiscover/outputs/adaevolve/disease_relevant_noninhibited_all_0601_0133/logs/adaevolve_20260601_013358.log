import numpy as np
from scipy.optimize import least_squares
import csv, re

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'

def load_fit(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.I)
            if m: parsed.append(float(m.group(1)))
            else: parsed = None; break
        if parsed is None:
            params = [float(i+1) for i in range(len(response_headers))]
        else:
            params = parsed
        feats, tgts = [], []
        for row in reader:
            if not row: continue
            x0v = float(row[0])
            for p, v in zip(params, row[1:]):
                if v.strip() and v.strip().lower() != 'nan':
                    feats.append([x0v, p])
                    tgts.append(float(v))
    return np.array(feats), np.array(tgts)

# Check Kar2011 data
path = base + 'htt/Kar2011/Fits/Kar2011_Q30_without_lowest_conc_rpim/fit.tsv'
X, y = load_fit(path)
x0, x1 = X[:,0], X[:,1]
print('x0 range:', x0.min(), x0.max())
print('x1 range:', x1.min(), x1.max())
print('x0*x1 range:', (x0*x1).min(), (x0*x1).max())
print('y range:', y.min(), y.max())

# For the Gompertz: exp(c0 - c1*x0*x1^c2)
# With c0=1, c1=0.001, c2=0: c0 - c1*x0 = 1 - 0.001*1718518 = -1716 -> exp(-1716) ~ 0 (good)
# But during optimization, c1 might become negative -> exp(+1716) -> overflow
# Solution: use x0*x1^c2 but clip or use log1p

# Try: y = c3*exp(-exp(c0 - c1*log(1 + x0*x1^c2))) + c4
# This maps x0 to log scale, making it robust to large x0
def make_res_gomLog(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            z = np.log1p(x0 * np.abs(x1)**c2)
            pred = c3 * np.exp(-np.exp(c0 - c1 * z)) + c4
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

def eval_gomLog(c, Xv):
    x0v, x1v = Xv[:,0], Xv[:,1]
    z = np.log1p(x0v * np.abs(x1v)**c[2])
    return c[3]*np.exp(-np.exp(c[0] - c[1]*z)) + c[4]

# Also try: y = c3*exp(-exp(c0 - c1*x0^c2*x1^c3)) + c4  -- power of x0 too
def make_res_gomPow(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4,c5 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            pred = c4 * np.exp(-np.exp(c0 - c1 * x0**c2 * x1**c3)) + c5
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

def eval_gomPow(c, Xv):
    x0v, x1v = Xv[:,0], Xv[:,1]
    return c[4]*np.exp(-np.exp(c[0] - c[1]*x0v**c[2]*x1v**c[3])) + c[5]

import glob
files = glob.glob(base + '**/fit.tsv', recursive=True)
files.sort()

p0L = [1.0, 1.0, 0.0, 1.0, 0.0]
p0P = [1.0, 0.001, 1.0, 0.0, 1.0, 0.0]
p0A = [1.0, 0.001, 0.0, 1.0, 0.0]

def make_res_gomA(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            pred = c3 * np.exp(-np.exp(c0 - c1 * x0 * x1**c2)) + c4
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res
def eval_gomA(c, Xv):
    x0v, x1v = Xv[:,0], Xv[:,1]
    return c[3]*np.exp(-np.exp(c[0] - c[1]*x0v*x1v**c[2])) + c[4]

results = {'A':[], 'Log':[], 'Pow':[]}
for f in files:
    X, y = load_fit(f)
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    split = int(round(len(y)*0.75))
    Xtr, Xv = X[np.sort(idx[:split])], X[np.sort(idx[split:])]
    ytr, yv = y[np.sort(idx[:split])], y[np.sort(idx[split:])]
    for key, rfn, p0, efn in [
        ('A', make_res_gomA, p0A, eval_gomA),
        ('Log', make_res_gomLog, p0L, eval_gomLog),
        ('Pow', make_res_gomPow, p0P, eval_gomPow),
    ]:
        try:
            r = least_squares(rfn(Xtr,ytr), p0, loss='soft_l1', max_nfev=300)
            pred = efn(r.x, Xv)
            nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf
            results[key].append(nm)
        except: results[key].append(np.inf)

for k,v in results.items():
    print(f'Model{k:4s} mean={np.mean(v):.4f} median={np.median(v):.4f} >1:{sum(1 for x in v if x>1)}/{len(v)}')
