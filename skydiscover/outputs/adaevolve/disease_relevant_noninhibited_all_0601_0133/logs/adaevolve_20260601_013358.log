import numpy as np
from scipy.optimize import least_squares
import csv, re, glob

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
files = glob.glob(base + '**/fit.tsv', recursive=True)
files.sort()

def load_fit(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.I)
            if m: parsed.append(float(m.group(1)))
            else: parsed = None; break
        if parsed is None:
            params = [float(i+1) for i in range(len(response_headers))]
        else:
            params = parsed
        feats, tgts = [], []
        for row in reader:
            if not row: continue
            x0v = float(row[0])
            for p, v in zip(params, row[1:]):
                if v.strip() and v.strip().lower() != 'nan':
                    feats.append([x0v, p])
                    tgts.append(float(v))
    return np.array(feats), np.array(tgts)

def make_res_gomA(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            pred = c3 * np.exp(-np.exp(c0 - c1 * x0 * x1**c2)) + c4
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

def eval_gomA(c, Xv):
    x0v, x1v = Xv[:,0], Xv[:,1]
    return c[3]*np.exp(-np.exp(c[0] - c[1]*x0v*x1v**c[2])) + c[4]

p0A = [1.0, 0.001, 0.0, 1.0, 0.0]

for f in files:
    X, y = load_fit(f)
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    split = int(round(len(y)*0.75))
    Xtr, Xv = X[np.sort(idx[:split])], X[np.sort(idx[split:])]
    ytr, yv = y[np.sort(idx[:split])], y[np.sort(idx[split:])]
    try:
        r = least_squares(make_res_gomA(Xtr, ytr), p0A, loss='soft_l1', max_nfev=300)
        pred = eval_gomA(r.x, Xv)
        nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf
    except: nm = np.inf
    if nm > 0.3:
        name = f.replace(base,'')[:55]
        x0r = (X[:,0].min(), X[:,0].max())
        x1r = (X[:,1].min(), X[:,1].max())
        print(f'NMSE={nm:.3f} x0=[{x0r[0]:.1f},{x0r[1]:.1f}] x1=[{x1r[0]:.2f},{x1r[1]:.2f}] {name}')
        # show y shape
        print(f'  y=[{y.min():.3f},{y.max():.3f}] mean={y.mean():.3f}')
