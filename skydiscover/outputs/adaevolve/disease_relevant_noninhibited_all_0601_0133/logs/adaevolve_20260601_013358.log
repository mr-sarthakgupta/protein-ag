import numpy as np
from scipy.optimize import least_squares
import csv, re, glob

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
files = glob.glob(base + '**/fit.tsv', recursive=True)
files.sort()

def load_fit(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.I)
            if m: parsed.append(float(m.group(1)))
            else: parsed = None; break
        if parsed is None:
            params = [float(i+1) for i in range(len(response_headers))]
        else:
            params = parsed
        feats, tgts = [], []
        for row in reader:
            if not row: continue
            x0v = float(row[0])
            for p, v in zip(params, row[1:]):
                if v.strip() and v.strip().lower() != 'nan':
                    feats.append([x0v, p])
                    tgts.append(float(v))
    return np.array(feats), np.array(tgts)

# Model: y = c4 * exp(-exp(c0 - c1*x0*x1^c2)) + c5
# At half-point (y=c4*exp(-1)+c5): c0 = c1*x0_half*x1^c2
# c0 is O(1), c1*x0_half*x1^c2 ~ 1
# Initial: c0=1, c1=0.01, c2=0, c4=1, c5=0
def make_res_gom2(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4,c5 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            rate = c1 * x1**c2
            ht = c3 * x1**0  # just c3, no x1 dep on halftime
            pred = c4 * np.exp(-np.exp(c0 - rate*(x0 - ht))) + c5
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

# Model A: y = c4*exp(-exp(c0 - c1*x0*x1^c2)) + c3
# c0 ~ log(c1*x0_half*x1^c2), initial c0=1 (scale-free), c1 small
def make_res_gomA(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            pred = c3 * np.exp(-np.exp(c0 - c1 * x0 * x1**c2)) + c4
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

# Model B: original Gompertz with better p0
def make_res_gomB(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4,c5 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            rate = c0 * x1**c1
            ht = c2 * x1**c3
            pred = c4 * np.exp(-np.exp(-rate*(x0-ht))) + c5
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

p0A = [1.0, 0.01, 0.0, 1.0, 0.0]   # ModelA: c0,c1,c2,c3,c4
p0B = [0.1, 0.5, 10.0, -0.5, 1.0, 0.0]  # original

nmse_A, nmse_B = [], []
for f in files:
    X, y = load_fit(f)
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    split = int(round(len(y)*0.75))
    Xtr, Xv = X[np.sort(idx[:split])], X[np.sort(idx[split:])]
    ytr, yv = y[np.sort(idx[:split])], y[np.sort(idx[split:])]
    
    # Model A
    try:
        r = least_squares(make_res_gomA(Xtr, ytr), p0A, loss='soft_l1', max_nfev=300)
        c = r.x
        x0v, x1v = Xv[:,0], Xv[:,1]
        pred = c[2]*np.exp(-np.exp(c[0] - c[1]*x0v*x1v**c[2])) + c[3]  # bug: reuse c[2]
        # fix:
        pred = c[2]*np.exp(-np.exp(c[0] - c[1]*x0v*x1v**c[2])) + c[3]
        nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf
        nmse_A.append(nm)
    except: nmse_A.append(np.inf)
    
    # Model B (Gompertz original)
    try:
        r = least_squares(make_res_gomB(Xtr, ytr), p0B, loss='soft_l1', max_nfev=300)
        c = r.x
        x0v, x1v = Xv[:,0], Xv[:,1]
        pred = c[4]*np.exp(-np.exp(-c[0]*x1v**c[1]*(x0v-c[2]*x1v**c[3])))+c[5]
        nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf
        nmse_B.append(nm)
    except: nmse_B.append(np.inf)

print(f'ModelA(c0-c1*x0*x1^c2) mean={np.mean(nmse_A):.4f} >1:{sum(1 for v in nmse_A if v>1)}/{len(nmse_A)}')
print(f'ModelB(Gompertz orig)   mean={np.mean(nmse_B):.4f} >1:{sum(1 for v in nmse_B if v>1)}/{len(nmse_B)}')
