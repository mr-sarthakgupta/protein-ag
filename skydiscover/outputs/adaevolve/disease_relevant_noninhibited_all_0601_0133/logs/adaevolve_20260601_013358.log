$ python3 -c "
import numpy as np
from scipy.optimize import least_squares
import csv, re, glob, sys
sys.path.insert(0, '/home/mrsar/protein-ag')

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
files = glob.glob(base + '**/fit.tsv', recursive=True)
files.sort()

def load_fit(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.I)
            if m: parsed.append(float(m.group(1)))
            else: parsed = None; break
        if parsed is None:
            params = [float(i+1) for i in range(len(response_headers))]
        else:
            params = parsed
        feats, tgts = [], []
        for row in reader:
            if not row: continue
            x0v = float(row[0])
            for p, v in zip(params, row[1:]):
                if v.strip() and v.strip().lower() != 'nan':
                    feats.append([x0v, p])
                    tgts.append(float(v))
    return np.array(feats), np.array(tgts)

def make_res_sq(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4,c5 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            pred = c4 * np.exp(-np.exp(c0 - c1 * (x0**2)**c2 * x1**c3)) + c5
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

def eval_sq(c, Xv):
    x0v, x1v = Xv[:,0], Xv[:,1]
    with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
        return c[4]*np.exp(-np.exp(c[0] - c[1]*(x0v**2)**c[2]*x1v**c[3])) + c[5]

p0 = [1.0, 0.01, 0.35, 0.0, 1.0, 0.0]
nmse_list = []
for f in files:
    X, y = load_fit(f)
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    split = int(round(len(y)*0.75))
    Xtr, Xv = X[np.sort(idx[:split])], X[np.sort(idx[split:])]
    ytr, yv = y[np.sort(idx[:split])], y[np.sort(idx[split:])]
    try:
        r = least_squares(make_res_sq(Xtr, ytr), p0, loss='soft_l1', max_nfev=300)
        pred = eval_sq(r.x, Xv)
        nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf
        nmse_list.append(nm)
    except: nmse_list.append(np.inf)

mean_nmse = np.mean(nmse_list)
# complexity of (x0**2)**c2: let's count
import sympy as sp
x0s, x1s = sp.symbols('x0 x1')
c0s,c1s,c2s,c3s,c4s,c5s = sp.symbols('c0 c1 c2 c3 c4 c5')
expr = c4s * sp.exp(-sp.exp(c0s - c1s * (x0s**2)**c2s * x1s**c3s)) + c5s
complexity = sum(1 for _ in sp.preorder_traversal(expr))
parsimony = 1.0 - 0.2 * (complexity/160)
fit_score = 1.0/(1.0 + mean_nmse)
combined = fit_score * parsimony

print(f'Expression: {expr}')
print(f'Complexity: {complexity}')
print(f'Mean NMSE: {mean_nmse:.4f}')
print(f'Parsimony factor: {parsimony:.4f}')
print(f'Fit score: {fit_score:.4f}')
print(f'Estimated combined_score: {combined:.4f}')
print()
for f, nm in zip(files, nmse_list):
    if nm > 0.5:
        print(f'  NMSE={nm:.3f}  {f.replace(base,\"\")[:60]}')
" 2>/dev/null
