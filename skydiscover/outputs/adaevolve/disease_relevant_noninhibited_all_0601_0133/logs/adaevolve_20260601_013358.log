import numpy as np
from scipy.optimize import least_squares
import csv, re, glob

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
files = glob.glob(base + '**/fit.tsv', recursive=True)
files.sort()

def load_fit(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.I)
            if m: parsed.append(float(m.group(1)))
            else: parsed = None; break
        if parsed is None:
            params = [float(i+1) for i in range(len(response_headers))]
        else:
            params = parsed
        feats, tgts = [], []
        for row in reader:
            if not row: continue
            x0v = float(row[0])
            for p, v in zip(params, row[1:]):
                if v.strip() and v.strip().lower() != 'nan':
                    feats.append([x0v, p])
                    tgts.append(float(v))
    return np.array(feats), np.array(tgts)

# ModelPow with better initial values: c2=0.5 instead of 1.0
# y = c4*exp(-exp(c0 - c1*x0^c2*x1^c3)) + c5
def make_res_gomPow(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4,c5 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            # use abs(x0) to handle negative x0 (Ye2011)
            pred = c4 * np.exp(-np.exp(c0 - c1 * np.abs(x0)**c2 * x1**c3)) + c5
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

def eval_gomPow(c, Xv):
    x0v, x1v = Xv[:,0], Xv[:,1]
    return c[4]*np.exp(-np.exp(c[0] - c[1]*np.abs(x0v)**c[2]*x1v**c[3])) + c[5]

# Try different initial values for c2
results = {}
for c2_init, c1_init in [(1.0, 0.001), (0.5, 0.1), (0.7, 0.01)]:
    key = f'c2={c2_init}'
    p0 = [1.0, c1_init, c2_init, 0.0, 1.0, 0.0]
    nmse_list = []
    for f in files:
        X, y = load_fit(f)
        rng = np.random.default_rng(42)
        idx = rng.permutation(len(y))
        split = int(round(len(y)*0.75))
        Xtr, Xv = X[np.sort(idx[:split])], X[np.sort(idx[split:])]
        ytr, yv = y[np.sort(idx[:split])], y[np.sort(idx[split:])]
        try:
            r = least_squares(make_res_gomPow(Xtr, ytr), p0, loss='soft_l1', max_nfev=300)
            pred = eval_gomPow(r.x, Xv)
            nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf
            nmse_list.append(nm)
        except: nmse_list.append(np.inf)
    results[key] = nmse_list

for k, v in results.items():
    print(f'{k}: mean={np.mean(v):.4f} median={np.median(v):.4f} >0.5:{sum(1 for x in v if x>0.5)}/{len(v)}')
