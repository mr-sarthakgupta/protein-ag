import csv, numpy as np
from pathlib import Path
import os, re, sys
sys.path.insert(0, '.')

root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')
datasets = []
for dirpath, _, filenames in os.walk(root):
    if 'fit.tsv' in filenames:
        datasets.append((Path(dirpath).name, Path(dirpath) / 'fit.tsv'))
datasets.sort()

from scipy.optimize import least_squares
from pysr_harness.metrics import nmse as base_nmse

def gaussian_smooth_1d(values, sigma=1.0):
    values = np.asarray(values, dtype=float).ravel()
    if values.size < 3: return values
    radius = max(1, int(round(3.0 * sigma)))
    offsets = np.arange(-radius, radius + 1, dtype=float)
    kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
    kernel /= np.sum(kernel)
    padded = np.pad(values, (radius, radius), mode='edge')
    return np.convolve(padded, kernel, mode='valid')

def nmse_s(y_true, y_pred):
    raw = base_nmse(y_true, y_pred)
    smooth = base_nmse(gaussian_smooth_1d(y_true), y_pred)
    return float((raw + smooth) / 2.0)

def load_ds(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [r for r in reader if r]
    response_headers = header[1:]
    parsed = []
    for h in response_headers:
        m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.IGNORECASE)
        if m: parsed.append(float(m.group(1)))
        else: parsed.append(None)
    if all(p is not None for p in parsed):
        params = [float(p) for p in parsed]
    else:
        params = [float(i+1) for i in range(len(response_headers))]
    features, targets = [], []
    for row in rows:
        if not row: continue
        t = float(row[0])
        for pi, val in zip(params, row[1:]):
            if val and val.strip().lower() != 'nan':
                features.append([t, pi])
                targets.append(float(val))
    return np.array(features), np.array(targets)

results = {}

for name, path in datasets:
    try:
        X, y = load_ds(path)
        rng = np.random.default_rng(42)
        idx = rng.permutation(len(y))
        split = int(round(len(y) * 0.75))
        tr, va = np.sort(idx[:split]), np.sort(idx[split:])
        Xtr, ytr = X[tr], y[tr]
        Xva, yva = X[va], y[va]
        t, tv = Xtr[:,0], Xva[:,0]
        t0_init = np.median(t)

        # Better logistic init: t50 = median time where y crosses 0.5
        # Use data-informed init
        sorted_t = np.sort(t)
        sorted_y = ytr[np.argsort(t)]
        # Find approximate t50
        above = sorted_t[sorted_y > 0.5]
        t50_init = above[0] if len(above) > 0 else t0_init

        # Model 1: standard logistic, better init
        def res_l(p):
            with np.errstate(over='ignore'):
                pred = p[2]/(1+np.exp(-p[0]*(t-p[1])))+p[3]
            return pred - ytr
        r = least_squares(res_l, [1.0, t50_init, 1.0, 0.0], loss='soft_l1', max_nfev=300)
        with np.errstate(over='ignore'):
            pred = r.x[2]/(1+np.exp(-r.x[0]*(tv-r.x[1])))+r.x[3]
        results.setdefault('logistic_betterinit', []).append(nmse_s(yva, pred))

        # Model 2: tanh, better init
        def res_t(p):
            return p[0]*np.tanh(p[1]*(t-p[2]))+p[3] - ytr
        # For 0->1 data: A=0.5, b=0.5, t50=t50_init
        r = least_squares(res_t, [0.5, 1.0/max(t50_init,1e-6), t50_init, 0.5], loss='soft_l1', max_nfev=300)
        pred = r.x[0]*np.tanh(r.x[1]*(tv-r.x[2]))+r.x[3]
        results.setdefault('tanh_betterinit', []).append(nmse_s(yva, pred))

        # Model 3: logistic with log(t) - handles wide time ranges better
        # A/(1+exp(-k*(log(t+c1) - c2))) + b  -- but log requires t>0
        tmin = t.min()
        tshift = max(-tmin + 1.0, 0.0)  # ensure t+shift > 0
        def res_lt(p):
            lt = np.log(np.maximum(t + tshift, 1e-10))
            with np.errstate(over='ignore'):
                pred = p[2]/(1+np.exp(-p[0]*(lt - p[1])))+p[3]
            return pred - ytr
        lt50 = np.log(max(t50_init + tshift, 1e-10))
        r = least_squares(res_lt, [2.0, lt50, 1.0, 0.0], loss='soft_l1', max_nfev=300)
        ltvv = np.log(np.maximum(tv + tshift, 1e-10))
        with np.errstate(over='ignore'):
            pred = r.x[2]/(1+np.exp(-r.x[0]*(ltvv - r.x[1])))+r.x[3]
        results.setdefault('logistic_logt', []).append(nmse_s(yva, pred))

    except Exception as e:
        for k in results: results[k].append(np.inf)

def safe_mean(arr):
    a = [x for x in arr if np.isfinite(x)]
    return np.mean(a) if a else np.inf

for k, v in results.items():
    print(f'{k:30s}: mean_nmse={safe_mean(v):.4f}, n_inf={sum(not np.isfinite(x) for x in v)}')
