import numpy as np
from scipy.optimize import curve_fit
import pandas as pd
import glob

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
files = glob.glob(base + '**/fit.tsv', recursive=True)
files.sort()

def logistic_full(X, c0, c1, c2, c3, c4, c5):
    x0, x1 = X[:,0], X[:,1]
    rate = c0 * x1**c1
    ht = c2 * x1**c3
    return c4 / (1 + np.exp(-rate * (x0 - ht))) + c5

def gompertz_full(X, c0, c1, c2, c3, c4, c5):
    x0, x1 = X[:,0], X[:,1]
    rate = c0 * x1**c1
    ht = c2 * x1**c3
    return c4 * np.exp(-np.exp(-rate * (x0 - ht))) + c5

import sys, os
sys.path.insert(0, '/home/mrsar/protein-ag')
# manually load evaluator
import csv, re

def load_fit(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.I)
            if m: parsed.append(float(m.group(1)))
            else: parsed = None; break
        if parsed is None:
            params = [float(i+1) for i in range(len(response_headers))]
        else:
            params = parsed
        feats, tgts = [], []
        for row in reader:
            if not row: continue
            x0v = float(row[0])
            for p, v in zip(params, row[1:]):
                if v.strip() and v.strip().lower() != 'nan':
                    feats.append([x0v, p])
                    tgts.append(float(v))
    return np.array(feats), np.array(tgts)

