import numpy as np
from scipy.optimize import least_squares
import csv, re, glob, sys
sys.path.insert(0, '/home/mrsar/protein-ag')

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
files = glob.glob(base + '**/fit.tsv', recursive=True)
files.sort()

def load_fit(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.I)
            if m: parsed.append(float(m.group(1)))
            else: parsed = None; break
        if parsed is None:
            params = [float(i+1) for i in range(len(response_headers))]
        else:
            params = parsed
        feats, tgts = [], []
        for row in reader:
            if not row: continue
            x0v = float(row[0])
            for p, v in zip(params, row[1:]):
                if v.strip() and v.strip().lower() != 'nan':
                    feats.append([x0v, p])
                    tgts.append(float(v))
    return np.array(feats), np.array(tgts)

# No abs - plain x0^c2 (x0 could be negative for Ye2011)
def make_res(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4,c5 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            pred = c4 * np.exp(-np.exp(c0 - c1 * x0**c2 * x1**c3)) + c5
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

def eval_fn(c, Xv):
    x0v, x1v = Xv[:,0], Xv[:,1]
    with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
        return c[4]*np.exp(-np.exp(c[0] - c[1]*x0v**c[2]*x1v**c[3])) + c[5]

p0 = [1.0, 0.01, 0.7, 0.0, 1.0, 0.0]
nmse_list = []
for f in files:
    X, y = load_fit(f)
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    split = int(round(len(y)*0.75))
    Xtr, Xv = X[np.sort(idx[:split])], X[np.sort(idx[split:])]
    ytr, yv = y[np.sort(idx[:split])], y[np.sort(idx[split:])]
    try:
        r = least_squares(make_res(Xtr, ytr), p0, loss='soft_l1', max_nfev=300)
        pred = eval_fn(r.x, Xv)
        nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf
        nmse_list.append(nm)
    except: nmse_list.append(np.inf)

finite = [v for v in nmse_list if np.isfinite(v)]
mean_nmse = np.mean(nmse_list)  # inf if any fail
print(f'mean NMSE (all): {mean_nmse:.4f}')
print(f'mean NMSE (finite only): {np.mean(finite):.4f}')
print(f'failures (>1): {sum(1 for v in nmse_list if v > 1)}/{len(nmse_list)}')
print(f'failures (inf): {sum(1 for v in nmse_list if not np.isfinite(v))}/{len(nmse_list)}')

# Estimate combined score (using harness formula: 1/(1+mean_nmse) * parsimony)
# complexity=19, parsimony = 1 - 0.2*(19/160) = 1 - 0.02375 = 0.97625
parsimony = 1.0 - 0.2 * (19/160)
fit_score = 1.0 / (1.0 + mean_nmse)
print(f'complexity=19, parsimony={parsimony:.4f}')
print(f'estimated combined_score: {fit_score * parsimony:.4f}')

# Also show per-dataset for worst ones
print()
for i, (f, nm) in enumerate(zip(files, nmse_list)):
    if nm > 0.3:
        print(f'  NMSE={nm:.3f}  {f.replace(base,\"\")[:55]}')
