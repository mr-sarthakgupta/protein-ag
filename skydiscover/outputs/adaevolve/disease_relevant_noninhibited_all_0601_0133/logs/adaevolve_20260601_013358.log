import sympy as sp
import numpy as np

# Check complexity of the expression
x0, x1 = sp.symbols('x0 x1')
c0,c1,c2,c3,c4,c5 = sp.symbols('c0 c1 c2 c3 c4 c5')

# ModelPow with abs(x0): y = c4*exp(-exp(c0 - c1*x0^c2*x1^c3)) + c5
# Note: abs(x0) in sympy is sp.Abs(x0) but we can use x0**2)**0.5 or just x0^c2 
# since x0 >= 0 for most datasets (only Ye2011 has negative x0 starting at -256)
# Actually Ye2011 x0 min is -256 but that's just the time offset

# Expression without abs (simpler):
expr = c4 * sp.exp(-sp.exp(c0 - c1 * x0**c2 * x1**c3)) + c5
print('Without abs:')
print('  expr:', expr)
print('  complexity:', sum(1 for _ in sp.preorder_traversal(expr)))

# With sp.sqrt(x0**2) for abs - too complex
# Alternative: use (x0 + c5)**c2 to shift x0 away from 0/negative
# But that adds a constant

# Check: what is x0 range for Ye2011?
# x0=[-256.6, 115478.6] - negative x0 with power c2=0.7 gives complex numbers
# Solution: use x0^c2 and hope c2 converges to integer, OR use (x0-c_min)^c2

# Actually the simplest fix: use sp.Abs in sympy
expr_abs = c4 * sp.exp(-sp.exp(c0 - c1 * sp.Abs(x0)**c2 * x1**c3)) + c5
print('With Abs:')
print('  complexity:', sum(1 for _ in sp.preorder_traversal(expr_abs)))

# Check if sp.Abs is banned
import sys
sys.path.insert(0, '/home/mrsar/protein-ag')
from pysr_harness.equation_session import _BANNED_EXPR_TYPES, _BANNED_EXPR_FUNCTIONS
print('Abs in banned types:', sp.Abs in _BANNED_EXPR_TYPES)
print('Abs in banned fns:', 'Abs' in _BANNED_EXPR_FUNCTIONS)
print('Banned fn names:', _BANNED_EXPR_FUNCTIONS)
