import numpy as np
import csv
from pathlib import Path

data_file = Path('alphasyn_gaspar2017_03um_seed_all/fit.tsv')
features = []
targets = []
import re

with data_file.open(newline='') as f:
    reader = csv.reader(f, delimiter='\t')
    header = next(reader)
    concs = []
    for name in header[1:]:
        m = re.search(r':\s*([0-9]+(?:\.[0-9]+)?)uM\s*$', name)
        concs.append(float(m.group(1)) if m else 1.0)
    for row in reader:
        if not row: continue
        t = float(row[0])
        for c, v in zip(concs, row[1:]):
            if v and v.strip().lower() != 'nan':
                features.append([t, c])
                targets.append(float(v))

X = np.array(features)
y = np.array(targets)
print(f'Shape: {X.shape}, y range: [{y.min():.3f}, {y.max():.3f}]')
print(f'x0 (time) range: [{X[:,0].min():.3f}, {X[:,0].max():.3f}]')
print(f'x1 (conc) range: [{X[:,1].min():.3f}, {X[:,1].max():.3f}], unique: {np.unique(X[:,1])}')
print(f'y mean: {y.mean():.3f}, std: {y.std():.3f}')
# Check shape of curve - sample a few time points
for c in np.unique(X[:,1])[:3]:
    mask = X[:,1] == c
    t_sub = X[mask, 0]
    y_sub = y[mask]
    idx_sort = np.argsort(t_sub)
    print(f'  conc={c}uM: t=[{t_sub[idx_sort[0]]:.2f}..{t_sub[idx_sort[-1]]:.2f}], y=[{y_sub[idx_sort[0]]:.3f}..{y_sub[idx_sort[-1]]:.3f}]')
"
