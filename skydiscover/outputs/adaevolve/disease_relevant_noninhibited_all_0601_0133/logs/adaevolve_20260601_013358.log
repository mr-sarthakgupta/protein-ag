import numpy as np
from scipy.optimize import least_squares
import csv, re, glob

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
files = glob.glob(base + '**/fit.tsv', recursive=True)
files.sort()

def load_fit(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.I)
            if m: parsed.append(float(m.group(1)))
            else: parsed = None; break
        if parsed is None:
            params = [float(i+1) for i in range(len(response_headers))]
        else:
            params = parsed
        feats, tgts = [], []
        for row in reader:
            if not row: continue
            x0v = float(row[0])
            for p, v in zip(params, row[1:]):
                if v.strip() and v.strip().lower() != 'nan':
                    feats.append([x0v, p])
                    tgts.append(float(v))
    return np.array(feats), np.array(tgts)

def make_residual_log(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4,c5 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            rate = c0 * x1**c1
            ht = c2 * x1**c3
            pred = c4 * np.exp(-np.exp(-rate*(x0-ht))) + c5
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

def make_residual_logistic(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4,c5 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            rate = c0 * x1**c1
            ht = c2 * x1**c3
            pred = c4 / (1 + np.exp(-rate*(x0-ht))) + c5
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

p0 = [0.1, 0.5, 10.0, -0.5, 1.0, 0.0]
nmse_gom, nmse_log = [], []

for f in files:
    X, y = load_fit(f)
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    split = int(round(len(y)*0.75))
    Xtr, Xv = X[np.sort(idx[:split])], X[np.sort(idx[split:])]
    ytr, yv = y[np.sort(idx[:split])], y[np.sort(idx[split:])]
    
    for res_fn, lst in [(make_residual_log, nmse_gom), (make_residual_logistic, nmse_log)]:
        try:
            r = least_squares(res_fn(Xtr, ytr), p0, loss='soft_l1', max_nfev=300)
            c = r.x
            x0v, x1v = Xv[:,0], Xv[:,1]
            if res_fn == make_residual_log:
                pred = c[4]*np.exp(-np.exp(-c[0]*x1v**c[1]*(x0v-c[2]*x1v**c[3])))+c[5]
            else:
                pred = c[4]/(1+np.exp(-c[0]*x1v**c[1]*(x0v-c[2]*x1v**c[3])))+c[5]
            nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf
            lst.append(nm)
        except: lst.append(np.inf)

print(f'Gompertz  mean NMSE: {np.mean(nmse_gom):.4f}, median: {np.median(nmse_gom):.4f}')
print(f'Logistic  mean NMSE: {np.mean(nmse_log):.4f}, median: {np.median(nmse_log):.4f}')
print(f'Gompertz  >1: {sum(1 for v in nmse_gom if v > 1.0)}/{len(nmse_gom)}')
print(f'Logistic  >1: {sum(1 for v in nmse_log if v > 1.0)}/{len(nmse_log)}')
