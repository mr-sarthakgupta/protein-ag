import sympy as sp
import sys
sys.path.insert(0, '.')

# Count complexity of the log-logistic model
x0, c0, c1, c2, c3, c4 = sp.symbols('x0 c0 c1 c2 c3 c4')

expr = c3 / (1 + sp.exp(-c0 * (sp.log(x0 + c1) - c2))) + c4
print('Expression:', expr)
complexity = sum(1 for _ in sp.preorder_traversal(expr))
print(f'Complexity: {complexity}')

# Also test: c3 / (1 + exp(-c0 * sp.log(x0 + c1) + c2)) + c4  (equivalent, slightly different form)
expr2 = c3 / (1 + sp.exp(-c0 * sp.log(x0 + c1) + c2)) + c4
complexity2 = sum(1 for _ in sp.preorder_traversal(expr2))
print(f'Alt form complexity: {complexity2}')
print('Alt form:', expr2)
