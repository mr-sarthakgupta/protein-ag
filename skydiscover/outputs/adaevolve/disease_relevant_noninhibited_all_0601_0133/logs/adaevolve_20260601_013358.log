import numpy as np
from scipy.optimize import least_squares
import csv, re, glob

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
files = glob.glob(base + '**/fit.tsv', recursive=True)
files.sort()

def load_fit(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.I)
            if m: parsed.append(float(m.group(1)))
            else: parsed = None; break
        if parsed is None:
            params = [float(i+1) for i in range(len(response_headers))]
        else:
            params = parsed
        feats, tgts = [], []
        for row in reader:
            if not row: continue
            x0v = float(row[0])
            for p, v in zip(params, row[1:]):
                if v.strip() and v.strip().lower() != 'nan':
                    feats.append([x0v, p])
                    tgts.append(float(v))
    return np.array(feats), np.array(tgts)

# Model A FIXED: y = c3*exp(-exp(c0 - c1*x0*x1^c2)) + c4
# 5 constants, scale-invariant c0
def make_res_gomA(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            pred = c3 * np.exp(-np.exp(c0 - c1 * x0 * x1**c2)) + c4
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

def eval_gomA(c, Xv):
    x0v, x1v = Xv[:,0], Xv[:,1]
    return c[3]*np.exp(-np.exp(c[0] - c[1]*x0v*x1v**c[2])) + c[4]

# Model C: Gompertz with log(x0) parameterization
# y = c4*exp(-exp(c0 - c1*log(x0)*x1^c2)) + c3  -- but log(0) is undefined
# Model D: y = c4*exp(-exp(c0 - c1*(x0+1)*x1^c2)) + c3  -- add 1 for x0=0 safety
def make_res_gomD(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            pred = c3 * np.exp(-np.exp(c0 - c1 * (x0+1) * x1**c2)) + c4
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

def eval_gomD(c, Xv):
    x0v, x1v = Xv[:,0], Xv[:,1]
    return c[3]*np.exp(-np.exp(c[0] - c[1]*(x0v+1)*x1v**c[2])) + c[4]

# Model B: original Gompertz 6-param
def make_res_gomB(X, y):
    x0, x1 = X[:,0], X[:,1]
    def res(theta):
        c0,c1,c2,c3,c4,c5 = theta
        with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
            rate = c0 * x1**c1
            ht = c2 * x1**c3
            pred = c4 * np.exp(-np.exp(-rate*(x0-ht))) + c5
        if not np.all(np.isfinite(pred)): return np.full(len(y), 1e12)
        return pred - y
    return res

def eval_gomB(c, Xv):
    x0v, x1v = Xv[:,0], Xv[:,1]
    return c[4]*np.exp(-np.exp(-c[0]*x1v**c[1]*(x0v-c[2]*x1v**c[3])))+c[5]

p0A = [1.0, 0.001, 0.0, 1.0, 0.0]
p0D = [1.0, 0.001, 0.0, 1.0, 0.0]
p0B = [0.1, 0.5, 10.0, -0.5, 1.0, 0.0]

results = {'A': [], 'D': [], 'B': []}
for f in files:
    X, y = load_fit(f)
    rng = np.random.default_rng(42)
    idx = rng.permutation(len(y))
    split = int(round(len(y)*0.75))
    Xtr, Xv = X[np.sort(idx[:split])], X[np.sort(idx[split:])]
    ytr, yv = y[np.sort(idx[:split])], y[np.sort(idx[split:])]
    
    for key, res_fn, p0, eval_fn in [
        ('A', make_res_gomA, p0A, eval_gomA),
        ('D', make_res_gomD, p0D, eval_gomD),
        ('B', make_res_gomB, p0B, eval_gomB),
    ]:
        try:
            r = least_squares(res_fn(Xtr, ytr), p0, loss='soft_l1', max_nfev=300)
            pred = eval_fn(r.x, Xv)
            nm = np.mean((yv-pred)**2)/np.var(yv) if np.all(np.isfinite(pred)) else np.inf
            results[key].append(nm)
        except: results[key].append(np.inf)

for k, v in results.items():
    print(f'Model{k} mean={np.mean(v):.4f} median={np.median(v):.4f} >1:{sum(1 for x in v if x>1)}/{len(v)}')
