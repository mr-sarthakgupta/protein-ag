import csv
import numpy as np
from pathlib import Path
import os

root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')
datasets = []
for dirpath, _, filenames in os.walk(root):
    if 'fit.tsv' in filenames:
        datasets.append(Path(dirpath) / 'fit.tsv')
datasets.sort()

# Look at a few representative datasets to understand the data shape
for p in datasets[:3]:
    with open(p) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [r for r in reader if r]
    X = np.array([[float(r[0]), float(i+1)] for r in rows for i in range(len(header)-1) if r[i+1]])
    y = np.array([float(r[i+1]) for r in rows for i in range(len(header)-1) if r[i+1]])
    print(f'{p.parent.name}: x0 range=[{X[:,0].min():.2f},{X[:,0].max():.2f}], x1 range=[{X[:,1].min():.2f},{X[:,1].max():.2f}], y range=[{y.min():.3f},{y.max():.3f}]')
    # Check shape - is it sigmoidal?
    mid_idx = len(rows)//2
    early_y = np.mean(y[:len(y)//4])
    mid_y = np.mean(y[len(y)//4:len(y)//2])
    late_y = np.mean(y[3*len(y)//4:])
    print(f'  early_y={early_y:.3f}, mid_y={mid_y:.3f}, late_y={late_y:.3f}')
"
