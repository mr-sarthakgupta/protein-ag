import numpy as np
from scipy.optimize import curve_fit
import csv, re, glob

base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
files = glob.glob(base + '**/fit.tsv', recursive=True)
files.sort()

def load_fit(path):
    with open(path) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = []
        for h in response_headers:
            m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.I)
            if m: parsed.append(float(m.group(1)))
            else: parsed = None; break
        if parsed is None:
            params = [float(i+1) for i in range(len(response_headers))]
        else:
            params = parsed
        feats, tgts = [], []
        for row in reader:
            if not row: continue
            x0v = float(row[0])
            for p, v in zip(params, row[1:]):
                if v.strip() and v.strip().lower() != 'nan':
                    feats.append([x0v, p])
                    tgts.append(float(v))
    return np.array(feats), np.array(tgts)

def gompertz_full(X, c0, c1, c2, c3, c4, c5):
    x0, x1 = X[:,0], X[:,1]
    rate = c0 * x1**c1
    ht = c2 * x1**c3
    return c4 * np.exp(-np.exp(-rate * (x0 - ht))) + c5

# Check failing datasets (3-9)
for f in files[3:7]:
    X, y = load_fit(f)
    name = f.replace(base,'')[:50]
    x0 = X[:,0]
    x1 = X[:,1]
    print(f'{name}')
    print(f'  x0=[{x0.min():.1f},{x0.max():.1f}], x1=[{x1.min():.2f},{x1.max():.2f}]')
    print(f'  y=[{y.min():.3f},{y.max():.3f}], mean={y.mean():.3f}')
    # estimate good initial values
    t_half_est = x0[np.argmin(np.abs(y - 0.5))]
    rate_est = 4.0 / (x0.max() - x0.min())
    print(f'  t_half_est={t_half_est:.1f}, rate_est={rate_est:.6f}')
    try:
        p, _ = curve_fit(gompertz_full, X, y, 
                         p0=[rate_est, 0.0, t_half_est, 0.0, 1.0, 0.0], 
                         maxfev=10000)
        yp = gompertz_full(X, *p)
        nmse = np.mean((y-yp)**2)/np.var(y)
        print(f'  NMSE={nmse:.4f}, params={[f\"{v:.3f}\" for v in p]}')
    except Exception as e:
        print(f'  FAILED: {e}')
