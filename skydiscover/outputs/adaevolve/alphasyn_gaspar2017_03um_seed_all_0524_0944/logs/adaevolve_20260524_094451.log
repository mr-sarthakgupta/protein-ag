  96 | 
  97 | def fit_expression_constants(
  98 |     expression: sp.Expr | str | float | int,
  99 |     X_train: NDArray,
 100 |     y_train: NDArray,
 101 |     X_val: NDArray,
 102 |     *,
 103 |     constants: Sequence[sp.Symbol] | None = None,
 104 |     initial_values: Sequence[float] | None = None,
 105 |     max_nfev: int = 300,
 106 | ) -> FittedExpression:
 107 |     """
 108 |     Fit free constants in a SkyDiscover-proposed expression template.
 109 | 
 110 |     The expression structure is supplied by the evolved program. This helper only
 111 |     performs the continuous inner fit and PySR-style export/evaluation.
 112 |     """
 113 |     X_train = np.asarray(X_train, dtype=float)
 114 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 115 |     X_val = np.asarray(X_val, dtype=float)
 116 |     feature_names = [f"x{i}" for i in range(X_train.shape[1])]
 117 |     template = _as_sympy_expr(expression, feature_names)
 118 | 
 119 |     if constants is None:
 120 |         feature_set = set(feature_symbols(X_train.shape[1]))
 121 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 122 |     constants = list(constants)
 123 | 
 124 |     if not constants:
 125 |         fitted_expr = sp.simplify(template)
 126 |         return FittedExpression(
 127 |             expression_template=template,
 128 |             expression=fitted_expr,
 129 |             constants={},
 130 |             y_pred_train=_predict(fitted_expr, X_train, feature_names),
 131 |             y_pred_val=_predict(fitted_expr, X_val, feature_names),
 132 |         )
 133 | 
 134 |     if initial_values is None:
 135 |         x0 = np.ones(len(constants), dtype=float)
 136 |     else:
 137 |         x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 138 |         if x0.size != len(constants):
 139 |             raise ValueError("initial_values must match the number of constants")
 140 | 
 141 |     def residual(theta: NDArray) -> NDArray:
 142 |         substitutions = {symbol: float(value) for symbol, value in zip(constants, theta)}
 143 |         candidate = template.subs(substitutions)
 144 |         try:
 145 |             prediction = _predict(candidate, X_train, feature_names)
 146 |         except Exception:
 147 |             return np.full_like(y_train, 1e12, dtype=float)
 148 |         if prediction.shape != y_train.shape or not np.all(np.isfinite(prediction)):
 149 |             return np.full_like(y_train, 1e12, dtype=float)
 150 |         return prediction - y_train
 151 | 
 152 |     result = least_squares(
 153 |         residual,
 154 |         x0,
 155 |         loss="soft_l1",
 156 |         max_nfev=max_nfev,
 157 |     )
 158 |     fitted_constants = {
 159 |         str(symbol): float(value) for symbol, value in zip(constants, result.x)
 160 |     }
 161 |     substitutions = dict(zip(constants, result.x))
 162 |     fitted_expr = sp.simplify(template.subs(substitutions))
 163 | 
 164 |     return FittedExpression(
 165 |         expression_template=template,
 166 |         expression=fitted_expr,
 167 |         constants=fitted_constants,
 168 |         y_pred_train=_predict(fitted_expr, X_train, feature_names),
 169 |         y_pred_val=_predict(fitted_expr, X_val, feature_names),
 170 |     )
 171 | 
 172 | 
 173 | def evaluate_expression(
 174 |     expression: sp.Expr | str | float | int,
 175 |     X_train: NDArray,
 176 |     y_train: NDArray,
 177 |     X_val: NDArray,
 178 |     y_val: NDArray,
 179 |     *,
 180 |     constants: Sequence[sp.Symbol] | None = None,
 181 |     initial_values: Sequence[float] | None = None,
 182 |     max_nfev: int = 300,
 183 | ) -> dict[str, Any]:
 184 |     """Score a proposed equation template after fitting its constants."""
 185 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 186 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 187 |     fitted = fit_expression_constants(
 188 |         expression,
 189 |         X_train,
 190 |         y_train,
 191 |         X_val,
 192 |         constants=constants,
 193 |         initial_values=initial_values,
 194 |         max_nfev=max_nfev,
 195 |     )
 196 |     nmse_train = nmse(y_train, fitted.y_pred_train)
 197 |     nmse_val = nmse(y_val, fitted.y_pred_val)
 198 |     loss = float(np.mean((fitted.y_pred_train - y_train) ** 2))
 199 | 
 200 |     return {
 201 |         "equation_template": str(fitted.expression_template),
 202 |         "equation": str(fitted.expression),
 203 |         "constants": fitted.constants,
 204 |         "loss": loss,
 205 |         "complexity": _complexity(fitted.expression_template),
 206 |         "nmse_train": nmse_train,
 207 |         "nmse_val": nmse_val,
 208 |         "combined_score": combined_score_from_nmse(nmse_val),
 209 |     }
