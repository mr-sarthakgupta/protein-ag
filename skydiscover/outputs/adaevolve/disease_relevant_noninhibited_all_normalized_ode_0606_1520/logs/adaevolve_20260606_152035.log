1039 | def evaluate_stage1(program_path: str) -> dict:
1040 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
1041 |     try:
1042 |         harness_root = str(BENCHMARK_ROOT)
1043 |         if harness_root not in sys.path:
1044 |             sys.path.insert(0, harness_root)
1045 | 
1046 |         all_datasets = load_all_datasets()
1047 |         rng = np.random.default_rng(RANDOM_STATE)
1048 |         if len(all_datasets) > 8:
1049 |             indices = rng.choice(len(all_datasets), size=8, replace=False)
1050 |             subset = [all_datasets[i] for i in sorted(indices)]
1051 |         else:
1052 |             subset = all_datasets
1053 | 
1054 |         work_items = [
1055 |             (name, X_train, X_val, y_train, y_val, program_path)
1056 |             for name, X_train, X_val, y_train, y_val in subset
1057 |         ]
1058 | 
1059 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1060 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
1061 |             worker_results = [future.result() for future in concurrent.futures.as_completed(futures)]
1062 | 
1063 |         combined_scores = [score for score, _error, _template in worker_results]
1064 |         successful_scores = [score for score in combined_scores if score > 0]
1065 |         errors = sorted({error for _score, error, _template in worker_results if error})
1066 |         violation_errors = sorted(
1067 |             {
1068 |                 error
1069 |                 for _score, error, _template in worker_results
1070 |                 if error and SINGLE_EQUATION_ERROR_PREFIX in error
1071 |             }
1072 |         )
1073 |         if violation_errors:
1074 |             return {
1075 |                 "combined_score": 0.0,
1076 |                 "n_stage1_datasets": len(subset),
1077 |                 "n_stage1_successful": len(successful_scores),
1078 |                 "eval_workers": NUM_WORKERS,
1079 |                 "error": violation_errors[0],
1080 |             }
1081 |         if errors:
1082 |             return {
1083 |                 "combined_score": 0.0,
1084 |                 "n_stage1_datasets": len(subset),
1085 |                 "n_stage1_successful": len(successful_scores),
1086 |                 "eval_workers": NUM_WORKERS,
1087 |                 "error": (
1088 |                     "Single-equation violation: stage 1 candidate failed on "
1089 |                     f"{len(errors)} dataset evaluations. Example: {errors[0]}"
1090 |                 ),
1091 |             }
1092 |         templates = sorted(
1093 |             {
1094 |                 template
1095 |                 for score, _error, template in worker_results
1096 |                 if score > 0 and template
1097 |             }
1098 |         )
1099 |         if len(templates) > 1:
1100 |             examples = "; ".join(templates[:3])
1101 |             return {
1102 |                 "combined_score": 0.0,
1103 |                 "n_stage1_datasets": len(subset),
1104 |                 "n_stage1_successful": len(successful_scores),
1105 |                 "eval_workers": NUM_WORKERS,
1106 |                 "error": (
1107 |                     "Single-equation violation: stage 1 produced "
1108 |                     f"{len(templates)} distinct equation templates across datasets. "
1109 |                     "The base equation must be identical for all datasets. "
1110 |                     f"Example templates: {examples}"
1111 |                 ),
1112 |             }
1113 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
1114 |         return {
1115 |             "combined_score": agg_combined,
1116 |             "n_stage1_datasets": len(subset),
1117 |             "n_stage1_successful": len(successful_scores),
1118 |             "eval_workers": NUM_WORKERS,
1119 |         }
1120 |     except Exception as exc:
1121 |         print(f"Stage 1 evaluation failed: {exc}")
1122 |         return {"combined_score": 0.0, "error": str(exc)}
