 121 |         "weight_simplify",
 122 |         "weight_randomize",
 123 |         "weight_do_nothing",
 124 |         "weight_optimize",
 125 |     }
 126 | 
 127 |     regressor_kwargs = {
 128 |         k: v
 129 |         for k, v in merged.items()
 130 |         if k not in _HARNESS_KEYS
 131 |         and k not in mutation_keys
 132 |         and k in _PYSR_INIT_PARAMS
 133 |     }
