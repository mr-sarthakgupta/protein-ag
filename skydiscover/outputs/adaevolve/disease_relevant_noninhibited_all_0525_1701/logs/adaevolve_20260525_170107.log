import sys
sys.path.insert(0, '.')
import numpy as np
from scipy.optimize import least_squares
from pysr_harness.metrics import nmse, combined_score_from_nmse
import csv
from pathlib import Path

data_root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')
p = data_root / 'Abeta/Meisl2014/Ab40_sec_IN_HOURS/fit.tsv'
with p.open() as f:
    reader = csv.reader(f, delimiter='\t')
    header = next(reader)
    rows = [r for r in reader if r]

import re
def parse_param(h):
    m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.IGNORECASE)
    if m: return float(m.group(1))
    return 1.0

params = [parse_param(h) for h in header[1:]]
features, targets = [], []
for row in rows:
    t = float(row[0])
    for param, val in zip(params, row[1:]):
        if val and val.strip().lower() != 'nan':
            features.append([t, param])
            targets.append(float(val))

X = np.array(features); y = np.array(targets)
rng = np.random.default_rng(42)
idx = rng.permutation(len(y))
split = int(round(len(y) * 0.75))
X_train, X_val = X[idx[:split]], X[idx[split:]]
y_train, y_val = y[idx[:split]], y[idx[split:]]

# Generalized logistic with concentration-dependent rate and half-time
# y = c4 / (1 + exp(-c0 * |x1|^c1 * (x0 - c2 * |x1|^c3)))^(1/c5) + c6
# But let's start simple: logistic with conc-dependent rate/half-time
def model_logistic(theta, X):
    c0, c1, c2, c3, c4, c5 = theta
    t, p = X[:, 0], np.abs(X[:, 1])
    p_safe = np.where(p > 0, p, 1.0)
    rate = c0 * p_safe**c1
    t_half = c2 * p_safe**c3
    arg = np.clip(-rate * (t - t_half), -500, 500)
    return c4 / (1 + np.exp(arg)) + c5

def model_gompertz(theta, X):
    c0, c1, c2, c3, c4, c5 = theta
    t, p = X[:, 0], np.abs(X[:, 1])
    p_safe = np.where(p > 0, p, 1.0)
    rate = c0 * p_safe**c1
    t_half = c2 * p_safe**c3
    arg = np.clip(-np.exp(-rate * (t - t_half)), -500, 0)
    return c4 * np.exp(arg) + c5

# Data-adaptive init
t_data = X_train[:, 0]
y_data = y_train
t_range = max(t_data.max() - t_data.min(), 1e-10)
t_min = t_data.min()

# Estimate t_half
mid_mask = y_data > 0.4
t_half_est = float(np.median(t_data[mid_mask])) if mid_mask.any() else float(np.median(t_data))
rate_est = 4.0 / t_range
y_min_est = float(np.percentile(y_data, 5))
y_max_est = float(np.percentile(y_data, 95))
amp_est = max(y_max_est - y_min_est, 0.1)

init_sets = [
    [rate_est, 0.5, t_half_est, -0.5, amp_est, y_min_est],
    [rate_est*2, 1.0, t_half_est, -1.0, amp_est, y_min_est],
    [rate_est*0.5, 0.0, t_half_est, 0.0, amp_est, y_min_est],
    [rate_est, 2.0, t_half_est, -1.0, amp_est, y_min_est],
]

best_nmse = float('inf')
best_model_name = None
best_params = None

for model_fn, model_name in [(model_logistic, 'logistic'), (model_gompertz, 'gompertz')]:
    for init in init_sets:
        try:
            def res(theta): 
                pred = model_fn(theta, X_train)
                if not np.all(np.isfinite(pred)): return np.full(len(y_train), 1e6)
                return pred - y_train
            r = least_squares(res, init, loss='soft_l1', max_nfev=400)
            pred_val = model_fn(r.x, X_val)
            if np.all(np.isfinite(pred_val)):
                nv = nmse(y_val, pred_val)
                if nv < best_nmse:
                    best_nmse = nv
                    best_model_name = model_name
                    best_params = r.x
        except Exception as e:
            pass

print(f'Best: {best_model_name}, nmse_val={best_nmse:.6f}, score={combined_score_from_nmse(best_nmse):.4f}')
print(f'Params: {best_params}')
