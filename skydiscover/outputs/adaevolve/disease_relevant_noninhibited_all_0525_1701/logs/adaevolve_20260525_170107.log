import sys
sys.path.insert(0, '.')
from pysr_harness.equation_session import feature_symbols, constant_symbols, evaluate_expression
import sympy as sp
import numpy as np

# Test basic functionality
x = feature_symbols(2)
c = constant_symbols(6)
time = x[0]
param = x[1]
rate = c[0] * sp.Abs(param)**c[1]
half_time = c[2] * sp.Abs(param)**c[3]
expr = c[4] / (1 + sp.exp(-rate * (time - half_time))) + c[5]

X_train = np.random.rand(50, 2)
