 139 |             "parallelism": "serial",
 140 |             "procs": 0,
 141 |         }
 142 |     )
 143 |     for key in mutation_keys:
 144 |         if key in merged:
 145 |             regressor_kwargs[key] = merged[key]
 146 | 
 147 |     return PySRRegressor(**regressor_kwargs)
