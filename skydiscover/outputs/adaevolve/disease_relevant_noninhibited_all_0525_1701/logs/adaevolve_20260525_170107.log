import sys
sys.path.insert(0, '.')
import numpy as np
from scipy.optimize import least_squares
from pysr_harness.metrics import nmse, combined_score_from_nmse

# Test multi-model approach on a real dataset
import csv
from pathlib import Path

data_root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')
p = data_root / 'Abeta/Meisl2014/Ab40_sec_IN_HOURS/fit.tsv'
with p.open() as f:
    reader = csv.reader(f, delimiter='\t')
    header = next(reader)
    rows = [r for r in reader if r]

import re
def parse_param(h):
    m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.IGNORECASE)
    if m: return float(m.group(1))
    return 1.0

params = [parse_param(h) for h in header[1:]]
features, targets = [], []
for row in rows:
    t = float(row[0])
    for param, val in zip(params, row[1:]):
        if val and val.strip().lower() != 'nan':
            features.append([t, param])
            targets.append(float(val))

X = np.array(features)
y = np.array(targets)

rng = np.random.default_rng(42)
idx = rng.permutation(len(y))
split = int(round(len(y) * 0.75))
X_train, X_val = X[idx[:split]], X[idx[split:]]
y_train, y_val = y[idx[:split]], y[idx[split:]]

print(f'Dataset: {len(y_train)} train, {len(y_val)} val')
print(f'X ranges: t=[{X[:,0].min():.2f},{X[:,0].max():.2f}], p=[{X[:,1].min():.1f},{X[:,1].max():.1f}]')
print(f'y range: [{y.min():.4f},{y.max():.4f}]')

# Estimate good initial values from data
t_data = X_train[:, 0]
p_data = X_train[:, 1]
y_data = y_train

# Estimate half-time from data
t_half_est = np.median(t_data[y_data > 0.4]) if np.any(y_data > 0.4) else np.median(t_data)
t_range = t_data.max() - t_data.min()
rate_est = 4.0 / max(t_range, 1e-10)
p_mean = np.mean(p_data)

print(f't_half_est={t_half_est:.2f}, rate_est={rate_est:.4f}, p_mean={p_mean:.2f}')
"
