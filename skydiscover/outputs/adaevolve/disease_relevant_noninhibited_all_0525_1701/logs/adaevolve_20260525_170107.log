import sys
sys.path.insert(0, '.')
import numpy as np

# Load a real dataset
import csv
from pathlib import Path

def load_fit_table(data_file):
    import re
    def parse_param(col):
        m = re.search(r'(\d+(?:\.\d+)?)\s*uM', col, re.IGNORECASE)
        if m: return float(m.group(1))
        m = re.search(r'(\d+(?:\.\d+)?)\s*mM', col, re.IGNORECASE)
        if m: return float(m.group(1)) * 1000.0
        m = re.search(r'pH\s+(\d+(?:\.\d+)?)', col, re.IGNORECASE)
        if m: return float(m.group(1))
        return None
    
    with open(data_file) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        response_headers = header[1:]
        parsed = [parse_param(h) for h in response_headers]
        if all(p is not None for p in parsed):
            parameters = [float(p) for p in parsed]
        else:
            parameters = [float(i+1) for i in range(len(response_headers))]
        features, targets = [], []
        for row in reader:
            if not row: continue
            mx = float(row[0])
            for param, val in zip(parameters, row[1:]):
                if val == '' or val.strip().lower() == 'nan': continue
                features.append([mx, param])
                targets.append(float(val))
    return np.array(features), np.array(targets)

path = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/Abeta/Meisl2014/Ab40_sec_IN_HOURS/fit.tsv'
