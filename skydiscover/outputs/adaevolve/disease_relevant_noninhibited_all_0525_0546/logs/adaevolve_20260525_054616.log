 325 | def evaluate(program_path: str) -> dict:
 326 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
 327 |     try:
 328 |         start = time.time()
 329 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=1200)
 330 |         metrics = _metrics_from_result(result, time.time() - start)
 331 |         print(
 332 |             "Evaluation: "
 333 |             f"nmse_val={metrics['nmse_val']:.6f}, "
 334 |             f"combined_score={metrics['combined_score']:.6f}, "
 335 |             f"n_datasets={metrics['n_datasets']}, "
 336 |             f"n_successful={metrics['n_successful']}, "
 337 |             f"time={metrics['eval_time']:.2f}s"
 338 |         )
 339 |         print(f"Equation template: {metrics['equation']}")
 340 |         return metrics
 341 |     except Exception as exc:
 342 |         print(f"Evaluation failed: {exc}")
 343 |         traceback.print_exc()
 344 |         return {
 345 |             "equation": "",
 346 |             "loss": float("inf"),
 347 |             "complexity": 0.0,
 348 |             "nmse_train": float("inf"),
 349 |             "nmse_val": float("inf"),
 350 |             "combined_score": 0.0,
 351 |             "eval_time": 0.0,
 352 |             "n_datasets": 0,
 353 |             "n_successful": 0,
 354 |             "per_dataset": {},
 355 |             "error": str(exc),
