 304 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
 305 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
 306 |     nmse_val = float(result.get("nmse_val", float("inf")))
 307 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
 308 |     if not np.isfinite(combined):
 309 |         combined = 0.0
 310 | 
 311 |     return {
 312 |         "equation": str(result.get("equation", "")),
 313 |         "loss": nmse_val,
 314 |         "complexity": 0.0,
 315 |         "nmse_train": float("inf"),
 316 |         "nmse_val": nmse_val,
 317 |         "combined_score": combined,
 318 |         "eval_time": float(eval_time),
 319 |         "n_datasets": result.get("n_datasets", 0),
 320 |         "n_successful": result.get("n_successful", 0),
 321 |         "per_dataset": result.get("per_dataset", {}),
 322 |     }
