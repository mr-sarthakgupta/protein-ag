 253 | 
 254 |     aggregated = {{
 255 |         "equation": eq_template,
 256 |         "nmse_val": agg_nmse,
 257 |         "combined_score": agg_combined,
 258 |         "n_datasets": len(datasets),
 259 |         "n_successful": sum(1 for s in combined_scores if s > 0),
 260 |         "per_dataset": per_dataset_results,
 261 |     }}
 262 | 
 263 |     with open(results_path, "wb") as f:
