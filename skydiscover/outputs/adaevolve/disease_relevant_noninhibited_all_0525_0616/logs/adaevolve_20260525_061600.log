import json
# Find the trace with the best score
import os
best_score = 0
best_file = None
for fname in os.listdir('reference'):
    if not fname.endswith('.json'):
        continue
    try:
        with open(f'reference/{fname}') as f:
            data = json.load(f)
        conv = data.get('conversation', [])
        for msg in conv:
            if msg.get('role') == 'user':
                content = msg.get('content', '')
                if isinstance(content, str) and 'combined_score' in content:
                    import re
                    m = re.search(r'combined_score: ([0-9.]+)', content)
                    if m:
                        score = float(m.group(1))
                        if score > best_score:
                            best_score = score
                            best_file = fname
    except:
        pass
print(f'Best score: {best_score} in {best_file}')
