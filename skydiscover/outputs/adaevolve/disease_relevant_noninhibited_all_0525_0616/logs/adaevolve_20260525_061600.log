 214 | 
 215 |     datasets = evaluator.load_all_datasets()
 216 |     per_dataset_results = {{}}
 217 |     nmse_vals = []
 218 |     combined_scores = []
 219 | 
 220 |     for ds_name, X_train, X_val, y_train, y_val in datasets:
 221 |         try:
 222 |             result = fn(X_train, y_train, X_val, y_val)
 223 |             ds_nmse = float(result.get("nmse_val", float("inf")))
 224 |             ds_combined = float(result.get("combined_score", 0.0))
 225 |             per_dataset_results[ds_name] = {{
 226 |                 "nmse_val": ds_nmse,
 227 |                 "combined_score": ds_combined,
 228 |                 "equation": str(result.get("equation", "")),
 229 |                 "constants": result.get("constants", {{}}),
 230 |             }}
 231 |             nmse_vals.append(ds_nmse)
 232 |             combined_scores.append(ds_combined)
 233 |         except Exception as exc:
