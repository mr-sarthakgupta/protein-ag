 235 |             per_dataset_results[ds_name] = {{
 236 |                 "nmse_val": float("inf"),
 237 |                 "combined_score": 0.0,
 238 |                 "error": str(exc),
 239 |             }}
 240 |             nmse_vals.append(float("inf"))
 241 |             combined_scores.append(0.0)
 242 | 
 243 |     finite_nmse = [v for v in nmse_vals if np.isfinite(v)]
