 793 | def _eval_stage1_worker(args):
 794 |     """Module-level worker for stage 1 parallel evaluation."""
 795 |     name, X_train, X_val, y_train, y_val, program_path = args
 796 |     harness_root = str(BENCHMARK_ROOT)
 797 |     if harness_root not in sys.path:
 798 |         sys.path.insert(0, harness_root)
 799 |     validate_candidate_source(program_path)
 800 |     spec = importlib.util.spec_from_file_location("program", program_path)
 801 |     program = importlib.util.module_from_spec(spec)
 802 |     spec.loader.exec_module(program)
 803 |     from pysr_harness.equation_session import (
 804 |         single_equation_evaluation,
 805 |         validate_single_equation_result,
 806 |     )
 807 | 
 808 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
 809 |         program, "run_discovery", None
 810 |     )
 811 |     if fn is None:
 812 |         return 0.0, "missing evaluate_symbolic_candidate()", ""
 813 |     n = min(200, len(X_train))
 814 |     m = min(80, len(X_val))
 815 |     try:
 816 |         with single_equation_evaluation():
 817 |             result = fn(X_train[:n], y_train[:n], X_val[:m], y_val[:m])
 818 |             validate_single_equation_result(result)
 819 |         return float(result.get("combined_score", 0.0)), None, str(
 820 |             result.get("equation_template", "")
 821 |         )
 822 |     except Exception as exc:
 823 |         return 0.0, str(exc), ""
 824 | 
