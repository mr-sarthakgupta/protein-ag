 826 | def evaluate_stage1(program_path: str) -> dict:
 827 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
 828 |     try:
 829 |         harness_root = str(BENCHMARK_ROOT)
 830 |         if harness_root not in sys.path:
 831 |             sys.path.insert(0, harness_root)
 832 | 
 833 |         all_datasets = load_all_datasets()
 834 |         rng = np.random.default_rng(RANDOM_STATE)
 835 |         if len(all_datasets) > 8:
 836 |             indices = rng.choice(len(all_datasets), size=8, replace=False)
 837 |             subset = [all_datasets[i] for i in sorted(indices)]
 838 |         else:
 839 |             subset = all_datasets
 840 | 
 841 |         work_items = [
 842 |             (name, X_train, X_val, y_train, y_val, program_path)
 843 |             for name, X_train, X_val, y_train, y_val in subset
 844 |         ]
 845 | 
 846 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
 847 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
 848 |             worker_results = [future.result() for future in concurrent.futures.as_completed(futures)]
 849 | 
 850 |         combined_scores = [score for score, _error, _template in worker_results]
 851 |         errors = sorted({error for _score, error, _template in worker_results if error})
 852 |         violation_errors = sorted(
 853 |             {
 854 |                 error
 855 |                 for _score, error, _template in worker_results
 856 |                 if error and SINGLE_EQUATION_ERROR_PREFIX in error
 857 |             }
 858 |         )
 859 |         if violation_errors:
 860 |             return {"combined_score": 0.0, "error": violation_errors[0]}
 861 |         if errors:
 862 |             return {
 863 |                 "combined_score": 0.0,
 864 |                 "error": (
 865 |                     "Single-equation violation: stage 1 candidate failed on "
 866 |                     f"{len(errors)} dataset evaluations. Example: {errors[0]}"
 867 |                 ),
 868 |             }
 869 |         templates = sorted(
 870 |             {
 871 |                 template
 872 |                 for score, _error, template in worker_results
 873 |                 if score > 0 and template
 874 |             }
 875 |         )
 876 |         if len(templates) > 1:
 877 |             examples = "; ".join(templates[:3])
 878 |             return {
 879 |                 "combined_score": 0.0,
 880 |                 "error": (
 881 |                     "Single-equation violation: stage 1 produced "
 882 |                     f"{len(templates)} distinct equation templates across datasets. "
 883 |                     "The base equation must be identical for all datasets. "
 884 |                     f"Example templates: {examples}"
 885 |                 ),
 886 |             }
 887 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
 888 |         return {"combined_score": agg_combined}
 889 |     except Exception as exc:
 890 |         print(f"Stage 1 evaluation failed: {exc}")
 891 |         return {"combined_score": 0.0, "error": str(exc)}
 892 | 
