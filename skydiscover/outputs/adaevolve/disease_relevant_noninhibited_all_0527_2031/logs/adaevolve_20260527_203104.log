 735 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
 736 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
 737 |     nmse_val = float(result.get("nmse_val", float("inf")))
 738 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
 739 |     if not np.isfinite(combined):
 740 |         combined = 0.0
 741 | 
 742 |     return {
 743 |         "equation": str(result.get("equation", "")),
 744 |         "loss": nmse_val,
 745 |         "complexity": 0.0,
 746 |         "nmse_train": float("inf"),
 747 |         "nmse_val": nmse_val,
 748 |         "combined_score": combined,
 749 |         "eval_time": float(eval_time),
 750 |         "n_datasets": result.get("n_datasets", 0),
 751 |         "n_successful": result.get("n_successful", 0),
 752 |         "per_dataset": result.get("per_dataset", {}),
 753 |         "error": str(result.get("error", "")),
 754 |     }
