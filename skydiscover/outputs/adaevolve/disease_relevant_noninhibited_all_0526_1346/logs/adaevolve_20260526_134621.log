sys.path.insert(0, 'benchmarks/pysr_symbolic/disease_relevant_noninhibited_all')
import evaluator as ev
import numpy as np
import sympy as sp
from pysr_harness.equation_session import constant_symbols, evaluate_expression, feature_symbols

datasets = ev.load_all_datasets()

# Test Hill equation (Program 2) on a few datasets
results = []
for name, Xtr, Xv, ytr, yv in datasets[:10]:
    x = feature_symbols(2)
    c = constant_symbols(4)
    time = x[0]
    expr = c[2] * time**c[0] / (c[1]**c[0] + time**c[0]) + c[3]
    
    t_train = Xtr[:, 0]
    half_idx = int(np.argmin(np.abs(ytr - 0.5)))
    t_half_est = float(t_train[half_idx])
    if t_half_est <= 0:
        t_half_est = float(np.median(t_train[t_train > 0])) if np.any(t_train > 0) else 1.0
    
    res = evaluate_expression(expr, Xtr, ytr, Xv, yv, constants=c, initial_values=[2.0, t_half_est, 1.0, 0.0], max_nfev=500)
    results.append((name, res['nmse_val']))
    print(f'{name}: nmse_val={res[\"nmse_val\"]:.4f}')

print(f'Mean nmse_val: {np.mean([r[1] for r in results]):.4f}')
