    import numpy as np
    ys = np.array(ys_all)
    print(f'{str(p.parent.relative_to(root))[:50]:50s}  t:[{min(xs):.2f},{max(xs):.2f}]  y:[{ys.min():.3f},{ys.max():.3f}]  ncols={len(header)-1}  nrows={len(rows)}')
"
