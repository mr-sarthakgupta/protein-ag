vide='ignore', invalid='ignore'):\\n        t_lag = c[1] * np.abs(p)**c[6]\\n        t_half_rel = np.abs(c[3]) * np.abs(p)**c[7]\\n        n = np.abs(c[2]) + 0.1\\n        dt = np.maximum(t - t_lag, 0.0)\\n        dt_n = dt**n\\n        t_half_n = (t_half_rel + 1e-30)**n\\n        return c[4] * dt_n / (t_half_n + dt_n) + c[5]\\n\\ndef compute_inits(X, y):\\n    t = X[:,0]; p = X[:,1]\\n    y_min, y_max = y.min(), y.max()\\n    y_range = max(y_max - y_min, 1e-10)\\n    y_norm = (y - y_min) / y_range\\n    sort_idx = np.argsort(t)\\n    t_s, y_s = t[sort_idx], y_norm[sort_idx]\\n    lag_idx = np.clip(np.searchsorted(y_s, 0.01), 0, len(t_s)-1)\\n    t_lag_est = t_s[max(0, lag_idx-1)]\\n    idx50 = np.clip(np.searchsorted(y_s, 0.5), 0, len(t_s)-1)\\n    t50 = t_s[idx50]\\n    t_half_rel_est = max(t50 - t_lag_est, (t.max()-t.min())*0.01)\\n    \\n    # Per-concentration log-log regression for concentration scaling\\n    p_unique = np.unique(p)\\n    beta_est = 0.0\\n    t50_at_1 = t_half_rel_est\\n    if len(p_unique) > 1:\\n        t50_per = []\\n        for conc in p_unique:\\n            mask = p == conc\\n            tc = t[mask]; yc = y_norm[mask]\\n            sc = np.argsort(tc)\\n            tc_s, yc_s = tc[sc], yc[sc]\\n            i50 = np.clip(np.searchsorted(yc_s, 0.5), 0, len(tc_s)-1)\\n            t50_per.append(tc_s[i50])\\n        t50_arr = np.array(t50_per)\\n        log_p = np.log(np.abs(p_unique) + 1e-10)\\n        log_t50 = np.log(np.abs(t50_arr) + 1e-10)\\n        A = np.column_stack([np.ones_like(log_p), log_p])\\n        try:\\n            coeffs, _, _, _ = np.linalg.lstsq(A, log_t50, rcond=None)\\n            beta_est = float(coeffs[1])\\n            t50_at_1 = float(np.exp(coeffs[0])) * 0.5\\n        except: pass\\n    \\n    inits = []\\n    for n_val in [2.0, 4.0, 6.0, 10.0]:\\n        for lag_mult in [0.9, 1.0]:\\n            for half_mult in [0.9, 1.1]:\\n                # No conc scaling\\n                inits.append([1.0, t_lag_est*lag_mul