ata itself\\n# Then pass these as initial values to the optimizer\\n\\n# Generalized logistic: y = c4 / (1 + exp(-c0*(t - c1)))^(1/c2) + c5\\n# c0=rate, c1=t_half, c2=nu (asymmetry), c3=unused, c4=amplitude, c5=baseline\\n# with concentration scaling: rate = c0 * x1^c6, t_half = c1 * x1^c7\\n\\n# Strategy: use data-driven init per dataset\\ndef compute_smart_inits(X, y):\\n    t = X[:,0]\\n    p = X[:,1]\\n    \\n    # Normalize y to [0,1] range for estimation\\n    y_min, y_max = y.min(), y.max()\\n    y_range = y_max - y_min + 1e-10\\n    y_norm = (y - y_min) / y_range\\n    \\n    # Sort by time to find t10, t50, t90\\n    sort_idx = np.argsort(t)\\n    t_sorted = t[sort_idx]\\n    y_sorted = y_norm[sort_idx]\\n    \\n    # Find t50 (median time)\\n    idx50 = np.searchsorted(y_sorted, 0.5)\\n    idx50 = np.clip(idx50, 0, len(t_sorted)-1)\\n    t50 = t_sorted[idx50]\\n    \\n    idx10 = np.searchsorted(y_sorted, 0.1)\\n    idx10 = np.clip(idx10, 0, len(t_sorted)-1)\\n    t10 = t_sorted[idx10]\\n    \\n    idx90 = np.searchsorted(y_sorted, 0.9)\\n    idx90 = np.clip(idx90, 0, len(t_sorted)-1)\\n    t90 = t_sorted[idx90]\\n    \\n    # Rate estimate from t10-t90 span\\n    t_span = max(t90 - t10, (t.max()-t.min())*0.01)\\n    rate_est = 4.0 / t_span  # logistic: 4/span gives ~80% rise\\n    \\n    # Asymmetry: if t90-t50 >> t50-t10, nu > 1 (right-skewed = long tail)\\n    asym = (t90 - t50) / max(t50 - t10, 1e-10)\\n    \\n    # Concentration scaling init\\n    p_unique = np.unique(p)\\n    \\n    inits = []\\n    for nu_init in [1.0, 2.0, 3.0, 0.5]:\\n        for rate_mult in [1.0, 0.5, 2.0]:\\n            for t50_mult in [1.0, 0.9, 1.1]:\\n                inits.append([\\n                    rate_est * rate_mult,   # c0: rate\\n                    t50 * t50_mult,          # c1: t_half  \\n                    nu_init,                 # c2: nu (asymmetry)\\n                    y_min,                   # c3: baseline (not used here)\\n                    y_range,                 # c4: amplitude\\n                    y_min,                   # c5: offset\\n                    1.0,                     # c6: conc power for rate\\n                    -0.5,                    # c7: conc power for t_half\\n                ])\\n    return inits\\n\\n# Model: Generalized logistic with concentration scaling\\ndef gen_logistic_conc(X, c):\\n    t, p = X[:,0], X[:,1]\\n    with np.errstate(over='ignore', divide='ignore', invalid='ignore'):\\n        # Use abs to keep rate positive, allow nu to be any sign\\n        rate = np.abs(c[0]) * np.abs(p)**c[6]\\n        half_time = c[1] * np.abs(p)**c[7]\\n        nu = np.abs(c[2]) + 1e-6\\n        # Clamp exponent to prevent overflow\\n        exp_arg = np.clip(-rate * (t - half_time), -500, 500)\\n        denom = (1 + nu * np.exp(exp_arg))**(1.0/nu)\\n        return c[4] / denom + c[5]\\n\\ndef eval_best(model_fn, X, y, inits):\\n    Xtr, Xv, ytr, yv = split(X, y)\\n    best_nmse = float('inf')\\n    best_c = None\\n    Xcols = [Xtr[:,i] for i in range(Xtr.shape[1])]\\n    \\n    import sympy as sp\\n    \\n    for c0 in inits:\\n        def res(c):\\n            with np.errstate(over='ignore', divide='ignore', invalid='ignore'):\\n                pred = model_fn(Xtr, c)\\n            if not np.all(np.isfinite(pred)): return np.full(len(ytr), 1e6)\\n            return pred - ytr\\n        try:\\n            with warnings.catch_warnings():\\n                warnings.simplefilter('ignore')\\n                r = least_squares(res, c0, loss='soft_l1', max_nfev=500)\\n            pv = model_fn(Xv, r.x)\\n            if not np.all(np.isfinite(pv)): continue\\n            nmse_v = np.mean((pv-yv)**2)/np.var(yv) if np.var(yv)>0 else float('inf')\\n            if nmse_v < best_nmse:\\n                best_nmse = nmse_v\\n                best_c = r.x\\n        except: pass\\n    return best_nmse, best_c\\n\\nall_datasets = [\\n    ('IAPP_sec',     'IAPP/Daval2010/Fits/Daval2010_sec/fit.tsv'),\\n    ('ha