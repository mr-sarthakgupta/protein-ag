, max_nfev=200)\\n            pv = hill_numpy(X_val, r.x)\\n            if np.all(np.isfinite(pv)):\\n                nv = np.mean((pv-y_val)**2)/np.var(y_val) if np.var(y_val)>0 else float('inf')\\n                if nv < best_nmse_v:\\n                    best_nmse_v = nv\\n                    best_init = list(r.x)\\n                    if nv < 1e-6: break\\n        except: pass\\n    return best_init\\n\\n# Build SymPy expression once\\nx = feature_symbols(2)\\nc = constant_symbols(8)\\nt_sym, p_sym = x[0], x[1]\\nt_lag_sym = c[1] * sp.Abs(p_sym)**c[6]\\nt_half_rel_sym = sp.Abs(c[3]) * sp.Abs(p_sym)**c[7]\\nn_sym = sp.Abs(c[2]) + sp.Rational(1, 10)\\ndt_sym = (t_sym - t_lag_sym + sp.Abs(t_sym - t_lag_sym)) / 2\\ndt_n_sym = dt_sym**n_sym\\nt_half_n_sym = (t_half_rel_sym + sp.Float(1e-30))**n_sym\\nexpression = c[4] * dt_n_sym / (t_half_n_sym + dt_n_sym) + c[5]\\n\\n# Test on ALL 60 datasets (second half)\\nall_paths = sorted([Path(d)/f for d,_,fs in os.walk(root) for f in fs if f=='fit.tsv'])\\nt0 = time.time()\\nnmses = []\\nfor p in all_paths[20:]:\\n    name = str(p.parent.relative_to(root))\\n    X, y = load_fit(p)\\n    Xtr, Xv, ytr, yv = split_data(X, y)\\n    best_init = find_best_init(Xtr, ytr, Xv, yv)\\n    result = evaluate_expression(expression, Xtr, ytr, Xv, yv,\\n                                  constants=c, initial_values=best_init, max_nfev=300)\\n    nv = result.get('nmse_val', float('inf'))\\n    nmses.append(nv)\\n    print(f'{name[:50]:50s}  nmse={nv:.4f}  score={1/(1+nv):.4f}')\\n\\nelapsed = time.time() - t0\\nfinite = [v for v in nmses if np.isfinite(v)]\\nprint(f'\\\\\\\\n40 datasets (20-60) in {elapsed:.1f}s')\\nprint(f'Mean NMSE: {np.mean(finite):.4f}  Score: {1/(1+np.mean(finite)):.4f}')\\n\\\" 2>&1\\n<parameter name=\\\"timeout\\\">120\"}"
