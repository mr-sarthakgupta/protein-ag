  24 | BENCHMARK_ROOT = Path(__file__).resolve().parents[1]
  25 | if str(BENCHMARK_ROOT) not in sys.path:
  26 |     sys.path.insert(0, str(BENCHMARK_ROOT))
  27 | 
  28 | import importlib.util as _ilu
  29 | 
  30 | import numpy as np
  31 | 
  32 | # Import metrics directly to avoid triggering pysr_harness.__init__'s
  33 | # heavy pysr/Julia imports (only needed at candidate evaluation time).
  34 | _metrics_spec = _ilu.spec_from_file_location(
  35 |     "pysr_harness.metrics",
  36 |     str(BENCHMARK_ROOT / "pysr_harness" / "metrics.py"),
  37 | )
  38 | _metrics_mod = _ilu.module_from_spec(_metrics_spec)
  39 | _metrics_spec.loader.exec_module(_metrics_mod)
  40 | combined_score_from_nmse = _metrics_mod.combined_score_from_nmse
