 194 | def evaluate_expression(
 195 |     expression: sp.Expr | str | float | int,
 196 |     X_train: NDArray,
 197 |     y_train: NDArray,
 198 |     X_val: NDArray,
 199 |     y_val: NDArray,
 200 |     *,
 201 |     constants: Sequence[sp.Symbol] | None = None,
 202 |     initial_values: Sequence[float] | None = None,
 203 |     max_nfev: int = 300,
 204 | ) -> dict[str, Any]:
 205 |     """Score a proposed equation template after fitting its constants."""
 206 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 207 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 208 |     fitted = fit_expression_constants(
 209 |         expression,
 210 |         X_train,
 211 |         y_train,
 212 |         X_val,
 213 |         constants=constants,
 214 |         initial_values=initial_values,
 215 |         max_nfev=max_nfev,
 216 |     )
 217 |     nmse_train = nmse(y_train, fitted.y_pred_train)
 218 |     nmse_val = nmse(y_val, fitted.y_pred_val)
 219 |     loss = float(np.mean((fitted.y_pred_train - y_train) ** 2))
 220 | 
 221 |     return {
 222 |         "equation_template": str(fitted.expression_template),
 223 |         "equation": str(fitted.expression),
 224 |         "constants": fitted.constants,
 225 |         "loss": loss,
 226 |         "complexity": _complexity(fitted.expression_template),
 227 |         "nmse_train": nmse_train,
 228 |         "nmse_val": nmse_val,
 229 |         "combined_score": combined_score_from_nmse(nmse_val),
 230 |     }
