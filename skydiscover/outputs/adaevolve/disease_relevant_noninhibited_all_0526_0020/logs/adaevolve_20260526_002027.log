   1 | """Evaluator for multi-dataset symbolic regression across all disease-relevant non-inhibited proteins.
   2 | 
   3 | Discovers all fit.tsv datasets in the source data directory, evaluates a
   4 | candidate equation on each independently (fitting a separate set of constants
   5 | per dataset), and returns an aggregate score.
   6 | """
   7 | 
   8 | from __future__ import annotations
   9 | 
  10 | import csv
  11 | import importlib.util
  12 | import os
  13 | import pickle
  14 | import re
  15 | import subprocess
  16 | import sys
