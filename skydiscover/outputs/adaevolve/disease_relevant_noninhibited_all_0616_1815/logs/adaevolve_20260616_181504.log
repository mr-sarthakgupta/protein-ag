 309 | def validate_candidate_source(program_path: str) -> None:
 310 |     """Reject reward-hacking program structure before importing candidate code."""
 311 |     source = Path(program_path).read_text()
 312 |     tree = ast.parse(source, filename=program_path)
 313 |     postponed_annotations = _has_postponed_annotations(tree)
 314 | 
 315 |     for node in tree.body:
 316 |         if _is_module_docstring(node) or _is_main_guard(node):
 317 |             continue
 318 |         if isinstance(node, ast.FunctionDef):
 319 |             _validate_top_level_function(node, postponed_annotations=postponed_annotations)
 320 |             continue
 321 |         if isinstance(node, ast.Import):
 322 |             for alias in node.names:
 323 |                 _validate_plain_import(alias)
 324 |         elif isinstance(node, ast.ImportFrom):
 325 |             module = node.module or ""
 326 |             if module not in _ALLOWED_FROM_IMPORTS:
 327 |                 raise ValueError(
 328 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: from-import '{module}' is not allowed."
 329 |                 )
 330 |             if module == "pysr_harness.equation_session":
 331 |                 aliased = [alias.name for alias in node.names if alias.asname]
 332 |                 if aliased:
 333 |                     raise ValueError(
 334 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: harness imports may not "
 335 |                         f"use aliases: {sorted(aliased)}."
 336 |                     )
 337 |                 imported = {alias.name for alias in node.names}
 338 |                 extra = imported - _ALLOWED_HARNESS_IMPORTS
 339 |                 if extra:
 340 |                     raise ValueError(
 341 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: unsupported harness imports "
 342 |                         f"{sorted(extra)}. Use only feature_symbols, constant_symbols, "
 343 |                         "and evaluate_expression."
 344 |                     )
 345 |         else:
 346 |             raise ValueError(
 347 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level executable code is not "
 348 |                 "allowed in candidate programs. Build and score the equation only "
 349 |                 "inside evaluate_symbolic_candidate()."
 350 |             )
 351 | 
 352 |     eval_fns = [
 353 |         node
 354 |         for node in tree.body
 355 |         if isinstance(node, ast.FunctionDef) and node.name == "evaluate_symbolic_candidate"
 356 |     ]
 357 |     if len(eval_fns) != 1:
 358 |         raise ValueError(
 359 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: program must define exactly one "
 360 |             "evaluate_symbolic_candidate() function."
 361 |         )
 362 |     fn = eval_fns[0]
 363 | 
 364 |     returns = [node for node in ast.walk(fn) if isinstance(node, ast.Return)]
 365 |     if len(returns) != 1:
 366 |         raise ValueError(
 367 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must have "
 368 |             "exactly one return statement."
 369 |         )
 370 |     return_value = returns[0].value
 371 |     if not (
 372 |         isinstance(return_value, ast.Call)
 373 |         and isinstance(return_value.func, ast.Name)
 374 |         and return_value.func.id == "evaluate_expression"
 375 |     ):
 376 |         raise ValueError(
 377 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must directly "
 378 |             "return evaluate_expression(...), with no wrapper or post-processing."
 379 |         )
 380 |     allowed_data_arg_ids = _validate_evaluate_expression_data_args(return_value)
 381 |     allowed_data_arg_ids.update(_allowed_feature_symbols_data_ids(fn))
 382 |     _validate_no_dataset_data_leak(fn, allowed_data_arg_ids)
 383 | 
 384 |     evaluate_calls = 0
 385 |     for node in ast.walk(fn):
 386 |         if isinstance(node, _DISALLOWED_CONTROL_NODES):
 387 |             raise ValueError(
 388 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: control flow, nested definitions, "
 389 |                 "comprehensions, and conditionals are not allowed inside "
 390 |                 "evaluate_symbolic_candidate(). Build one straight-line equation."
 391 |             )
 392 |         if isinstance(node, (ast.Import, ast.ImportFrom)):
 393 |             raise ValueError(
 394 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: imports are not allowed inside "
 395 |                 "evaluate_symbolic_candidate()."
 396 |             )
 397 |         if isinstance(node, (ast.Assign, ast.AnnAssign, ast.AugAssign)):
 398 |             targets = node.targets if isinstance(node, ast.Assign) else [node.target]
 399 |             assigned = set().union(*(_assigned_names(target) for target in targets))
 400 |             protected = assigned & _PROTECTED_NAMES
 401 |             if protected:
 402 |                 raise ValueError(
