import os, csv, re
import numpy as np

base = '/home/mrsar/protein-ag/disease-relevant non-inhibited_clean'

# Load one multi-curve dataset and examine y vs x0 shape
path = os.path.join(base, 'Abeta/Cohen2013/Ab42_sec_IN_HOURS/data.tsv')
with open(path) as fh:
    reader = csv.reader(fh, delimiter='\t')
    header = next(reader)
    rows = [r for r in reader if r]

# Parse first 3 curves
curves = []
for i in range(len(header)-1):
    xh = header[i]; yh = header[i+1]
    if xh.strip().endswith('X') and yh.strip().endswith('Y'):
        m = re.search(r'm0:\s*([-+]?\d+(?:\.\d+)?(?:[eE][-+]?\d+)?)', xh)
        M = re.search(r'M0:\s*([-+]?\d+(?:\.\d+)?(?:[eE][-+]?\d+)?)', xh)
        m0 = float(m.group(1)) if m else 0
        M0 = float(M.group(1)) if M else 0
        xs, ys = [], []
        for row in rows:
            if i+1 < len(row) and row[i].strip() and row[i+1].strip():
                try:
                    xs.append(float(row[i])); ys.append(float(row[i+1]))
                except: pass
        if xs:
            curves.append((m0, M0, np.array(xs), np.array(ys)))

print(f'Loaded {len(curves)} curves from Ab42')
for m0, M0, xs, ys in curves[:3]:
    print(f'  m0={m0}, M0={M0}: t=[{xs[0]:.2f}..{xs[-1]:.2f}], y=[{ys[0]:.3f}..{ys[-1]:.3f}], n={len(xs)}')
    # show a few interior points
    mid = len(xs)//2
    print(f'    midpoint: t={xs[mid]:.2f}, y={ys[mid]:.3f}')
