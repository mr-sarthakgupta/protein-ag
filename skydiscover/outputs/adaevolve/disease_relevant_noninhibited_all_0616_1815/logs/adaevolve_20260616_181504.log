1203 | def _eval_stage1_worker(args):
1204 |     """Module-level worker for stage 1 parallel evaluation."""
1205 |     name, X_train, X_val, y_train, y_val, program_path = args
1206 |     harness_root = str(BENCHMARK_ROOT)
1207 |     if harness_root not in sys.path:
1208 |         sys.path.insert(0, harness_root)
1209 |     validate_candidate_source(program_path)
1210 |     import pysr_harness.equation_session as equation_session
1211 |     equation_session.evaluate_expression = evaluate_symbolic_expression
1212 |     equation_session.nmse = _nmse_with_gaussian_smoothed_target
1213 |     spec = importlib.util.spec_from_file_location("program", program_path)
1214 |     program = importlib.util.module_from_spec(spec)
1215 |     spec.loader.exec_module(program)
1216 |     from pysr_harness.equation_session import (
1217 |         single_equation_evaluation,
1218 |         validate_single_equation_result,
