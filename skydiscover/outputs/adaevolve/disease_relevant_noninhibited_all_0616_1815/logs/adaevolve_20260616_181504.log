 600 | def load_all_datasets(
 601 |     root: Path = DATA_ROOT,
 602 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 603 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 604 |     entries = discover_datasets(root)
 605 |     results = []
 606 |     for name, path in entries:
 607 |         try:
 608 |             X_train, X_val, y_train, y_val = load_dataset(path, dataset_name=name)
 609 |             results.append((name, X_train, X_val, y_train, y_val))
 610 |         except Exception as exc:
 611 |             print(f"Warning: skipping dataset {name}: {exc}")
 612 |     return results
