1260 | def evaluate_stage1(program_path: str) -> dict:
1261 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
1262 |     try:
1263 |         harness_root = str(BENCHMARK_ROOT)
1264 |         if harness_root not in sys.path:
1265 |             sys.path.insert(0, harness_root)
1266 | 
1267 |         all_datasets = load_all_datasets()
1268 |         scoring_datasets = [
1269 |             dataset
1270 |             for dataset in all_datasets
1271 |             if dataset[0] not in EVALUATION_ONLY_DATASETS and dataset[4].size > 0
1272 |         ]
1273 |         rng = np.random.default_rng(RANDOM_STATE)
1274 |         if len(scoring_datasets) > 8:
1275 |             indices = rng.choice(len(scoring_datasets), size=8, replace=False)
1276 |             subset = [scoring_datasets[i] for i in sorted(indices)]
1277 |         else:
1278 |             subset = scoring_datasets
1279 | 
1280 |         work_items = [
1281 |             (name, X_train, X_val, y_train, y_val, program_path)
1282 |             for name, X_train, X_val, y_train, y_val in subset
1283 |         ]
1284 | 
1285 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1286 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
1287 |             worker_results = [future.result() for future in concurrent.futures.as_completed(futures)]
1288 | 
1289 |         combined_scores = [score for score, _error, _template in worker_results]
1290 |         successful_scores = [score for score in combined_scores if score > 0]
1291 |         errors = sorted({error for _score, error, _template in worker_results if error})
1292 |         violation_errors = sorted(
1293 |             {
1294 |                 error
1295 |                 for _score, error, _template in worker_results
1296 |                 if error and SINGLE_EQUATION_ERROR_PREFIX in error
1297 |             }
1298 |         )
1299 |         if violation_errors:
1300 |             return {
1301 |                 "combined_score": 0.0,
1302 |                 "n_stage1_datasets": len(subset),
1303 |                 "n_stage1_successful": len(successful_scores),
1304 |                 "eval_workers": NUM_WORKERS,
1305 |                 "error": violation_errors[0],
1306 |             }
1307 |         if errors:
1308 |             return {
1309 |                 "combined_score": 0.0,
1310 |                 "n_stage1_datasets": len(subset),
1311 |                 "n_stage1_successful": len(successful_scores),
1312 |                 "eval_workers": NUM_WORKERS,
1313 |                 "error": (
1314 |                     "Single-equation violation: stage 1 candidate failed on "
1315 |                     f"{len(errors)} dataset evaluations. Example: {errors[0]}"
1316 |                 ),
1317 |             }
1318 |         templates = sorted(
1319 |             {
1320 |                 template
1321 |                 for score, _error, template in worker_results
1322 |                 if score > 0 and template
1323 |             }
1324 |         )
1325 |         if len(templates) > 1:
1326 |             examples = "; ".join(templates[:3])
1327 |             return {
1328 |                 "combined_score": 0.0,
1329 |                 "n_stage1_datasets": len(subset),
1330 |                 "n_stage1_successful": len(successful_scores),
1331 |                 "eval_workers": NUM_WORKERS,
1332 |                 "error": (
1333 |                     "Single-equation violation: stage 1 produced "
1334 |                     f"{len(templates)} distinct equation templates across datasets. "
1335 |                     "The base equation must be identical for all datasets. "
1336 |                     f"Example templates: {examples}"
1337 |                 ),
1338 |             }
1339 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
1340 |         return {
1341 |             "combined_score": agg_combined,
1342 |             "n_stage1_datasets": len(subset),
1343 |             "n_stage1_successful": len(successful_scores),
1344 |             "eval_workers": NUM_WORKERS,
1345 |             "stage1_full_selected_datasets": 1.0,
1346 |         }
1347 |     except Exception as exc:
1348 |         print(f"Stage 1 evaluation failed: {exc}")
1349 |         return {"combined_score": 0.0, "error": str(exc)}
