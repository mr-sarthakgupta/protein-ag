 396 |             )
 397 |         if isinstance(node, (ast.Assign, ast.AnnAssign, ast.AugAssign)):
 398 |             targets = node.targets if isinstance(node, ast.Assign) else [node.target]
 399 |             assigned = set().union(*(_assigned_names(target) for target in targets))
 400 |             protected = assigned & _PROTECTED_NAMES
 401 |             if protected:
 402 |                 raise ValueError(
 403 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: cannot reassign protected scorer "
 404 |                     f"or harness names {sorted(protected)}."
 405 |                 )
 406 |         if isinstance(node, ast.Call):
 407 |             name = _call_name(node.func)
 408 |             if name == "evaluate_expression":
 409 |                 evaluate_calls += 1
 410 |             if name not in _ALLOWED_EVALUATE_CALLS:
 411 |                 raise ValueError(
 412 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: call '{name or type(node.func).__name__}' "
 413 |                     "is not allowed inside evaluate_symbolic_candidate(). Allowed calls "
 414 |                     "are the symbol helpers, evaluate_expression, and basic sp.* math."
 415 |                 )
 416 | 
 417 |     if evaluate_calls != 1:
 418 |         raise ValueError(
 419 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must call "
 420 |             f"evaluate_expression() exactly once; found {evaluate_calls} calls."
 421 |         )
 422 | 
 423 | 
 424 | def _parse_metadata_number(header: str, key: str) -> float | None:
 425 |     """Extract the leading numeric value for a cleaned header field."""
 426 |     match = re.search(
 427 |         rf"(?:^|[\s_]){re.escape(key)}:\s*([-+]?\d+(?:\.\d+)?(?:[eE][-+]?\d+)?)",
 428 |         header,
 429 |     )
 430 |     if match is None:
 431 |         return None
 432 |     return float(match.group(1))
 433 | 
 434 | 
 435 | def _is_x_column(header: str) -> bool:
 436 |     return bool(re.search(r"\s*X\s*$", header.strip()))
 437 | 
 438 | 
 439 | def _is_y_column(header: str) -> bool:
 440 |     return bool(re.search(r"\s*Y\s*$", header.strip()))
 441 | 
 442 | 
 443 | def _remember_curve_ids(X: np.ndarray, curve_ids: np.ndarray) -> np.ndarray:
 444 |     _ARRAY_CURVE_IDS[id(X)] = np.asarray(curve_ids, dtype=int)
 445 |     return X
 446 | 
 447 | 
 448 | def _minmax_normalize(values: np.ndarray) -> np.ndarray:
 449 |     """Normalize one dataset column to 0..1, preserving constants as zeros."""
 450 |     values = np.asarray(values, dtype=float)
 451 |     v_min = float(np.min(values))
 452 |     v_max = float(np.max(values))
 453 |     scale = v_max - v_min
 454 |     if scale <= 0.0:
 455 |         return np.zeros_like(values, dtype=float)
 456 |     return (values - v_min) / scale
 457 | 
 458 | 
 459 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 460 |     """Load cleaned data.tsv and return X=[normalized time, m0, M0], y.
 461 | 
 462 |     Cleaned files store one trajectory per adjacent X/Y column pair. Each
 463 |     column header contains m0, M0, and L0 metadata; only m0 and M0 are exposed
 464 |     as model features. Units are intentionally ignored per the cleaned-data
 465 |     note: the leading numeric value is used as provided.
 466 |     """
 467 |     with data_file.open(newline="") as f:
 468 |         reader = csv.reader(f, delimiter="\t")
 469 |         header = next(reader)
 470 |         rows = [row for row in reader if row]
 471 | 
 472 |     features: list[list[float]] = []
 473 |     targets: list[float] = []
 474 |     curve_ids: list[int] = []
 475 |     curve_id = 0
 476 |     for col_idx in range(len(header) - 1):
 477 |         x_header = header[col_idx]
 478 |         y_header = header[col_idx + 1]
 479 |         if not (_is_x_column(x_header) and _is_y_column(y_header)):
 480 |             continue
 481 |         m0 = _parse_metadata_number(x_header, "m0")
 482 |         seed_m0 = _parse_metadata_number(x_header, "M0")
 483 |         if m0 is None or seed_m0 is None:
 484 |             continue
 485 |         for row in rows:
 486 |             if col_idx + 1 >= len(row):
 487 |                 continue
 488 |             time_value = row[col_idx].strip()
 489 |             response_value = row[col_idx + 1].strip()
 490 |             if (
 491 |                 not time_value
 492 |                 or not response_value
 493 |                 or time_value.lower() == "nan"
 494 |                 or response_value.lower() == "nan"
 495 |             ):
 496 |                 continue
 497 |             features.append([float(time_value), m0, seed_m0])
 498 |             targets.append(float(response_value))
 499 |             curve_ids.append(curve_id)
 500 |         curve_id += 1
 501 | 
 502 |     if not features:
 503 |         raise ValueError(f"No regression samples loaded from {data_file}")
 504 | 
 505 |     X = np.asarray(features, dtype=float)
 506 |     y = np.asarray(targets, dtype=float)
 507 |     time_norm = _minmax_normalize(X[:, 0])
 508 |     monomer_raw = X[:, 1]
 509 |     seed_raw = X[:, 2]
 510 |     y_norm = _minmax_normalize(y)
 511 | 
 512 |     X_out = np.column_stack([time_norm, monomer_raw, seed_raw])
 513 |     return _remember_curve_ids(X_out, np.asarray(curve_ids, dtype=int)), y_norm
 514 | 
 515 | 
 516 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 517 |     """Recursively find all cleaned data.tsv files and return dataset entries."""
 518 |     datasets: list[tuple[str, Path]] = []
 519 |     for dirpath, _dirnames, filenames in os.walk(root):
 520 |         if "data.tsv" in filenames:
 521 |             fit_path = Path(dirpath) / "data.tsv"
 522 |             rel = fit_path.parent.relative_to(root)
 523 |             name = str(rel).replace(os.sep, "/")
 524 |             datasets.append((name, fit_path))
 525 |     datasets.sort(key=lambda x: x[0])
 526 |     return datasets
 527 | 
 528 | 
 529 | def _curve_indices(X: np.ndarray) -> list[np.ndarray]:
 530 |     """Return cleaned-trajectory row indices."""
 531 |     if X.shape[0] == 0:
 532 |         return []
 533 |     curve_ids = _ARRAY_CURVE_IDS.get(id(X))
 534 |     if curve_ids is not None and curve_ids.shape[0] == X.shape[0]:
 535 |         return [np.flatnonzero(curve_ids == curve_id) for curve_id in dict.fromkeys(curve_ids)]
 536 |     return [np.arange(X.shape[0], dtype=int)]
 537 | 
 538 | 
 539 | def _trajectory_preserving_split(
 540 |     X: np.ndarray,
 541 |     y: np.ndarray,
 542 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 543 |     """Split whole cleaned X/Y curves into fit and NMSE-evaluation sets."""
 544 |     curves = _curve_indices(X)
 545 |     rng = np.random.default_rng(RANDOM_STATE)
 546 | 
 547 |     if len(curves) < 3:
 548 |         empty_X = np.empty((0, X.shape[1]), dtype=float)
 549 |         empty_y = np.empty(0, dtype=float)
 550 |         return X, empty_X, y, empty_y
 551 | 
 552 |     shuffled = rng.permutation(len(curves))
 553 |     n_val_curves = min(
 554 |         max(1, int(round(len(curves) * TEST_SIZE))), len(curves) - 1
 555 |     )
 556 |     val_curve_ids = set(int(i) for i in shuffled[:n_val_curves])
 557 | 
 558 |     fit_indices: list[int] = []
 559 |     val_indices: list[int] = []
 560 |     for curve_id, curve_idx in enumerate(curves):
 561 |         if curve_id in val_curve_ids:
 562 |             val_indices.extend(curve_idx.tolist())
 563 |         else:
 564 |             fit_indices.extend(curve_idx.tolist())
 565 | 
 566 |     fit_idx = np.sort(np.asarray(fit_indices, dtype=int))
 567 |     val_idx = np.sort(np.asarray(val_indices, dtype=int))
 568 |     curve_ids = _ARRAY_CURVE_IDS.get(id(X), np.zeros(X.shape[0], dtype=int))
 569 |     X_fit = X[fit_idx]
 570 |     X_val = X[val_idx]
 571 |     _remember_curve_ids(X_fit, curve_ids[fit_idx])
 572 |     _remember_curve_ids(X_val, curve_ids[val_idx])
 573 |     return X_fit, X_val, y[fit_idx], y[val_idx]
 574 | 
 575 | 
 576 | def _evaluation_only_split(
 577 |     X: np.ndarray,
 578 |     y: np.ndarray,
 579 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 580 |     """Hold out an entire dataset for validation-only cross-protein evaluation."""
 581 |     empty_X = np.empty((0, X.shape[1]), dtype=float)
 582 |     empty_y = np.empty(0, dtype=float)
 583 |     _remember_curve_ids(empty_X, np.empty(0, dtype=int))
 584 |     _remember_curve_ids(X, _ARRAY_CURVE_IDS.get(id(X), np.zeros(X.shape[0], dtype=int)))
 585 |     return empty_X, X, empty_y, y
 586 | 
