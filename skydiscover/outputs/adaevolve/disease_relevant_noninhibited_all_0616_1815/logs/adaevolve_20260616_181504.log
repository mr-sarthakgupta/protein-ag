import sympy as sp

def complexity(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

x0, x1, x2 = sp.symbols('x0 x1 x2')
c0,c1,c2,c3,c4,c5 = sp.symbols('c0 c1 c2 c3 c4 c5')

# Option A: remove monomer scaling from half_time, keep seed
# y = c3 / (1 + exp(-c0*x1^c1*(x0 - c2/(1+c4*x2))))
rate_a = c0 * x1**c1
ht_a = c2 / (1 + c4*x2)
ea = c3 / (1 + sp.exp(-rate_a * (x0 - ht_a)))
print('A (no mono in ht, seed denom):', complexity(ea), 'nodes, 5 constants')

# Option B: pure logistic with monomer-only half-time (no seed)
# y = c3 / (1 + exp(-c0*x1^c1*(x0 - c2*x1^c3))) 
rate_b = c0 * x1**c1
ht_b = c2 * x1**c3
eb = c4 / (1 + sp.exp(-rate_b * (x0 - ht_b)))
print('B (mono in ht, no seed, 5c):', complexity(eb), 'nodes, 5 constants')

# Option C: logistic, rate only depends on x1, half-time fixed constant
# y = c2 / (1 + exp(-c0*x1^c1*(x0 - c3)))
rate_c = c0 * x1**c1
ec = c2 / (1 + sp.exp(-rate_c * (x0 - c3)))
print('C (fixed half-time, 4c):', complexity(ec), 'nodes, 4 constants')

# Option D: keep monomer in both but use additive seed in half-time
# y = c3 / (1 + exp(-c0*x1^c1*(x0 - c2*x1^c1 - c4*x2)))
# shared exponent c1
rate_d = c0 * x1**c1
ht_d = c2 * x1**c1 + c4*x2
ed = c3 / (1 + sp.exp(-rate_d * (x0 - ht_d)))
print('D (shared exp, additive seed, 5c):', complexity(ed), 'nodes, 5 constants')

# Parsimony score projection (assuming nmse stays ~0.038)
fit = 1/(1+0.038)
for c, name in [(28,'current'),(complexity(ea),'A'),(complexity(eb),'B'),(complexity(ec),'C'),(complexity(ed),'D')]:
    p = 1 - 0.2*c/160
    print(f'  {name} c={c}: penalty={p:.4f}, projected_score={fit*p:.4f}')
"
