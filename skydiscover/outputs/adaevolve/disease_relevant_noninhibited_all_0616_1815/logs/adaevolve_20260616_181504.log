1182 | def evaluate(program_path: str) -> dict:
1183 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
1184 |     try:
1185 |         start = time.time()
1186 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=3000)
1187 |         metrics = _metrics_from_result(result, time.time() - start)
1188 |         print(
1189 |             "Evaluation: "
1190 |             f"nmse_val={metrics['nmse_val']:.6f}, "
1191 |             f"mean_nmse_val={metrics['mean_nmse_val']:.6f}, "
1192 |             f"mean_raw_nmse_val={metrics['mean_raw_nmse_val']:.6f}, "
1193 |             f"combined_score={metrics['combined_score']:.6f}, "
1194 |             f"n_datasets={metrics['n_datasets']}, "
1195 |             f"n_successful={metrics['n_successful']}, "
1196 |             f"time={metrics['eval_time']:.2f}s"
1197 |         )
1198 |         print(f"Equation template: {metrics['equation']}")
1199 |         if metrics.get("hard_case_feedback"):
1200 |             print(f"Hard-case feedback: {metrics['hard_case_feedback']}")
1201 |         if metrics.get("error"):
1202 |             print(f"Evaluator feedback: {metrics['error']}")
1203 |         return metrics
1204 |     except Exception as exc:
1205 |         print(f"Evaluation failed: {exc}")
1206 |         traceback.print_exc()
1207 |         return {
