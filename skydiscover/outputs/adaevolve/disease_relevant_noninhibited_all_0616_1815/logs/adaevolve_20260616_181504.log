 583 | def _dataset_name_from_path(data_file: Path, root: Path = DATA_ROOT) -> str:
 584 |     return str(data_file.parent.relative_to(root)).replace(os.sep, "/")
 585 | 
 586 | 
 587 | def load_dataset(
 588 |     data_file: Path,
 589 |     *,
 590 |     dataset_name: str | None = None,
 591 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 592 |     """Load a single data.tsv and return deterministic trajectory-preserving split."""
 593 |     X, y = _load_fit_table(data_file)
 594 |     name = dataset_name or _dataset_name_from_path(data_file)
 595 |     if name in EVALUATION_ONLY_DATASETS:
 596 |         return _evaluation_only_split(X, y)
 597 |     return _trajectory_preserving_split(X, y)
