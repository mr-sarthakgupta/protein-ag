n_val = min(max(1, int(round(3*0.35))), 2)
val_set = set(int(i) for i in shuf[:n_val])
print(f'insulin val_set (curve indices): {val_set}')
# curve 0: M0=0.172, curve 1: M0=0.344, curve 2: M0=0
print(f'  curve 0: M0=0.172, curve 1: M0=0.344, curve 2: M0=0')
