import pandas as pd, numpy as np, os

path = '/home/mrsar/protein-ag/disease-relevant non-inhibited_clean/'
# Check a few datasets with multiple concentration curves to understand scaling
datasets_to_check = [
    'Abeta/Meisl2014/Ab40_sec_IN_HOURS',
    'biofilm proteins/CsgA/CsgA_IN_HOURS',
    'Alphasyn_Gaspar2017/03uM_seed all',
]
for d in datasets_to_check:
    fpath = os.path.join(path, d, 'data.tsv')
    if os.path.exists(fpath):
        df = pd.read_csv(fpath, sep='\t')
        ncurves = df.shape[1] // 2
        print(f'{d}: {ncurves} curves')
