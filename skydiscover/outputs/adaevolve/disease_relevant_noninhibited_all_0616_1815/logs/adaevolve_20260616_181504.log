import sympy as sp

# Count nodes for different candidates
def complexity(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

x0, x1, x2 = sp.symbols('x0 x1 x2')
c0,c1,c2,c3,c4,c5 = sp.symbols('c0 c1 c2 c3 c4 c5')

# Current best (28 nodes)
rate = c0 * x1**c1
half_time = c2 * x1**c4 / (1 + c5*x2)
e1 = c3 / (1 + sp.exp(-rate * (x0 - half_time)))
print('Current best:', complexity(e1), 'nodes')

# Simpler: no monomer in half-time, just seed denominator
rate2 = c0 * x1**c1
half_time2 = c2 / (1 + c3*x2)
e2 = c4 / (1 + sp.exp(-rate2 * (x0 - half_time2)))
