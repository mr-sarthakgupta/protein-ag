  90 |     "constant_symbols",
  91 |     "evaluate_expression",
  92 |     "feature_symbols",
  93 |     "sp.exp",
  94 |     "sp.log",
  95 |     "sp.log1p",
  96 |     "sp.sqrt",
  97 |     "sp.sin",
  98 |     "sp.cos",
  99 |     "sp.tan",
 100 |     "sp.tanh",
 101 |     "sp.sinh",
 102 |     "sp.cosh",
 103 | }
 104 | _PROTECTED_NAMES = {
 105 |     "constant_symbols",
 106 |     "evaluate_expression",
 107 |     "feature_symbols",
 108 |     "single_equation_evaluation",
 109 |     "validate_single_equation_result",
 110 | }
 111 | _DISALLOWED_CONTROL_NODES = (
 112 |     ast.AsyncFunctionDef,
 113 |     ast.ClassDef,
 114 |     ast.For,
 115 |     ast.While,
 116 |     ast.If,
 117 |     ast.IfExp,
 118 |     ast.Try,
 119 |     ast.With,
 120 |     ast.AsyncWith,
 121 |     ast.Match,
 122 |     ast.Lambda,
 123 |     ast.ListComp,
 124 |     ast.SetComp,
 125 |     ast.DictComp,
 126 |     ast.GeneratorExp,
 127 | )
 128 | 
 129 | 
 130 | def _is_module_docstring(node: ast.AST) -> bool:
 131 |     return (
 132 |         isinstance(node, ast.Expr)
 133 |         and isinstance(node.value, ast.Constant)
 134 |         and isinstance(node.value.value, str)
 135 |     )
 136 | 
 137 | 
 138 | def _is_main_guard(node: ast.AST) -> bool:
 139 |     if not isinstance(node, ast.If):
 140 |         return False
 141 |     if node.orelse:
 142 |         return False
 143 |     test = node.test
 144 |     if not isinstance(test, ast.Compare) or len(test.ops) != 1 or len(test.comparators) != 1:
 145 |         return False
 146 |     if not isinstance(test.ops[0], ast.Eq):
 147 |         return False
 148 |     left = test.left
 149 |     right = test.comparators[0]
 150 |     return (
 151 |         isinstance(left, ast.Name)
 152 |         and left.id == "__name__"
 153 |         and isinstance(right, ast.Constant)
 154 |         and right.value == "__main__"
 155 |     )
 156 | 
 157 | 
 158 | def _has_postponed_annotations(tree: ast.Module) -> bool:
 159 |     for node in tree.body:
 160 |         if isinstance(node, ast.ImportFrom) and node.module == "__future__":
 161 |             if any(alias.name == "annotations" for alias in node.names):
 162 |                 return True
 163 |     return False
 164 | 
 165 | 
 166 | def _function_annotations(node: ast.FunctionDef) -> list[ast.AST]:
 167 |     annotations: list[ast.AST] = []
 168 |     args = node.args
 169 |     for arg in [*args.posonlyargs, *args.args, *args.kwonlyargs]:
 170 |         if arg.annotation is not None:
 171 |             annotations.append(arg.annotation)
 172 |     if args.vararg is not None and args.vararg.annotation is not None:
 173 |         annotations.append(args.vararg.annotation)
 174 |     if args.kwarg is not None and args.kwarg.annotation is not None:
 175 |         annotations.append(args.kwarg.annotation)
 176 |     if node.returns is not None:
 177 |         annotations.append(node.returns)
 178 |     return annotations
 179 | 
 180 | 
 181 | def _validate_top_level_function(node: ast.FunctionDef, *, postponed_annotations: bool) -> None:
 182 |     if node.name in _PROTECTED_NAMES:
 183 |         raise ValueError(
 184 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function '{node.name}' "
 185 |             "shadows a protected scorer or harness name."
 186 |         )
 187 |     if node.decorator_list:
 188 |         raise ValueError(
 189 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function decorators are not "
 190 |             "allowed because decorators execute during candidate import."
 191 |         )
 192 |     if node.args.defaults or node.args.kw_defaults:
 193 |         raise ValueError(
 194 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function default arguments "
 195 |             "are not allowed because defaults execute during candidate import."
 196 |         )
 197 |     if _function_annotations(node) and not postponed_annotations:
 198 |         raise ValueError(
 199 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function annotations require "
 200 |             "'from __future__ import annotations' because annotations otherwise "
 201 |             "execute during candidate import."
 202 |         )
 203 | 
 204 | 
 205 | def _call_name(func: ast.AST) -> str:
 206 |     if isinstance(func, ast.Name):
 207 |         return func.id
 208 |     if isinstance(func, ast.Attribute) and isinstance(func.value, ast.Name):
 209 |         return f"{func.value.id}.{func.attr}"
 210 |     return ""
 211 | 
 212 | 
 213 | def _assigned_names(target: ast.AST) -> set[str]:
 214 |     if isinstance(target, ast.Name):
 215 |         return {target.id}
 216 |     if isinstance(target, (ast.Tuple, ast.List)):
 217 |         names: set[str] = set()
 218 |         for elt in target.elts:
 219 |             names.update(_assigned_names(elt))
 220 |         return names
 221 |     return set()
 222 | 
 223 | 
 224 | def _validate_plain_import(alias: ast.alias) -> None:
 225 |     if alias.name not in _ALLOWED_IMPORTS:
 226 |         raise ValueError(
 227 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: import '{alias.name}' is not allowed. "
 228 |             "Candidates may only import sympy/numpy and the equation harness."
 229 |         )
 230 |     if alias.name == "sympy" and alias.asname != "sp":
 231 |         raise ValueError(
 232 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: sympy must be imported canonically "
 233 |             "as 'import sympy as sp'."
 234 |         )
 235 |     if alias.name == "numpy" and alias.asname not in {None, "np"}:
 236 |         raise ValueError(
 237 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: numpy may only be imported as "
 238 |             "'import numpy' or 'import numpy as np'."
 239 |         )
 240 | 
 241 | 
 242 | def _validate_evaluate_expression_data_args(call: ast.Call) -> set[int]:
 243 |     expected = ["X_train", "y_train", "X_val", "y_val"]
 244 |     if len(call.args) < 5:
 245 |         raise ValueError(
 246 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must be called "
 247 |             "as evaluate_expression(expression, X_train, y_train, X_val, y_val, ...)."
 248 |         )
 249 |     actual_data_args = call.args[1:5]
 250 |     if not all(
 251 |         isinstance(arg, ast.Name) and arg.id == expected_name
 252 |         for arg, expected_name in zip(actual_data_args, expected)
 253 |     ):
 254 |         raise ValueError(
 255 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must use the "
 256 |             "canonical data arguments exactly as X_train, y_train, X_val, y_val. "
 257 |             "Do not fit constants on validation labels or reorder the split."
 258 |         )
 259 |     return {id(arg) for arg in call.args[1:5]}
 260 | 
 261 | 
 262 | def _x_train_shape_feature_arg_id(node: ast.AST) -> int | None:
 263 |     if not (
 264 |         isinstance(node, ast.Subscript)
 265 |         and isinstance(node.value, ast.Attribute)
 266 |         and node.value.attr == "shape"
 267 |         and isinstance(node.value.value, ast.Name)
 268 |         and node.value.value.id == "X_train"
 269 |     ):
 270 |         return None
 271 |     slice_node = node.slice
 272 |     if isinstance(slice_node, ast.Constant) and slice_node.value == 1:
 273 |         return id(node.value.value)
 274 |     return None
 275 | 
 276 | 
 277 | def _allowed_feature_symbols_data_ids(fn: ast.FunctionDef) -> set[int]:
 278 |     allowed: set[int] = set()
 279 |     for node in ast.walk(fn):
 280 |         if not (
 281 |             isinstance(node, ast.Call)
 282 |             and isinstance(node.func, ast.Name)
 283 |             and node.func.id == "feature_symbols"
 284 |             and len(node.args) == 1
 285 |         ):
 286 |             continue
 287 |         x_train_id = _x_train_shape_feature_arg_id(node.args[0])
 288 |         if x_train_id is not None:
 289 |             allowed.add(x_train_id)
 290 |     return allowed
 291 | 
 292 | 
 293 | def _validate_no_dataset_data_leak(fn: ast.FunctionDef, allowed_node_ids: set[int]) -> None:
 294 |     for node in ast.walk(fn):
 295 |         if (
 296 |             isinstance(node, ast.Name)
 297 |             and node.id in {"X_train", "y_train", "X_val", "y_val"}
 298 |             and id(node) not in allowed_node_ids
 299 |         ):
 300 |             raise ValueError(
 301 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: dataset array '{node.id}' may only "
 302 |                 "appear in feature_symbols(X_train.shape[1]) or as the canonical "
 303 |                 "evaluate_expression(expression, X_train, y_train, X_val, y_val, ...) "
 304 |                 "arguments. Do not use dataset values to choose expressions, mutate "
 305 |                 "splits, or tune constants/initial values."
 306 |             )
 307 | 
 308 | 
 309 | def validate_candidate_source(program_path: str) -> None:
 310 |     """Reject reward-hacking program structure before importing candidate code."""
 311 |     source = Path(program_path).read_text()
 312 |     tree = ast.parse(source, filename=program_path)
 313 |     postponed_annotations = _has_postponed_annotations(tree)
 314 | 
 315 |     for node in tree.body:
 316 |         if _is_module_docstring(node) or _is_main_guard(node):
 317 |             continue
 318 |         if isinstance(node, ast.FunctionDef):
 319 |             _validate_top_level_function(node, postponed_annotations=postponed_annotations)
 320 |             continue
 321 |         if isinstance(node, ast.Import):
 322 |             for alias in node.names:
 323 |                 _validate_plain_import(alias)
 324 |         elif isinstance(node, ast.ImportFrom):
 325 |             module = node.module or ""
 326 |             if module not in _ALLOWED_FROM_IMPORTS:
 327 |                 raise ValueError(
 328 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: from-import '{module}' is not allowed."
 329 |                 )
 330 |             if module == "pysr_harness.equation_session":
 331 |                 aliased = [alias.name for alias in node.names if alias.asname]
 332 |                 if aliased:
 333 |                     raise ValueError(
 334 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: harness imports may not "
 335 |                         f"use aliases: {sorted(aliased)}."
 336 |                     )
 337 |                 imported = {alias.name for alias in node.names}
 338 |                 extra = imported - _ALLOWED_HARNESS_IMPORTS
 339 |                 if extra:
 340 |                     raise ValueError(
 341 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: unsupported harness imports "
 342 |                         f"{sorted(extra)}. Use only feature_symbols, constant_symbols, "
 343 |                         "and evaluate_expression."
 344 |                     )
 345 |         else:
 346 |             raise ValueError(
 347 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level executable code is not "
 348 |                 "allowed in candidate programs. Build and score the equation only "
 349 |                 "inside evaluate_symbolic_candidate()."
 350 |             )
 351 | 
 352 |     eval_fns = [
 353 |         node
 354 |         for node in tree.body
 355 |         if isinstance(node, ast.FunctionDef) and node.name == "evaluate_symbolic_candidate"
 356 |     ]
 357 |     if len(eval_fns) != 1:
 358 |         raise ValueError(
 359 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: program must define exactly one "
 360 |             "evaluate_symbolic_candidate() function."
 361 |         )
 362 |     fn = eval_fns[0]
 363 | 
 364 |     returns = [node for node in ast.walk(fn) if isinstance(node, ast.Return)]
 365 |     if len(returns) != 1:
 366 |         raise ValueError(
 367 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must have "
 368 |             "exactly one return statement."
 369 |         )
 370 |     return_value = returns[0].value
 371 |     if not (
 372 |         isinstance(return_value, ast.Call)
 373 |         and isinstance(return_value.func, ast.Name)
 374 |         and return_value.func.id == "evaluate_expression"
 375 |     ):
 376 |         raise ValueError(
 377 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must directly "
 378 |             "return evaluate_expression(...), with no wrapper or post-processing."
 379 |         )
 380 |     allowed_data_arg_ids = _validate_evaluate_expression_data_args(return_value)
 381 |     allowed_data_arg_ids.update(_allowed_feature_symbols_data_ids(fn))
 382 |     _validate_no_dataset_data_leak(fn, allowed_data_arg_ids)
 383 | 
 384 |     evaluate_calls = 0
 385 |     for node in ast.walk(fn):
 386 |         if isinstance(node, _DISALLOWED_CONTROL_NODES):
 387 |             raise ValueError(
 388 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: control flow, nested definitions, "
 389 |                 "comprehensions, and conditionals are not allowed inside "
 390 |                 "evaluate_symbolic_candidate(). Build one straight-line equation."
 391 |             )
 392 |         if isinstance(node, (ast.Import, ast.ImportFrom)):
 393 |             raise ValueError(
 394 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: imports are not allowed inside "
 395 |                 "evaluate_symbolic_candidate()."
 396 |             )
 397 |         if isinstance(node, (ast.Assign, ast.AnnAssign, ast.AugAssign)):
 398 |             targets = node.targets if isinstance(node, ast.Assign) else [node.target]
 399 |             assigned = set().union(*(_assigned_names(target) for target in targets))
 400 |             protected = assigned & _PROTECTED_NAMES
 401 |             if protected:
 402 |                 raise ValueError(
 403 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: cannot reassign protected scorer "
 404 |                     f"or harness names {sorted(protected)}."
 405 |                 )
 406 |         if isinstance(node, ast.Call):
 407 |             name = _call_name(node.func)
 408 |             if name == "evaluate_expression":
 409 |                 evaluate_calls += 1
 410 |             if name not in _ALLOWED_EVALUATE_CALLS:
 411 |                 raise ValueError(
 412 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: call '{name or type(node.func).__name__}' "
 413 |                     "is not allowed inside evaluate_symbolic_candidate(). Allowed calls "
 414 |                     "are the symbol helpers, evaluate_expression, and basic sp.* math."
 415 |                 )
 416 | 
 417 |     if evaluate_calls != 1:
 418 |         raise ValueError(
 419 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must call "
 420 |             f"evaluate_expression() exactly once; found {evaluate_calls} calls."
 421 |         )
 422 | 
 423 | 
 424 | def _parse_metadata_number(header: str, key: str) -> float | None:
 425 |     """Extract the leading numeric value for a cleaned header field."""
 426 |     match = re.search(
 427 |         rf"(?:^|[\s_]){re.escape(key)}:\s*([-+]?\d+(?:\.\d+)?(?:[eE][-+]?\d+)?)",
 428 |         header,
 429 |     )
 430 |     if match is None:
 431 |         return None
 432 |     return float(match.group(1))
 433 | 
 434 | 
 435 | def _is_x_column(header: str) -> bool:
 436 |     return bool(re.search(r"\s*X\s*$", header.strip()))
 437 | 
 438 | 
 439 | def _is_y_column(header: str) -> bool:
 440 |     return bool(re.search(r"\s*Y\s*$", header.strip()))
 441 | 
 442 | 
 443 | def _remember_curve_ids(X: np.ndarray, curve_ids: np.ndarray) -> np.ndarray:
 444 |     _ARRAY_CURVE_IDS[id(X)] = np.asarray(curve_ids, dtype=int)
 445 |     return X
 446 | 
 447 | 
 448 | def _minmax_normalize(values: np.ndarray) -> np.ndarray:
 449 |     """Normalize one dataset column to 0..1, preserving constants as zeros."""
 450 |     values = np.asarray(values, dtype=float)
 451 |     v_min = float(np.min(values))
 452 |     v_max = float(np.max(values))
 453 |     scale = v_max - v_min
 454 |     if scale <= 0.0:
 455 |         return np.zeros_like(values, dtype=float)
 456 |     return (values - v_min) / scale
 457 | 
 458 | 
 459 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 460 |     """Load cleaned data.tsv and return X=[normalized time, m0, M0], y.
 461 | 
 462 |     Cleaned files store one trajectory per adjacent X/Y column pair. Each
 463 |     column header contains m0, M0, and L0 metadata; only m0 and M0 are exposed
 464 |     as model features. Units are intentionally ignored per the cleaned-data
 465 |     note: the leading numeric value is used as provided.
 466 |     """
 467 |     with data_file.open(newline="") as f:
 468 |         reader = csv.reader(f, delimiter="\t")
 469 |         header = next(reader)
 470 |         rows = [row for row in reader if row]
 471 | 
 472 |     features: list[list[float]] = []
 473 |     targets: list[float] = []
 474 |     curve_ids: list[int] = []
 475 |     curve_id = 0
 476 |     for col_idx in range(len(header) - 1):
 477 |         x_header = header[col_idx]
 478 |         y_header = header[col_idx + 1]
 479 |         if not (_is_x_column(x_header) and _is_y_column(y_header)):
 480 |             continue
 481 |         m0 = _parse_metadata_number(x_header, "m0")
 482 |         seed_m0 = _parse_metadata_number(x_header, "M0")
 483 |         if m0 is None or seed_m0 is None:
 484 |             continue
 485 |         for row in rows:
 486 |             if col_idx + 1 >= len(row):
 487 |                 continue
 488 |             time_value = row[col_idx].strip()
 489 |             response_value = row[col_idx + 1].strip()
 490 |             if (
 491 |                 not time_value
 492 |                 or not response_value
 493 |                 or time_value.lower() == "nan"
 494 |                 or response_value.lower() == "nan"
 495 |             ):
 496 |                 continue
 497 |             features.append([float(time_value), m0, seed_m0])
 498 |             targets.append(float(response_value))
 499 |             curve_ids.append(curve_id)
 500 |         curve_id += 1
 501 | 
 502 |     if not features:
 503 |         raise ValueError(f"No regression samples loaded from {data_file}")
 504 | 
 505 |     X = np.asarray(features, dtype=float)
 506 |     y = np.asarray(targets, dtype=float)
 507 |     time_norm = _minmax_normalize(X[:, 0])
 508 |     monomer_raw = X[:, 1]
 509 |     seed_raw = X[:, 2]
 510 |     y_norm = _minmax_normalize(y)
 511 | 
 512 |     X_out = np.column_stack([time_norm, monomer_raw, seed_raw])
 513 |     return _remember_curve_ids(X_out, np.asarray(curve_ids, dtype=int)), y_norm
 514 | 
 515 | 
 516 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 517 |     """Recursively find all cleaned data.tsv files and return dataset entries."""
 518 |     datasets: list[tuple[str, Path]] = []
 519 |     for dirpath, _dirnames, filenames in os.walk(root):
 520 |         if "data.tsv" in filenames:
 521 |             fit_path = Path(dirpath) / "data.tsv"
 522 |             rel = fit_path.parent.relative_to(root)
 523 |             name = str(rel).replace(os.sep, "/")
 524 |             datasets.append((name, fit_path))
 525 |     datasets.sort(key=lambda x: x[0])
 526 |     return datasets
 527 | 
 528 | 
 529 | def _curve_indices(X: np.ndarray) -> list[np.ndarray]:
 530 |     """Return cleaned-trajectory row indices."""
 531 |     if X.shape[0] == 0:
 532 |         return []
 533 |     curve_ids = _ARRAY_CURVE_IDS.get(id(X))
 534 |     if curve_ids is not None and curve_ids.shape[0] == X.shape[0]:
 535 |         return [np.flatnonzero(curve_ids == curve_id) for curve_id in dict.fromkeys(curve_ids)]
 536 |     return [np.arange(X.shape[0], dtype=int)]
 537 | 
 538 | 
 539 | def _trajectory_preserving_split(
 540 |     X: np.ndarray,
 541 |     y: np.ndarray,
 542 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 543 |     """Split whole cleaned X/Y curves into fit and NMSE-evaluation sets."""
 544 |     curves = _curve_indices(X)
 545 |     rng = np.random.default_rng(RANDOM_STATE)
 546 | 
 547 |     if len(curves) < 3:
 548 |         empty_X = np.empty((0, X.shape[1]), dtype=float)
 549 |         empty_y = np.empty(0, dtype=float)
 550 |         return X, empty_X, y, empty_y
 551 | 
 552 |     shuffled = rng.permutation(len(curves))
 553 |     n_val_curves = min(
 554 |         max(1, int(round(len(curves) * TEST_SIZE))), len(curves) - 1
 555 |     )
 556 |     val_curve_ids = set(int(i) for i in shuffled[:n_val_curves])
 557 | 
 558 |     fit_indices: list[int] = []
 559 |     val_indices: list[int] = []
 560 |     for curve_id, curve_idx in enumerate(curves):
 561 |         if curve_id in val_curve_ids:
 562 |             val_indices.extend(curve_idx.tolist())
 563 |         else:
 564 |             fit_indices.extend(curve_idx.tolist())
 565 | 
 566 |     fit_idx = np.sort(np.asarray(fit_indices, dtype=int))
 567 |     val_idx = np.sort(np.asarray(val_indices, dtype=int))
 568 |     curve_ids = _ARRAY_CURVE_IDS.get(id(X), np.zeros(X.shape[0], dtype=int))
 569 |     X_fit = X[fit_idx]
 570 |     X_val = X[val_idx]
 571 |     _remember_curve_ids(X_fit, curve_ids[fit_idx])
 572 |     _remember_curve_ids(X_val, curve_ids[val_idx])
 573 |     return X_fit, X_val, y[fit_idx], y[val_idx]
 574 | 
 575 | 
 576 | def _evaluation_only_split(
 577 |     X: np.ndarray,
 578 |     y: np.ndarray,
 579 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 580 |     """Hold out an entire dataset for validation-only cross-protein evaluation."""
 581 |     empty_X = np.empty((0, X.shape[1]), dtype=float)
 582 |     empty_y = np.empty(0, dtype=float)
 583 |     _remember_curve_ids(empty_X, np.empty(0, dtype=int))
 584 |     _remember_curve_ids(X, _ARRAY_CURVE_IDS.get(id(X), np.zeros(X.shape[0], dtype=int)))
 585 |     return empty_X, X, empty_y, y
 586 | 
 587 | 
 588 | def _dataset_name_from_path(data_file: Path, root: Path = DATA_ROOT) -> str:
 589 |     return str(data_file.parent.relative_to(root)).replace(os.sep, "/")
 590 | 
 591 | 
 592 | def load_dataset(
 593 |     data_file: Path,
 594 |     *,
 595 |     dataset_name: str | None = None,
 596 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 597 |     """Load a single data.tsv and return deterministic trajectory-preserving split."""
 598 |     X, y = _load_fit_table(data_file)
 599 |     name = dataset_name or _dataset_name_from_path(data_file)
 600 |     if name in EVALUATION_ONLY_DATASETS:
 601 |         return _evaluation_only_split(X, y)
 602 |     return _trajectory_preserving_split(X, y)
 603 | 
 604 | 
 605 | def load_all_datasets(
 606 |     root: Path = DATA_ROOT,
 607 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 608 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 609 |     entries = discover_datasets(root)
 610 |     results = []
 611 |     for name, path in entries:
 612 |         try:
 613 |             X_train, X_val, y_train, y_val = load_dataset(path, dataset_name=name)
 614 |             results.append((name, X_train, X_val, y_train, y_val))
 615 |         except Exception as exc:
 616 |             print(f"Warning: skipping dataset {name}: {exc}")
 617 |     return results
 618 | 
 619 | 
 620 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 621 | PARSIMONY_WEIGHT = float(os.environ.get("SKYDISCOVER_PARSIMONY_WEIGHT", "0.20"))
 622 | PARSIMONY_COMPLEXITY_SCALE = float(
 623 |     os.environ.get("SKYDISCOVER_PARSIMONY_COMPLEXITY_SCALE", "160")
 624 | )
 625 | 
 626 | 
 627 | def _parsimony_penalty_factor(complexity: float) -> float:
 628 |     """Bounded penalty factor for expression complexity."""
 629 |     if not np.isfinite(complexity) or PARSIMONY_COMPLEXITY_SCALE <= 0:
 630 |         return 1.0
 631 |     normalized = min(max(float(complexity), 0.0) / PARSIMONY_COMPLEXITY_SCALE, 1.0)
 632 |     return max(0.0, 1.0 - PARSIMONY_WEIGHT * normalized)
 633 | 
 634 | 
 635 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 636 |     values = np.asarray(values, dtype=float).ravel()
 637 |     if values.size < 3 or sigma <= 0.0:
 638 |         return values
 639 |     radius = max(1, int(round(3.0 * sigma)))
 640 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 641 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 642 |     kernel /= np.sum(kernel)
 643 |     padded = np.pad(values, (radius, radius), mode="edge")
 644 |     return np.convolve(padded, kernel, mode="valid")
 645 | 
 646 | 
 647 | def _curve_smoothed_target(X: np.ndarray, y_true: np.ndarray) -> np.ndarray:
 648 |     """Smooth targets independently for each parameter curve in time order."""
 649 |     X = np.asarray(X, dtype=float)
 650 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 651 |     if X.shape[0] != y_true.shape[0] or X.shape[1] < 2:
 652 |         return _gaussian_smooth_1d(y_true)
 653 | 
 654 |     smoothed = np.empty_like(y_true, dtype=float)
 655 |     for parameter in np.unique(X[:, 1]):
 656 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 657 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 658 |         smoothed_curve = _gaussian_smooth_1d(y_true[ordered_idx])
 659 |         smoothed[ordered_idx] = smoothed_curve
 660 |     return smoothed
 661 | 
 662 | 
 663 | def _normalized_mse_with_reference_variance(
 664 |     y_true: np.ndarray,
 665 |     y_pred: np.ndarray,
 666 |     reference_values: np.ndarray,
 667 | ) -> float:
 668 |     """MSE normalized by full dataset scale, not by a flat validation segment."""
 669 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 670 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 671 |     reference_values = np.asarray(reference_values, dtype=float).reshape(-1)
 672 |     if y_true.shape != y_pred.shape:
 673 |         return float("inf")
 674 |     if not np.all(np.isfinite(y_pred)):
 675 |         return float("inf")
 676 |     var = float(np.var(reference_values))
 677 |     if var <= 0.0:
 678 |         return float(np.mean((y_true - y_pred) ** 2))
 679 |     return float(np.mean((y_true - y_pred) ** 2) / var)
 680 | 
 681 | 
 682 | def _nmse_with_gaussian_smoothed_target(
 683 |     y_true: np.ndarray,
 684 |     y_pred: np.ndarray,
 685 |     X: np.ndarray | None = None,
 686 |     reference_values: np.ndarray | None = None,
 687 | ) -> float:
 688 |     reference = y_true if reference_values is None else reference_values
 689 |     return _normalized_mse_with_reference_variance(y_true, y_pred, reference)
 690 | 
 691 | 
 692 | def evaluate_symbolic_expression(
 693 |     expression: Any,
 694 |     X_train: np.ndarray,
 695 |     y_train: np.ndarray,
 696 |     X_val: np.ndarray,
 697 |     y_val: np.ndarray,
 698 |     *,
 699 |     constants: Any | None = None,
 700 |     initial_values: Any | None = None,
 701 |     max_nfev: int = 300,
 702 | ) -> dict[str, Any]:
 703 |     """Score a proposed expression by directly predicting normalized response."""
 704 |     import sympy as sp
 705 |     from pysr_harness import equation_session
 706 |     from scipy.optimize import least_squares
 707 | 
 708 |     X_train = np.asarray(X_train, dtype=float)
 709 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 710 |     X_val = np.asarray(X_val, dtype=float)
 711 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 712 |     evaluation_only = X_train.shape[0] == 0 and X_val.shape[0] > 0
 713 |     train_only = X_val.shape[0] == 0 and X_train.shape[0] > 0
 714 |     if evaluation_only:
 715 |         X_fit, y_fit = X_val, y_val
 716 |     else:
 717 |         X_fit, y_fit = X_train, y_train
 718 |     y_reference = np.concatenate([y_train, y_val]) if y_train.size else y_val
 719 |     n_features = X_fit.shape[1] if X_fit.shape[0] else X_val.shape[1]
 720 |     feature_names = [f"x{i}" for i in range(n_features)]
 721 |     template = equation_session._as_sympy_expr(expression, feature_names)
 722 |     equation_session._record_scored_template(template)
 723 | 
 724 |     if constants is None:
 725 |         feature_set = set(equation_session.feature_symbols(n_features))
 726 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 727 |     constants = list(constants)
 728 |     equation_session._validate_expression_template(template, constants)
 729 | 
 730 |     if initial_values is None:
 731 |         base_x0 = np.ones(len(constants), dtype=float)
 732 |     else:
 733 |         base_x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 734 |         if base_x0.size != len(constants):
 735 |             raise ValueError("initial_values must match the number of constants")
 736 | 
 737 |     if not constants:
 738 |         fitted_expr = template
 739 |         fitted_constants = {}
 740 |     else:
 741 |         feature_syms = equation_session.feature_symbols(n_features)
 742 |         X_cols = [X_fit[:, i] for i in range(n_features)]
 743 |         compiled = sp.lambdify(feature_syms + constants, template, modules=["numpy"])
 744 | 
 745 |         def residual(theta: np.ndarray) -> np.ndarray:
 746 |             try:
 747 |                 args = X_cols + [float(v) for v in theta]
 748 |                 prediction = np.asarray(compiled(*args), dtype=float).reshape(-1)
 749 |             except Exception:
 750 |                 return np.full_like(y_fit, 1e12, dtype=float)
 751 |             if prediction.shape != y_fit.shape or not np.all(np.isfinite(prediction)):
 752 |                 return np.full_like(y_fit, 1e12, dtype=float)
 753 |             return prediction - y_fit
 754 | 
 755 |         import warnings
 756 | 
 757 |         initial_candidates: list[np.ndarray] = []
 758 |         for scale in EXPRESSION_MULTISTART_SCALES or (1.0,):
 759 |             candidate = base_x0 * float(scale)
 760 |             if not any(np.array_equal(candidate, existing) for existing in initial_candidates):
 761 |                 initial_candidates.append(candidate)
 762 | 
 763 |         best_fit = None
 764 |         best_loss = float("inf")
 765 |         with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 766 |             warnings.simplefilter("ignore", RuntimeWarning)
 767 |             for initial_candidate in initial_candidates:
 768 |                 fit = least_squares(
 769 |                     residual,
 770 |                     initial_candidate,
 771 |                     loss="soft_l1",
 772 |                     max_nfev=max_nfev,
 773 |                 )
 774 |                 fit_residual = residual(fit.x)
 775 |                 fit_loss = float(np.mean(fit_residual**2))
 776 |                 if fit_loss < best_loss:
 777 |                     best_loss = fit_loss
 778 |                     best_fit = fit
 779 | 
 780 |         if best_fit is None:
 781 |             raise RuntimeError("constant fitting did not produce a result")
 782 | 
 783 |         fitted_constants = {
 784 |             str(symbol): float(value) for symbol, value in zip(constants, best_fit.x)
 785 |         }
 786 |         fitted_expr = template.subs(dict(zip(constants, best_fit.x)))
 787 | 
 788 |     y_pred_fit = equation_session._predict(fitted_expr, X_fit, feature_names)
 789 |     y_pred_train = (
 790 |         np.empty(0, dtype=float)
 791 |         if evaluation_only
 792 |         else equation_session._predict(fitted_expr, X_train, feature_names)
 793 |     )
 794 |     y_pred_val = (
 795 |         np.empty(0, dtype=float)
 796 |         if train_only
 797 |         else equation_session._predict(fitted_expr, X_val, feature_names)
 798 |     )
 799 |     nmse_train = (
 800 |         float("nan")
 801 |         if evaluation_only
 802 |         else _nmse_with_gaussian_smoothed_target(
 803 |             y_train, y_pred_train, X_train, y_reference
 804 |         )
 805 |     )
 806 |     nmse_val = (
 807 |         float("nan")
 808 |         if train_only
 809 |         else _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 810 |     )
 811 |     loss = float(np.mean((y_pred_fit - y_fit) ** 2))
 812 | 
 813 |     result = {
 814 |         "equation_template": str(template),
 815 |         "equation": str(fitted_expr),
 816 |         "constants": fitted_constants,
 817 |         "loss": loss,
 818 |         "complexity": equation_session._complexity(template),
 819 |         "nmse_train": nmse_train,
 820 |         "nmse_val": nmse_val,
 821 |         "n_val_points": int(len(y_val)),
 822 |         "evaluation_only": evaluation_only,
 823 |         "train_only": train_only,
 824 |         "combined_score": (
 825 |             0.0
 826 |             if train_only or not np.isfinite(nmse_val)
 827 |             else combined_score_from_nmse(nmse_val)
 828 |         ),
 829 |     }
 830 |     equation_session._record_scorer_result(result)
 831 |     return result
 832 | 
 833 | 
 834 | def _point_weighted_mean(
 835 |     values: list[float],
 836 |     weights: list[int],
 837 | ) -> float:
 838 |     """Average values with one weight per evaluation point."""
 839 |     total_weight = sum(weights)
 840 |     if total_weight <= 0:
 841 |         return float("inf")
 842 |     weighted = sum(
 843 |         float(value) * float(weight)
 844 |         for value, weight in zip(values, weights)
 845 |         if np.isfinite(float(value))
 846 |     )
 847 |     if not np.isfinite(weighted):
 848 |         return float("inf")
 849 |     return float(weighted / total_weight)
 850 | 
 851 | 
 852 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 853 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 854 |     scoring_results = {
 855 |         name: result
 856 |         for name, result in per_dataset_results.items()
 857 |         if int(result.get("n_val_points", 0)) > 0
 858 |     }
 859 |     raw_nmse_vals = [float(r["nmse_val"]) for r in scoring_results.values()]
 860 |     nmse_vals = list(raw_nmse_vals)
 861 |     train_nmse_vals = [
 862 |         float(r["nmse_train"])
 863 |         for r in per_dataset_results.values()
 864 |         if np.isfinite(float(r.get("nmse_train", float("inf"))))
 865 |     ]
 866 |     complexity_vals = []
 867 |     for r in per_dataset_results.values():
 868 |         try:
 869 |             value = float(r.get("complexity", float("nan")))
 870 |         except (TypeError, ValueError):
 871 |             continue
 872 |         if np.isfinite(value):
 873 |             complexity_vals.append(value)
 874 |     aggregate_complexity = float(max(complexity_vals)) if complexity_vals else 0.0
 875 | 
 876 |     violation_errors = sorted(
 877 |         {
 878 |             str(r.get("error"))
 879 |             for r in per_dataset_results.values()
 880 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 881 |         }
 882 |     )
 883 |     failed_datasets = sorted(
 884 |         name
 885 |         for name, result in scoring_results.items()
 886 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 887 |     )
 888 |     templates = sorted(
 889 |         {
 890 |             str(r.get("equation_template"))
 891 |             for r in per_dataset_results.values()
 892 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 893 |         }
 894 |     )
 895 | 
 896 |     eq_template = ""
 897 |     for r in per_dataset_results.values():
 898 |         if r.get("equation"):
 899 |             eq_template = r["equation"]
 900 |             break
 901 | 
 902 |     hard_cases = [
 903 |         {"dataset": name, "nmse_val": float(result["nmse_val"])}
 904 |         for name, result in scoring_results.items()
 905 |         if np.isfinite(float(result.get("nmse_val", float("inf"))))
 906 |     ]
 907 |     hard_cases.sort(key=lambda item: item["nmse_val"], reverse=True)
 908 |     hard_cases = hard_cases[:5]
 909 |     hard_case_feedback = "; ".join(
 910 |         f"{case['dataset']} nmse={case['nmse_val']:.4g}" for case in hard_cases
 911 |     )
 912 | 
 913 |     violation_error = None
 914 |     if violation_errors:
 915 |         violation_error = violation_errors[0]
 916 |     elif failed_datasets:
 917 |         examples = ", ".join(failed_datasets[:3])
 918 |         violation_error = (
 919 |             "Single-equation violation: candidate failed on "
 920 |             f"{len(failed_datasets)}/{len(scoring_results)} validation datasets. "
 921 |             "Failed datasets are not dropped from the aggregate reward. "
 922 |             f"Examples: {examples}"
 923 |         )
 924 |     elif len(templates) > 1:
 925 |         examples = "; ".join(templates[:3])
 926 |         violation_error = (
 927 |             "Single-equation violation: evaluate_symbolic_candidate() produced "
 928 |             f"{len(templates)} distinct equation templates across datasets. "
 929 |             "The base equation must be identical for all datasets; only fitted "
 930 |             f"constants may vary. Example templates: {examples}"
 931 |         )
 932 | 
 933 |     if violation_error:
 934 |         agg_nmse = float("inf")
 935 |         mean_nmse = float("inf")
 936 |         agg_train_nmse = float("inf")
 937 |         agg_combined = 0.0
 938 |         n_successful = 0
 939 |     else:
 940 |         val_point_weights = [
 941 |             int(r.get("n_val_points", 0)) for r in scoring_results.values()
 942 |         ]
 943 |         mean_nmse = _point_weighted_mean(nmse_vals, val_point_weights)
 944 |         raw_mean_nmse = _point_weighted_mean(raw_nmse_vals, val_point_weights)
 945 |         eval_only_results = {
 946 |             name: result
 947 |             for name, result in scoring_results.items()
 948 |             if result.get("evaluation_only")
 949 |         }
 950 |         eval_only_nmse_vals = [
 951 |             float(result["nmse_val"])
 952 |             for result in eval_only_results.values()
 953 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
 954 |         ]
 955 |         eval_only_weights = [
 956 |             int(result.get("n_val_points", 0))
 957 |             for result in eval_only_results.values()
 958 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
 959 |         ]
 960 |         mean_nmse_eval_only = (
 961 |             _point_weighted_mean(eval_only_nmse_vals, eval_only_weights)
 962 |             if eval_only_nmse_vals
 963 |             else float("nan")
 964 |         )
 965 |         agg_nmse = mean_nmse
 966 |         agg_train_nmse = float(np.mean(train_nmse_vals)) if train_nmse_vals else float("inf")
 967 |         raw_combined = (
 968 |             float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
 969 |         )
 970 |         parsimony_factor = _parsimony_penalty_factor(aggregate_complexity)
 971 |         agg_combined = raw_combined * parsimony_factor
 972 |         n_successful = sum(1 for value in nmse_vals if np.isfinite(value))
 973 | 
 974 |     aggregated = {
 975 |         "equation": eq_template,
 976 |         "nmse_train": agg_train_nmse,
 977 |         "nmse_val": agg_nmse,
 978 |         "mean_nmse_val": mean_nmse,
 979 |         "mean_raw_nmse_val": raw_mean_nmse if not violation_error else float("inf"),
 980 |         "combined_score": agg_combined,
 981 |         "fit_score": raw_combined if not violation_error else 0.0,
 982 |         "complexity": aggregate_complexity,
 983 |         "parsimony_weight": PARSIMONY_WEIGHT,
 984 |         "parsimony_penalty_factor": (
 985 |             _parsimony_penalty_factor(aggregate_complexity) if not violation_error else 1.0
 986 |         ),
 987 |         "n_datasets": len(scoring_results),
 988 |         "n_total_datasets": len(per_dataset_results),
 989 |         "n_train_only_datasets": len(per_dataset_results) - len(scoring_results),
 990 |         "n_successful": n_successful,
 991 |         "n_evaluation_only_datasets": len(
 992 |             [name for name, result in per_dataset_results.items() if result.get("evaluation_only")]
 993 |         ),
 994 |         "mean_nmse_eval_only": (
 995 |             mean_nmse_eval_only if not violation_error else float("inf")
 996 |         ),
 997 |         "eval_workers": NUM_WORKERS,
 998 |         "hard_cases": hard_cases,
 999 |         "hard_case_feedback": hard_case_feedback,
1000 |         "per_dataset": per_dataset_results,
1001 |     }
1002 |     if violation_error:
1003 |         aggregated["error"] = violation_error
1004 |     return aggregated
1005 | 
1006 | 
1007 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
1008 |     """Evaluate a candidate program across ALL datasets in a subprocess.
1009 | 
1010 |     The subprocess loads every dataset, calls the candidate's
1011 |     evaluate_symbolic_candidate() once per dataset (fitting independent
1012 |     constants each time) using parallel threads, and returns aggregated
1013 |     metrics.
1014 |     """
1015 |     validate_candidate_source(program_path)
1016 |     harness_root = str(BENCHMARK_ROOT)
1017 |     evaluator_path = str(Path(__file__).resolve())
1018 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
1019 |         script = f"""
1020 | import importlib.util
1021 | import os
1022 | import pickle
1023 | import sys
1024 | import traceback
1025 | from concurrent.futures import ThreadPoolExecutor, as_completed
1026 | 
1027 | os.environ.setdefault("OMP_NUM_THREADS", "1")
1028 | os.environ.setdefault("MKL_NUM_THREADS", "1")
1029 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
1030 | 
1031 | import numpy as np
1032 | 
1033 | sys.path.insert(0, {harness_root!r})
1034 | 
1035 | program_path = {program_path!r}
1036 | evaluator_path = {evaluator_path!r}
1037 | results_path = {temp_file.name + ".results"!r}
1038 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
1039 | 
1040 | def _write_payload_and_exit(payload):
1041 |     with open(results_path, "wb") as f:
1042 |         pickle.dump(payload, f)
1043 |     sys.stdout.flush()
1044 |     sys.stderr.flush()
1045 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
1046 |     # interpreter shutdown. The parent only needs the pickle payload.
1047 |     os._exit(0)
1048 | 
1049 | try:
1050 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
1051 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
1052 |     evaluator_spec.loader.exec_module(evaluator)
1053 |     evaluator.validate_candidate_source(program_path)
1054 | 
1055 |     import pysr_harness.equation_session as equation_session
1056 |     equation_session.evaluate_expression = evaluator.evaluate_symbolic_expression
1057 |     equation_session.nmse = evaluator._nmse_with_gaussian_smoothed_target
1058 |     spec = importlib.util.spec_from_file_location("program", program_path)
1059 |     program = importlib.util.module_from_spec(spec)
1060 |     spec.loader.exec_module(program)
1061 |     from pysr_harness.equation_session import (
1062 |         single_equation_evaluation,
1063 |         validate_single_equation_result,
1064 |     )
1065 | 
1066 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1067 |         program, "run_discovery", None
1068 |     )
1069 |     if fn is None:
1070 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
1071 | 
1072 |     datasets = evaluator.load_all_datasets()
1073 | 
1074 |     def _eval_one(args):
1075 |         ds_name, X_train, X_val, y_train, y_val = args
1076 |         try:
1077 |             with single_equation_evaluation():
1078 |                 result = fn(X_train, y_train, X_val, y_val)
1079 |                 validate_single_equation_result(result)
1080 |             ds_nmse = float(result.get("nmse_val", float("inf")))
1081 |             ds_train_nmse = float(result.get("nmse_train", float("inf")))
1082 |             ds_combined = float(result.get("combined_score", 0.0))
1083 |             return ds_name, {{
1084 |                 "nmse_train": ds_train_nmse,
1085 |                 "nmse_val": ds_nmse,
1086 |                 "n_val_points": int(result.get("n_val_points", 0)),
1087 |                 "evaluation_only": bool(result.get("evaluation_only", False)),
1088 |                 "combined_score": ds_combined,
1089 |                 "complexity": float(result.get("complexity", 0.0)),
1090 |                 "equation": str(result.get("equation", "")),
1091 |                 "equation_template": str(result.get("equation_template", "")),
1092 |                 "constants": result.get("constants", {{}}),
1093 |             }}
1094 |         except Exception as exc:
1095 |             return ds_name, {{
1096 |                 "nmse_train": float("inf"),
1097 |                 "nmse_val": float("inf"),
1098 |                 "n_val_points": int(len(y_val)),
1099 |                 "evaluation_only": bool(X_train.shape[0] == 0 and X_val.shape[0] > 0),
1100 |                 "combined_score": 0.0,
1101 |                 "error": str(exc),
1102 |             }}
1103 | 
1104 |     per_dataset_results = {{}}
1105 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1106 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
1107 |         for future in as_completed(futures):
1108 |             ds_name, ds_result = future.result()
1109 |             per_dataset_results[ds_name] = ds_result
1110 | 
1111 |     aggregated = evaluator._aggregate_per_dataset_results(per_dataset_results)
1112 | 
1113 |     _write_payload_and_exit({{"result": aggregated}})
1114 | except Exception as exc:
1115 |     traceback.print_exc()
1116 |     _write_payload_and_exit({{"error": str(exc)}})
1117 | """
1118 |         temp_file.write(script.encode())
1119 |         temp_path = temp_file.name
1120 | 
1121 |     results_path = f"{temp_path}.results"
1122 |     try:
1123 |         process = subprocess.Popen(
1124 |             [sys.executable, temp_path],
1125 |             stdout=subprocess.PIPE,
1126 |             stderr=subprocess.PIPE,
1127 |         )
1128 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
1129 |         if stdout:
1130 |             print(stdout.decode())
1131 |         if stderr:
1132 |             print(stderr.decode())
1133 |         if process.returncode != 0:
1134 |             raise RuntimeError(f"Subprocess exited with code {process.returncode}")
1135 |         if not os.path.exists(results_path):
1136 |             raise RuntimeError("Results file not found")
1137 |         with open(results_path, "rb") as f:
1138 |             payload = pickle.load(f)
1139 |         if "error" in payload:
