import sympy as sp
import sys
sys.path.insert(0, '.')
from pysr_harness.equation_session import feature_symbols, constant_symbols

# Count complexity of Program 3's expression
x = feature_symbols(3)
c = constant_symbols(7)
time, monomer, seed = x[0], x[1], x[2]

# Program 3 (best, score=0.9345)
rate = c[0] * monomer ** c[1]
lag = c[2] * monomer ** c[3] / (1 + c[4] * seed)
expr3 = c[5] / (1 + sp.exp(-rate * time + lag)) ** c[6]
print('Program 3:', expr3)
print('Complexity (nodes):', sp.count_ops(expr3, visual=False))

# Current parent (score=0.9319)
rate_p = c[0] * monomer ** c[1]
half_time_p = c[2] * monomer ** c[4] / (1 + c[5] * seed)
expr_parent = c[3] / (1 + sp.exp(-rate_p * (time - half_time_p))) ** c[6]
print('Parent:', expr_parent)
print('Complexity parent:', sp.count_ops(expr_parent, visual=False))
"
