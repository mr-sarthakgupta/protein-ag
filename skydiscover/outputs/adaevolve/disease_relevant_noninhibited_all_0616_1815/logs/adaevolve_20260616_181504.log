half_time = c2 * x1**c4 / (1 + c5*x2)
expr_current = c3 / (1 + sp.exp(-rate * (x0 - half_time)))
print(f'Current: {count_nodes(expr_current)} nodes')
print(f'  Expr: {expr_current}')

# Simplified: drop x2 dependency (seed effect) - just logistic with monomer-dependent rate/halfTime
# rate = c0*x1^c1, half_time = c2*x1^c3
