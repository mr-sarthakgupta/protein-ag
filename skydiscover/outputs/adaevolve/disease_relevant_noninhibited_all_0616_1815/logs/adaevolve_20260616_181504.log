            path = os.path.join(root, f)
            df = pd.read_csv(path, sep='\t')
            xcols = [c for c in df.columns if c.endswith(' X')]
            has_seed = any('M0:0' not in c for c in xcols)
            if has_seed:
                seeded.append(path.replace(base,''))
