  65 |         "lysozyme/Hasecke2018_7uM_sec",
  66 |         "serum amyloid/Srinivasan2013_Saa1.1_sec",
  67 |     }
  68 | )
  69 | GAUSSIAN_SMOOTH_SIGMA = float(os.environ.get("SKYDISCOVER_GAUSSIAN_SMOOTH_SIGMA", "1.0"))
  70 | SINGLE_EQUATION_ERROR_PREFIX = "Single-equation violation"
  71 | _ARRAY_CURVE_IDS: dict[int, np.ndarray] = {}
  72 | _ALLOWED_IMPORTS = {"sympy", "numpy"}
  73 | _ALLOWED_FROM_IMPORTS = {
  74 |     "__future__",
  75 |     "typing",
  76 |     "numpy.typing",
  77 |     "pysr_harness.equation_session",
  78 | }
  79 | _ALLOWED_HARNESS_IMPORTS = {
  80 |     "constant_symbols",
  81 |     "evaluate_expression",
  82 |     "feature_symbols",
  83 | }
  84 | _ALLOWED_EVALUATE_CALLS = {
  85 |     "constant_symbols",
  86 |     "evaluate_expression",
  87 |     "feature_symbols",
  88 |     "sp.exp",
  89 |     "sp.log",
  90 |     "sp.log1p",
  91 |     "sp.sqrt",
  92 |     "sp.sin",
  93 |     "sp.cos",
  94 |     "sp.tan",
  95 |     "sp.tanh",
  96 |     "sp.sinh",
  97 |     "sp.cosh",
  98 | }
  99 | _PROTECTED_NAMES = {
 100 |     "constant_symbols",
 101 |     "evaluate_expression",
 102 |     "feature_symbols",
 103 |     "single_equation_evaluation",
 104 |     "validate_single_equation_result",
 105 | }
 106 | _DISALLOWED_CONTROL_NODES = (
 107 |     ast.AsyncFunctionDef,
 108 |     ast.ClassDef,
 109 |     ast.For,
 110 |     ast.While,
 111 |     ast.If,
 112 |     ast.IfExp,
 113 |     ast.Try,
 114 |     ast.With,
 115 |     ast.AsyncWith,
 116 |     ast.Match,
 117 |     ast.Lambda,
 118 |     ast.ListComp,
 119 |     ast.SetComp,
 120 |     ast.DictComp,
 121 |     ast.GeneratorExp,
 122 | )
 123 | 
 124 | 
 125 | def _is_module_docstring(node: ast.AST) -> bool:
 126 |     return (
 127 |         isinstance(node, ast.Expr)
 128 |         and isinstance(node.value, ast.Constant)
 129 |         and isinstance(node.value.value, str)
 130 |     )
 131 | 
 132 | 
 133 | def _is_main_guard(node: ast.AST) -> bool:
 134 |     if not isinstance(node, ast.If):
 135 |         return False
 136 |     if node.orelse:
 137 |         return False
 138 |     test = node.test
 139 |     if not isinstance(test, ast.Compare) or len(test.ops) != 1 or len(test.comparators) != 1:
 140 |         return False
 141 |     if not isinstance(test.ops[0], ast.Eq):
 142 |         return False
 143 |     left = test.left
 144 |     right = test.comparators[0]
 145 |     return (
 146 |         isinstance(left, ast.Name)
 147 |         and left.id == "__name__"
 148 |         and isinstance(right, ast.Constant)
 149 |         and right.value == "__main__"
 150 |     )
 151 | 
 152 | 
 153 | def _has_postponed_annotations(tree: ast.Module) -> bool:
 154 |     for node in tree.body:
 155 |         if isinstance(node, ast.ImportFrom) and node.module == "__future__":
 156 |             if any(alias.name == "annotations" for alias in node.names):
 157 |                 return True
 158 |     return False
 159 | 
 160 | 
 161 | def _function_annotations(node: ast.FunctionDef) -> list[ast.AST]:
 162 |     annotations: list[ast.AST] = []
 163 |     args = node.args
 164 |     for arg in [*args.posonlyargs, *args.args, *args.kwonlyargs]:
 165 |         if arg.annotation is not None:
 166 |             annotations.append(arg.annotation)
 167 |     if args.vararg is not None and args.vararg.annotation is not None:
 168 |         annotations.append(args.vararg.annotation)
 169 |     if args.kwarg is not None and args.kwarg.annotation is not None:
 170 |         annotations.append(args.kwarg.annotation)
 171 |     if node.returns is not None:
 172 |         annotations.append(node.returns)
 173 |     return annotations
 174 | 
 175 | 
 176 | def _validate_top_level_function(node: ast.FunctionDef, *, postponed_annotations: bool) -> None:
 177 |     if node.name in _PROTECTED_NAMES:
 178 |         raise ValueError(
 179 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function '{node.name}' "
 180 |             "shadows a protected scorer or harness name."
 181 |         )
 182 |     if node.decorator_list:
 183 |         raise ValueError(
 184 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function decorators are not "
 185 |             "allowed because decorators execute during candidate import."
 186 |         )
 187 |     if node.args.defaults or node.args.kw_defaults:
 188 |         raise ValueError(
 189 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function default arguments "
 190 |             "are not allowed because defaults execute during candidate import."
 191 |         )
 192 |     if _function_annotations(node) and not postponed_annotations:
 193 |         raise ValueError(
 194 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function annotations require "
 195 |             "'from __future__ import annotations' because annotations otherwise "
 196 |             "execute during candidate import."
 197 |         )
 198 | 
 199 | 
 200 | def _call_name(func: ast.AST) -> str:
 201 |     if isinstance(func, ast.Name):
 202 |         return func.id
 203 |     if isinstance(func, ast.Attribute) and isinstance(func.value, ast.Name):
 204 |         return f"{func.value.id}.{func.attr}"
 205 |     return ""
 206 | 
 207 | 
 208 | def _assigned_names(target: ast.AST) -> set[str]:
 209 |     if isinstance(target, ast.Name):
 210 |         return {target.id}
 211 |     if isinstance(target, (ast.Tuple, ast.List)):
 212 |         names: set[str] = set()
 213 |         for elt in target.elts:
 214 |             names.update(_assigned_names(elt))
 215 |         return names
 216 |     return set()
 217 | 
 218 | 
 219 | def _validate_plain_import(alias: ast.alias) -> None:
 220 |     if alias.name not in _ALLOWED_IMPORTS:
 221 |         raise ValueError(
 222 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: import '{alias.name}' is not allowed. "
 223 |             "Candidates may only import sympy/numpy and the equation harness."
 224 |         )
 225 |     if alias.name == "sympy" and alias.asname != "sp":
 226 |         raise ValueError(
 227 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: sympy must be imported canonically "
 228 |             "as 'import sympy as sp'."
 229 |         )
 230 |     if alias.name == "numpy" and alias.asname not in {None, "np"}:
 231 |         raise ValueError(
 232 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: numpy may only be imported as "
 233 |             "'import numpy' or 'import numpy as np'."
 234 |         )
 235 | 
 236 | 
 237 | def _validate_evaluate_expression_data_args(call: ast.Call) -> set[int]:
 238 |     expected = ["X_train", "y_train", "X_val", "y_val"]
 239 |     if len(call.args) < 5:
 240 |         raise ValueError(
 241 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must be called "
 242 |             "as evaluate_expression(expression, X_train, y_train, X_val, y_val, ...)."
 243 |         )
 244 |     actual_data_args = call.args[1:5]
 245 |     if not all(
 246 |         isinstance(arg, ast.Name) and arg.id == expected_name
 247 |         for arg, expected_name in zip(actual_data_args, expected)
 248 |     ):
 249 |         raise ValueError(
 250 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must use the "
 251 |             "canonical data arguments exactly as X_train, y_train, X_val, y_val. "
 252 |             "Do not fit constants on validation labels or reorder the split."
 253 |         )
 254 |     return {id(arg) for arg in call.args[1:5]}
 255 | 
 256 | 
 257 | def _x_train_shape_feature_arg_id(node: ast.AST) -> int | None:
 258 |     if not (
 259 |         isinstance(node, ast.Subscript)
 260 |         and isinstance(node.value, ast.Attribute)
 261 |         and node.value.attr == "shape"
 262 |         and isinstance(node.value.value, ast.Name)
 263 |         and node.value.value.id == "X_train"
 264 |     ):
 265 |         return None
 266 |     slice_node = node.slice
 267 |     if isinstance(slice_node, ast.Constant) and slice_node.value == 1:
 268 |         return id(node.value.value)
 269 |     return None
 270 | 
 271 | 
 272 | def _allowed_feature_symbols_data_ids(fn: ast.FunctionDef) -> set[int]:
 273 |     allowed: set[int] = set()
 274 |     for node in ast.walk(fn):
 275 |         if not (
 276 |             isinstance(node, ast.Call)
 277 |             and isinstance(node.func, ast.Name)
 278 |             and node.func.id == "feature_symbols"
 279 |             and len(node.args) == 1
 280 |         ):
 281 |             continue
 282 |         x_train_id = _x_train_shape_feature_arg_id(node.args[0])
 283 |         if x_train_id is not None:
 284 |             allowed.add(x_train_id)
 285 |     return allowed
 286 | 
 287 | 
 288 | def _validate_no_dataset_data_leak(fn: ast.FunctionDef, allowed_node_ids: set[int]) -> None:
 289 |     for node in ast.walk(fn):
 290 |         if (
 291 |             isinstance(node, ast.Name)
 292 |             and node.id in {"X_train", "y_train", "X_val", "y_val"}
 293 |             and id(node) not in allowed_node_ids
 294 |         ):
 295 |             raise ValueError(
 296 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: dataset array '{node.id}' may only "
 297 |                 "appear in feature_symbols(X_train.shape[1]) or as the canonical "
 298 |                 "evaluate_expression(expression, X_train, y_train, X_val, y_val, ...) "
 299 |                 "arguments. Do not use dataset values to choose expressions, mutate "
 300 |                 "splits, or tune constants/initial values."
 301 |             )
 302 | 
 303 | 
 304 | def validate_candidate_source(program_path: str) -> None:
 305 |     """Reject reward-hacking program structure before importing candidate code."""
 306 |     source = Path(program_path).read_text()
 307 |     tree = ast.parse(source, filename=program_path)
 308 |     postponed_annotations = _has_postponed_annotations(tree)
 309 | 
 310 |     for node in tree.body:
 311 |         if _is_module_docstring(node) or _is_main_guard(node):
 312 |             continue
 313 |         if isinstance(node, ast.FunctionDef):
 314 |             _validate_top_level_function(node, postponed_annotations=postponed_annotations)
 315 |             continue
 316 |         if isinstance(node, ast.Import):
 317 |             for alias in node.names:
 318 |                 _validate_plain_import(alias)
 319 |         elif isinstance(node, ast.ImportFrom):
 320 |             module = node.module or ""
 321 |             if module not in _ALLOWED_FROM_IMPORTS:
 322 |                 raise ValueError(
 323 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: from-import '{module}' is not allowed."
 324 |                 )
 325 |             if module == "pysr_harness.equation_session":
 326 |                 aliased = [alias.name for alias in node.names if alias.asname]
 327 |                 if aliased:
 328 |                     raise ValueError(
 329 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: harness imports may not "
 330 |                         f"use aliases: {sorted(aliased)}."
 331 |                     )
 332 |                 imported = {alias.name for alias in node.names}
 333 |                 extra = imported - _ALLOWED_HARNESS_IMPORTS
 334 |                 if extra:
 335 |                     raise ValueError(
 336 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: unsupported harness imports "
 337 |                         f"{sorted(extra)}. Use only feature_symbols, constant_symbols, "
 338 |                         "and evaluate_expression."
 339 |                     )
 340 |         else:
 341 |             raise ValueError(
 342 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level executable code is not "
 343 |                 "allowed in candidate programs. Build and score the equation only "
 344 |                 "inside evaluate_symbolic_candidate()."
 345 |             )
 346 | 
 347 |     eval_fns = [
 348 |         node
 349 |         for node in tree.body
 350 |         if isinstance(node, ast.FunctionDef) and node.name == "evaluate_symbolic_candidate"
 351 |     ]
 352 |     if len(eval_fns) != 1:
 353 |         raise ValueError(
 354 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: program must define exactly one "
 355 |             "evaluate_symbolic_candidate() function."
 356 |         )
 357 |     fn = eval_fns[0]
 358 | 
 359 |     returns = [node for node in ast.walk(fn) if isinstance(node, ast.Return)]
 360 |     if len(returns) != 1:
 361 |         raise ValueError(
 362 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must have "
 363 |             "exactly one return statement."
 364 |         )
 365 |     return_value = returns[0].value
 366 |     if not (
 367 |         isinstance(return_value, ast.Call)
 368 |         and isinstance(return_value.func, ast.Name)
 369 |         and return_value.func.id == "evaluate_expression"
 370 |     ):
 371 |         raise ValueError(
 372 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must directly "
 373 |             "return evaluate_expression(...), with no wrapper or post-processing."
 374 |         )
 375 |     allowed_data_arg_ids = _validate_evaluate_expression_data_args(return_value)
 376 |     allowed_data_arg_ids.update(_allowed_feature_symbols_data_ids(fn))
 377 |     _validate_no_dataset_data_leak(fn, allowed_data_arg_ids)
 378 | 
 379 |     evaluate_calls = 0
 380 |     for node in ast.walk(fn):
 381 |         if isinstance(node, _DISALLOWED_CONTROL_NODES):
 382 |             raise ValueError(
 383 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: control flow, nested definitions, "
 384 |                 "comprehensions, and conditionals are not allowed inside "
 385 |                 "evaluate_symbolic_candidate(). Build one straight-line equation."
 386 |             )
 387 |         if isinstance(node, (ast.Import, ast.ImportFrom)):
 388 |             raise ValueError(
 389 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: imports are not allowed inside "
 390 |                 "evaluate_symbolic_candidate()."
 391 |             )
 392 |         if isinstance(node, (ast.Assign, ast.AnnAssign, ast.AugAssign)):
 393 |             targets = node.targets if isinstance(node, ast.Assign) else [node.target]
 394 |             assigned = set().union(*(_assigned_names(target) for target in targets))
 395 |             protected = assigned & _PROTECTED_NAMES
 396 |             if protected:
 397 |                 raise ValueError(
 398 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: cannot reassign protected scorer "
 399 |                     f"or harness names {sorted(protected)}."
 400 |                 )
 401 |         if isinstance(node, ast.Call):
 402 |             name = _call_name(node.func)
 403 |             if name == "evaluate_expression":
 404 |                 evaluate_calls += 1
 405 |             if name not in _ALLOWED_EVALUATE_CALLS:
 406 |                 raise ValueError(
 407 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: call '{name or type(node.func).__name__}' "
 408 |                     "is not allowed inside evaluate_symbolic_candidate(). Allowed calls "
 409 |                     "are the symbol helpers, evaluate_expression, and basic sp.* math."
 410 |                 )
 411 | 
 412 |     if evaluate_calls != 1:
 413 |         raise ValueError(
 414 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must call "
 415 |             f"evaluate_expression() exactly once; found {evaluate_calls} calls."
 416 |         )
 417 | 
 418 | 
 419 | def _parse_metadata_number(header: str, key: str) -> float | None:
 420 |     """Extract the leading numeric value for a cleaned header field."""
 421 |     match = re.search(
 422 |         rf"(?:^|[\s_]){re.escape(key)}:\s*([-+]?\d+(?:\.\d+)?(?:[eE][-+]?\d+)?)",
 423 |         header,
 424 |     )
 425 |     if match is None:
 426 |         return None
 427 |     return float(match.group(1))
 428 | 
 429 | 
 430 | def _is_x_column(header: str) -> bool:
 431 |     return bool(re.search(r"\s*X\s*$", header.strip()))
 432 | 
 433 | 
 434 | def _is_y_column(header: str) -> bool:
 435 |     return bool(re.search(r"\s*Y\s*$", header.strip()))
 436 | 
 437 | 
 438 | def _remember_curve_ids(X: np.ndarray, curve_ids: np.ndarray) -> np.ndarray:
 439 |     _ARRAY_CURVE_IDS[id(X)] = np.asarray(curve_ids, dtype=int)
 440 |     return X
 441 | 
 442 | 
 443 | def _minmax_normalize(values: np.ndarray) -> np.ndarray:
 444 |     """Normalize one dataset column to 0..1, preserving constants as zeros."""
 445 |     values = np.asarray(values, dtype=float)
 446 |     v_min = float(np.min(values))
 447 |     v_max = float(np.max(values))
 448 |     scale = v_max - v_min
 449 |     if scale <= 0.0:
 450 |         return np.zeros_like(values, dtype=float)
 451 |     return (values - v_min) / scale
 452 | 
 453 | 
 454 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 455 |     """Load cleaned data.tsv and return X=[normalized time, m0, M0], y.
 456 | 
 457 |     Cleaned files store one trajectory per adjacent X/Y column pair. Each
 458 |     column header contains m0, M0, and L0 metadata; only m0 and M0 are exposed
 459 |     as model features. Units are intentionally ignored per the cleaned-data
 460 |     note: the leading numeric value is used as provided.
 461 |     """
 462 |     with data_file.open(newline="") as f:
 463 |         reader = csv.reader(f, delimiter="\t")
 464 |         header = next(reader)
 465 |         rows = [row for row in reader if row]
 466 | 
 467 |     features: list[list[float]] = []
 468 |     targets: list[float] = []
 469 |     curve_ids: list[int] = []
 470 |     curve_id = 0
 471 |     for col_idx in range(len(header) - 1):
 472 |         x_header = header[col_idx]
 473 |         y_header = header[col_idx + 1]
 474 |         if not (_is_x_column(x_header) and _is_y_column(y_header)):
 475 |             continue
 476 |         m0 = _parse_metadata_number(x_header, "m0")
 477 |         seed_m0 = _parse_metadata_number(x_header, "M0")
 478 |         if m0 is None or seed_m0 is None:
 479 |             continue
 480 |         for row in rows:
 481 |             if col_idx + 1 >= len(row):
 482 |                 continue
 483 |             time_value = row[col_idx].strip()
 484 |             response_value = row[col_idx + 1].strip()
 485 |             if (
 486 |                 not time_value
 487 |                 or not response_value
 488 |                 or time_value.lower() == "nan"
 489 |                 or response_value.lower() == "nan"
 490 |             ):
 491 |                 continue
 492 |             features.append([float(time_value), m0, seed_m0])
 493 |             targets.append(float(response_value))
 494 |             curve_ids.append(curve_id)
 495 |         curve_id += 1
 496 | 
 497 |     if not features:
 498 |         raise ValueError(f"No regression samples loaded from {data_file}")
 499 | 
 500 |     X = np.asarray(features, dtype=float)
 501 |     y = np.asarray(targets, dtype=float)
 502 |     time_norm = _minmax_normalize(X[:, 0])
 503 |     monomer_raw = X[:, 1]
 504 |     seed_raw = X[:, 2]
 505 |     y_norm = _minmax_normalize(y)
 506 | 
 507 |     X_out = np.column_stack([time_norm, monomer_raw, seed_raw])
 508 |     return _remember_curve_ids(X_out, np.asarray(curve_ids, dtype=int)), y_norm
 509 | 
 510 | 
 511 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 512 |     """Recursively find all cleaned data.tsv files and return dataset entries."""
 513 |     datasets: list[tuple[str, Path]] = []
 514 |     for dirpath, _dirnames, filenames in os.walk(root):
 515 |         if "data.tsv" in filenames:
 516 |             fit_path = Path(dirpath) / "data.tsv"
 517 |             rel = fit_path.parent.relative_to(root)
 518 |             name = str(rel).replace(os.sep, "/")
 519 |             datasets.append((name, fit_path))
 520 |     datasets.sort(key=lambda x: x[0])
 521 |     return datasets
 522 | 
 523 | 
 524 | def _curve_indices(X: np.ndarray) -> list[np.ndarray]:
 525 |     """Return cleaned-trajectory row indices."""
 526 |     if X.shape[0] == 0:
 527 |         return []
 528 |     curve_ids = _ARRAY_CURVE_IDS.get(id(X))
 529 |     if curve_ids is not None and curve_ids.shape[0] == X.shape[0]:
 530 |         return [np.flatnonzero(curve_ids == curve_id) for curve_id in dict.fromkeys(curve_ids)]
 531 |     return [np.arange(X.shape[0], dtype=int)]
 532 | 
 533 | 
 534 | def _trajectory_preserving_split(
 535 |     X: np.ndarray,
 536 |     y: np.ndarray,
 537 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 538 |     """Split whole cleaned X/Y curves into fit and NMSE-evaluation sets."""
 539 |     curves = _curve_indices(X)
 540 |     rng = np.random.default_rng(RANDOM_STATE)
 541 | 
 542 |     if len(curves) < 3:
 543 |         empty_X = np.empty((0, X.shape[1]), dtype=float)
 544 |         empty_y = np.empty(0, dtype=float)
 545 |         return X, empty_X, y, empty_y
 546 | 
 547 |     shuffled = rng.permutation(len(curves))
 548 |     n_val_curves = min(
 549 |         max(1, int(round(len(curves) * TEST_SIZE))), len(curves) - 1
 550 |     )
 551 |     val_curve_ids = set(int(i) for i in shuffled[:n_val_curves])
 552 | 
 553 |     fit_indices: list[int] = []
 554 |     val_indices: list[int] = []
 555 |     for curve_id, curve_idx in enumerate(curves):
 556 |         if curve_id in val_curve_ids:
 557 |             val_indices.extend(curve_idx.tolist())
 558 |         else:
 559 |             fit_indices.extend(curve_idx.tolist())
 560 | 
 561 |     fit_idx = np.sort(np.asarray(fit_indices, dtype=int))
 562 |     val_idx = np.sort(np.asarray(val_indices, dtype=int))
 563 |     curve_ids = _ARRAY_CURVE_IDS.get(id(X), np.zeros(X.shape[0], dtype=int))
 564 |     X_fit = X[fit_idx]
 565 |     X_val = X[val_idx]
 566 |     _remember_curve_ids(X_fit, curve_ids[fit_idx])
 567 |     _remember_curve_ids(X_val, curve_ids[val_idx])
 568 |     return X_fit, X_val, y[fit_idx], y[val_idx]
 569 | 
 570 | 
 571 | def _evaluation_only_split(
 572 |     X: np.ndarray,
 573 |     y: np.ndarray,
 574 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 575 |     """Hold out an entire dataset for validation-only cross-protein evaluation."""
 576 |     empty_X = np.empty((0, X.shape[1]), dtype=float)
 577 |     empty_y = np.empty(0, dtype=float)
 578 |     _remember_curve_ids(empty_X, np.empty(0, dtype=int))
 579 |     _remember_curve_ids(X, _ARRAY_CURVE_IDS.get(id(X), np.zeros(X.shape[0], dtype=int)))
 580 |     return empty_X, X, empty_y, y
 581 | 
 582 | 
 583 | def _dataset_name_from_path(data_file: Path, root: Path = DATA_ROOT) -> str:
 584 |     return str(data_file.parent.relative_to(root)).replace(os.sep, "/")
 585 | 
 586 | 
 587 | def load_dataset(
 588 |     data_file: Path,
 589 |     *,
 590 |     dataset_name: str | None = None,
 591 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 592 |     """Load a single data.tsv and return deterministic trajectory-preserving split."""
 593 |     X, y = _load_fit_table(data_file)
 594 |     name = dataset_name or _dataset_name_from_path(data_file)
 595 |     if name in EVALUATION_ONLY_DATASETS:
 596 |         return _evaluation_only_split(X, y)
 597 |     return _trajectory_preserving_split(X, y)
 598 | 
 599 | 
 600 | def load_all_datasets(
 601 |     root: Path = DATA_ROOT,
 602 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 603 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 604 |     entries = discover_datasets(root)
 605 |     results = []
 606 |     for name, path in entries:
 607 |         try:
 608 |             X_train, X_val, y_train, y_val = load_dataset(path, dataset_name=name)
 609 |             results.append((name, X_train, X_val, y_train, y_val))
 610 |         except Exception as exc:
 611 |             print(f"Warning: skipping dataset {name}: {exc}")
 612 |     return results
 613 | 
 614 | 
 615 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 616 | PARSIMONY_WEIGHT = float(os.environ.get("SKYDISCOVER_PARSIMONY_WEIGHT", "0.20"))
 617 | PARSIMONY_COMPLEXITY_SCALE = float(
 618 |     os.environ.get("SKYDISCOVER_PARSIMONY_COMPLEXITY_SCALE", "160")
 619 | )
 620 | 
 621 | 
 622 | def _parsimony_penalty_factor(complexity: float) -> float:
 623 |     """Bounded penalty factor for expression complexity."""
 624 |     if not np.isfinite(complexity) or PARSIMONY_COMPLEXITY_SCALE <= 0:
 625 |         return 1.0
 626 |     normalized = min(max(float(complexity), 0.0) / PARSIMONY_COMPLEXITY_SCALE, 1.0)
 627 |     return max(0.0, 1.0 - PARSIMONY_WEIGHT * normalized)
 628 | 
 629 | 
 630 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 631 |     values = np.asarray(values, dtype=float).ravel()
 632 |     if values.size < 3 or sigma <= 0.0:
 633 |         return values
 634 |     radius = max(1, int(round(3.0 * sigma)))
 635 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 636 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 637 |     kernel /= np.sum(kernel)
 638 |     padded = np.pad(values, (radius, radius), mode="edge")
 639 |     return np.convolve(padded, kernel, mode="valid")
 640 | 
 641 | 
 642 | def _curve_smoothed_target(X: np.ndarray, y_true: np.ndarray) -> np.ndarray:
 643 |     """Smooth targets independently for each parameter curve in time order."""
 644 |     X = np.asarray(X, dtype=float)
 645 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 646 |     if X.shape[0] != y_true.shape[0] or X.shape[1] < 2:
 647 |         return _gaussian_smooth_1d(y_true)
 648 | 
 649 |     smoothed = np.empty_like(y_true, dtype=float)
 650 |     for parameter in np.unique(X[:, 1]):
 651 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 652 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 653 |         smoothed_curve = _gaussian_smooth_1d(y_true[ordered_idx])
 654 |         smoothed[ordered_idx] = smoothed_curve
 655 |     return smoothed
 656 | 
 657 | 
 658 | def _normalized_mse_with_reference_variance(
 659 |     y_true: np.ndarray,
 660 |     y_pred: np.ndarray,
 661 |     reference_values: np.ndarray,
 662 | ) -> float:
 663 |     """MSE normalized by full dataset scale, not by a flat validation segment."""
 664 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 665 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 666 |     reference_values = np.asarray(reference_values, dtype=float).reshape(-1)
 667 |     if y_true.shape != y_pred.shape:
 668 |         return float("inf")
 669 |     if not np.all(np.isfinite(y_pred)):
 670 |         return float("inf")
 671 |     var = float(np.var(reference_values))
 672 |     if var <= 0.0:
 673 |         return float(np.mean((y_true - y_pred) ** 2))
 674 |     return float(np.mean((y_true - y_pred) ** 2) / var)
 675 | 
 676 | 
 677 | def _nmse_with_gaussian_smoothed_target(
 678 |     y_true: np.ndarray,
 679 |     y_pred: np.ndarray,
 680 |     X: np.ndarray | None = None,
 681 |     reference_values: np.ndarray | None = None,
 682 | ) -> float:
 683 |     reference = y_true if reference_values is None else reference_values
 684 |     return _normalized_mse_with_reference_variance(y_true, y_pred, reference)
 685 | 
 686 | 
 687 | def evaluate_symbolic_expression(
 688 |     expression: Any,
 689 |     X_train: np.ndarray,
 690 |     y_train: np.ndarray,
 691 |     X_val: np.ndarray,
 692 |     y_val: np.ndarray,
 693 |     *,
 694 |     constants: Any | None = None,
 695 |     initial_values: Any | None = None,
 696 |     max_nfev: int = 300,
 697 | ) -> dict[str, Any]:
 698 |     """Score a proposed expression by directly predicting normalized response."""
 699 |     import sympy as sp
 700 |     from pysr_harness import equation_session
 701 |     from scipy.optimize import least_squares
 702 | 
 703 |     X_train = np.asarray(X_train, dtype=float)
 704 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 705 |     X_val = np.asarray(X_val, dtype=float)
 706 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 707 |     evaluation_only = X_train.shape[0] == 0 and X_val.shape[0] > 0
 708 |     train_only = X_val.shape[0] == 0 and X_train.shape[0] > 0
 709 |     if evaluation_only:
 710 |         X_fit, y_fit = X_val, y_val
 711 |     else:
 712 |         X_fit, y_fit = X_train, y_train
 713 |     y_reference = np.concatenate([y_train, y_val]) if y_train.size else y_val
 714 |     n_features = X_fit.shape[1] if X_fit.shape[0] else X_val.shape[1]
 715 |     feature_names = [f"x{i}" for i in range(n_features)]
 716 |     template = equation_session._as_sympy_expr(expression, feature_names)
 717 |     equation_session._record_scored_template(template)
 718 | 
 719 |     if constants is None:
 720 |         feature_set = set(equation_session.feature_symbols(n_features))
 721 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 722 |     constants = list(constants)
 723 |     equation_session._validate_expression_template(template, constants)
 724 | 
 725 |     if initial_values is None:
 726 |         x0 = np.ones(len(constants), dtype=float)
 727 |     else:
 728 |         x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 729 |         if x0.size != len(constants):
 730 |             raise ValueError("initial_values must match the number of constants")
 731 | 
 732 |     if not constants:
 733 |         fitted_expr = template
 734 |         fitted_constants = {}
 735 |     else:
 736 |         feature_syms = equation_session.feature_symbols(n_features)
 737 |         X_cols = [X_fit[:, i] for i in range(n_features)]
 738 |         compiled = sp.lambdify(feature_syms + constants, template, modules=["numpy"])
 739 | 
 740 |         def residual(theta: np.ndarray) -> np.ndarray:
 741 |             try:
 742 |                 args = X_cols + [float(v) for v in theta]
 743 |                 prediction = np.asarray(compiled(*args), dtype=float).reshape(-1)
 744 |             except Exception:
 745 |                 return np.full_like(y_fit, 1e12, dtype=float)
 746 |             if prediction.shape != y_fit.shape or not np.all(np.isfinite(prediction)):
 747 |                 return np.full_like(y_fit, 1e12, dtype=float)
 748 |             return prediction - y_fit
 749 | 
 750 |         import warnings
 751 | 
 752 |         with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 753 |             warnings.simplefilter("ignore", RuntimeWarning)
 754 |             fit = least_squares(
 755 |                 residual,
 756 |                 x0,
 757 |                 loss="soft_l1",
 758 |                 max_nfev=max_nfev,
 759 |             )
 760 |         fitted_constants = {
 761 |             str(symbol): float(value) for symbol, value in zip(constants, fit.x)
 762 |         }
 763 |         fitted_expr = template.subs(dict(zip(constants, fit.x)))
 764 | 
 765 |     y_pred_fit = equation_session._predict(fitted_expr, X_fit, feature_names)
 766 |     y_pred_train = (
 767 |         np.empty(0, dtype=float)
 768 |         if evaluation_only
 769 |         else equation_session._predict(fitted_expr, X_train, feature_names)
 770 |     )
 771 |     y_pred_val = (
 772 |         np.empty(0, dtype=float)
 773 |         if train_only
 774 |         else equation_session._predict(fitted_expr, X_val, feature_names)
 775 |     )
 776 |     nmse_train = (
 777 |         float("nan")
 778 |         if evaluation_only
 779 |         else _nmse_with_gaussian_smoothed_target(
 780 |             y_train, y_pred_train, X_train, y_reference
 781 |         )
 782 |     )
 783 |     nmse_val = (
 784 |         float("nan")
 785 |         if train_only
 786 |         else _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 787 |     )
 788 |     loss = float(np.mean((y_pred_fit - y_fit) ** 2))
 789 | 
 790 |     result = {
 791 |         "equation_template": str(template),
 792 |         "equation": str(fitted_expr),
 793 |         "constants": fitted_constants,
 794 |         "loss": loss,
 795 |         "complexity": equation_session._complexity(template),
 796 |         "nmse_train": nmse_train,
 797 |         "nmse_val": nmse_val,
 798 |         "n_val_points": int(len(y_val)),
 799 |         "evaluation_only": evaluation_only,
 800 |         "train_only": train_only,
 801 |         "combined_score": (
 802 |             0.0
 803 |             if train_only or not np.isfinite(nmse_val)
 804 |             else combined_score_from_nmse(nmse_val)
 805 |         ),
 806 |     }
 807 |     equation_session._record_scorer_result(result)
 808 |     return result
 809 | 
 810 | 
 811 | def _point_weighted_mean(
 812 |     values: list[float],
 813 |     weights: list[int],
 814 | ) -> float:
 815 |     """Average values with one weight per evaluation point."""
 816 |     total_weight = sum(weights)
 817 |     if total_weight <= 0:
 818 |         return float("inf")
 819 |     weighted = sum(
 820 |         float(value) * float(weight)
 821 |         for value, weight in zip(values, weights)
 822 |         if np.isfinite(float(value))
 823 |     )
 824 |     if not np.isfinite(weighted):
 825 |         return float("inf")
 826 |     return float(weighted / total_weight)
 827 | 
 828 | 
 829 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 830 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 831 |     scoring_results = {
 832 |         name: result
 833 |         for name, result in per_dataset_results.items()
 834 |         if int(result.get("n_val_points", 0)) > 0
 835 |     }
 836 |     raw_nmse_vals = [float(r["nmse_val"]) for r in scoring_results.values()]
 837 |     nmse_vals = list(raw_nmse_vals)
 838 |     train_nmse_vals = [
 839 |         float(r["nmse_train"])
 840 |         for r in per_dataset_results.values()
 841 |         if np.isfinite(float(r.get("nmse_train", float("inf"))))
 842 |     ]
 843 |     complexity_vals = []
 844 |     for r in per_dataset_results.values():
 845 |         try:
 846 |             value = float(r.get("complexity", float("nan")))
 847 |         except (TypeError, ValueError):
 848 |             continue
 849 |         if np.isfinite(value):
 850 |             complexity_vals.append(value)
 851 |     aggregate_complexity = float(max(complexity_vals)) if complexity_vals else 0.0
 852 | 
 853 |     violation_errors = sorted(
 854 |         {
 855 |             str(r.get("error"))
 856 |             for r in per_dataset_results.values()
 857 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 858 |         }
 859 |     )
 860 |     failed_datasets = sorted(
 861 |         name
 862 |         for name, result in scoring_results.items()
 863 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 864 |     )
 865 |     templates = sorted(
 866 |         {
 867 |             str(r.get("equation_template"))
 868 |             for r in per_dataset_results.values()
 869 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 870 |         }
 871 |     )
 872 | 
 873 |     eq_template = ""
 874 |     for r in per_dataset_results.values():
 875 |         if r.get("equation"):
 876 |             eq_template = r["equation"]
 877 |             break
 878 | 
 879 |     hard_cases = [
 880 |         {"dataset": name, "nmse_val": float(result["nmse_val"])}
 881 |         for name, result in scoring_results.items()
 882 |         if np.isfinite(float(result.get("nmse_val", float("inf"))))
 883 |     ]
 884 |     hard_cases.sort(key=lambda item: item["nmse_val"], reverse=True)
 885 |     hard_cases = hard_cases[:5]
 886 |     hard_case_feedback = "; ".join(
 887 |         f"{case['dataset']} nmse={case['nmse_val']:.4g}" for case in hard_cases
 888 |     )
 889 | 
 890 |     violation_error = None
 891 |     if violation_errors:
 892 |         violation_error = violation_errors[0]
 893 |     elif failed_datasets:
 894 |         examples = ", ".join(failed_datasets[:3])
 895 |         violation_error = (
 896 |             "Single-equation violation: candidate failed on "
 897 |             f"{len(failed_datasets)}/{len(scoring_results)} validation datasets. "
 898 |             "Failed datasets are not dropped from the aggregate reward. "
 899 |             f"Examples: {examples}"
 900 |         )
 901 |     elif len(templates) > 1:
 902 |         examples = "; ".join(templates[:3])
 903 |         violation_error = (
 904 |             "Single-equation violation: evaluate_symbolic_candidate() produced "
 905 |             f"{len(templates)} distinct equation templates across datasets. "
 906 |             "The base equation must be identical for all datasets; only fitted "
 907 |             f"constants may vary. Example templates: {examples}"
 908 |         )
 909 | 
 910 |     if violation_error:
 911 |         agg_nmse = float("inf")
 912 |         mean_nmse = float("inf")
 913 |         agg_train_nmse = float("inf")
 914 |         agg_combined = 0.0
 915 |         n_successful = 0
 916 |     else:
 917 |         val_point_weights = [
 918 |             int(r.get("n_val_points", 0)) for r in scoring_results.values()
 919 |         ]
 920 |         mean_nmse = _point_weighted_mean(nmse_vals, val_point_weights)
 921 |         raw_mean_nmse = _point_weighted_mean(raw_nmse_vals, val_point_weights)
 922 |         eval_only_results = {
 923 |             name: result
 924 |             for name, result in scoring_results.items()
 925 |             if result.get("evaluation_only")
 926 |         }
 927 |         eval_only_nmse_vals = [
 928 |             float(result["nmse_val"])
 929 |             for result in eval_only_results.values()
 930 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
 931 |         ]
 932 |         eval_only_weights = [
 933 |             int(result.get("n_val_points", 0))
 934 |             for result in eval_only_results.values()
 935 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
 936 |         ]
 937 |         mean_nmse_eval_only = (
 938 |             _point_weighted_mean(eval_only_nmse_vals, eval_only_weights)
 939 |             if eval_only_nmse_vals
 940 |             else float("nan")
 941 |         )
 942 |         agg_nmse = mean_nmse
 943 |         agg_train_nmse = float(np.mean(train_nmse_vals)) if train_nmse_vals else float("inf")
 944 |         raw_combined = (
 945 |             float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
 946 |         )
 947 |         parsimony_factor = _parsimony_penalty_factor(aggregate_complexity)
 948 |         agg_combined = raw_combined * parsimony_factor
 949 |         n_successful = sum(1 for value in nmse_vals if np.isfinite(value))
 950 | 
 951 |     aggregated = {
 952 |         "equation": eq_template,
 953 |         "nmse_train": agg_train_nmse,
 954 |         "nmse_val": agg_nmse,
 955 |         "mean_nmse_val": mean_nmse,
 956 |         "mean_raw_nmse_val": raw_mean_nmse if not violation_error else float("inf"),
 957 |         "combined_score": agg_combined,
 958 |         "fit_score": raw_combined if not violation_error else 0.0,
 959 |         "complexity": aggregate_complexity,
 960 |         "parsimony_weight": PARSIMONY_WEIGHT,
 961 |         "parsimony_penalty_factor": (
 962 |             _parsimony_penalty_factor(aggregate_complexity) if not violation_error else 1.0
 963 |         ),
 964 |         "n_datasets": len(scoring_results),
 965 |         "n_total_datasets": len(per_dataset_results),
 966 |         "n_train_only_datasets": len(per_dataset_results) - len(scoring_results),
 967 |         "n_successful": n_successful,
 968 |         "n_evaluation_only_datasets": len(
 969 |             [name for name, result in per_dataset_results.items() if result.get("evaluation_only")]
 970 |         ),
 971 |         "mean_nmse_eval_only": (
 972 |             mean_nmse_eval_only if not violation_error else float("inf")
 973 |         ),
 974 |         "eval_workers": NUM_WORKERS,
 975 |         "hard_cases": hard_cases,
 976 |         "hard_case_feedback": hard_case_feedback,
 977 |         "per_dataset": per_dataset_results,
 978 |     }
 979 |     if violation_error:
 980 |         aggregated["error"] = violation_error
 981 |     return aggregated
 982 | 
 983 | 
 984 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 985 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 986 | 
 987 |     The subprocess loads every dataset, calls the candidate's
 988 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 989 |     constants each time) using parallel threads, and returns aggregated
 990 |     metrics.
 991 |     """
 992 |     validate_candidate_source(program_path)
 993 |     harness_root = str(BENCHMARK_ROOT)
 994 |     evaluator_path = str(Path(__file__).resolve())
 995 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
 996 |         script = f"""
 997 | import importlib.util
 998 | import os
 999 | import pickle
1000 | import sys
1001 | import traceback
1002 | from concurrent.futures import ThreadPoolExecutor, as_completed
1003 | 
1004 | os.environ.setdefault("OMP_NUM_THREADS", "1")
1005 | os.environ.setdefault("MKL_NUM_THREADS", "1")
1006 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
1007 | 
1008 | import numpy as np
1009 | 
1010 | sys.path.insert(0, {harness_root!r})
1011 | 
1012 | program_path = {program_path!r}
1013 | evaluator_path = {evaluator_path!r}
1014 | results_path = {temp_file.name + ".results"!r}
1015 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
1016 | 
1017 | def _write_payload_and_exit(payload):
1018 |     with open(results_path, "wb") as f:
1019 |         pickle.dump(payload, f)
1020 |     sys.stdout.flush()
1021 |     sys.stderr.flush()
1022 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
1023 |     # interpreter shutdown. The parent only needs the pickle payload.
1024 |     os._exit(0)
1025 | 
1026 | try:
1027 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
1028 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
1029 |     evaluator_spec.loader.exec_module(evaluator)
1030 |     evaluator.validate_candidate_source(program_path)
1031 | 
1032 |     import pysr_harness.equation_session as equation_session
1033 |     equation_session.evaluate_expression = evaluator.evaluate_symbolic_expression
1034 |     equation_session.nmse = evaluator._nmse_with_gaussian_smoothed_target
1035 |     spec = importlib.util.spec_from_file_location("program", program_path)
1036 |     program = importlib.util.module_from_spec(spec)
1037 |     spec.loader.exec_module(program)
1038 |     from pysr_harness.equation_session import (
1039 |         single_equation_evaluation,
1040 |         validate_single_equation_result,
1041 |     )
1042 | 
1043 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1044 |         program, "run_discovery", None
1045 |     )
1046 |     if fn is None:
1047 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
1048 | 
1049 |     datasets = evaluator.load_all_datasets()
1050 | 
1051 |     def _eval_one(args):
1052 |         ds_name, X_train, X_val, y_train, y_val = args
1053 |         try:
1054 |             with single_equation_evaluation():
1055 |                 result = fn(X_train, y_train, X_val, y_val)
1056 |                 validate_single_equation_result(result)
1057 |             ds_nmse = float(result.get("nmse_val", float("inf")))
1058 |             ds_train_nmse = float(result.get("nmse_train", float("inf")))
1059 |             ds_combined = float(result.get("combined_score", 0.0))
1060 |             return ds_name, {{
1061 |                 "nmse_train": ds_train_nmse,
1062 |                 "nmse_val": ds_nmse,
1063 |                 "n_val_points": int(result.get("n_val_points", 0)),
1064 |                 "evaluation_only": bool(result.get("evaluation_only", False)),
1065 |                 "combined_score": ds_combined,
1066 |                 "complexity": float(result.get("complexity", 0.0)),
1067 |                 "equation": str(result.get("equation", "")),
1068 |                 "equation_template": str(result.get("equation_template", "")),
1069 |                 "constants": result.get("constants", {{}}),
1070 |             }}
1071 |         except Exception as exc:
1072 |             return ds_name, {{
1073 |                 "nmse_train": float("inf"),
1074 |                 "nmse_val": float("inf"),
1075 |                 "n_val_points": int(len(y_val)),
1076 |                 "evaluation_only": bool(X_train.shape[0] == 0 and X_val.shape[0] > 0),
1077 |                 "combined_score": 0.0,
1078 |                 "error": str(exc),
1079 |             }}
1080 | 
1081 |     per_dataset_results = {{}}
1082 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1083 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
1084 |         for future in as_completed(futures):
1085 |             ds_name, ds_result = future.result()
1086 |             per_dataset_results[ds_name] = ds_result
1087 | 
1088 |     aggregated = evaluator._aggregate_per_dataset_results(per_dataset_results)
1089 | 
1090 |     _write_payload_and_exit({{"result": aggregated}})
1091 | except Exception as exc:
1092 |     traceback.print_exc()
1093 |     _write_payload_and_exit({{"error": str(exc)}})
1094 | """
1095 |         temp_file.write(script.encode())
1096 |         temp_path = temp_file.name
1097 | 
1098 |     results_path = f"{temp_path}.results"
1099 |     try:
1100 |         process = subprocess.Popen(
1101 |             [sys.executable, temp_path],
1102 |             stdout=subprocess.PIPE,
1103 |             stderr=subprocess.PIPE,
1104 |         )
1105 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
1106 |         if stdout:
1107 |             print(stdout.decode())
1108 |         if stderr:
1109 |             print(stderr.decode())
1110 |         if process.returncode != 0:
1111 |             raise RuntimeError(f"Subprocess exited with code {process.returncode}")
