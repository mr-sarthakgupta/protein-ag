 125 | def _is_module_docstring(node: ast.AST) -> bool:
 126 |     return (
 127 |         isinstance(node, ast.Expr)
 128 |         and isinstance(node.value, ast.Constant)
 129 |         and isinstance(node.value.value, str)
 130 |     )
 131 | 
 132 | 
 133 | def _is_main_guard(node: ast.AST) -> bool:
 134 |     if not isinstance(node, ast.If):
 135 |         return False
 136 |     if node.orelse:
 137 |         return False
 138 |     test = node.test
 139 |     if not isinstance(test, ast.Compare) or len(test.ops) != 1 or len(test.comparators) != 1:
 140 |         return False
 141 |     if not isinstance(test.ops[0], ast.Eq):
 142 |         return False
 143 |     left = test.left
 144 |     right = test.comparators[0]
 145 |     return (
 146 |         isinstance(left, ast.Name)
 147 |         and left.id == "__name__"
 148 |         and isinstance(right, ast.Constant)
 149 |         and right.value == "__main__"
 150 |     )
 151 | 
 152 | 
 153 | def _has_postponed_annotations(tree: ast.Module) -> bool:
 154 |     for node in tree.body:
 155 |         if isinstance(node, ast.ImportFrom) and node.module == "__future__":
 156 |             if any(alias.name == "annotations" for alias in node.names):
 157 |                 return True
 158 |     return False
 159 | 
 160 | 
 161 | def _function_annotations(node: ast.FunctionDef) -> list[ast.AST]:
 162 |     annotations: list[ast.AST] = []
 163 |     args = node.args
 164 |     for arg in [*args.posonlyargs, *args.args, *args.kwonlyargs]:
 165 |         if arg.annotation is not None:
 166 |             annotations.append(arg.annotation)
 167 |     if args.vararg is not None and args.vararg.annotation is not None:
 168 |         annotations.append(args.vararg.annotation)
 169 |     if args.kwarg is not None and args.kwarg.annotation is not None:
 170 |         annotations.append(args.kwarg.annotation)
 171 |     if node.returns is not None:
 172 |         annotations.append(node.returns)
 173 |     return annotations
 174 | 
 175 | 
 176 | def _validate_top_level_function(node: ast.FunctionDef, *, postponed_annotations: bool) -> None:
 177 |     if node.name in _PROTECTED_NAMES:
 178 |         raise ValueError(
 179 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function '{node.name}' "
 180 |             "shadows a protected scorer or harness name."
 181 |         )
 182 |     if node.decorator_list:
 183 |         raise ValueError(
 184 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function decorators are not "
 185 |             "allowed because decorators execute during candidate import."
 186 |         )
 187 |     if node.args.defaults or node.args.kw_defaults:
 188 |         raise ValueError(
 189 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function default arguments "
 190 |             "are not allowed because defaults execute during candidate import."
 191 |         )
 192 |     if _function_annotations(node) and not postponed_annotations:
 193 |         raise ValueError(
 194 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function annotations require "
 195 |             "'from __future__ import annotations' because annotations otherwise "
 196 |             "execute during candidate import."
 197 |         )
 198 | 
 199 | 
 200 | def _call_name(func: ast.AST) -> str:
 201 |     if isinstance(func, ast.Name):
 202 |         return func.id
 203 |     if isinstance(func, ast.Attribute) and isinstance(func.value, ast.Name):
 204 |         return f"{func.value.id}.{func.attr}"
 205 |     return ""
 206 | 
 207 | 
 208 | def _assigned_names(target: ast.AST) -> set[str]:
 209 |     if isinstance(target, ast.Name):
 210 |         return {target.id}
 211 |     if isinstance(target, (ast.Tuple, ast.List)):
 212 |         names: set[str] = set()
 213 |         for elt in target.elts:
 214 |             names.update(_assigned_names(elt))
 215 |         return names
 216 |     return set()
 217 | 
