 130 | def _is_module_docstring(node: ast.AST) -> bool:
 131 |     return (
 132 |         isinstance(node, ast.Expr)
 133 |         and isinstance(node.value, ast.Constant)
 134 |         and isinstance(node.value.value, str)
 135 |     )
 136 | 
 137 | 
 138 | def _is_main_guard(node: ast.AST) -> bool:
 139 |     if not isinstance(node, ast.If):
 140 |         return False
 141 |     if node.orelse:
 142 |         return False
 143 |     test = node.test
 144 |     if not isinstance(test, ast.Compare) or len(test.ops) != 1 or len(test.comparators) != 1:
 145 |         return False
 146 |     if not isinstance(test.ops[0], ast.Eq):
 147 |         return False
 148 |     left = test.left
 149 |     right = test.comparators[0]
 150 |     return (
 151 |         isinstance(left, ast.Name)
 152 |         and left.id == "__name__"
 153 |         and isinstance(right, ast.Constant)
 154 |         and right.value == "__main__"
 155 |     )
 156 | 
 157 | 
 158 | def _has_postponed_annotations(tree: ast.Module) -> bool:
 159 |     for node in tree.body:
 160 |         if isinstance(node, ast.ImportFrom) and node.module == "__future__":
 161 |             if any(alias.name == "annotations" for alias in node.names):
 162 |                 return True
 163 |     return False
 164 | 
 165 | 
 166 | def _function_annotations(node: ast.FunctionDef) -> list[ast.AST]:
 167 |     annotations: list[ast.AST] = []
 168 |     args = node.args
 169 |     for arg in [*args.posonlyargs, *args.args, *args.kwonlyargs]:
 170 |         if arg.annotation is not None:
 171 |             annotations.append(arg.annotation)
 172 |     if args.vararg is not None and args.vararg.annotation is not None:
 173 |         annotations.append(args.vararg.annotation)
 174 |     if args.kwarg is not None and args.kwarg.annotation is not None:
 175 |         annotations.append(args.kwarg.annotation)
 176 |     if node.returns is not None:
 177 |         annotations.append(node.returns)
 178 |     return annotations
 179 | 
 180 | 
 181 | def _validate_top_level_function(node: ast.FunctionDef, *, postponed_annotations: bool) -> None:
 182 |     if node.name in _PROTECTED_NAMES:
 183 |         raise ValueError(
 184 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function '{node.name}' "
 185 |             "shadows a protected scorer or harness name."
 186 |         )
 187 |     if node.decorator_list:
 188 |         raise ValueError(
 189 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function decorators are not "
 190 |             "allowed because decorators execute during candidate import."
 191 |         )
 192 |     if node.args.defaults or node.args.kw_defaults:
 193 |         raise ValueError(
 194 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function default arguments "
 195 |             "are not allowed because defaults execute during candidate import."
 196 |         )
 197 |     if _function_annotations(node) and not postponed_annotations:
 198 |         raise ValueError(
 199 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function annotations require "
 200 |             "'from __future__ import annotations' because annotations otherwise "
 201 |             "execute during candidate import."
 202 |         )
 203 | 
 204 | 
 205 | def _call_name(func: ast.AST) -> str:
 206 |     if isinstance(func, ast.Name):
 207 |         return func.id
 208 |     if isinstance(func, ast.Attribute) and isinstance(func.value, ast.Name):
 209 |         return f"{func.value.id}.{func.attr}"
 210 |     return ""
 211 | 
 212 | 
 213 | def _assigned_names(target: ast.AST) -> set[str]:
 214 |     if isinstance(target, ast.Name):
 215 |         return {target.id}
 216 |     if isinstance(target, (ast.Tuple, ast.List)):
 217 |         names: set[str] = set()
 218 |         for elt in target.elts:
 219 |             names.update(_assigned_names(elt))
 220 |         return names
 221 |     return set()
 222 | 
 223 | 
 224 | def _validate_plain_import(alias: ast.alias) -> None:
 225 |     if alias.name not in _ALLOWED_IMPORTS:
 226 |         raise ValueError(
 227 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: import '{alias.name}' is not allowed. "
 228 |             "Candidates may only import sympy/numpy and the equation harness."
 229 |         )
 230 |     if alias.name == "sympy" and alias.asname != "sp":
 231 |         raise ValueError(
 232 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: sympy must be imported canonically "
 233 |             "as 'import sympy as sp'."
 234 |         )
 235 |     if alias.name == "numpy" and alias.asname not in {None, "np"}:
 236 |         raise ValueError(
 237 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: numpy may only be imported as "
 238 |             "'import numpy' or 'import numpy as np'."
 239 |         )
 240 | 
 241 | 
 242 | def _validate_evaluate_expression_data_args(call: ast.Call) -> set[int]:
 243 |     expected = ["X_train", "y_train", "X_val", "y_val"]
 244 |     if len(call.args) < 5:
 245 |         raise ValueError(
 246 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must be called "
 247 |             "as evaluate_expression(expression, X_train, y_train, X_val, y_val, ...)."
 248 |         )
 249 |     actual_data_args = call.args[1:5]
 250 |     if not all(
 251 |         isinstance(arg, ast.Name) and arg.id == expected_name
 252 |         for arg, expected_name in zip(actual_data_args, expected)
 253 |     ):
 254 |         raise ValueError(
 255 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must use the "
 256 |             "canonical data arguments exactly as X_train, y_train, X_val, y_val. "
 257 |             "Do not fit constants on validation labels or reorder the split."
 258 |         )
 259 |     return {id(arg) for arg in call.args[1:5]}
