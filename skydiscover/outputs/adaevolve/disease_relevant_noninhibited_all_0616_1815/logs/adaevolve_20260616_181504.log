rate_s1 = c5s1[0] * monomer ** c5s1[1]
lag_s1 = c5s1[2] / (1 + c5s1[3] * seed)
expr_s1 = c5s1[4] / (1 + sp.exp(-rate_s1 * time + lag_s1))
x0_s1 = [5.0, 0.5, 2.5, 1.0, 1.0]
print(f'S1 (no shape, no m-lag) complexity: {_complexity(expr_s1):.0f}')

# S2: Richards shape, no monomer in lag (complexity=24)
c6s2 = constant_symbols(6)
rate_s2 = c6s2[0] * monomer ** c6s2[1]
lag_s2 = c6s2[2] / (1 + c6s2[3] * seed)
expr_s2 = c6s2[4] / (1 + sp.exp(-rate_s2 * time + lag_s2)) ** c6s2[5]
x0_s2 = [5.0, 0.5, 2.5, 1.0, 1.0, 1.0]
print(f'S2 (shape, no m-lag) complexity: {_complexity(expr_s2):.0f}')

# S3: No Richards shape, monomer in lag (complexity=25)
c6s3 = constant_symbols(6)
rate_s3 = c6s3[0] * monomer ** c6s3[1]
lag_s3 = c6s3[2] * monomer ** c6s3[3] / (1 + c6s3[4] * seed)
expr_s3 = c6s3[5] / (1 + sp.exp(-rate_s3 * time + lag_s3))
x0_s3 = [5.0, 0.5, 2.5, -0.5, 1.0, 1.0]
print(f'S3 (no shape, m-lag) complexity: {_complexity(expr_s3):.0f}')

# S4: Current minus Richards shape (complexity=27)
c6s4 = constant_symbols(6)
rate_s4 = c6s4[0] * monomer ** c6s4[1]
lag_s4 = c6s4[2] * monomer ** c6s4[3] / (1 + c6s4[4] * seed)
expr_s4 = c6s4[5] / (1 + sp.exp(-rate_s4 * time + lag_s4))
x0_s4 = [5.0, 0.5, 2.5, -0.5, 1.0, 1.0]
print(f'S4 (no shape) complexity: {_complexity(expr_s4):.0f}')

EVAL_ONLY = {'Abeta/Cohen2013/Ab42_sec_IN_HOURS', 'Abeta/Meisl2014/Ab40_sec_IN_HOURS',
             'biofilm proteins/CsgA/CsgA_IN_HOURS', 'htt/Kar2011/Kar2011_Q30_without_lowest_conc_sec',
             'gelsolin/Fig4A', 'IAPP/Daval2010', 'IAPP/Pilkington2017', 'SH3/Zurdo2001_pH2_sec',
             'haemoglobin/Ferrone1985a', 'hnRNPA/Kim2013/Kim2013_A1_sec',
             'lysozyme/Hasecke2018_7uM_sec', 'serum amyloid/Srinivasan2013_Saa1.1_sec'}

all_paths = []
for root, dirs, files in os.walk(base):
    if 'data.tsv' in files:
        all_paths.append(os.path.join(root, 'data.tsv'))
all_paths.sort()

r_cur, r_s1, r_s2, r_s3, r_s4, nv_all = [], [], [], [], [], []
hard = []
for path in all_paths:
    rel = path.replace(base+'/','')
    ds_name = '/'.join(rel.split('/')[:-1])
    res = load_raw(path)
    if res is None: continue
    X, y, cids = res
    is_eval = ds_name in EVAL_ONLY
    if is_eval:
        X_tr, X_va, y_tr, y_va = np.empty((0,3)), X, np.empty(0), y
    else:
