1237 | def evaluate_stage1(program_path: str) -> dict:
1238 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
1239 |     try:
1240 |         harness_root = str(BENCHMARK_ROOT)
1241 |         if harness_root not in sys.path:
1242 |             sys.path.insert(0, harness_root)
1243 | 
1244 |         all_datasets = load_all_datasets()
1245 |         scoring_datasets = [
1246 |             dataset
1247 |             for dataset in all_datasets
1248 |             if dataset[0] not in EVALUATION_ONLY_DATASETS and dataset[4].size > 0
1249 |         ]
1250 |         rng = np.random.default_rng(RANDOM_STATE)
1251 |         if len(scoring_datasets) > 8:
1252 |             indices = rng.choice(len(scoring_datasets), size=8, replace=False)
1253 |             subset = [scoring_datasets[i] for i in sorted(indices)]
1254 |         else:
1255 |             subset = scoring_datasets
1256 | 
1257 |         work_items = [
1258 |             (name, X_train, X_val, y_train, y_val, program_path)
1259 |             for name, X_train, X_val, y_train, y_val in subset
1260 |         ]
1261 | 
1262 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1263 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
1264 |             worker_results = [future.result() for future in concurrent.futures.as_completed(futures)]
1265 | 
1266 |         combined_scores = [score for score, _error, _template in worker_results]
1267 |         successful_scores = [score for score in combined_scores if score > 0]
1268 |         errors = sorted({error for _score, error, _template in worker_results if error})
1269 |         violation_errors = sorted(
1270 |             {
1271 |                 error
1272 |                 for _score, error, _template in worker_results
1273 |                 if error and SINGLE_EQUATION_ERROR_PREFIX in error
1274 |             }
1275 |         )
1276 |         if violation_errors:
1277 |             return {
1278 |                 "combined_score": 0.0,
1279 |                 "n_stage1_datasets": len(subset),
1280 |                 "n_stage1_successful": len(successful_scores),
1281 |                 "eval_workers": NUM_WORKERS,
1282 |                 "error": violation_errors[0],
1283 |             }
1284 |         if errors:
1285 |             return {
1286 |                 "combined_score": 0.0,
1287 |                 "n_stage1_datasets": len(subset),
1288 |                 "n_stage1_successful": len(successful_scores),
1289 |                 "eval_workers": NUM_WORKERS,
1290 |                 "error": (
1291 |                     "Single-equation violation: stage 1 candidate failed on "
1292 |                     f"{len(errors)} dataset evaluations. Example: {errors[0]}"
1293 |                 ),
1294 |             }
1295 |         templates = sorted(
1296 |             {
1297 |                 template
1298 |                 for score, _error, template in worker_results
1299 |                 if score > 0 and template
1300 |             }
1301 |         )
1302 |         if len(templates) > 1:
1303 |             examples = "; ".join(templates[:3])
1304 |             return {
1305 |                 "combined_score": 0.0,
1306 |                 "n_stage1_datasets": len(subset),
1307 |                 "n_stage1_successful": len(successful_scores),
1308 |                 "eval_workers": NUM_WORKERS,
1309 |                 "error": (
1310 |                     "Single-equation violation: stage 1 produced "
1311 |                     f"{len(templates)} distinct equation templates across datasets. "
1312 |                     "The base equation must be identical for all datasets. "
1313 |                     f"Example templates: {examples}"
1314 |                 ),
1315 |             }
1316 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
1317 |         return {
1318 |             "combined_score": agg_combined,
1319 |             "n_stage1_datasets": len(subset),
1320 |             "n_stage1_successful": len(successful_scores),
1321 |             "eval_workers": NUM_WORKERS,
1322 |             "stage1_full_selected_datasets": 1.0,
1323 |         }
1324 |     except Exception as exc:
