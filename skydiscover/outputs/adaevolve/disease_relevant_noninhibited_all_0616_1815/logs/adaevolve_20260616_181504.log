 984 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 985 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 986 | 
 987 |     The subprocess loads every dataset, calls the candidate's
 988 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 989 |     constants each time) using parallel threads, and returns aggregated
 990 |     metrics.
 991 |     """
 992 |     validate_candidate_source(program_path)
 993 |     harness_root = str(BENCHMARK_ROOT)
 994 |     evaluator_path = str(Path(__file__).resolve())
 995 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
 996 |         script = f"""
 997 | import importlib.util
 998 | import os
 999 | import pickle
1000 | import sys
1001 | import traceback
1002 | from concurrent.futures import ThreadPoolExecutor, as_completed
1003 | 
1004 | os.environ.setdefault("OMP_NUM_THREADS", "1")
1005 | os.environ.setdefault("MKL_NUM_THREADS", "1")
1006 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
1007 | 
1008 | import numpy as np
1009 | 
1010 | sys.path.insert(0, {harness_root!r})
1011 | 
1012 | program_path = {program_path!r}
1013 | evaluator_path = {evaluator_path!r}
1014 | results_path = {temp_file.name + ".results"!r}
1015 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
1016 | 
1017 | def _write_payload_and_exit(payload):
1018 |     with open(results_path, "wb") as f:
1019 |         pickle.dump(payload, f)
1020 |     sys.stdout.flush()
1021 |     sys.stderr.flush()
1022 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
1023 |     # interpreter shutdown. The parent only needs the pickle payload.
1024 |     os._exit(0)
1025 | 
1026 | try:
1027 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
1028 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
1029 |     evaluator_spec.loader.exec_module(evaluator)
1030 |     evaluator.validate_candidate_source(program_path)
1031 | 
1032 |     import pysr_harness.equation_session as equation_session
1033 |     equation_session.evaluate_expression = evaluator.evaluate_symbolic_expression
1034 |     equation_session.nmse = evaluator._nmse_with_gaussian_smoothed_target
1035 |     spec = importlib.util.spec_from_file_location("program", program_path)
1036 |     program = importlib.util.module_from_spec(spec)
1037 |     spec.loader.exec_module(program)
1038 |     from pysr_harness.equation_session import (
1039 |         single_equation_evaluation,
1040 |         validate_single_equation_result,
1041 |     )
1042 | 
1043 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1044 |         program, "run_discovery", None
1045 |     )
1046 |     if fn is None:
1047 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
1048 | 
1049 |     datasets = evaluator.load_all_datasets()
1050 | 
1051 |     def _eval_one(args):
1052 |         ds_name, X_train, X_val, y_train, y_val = args
1053 |         try:
1054 |             with single_equation_evaluation():
1055 |                 result = fn(X_train, y_train, X_val, y_val)
1056 |                 validate_single_equation_result(result)
1057 |             ds_nmse = float(result.get("nmse_val", float("inf")))
1058 |             ds_train_nmse = float(result.get("nmse_train", float("inf")))
1059 |             ds_combined = float(result.get("combined_score", 0.0))
1060 |             return ds_name, {{
1061 |                 "nmse_train": ds_train_nmse,
1062 |                 "nmse_val": ds_nmse,
1063 |                 "n_val_points": int(result.get("n_val_points", 0)),
1064 |                 "evaluation_only": bool(result.get("evaluation_only", False)),
1065 |                 "combined_score": ds_combined,
1066 |                 "complexity": float(result.get("complexity", 0.0)),
1067 |                 "equation": str(result.get("equation", "")),
1068 |                 "equation_template": str(result.get("equation_template", "")),
1069 |                 "constants": result.get("constants", {{}}),
1070 |             }}
1071 |         except Exception as exc:
1072 |             return ds_name, {{
1073 |                 "nmse_train": float("inf"),
1074 |                 "nmse_val": float("inf"),
1075 |                 "n_val_points": int(len(y_val)),
1076 |                 "evaluation_only": bool(X_train.shape[0] == 0 and X_val.shape[0] > 0),
1077 |                 "combined_score": 0.0,
1078 |                 "error": str(exc),
1079 |             }}
1080 | 
1081 |     per_dataset_results = {{}}
1082 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1083 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
1084 |         for future in as_completed(futures):
1085 |             ds_name, ds_result = future.result()
1086 |             per_dataset_results[ds_name] = ds_result
1087 | 
1088 |     aggregated = evaluator._aggregate_per_dataset_results(per_dataset_results)
1089 | 
1090 |     _write_payload_and_exit({{"result": aggregated}})
1091 | except Exception as exc:
1092 |     traceback.print_exc()
1093 |     _write_payload_and_exit({{"error": str(exc)}})
1094 | """
1095 |         temp_file.write(script.encode())
1096 |         temp_path = temp_file.name
1097 | 
1098 |     results_path = f"{temp_path}.results"
1099 |     try:
1100 |         process = subprocess.Popen(
1101 |             [sys.executable, temp_path],
1102 |             stdout=subprocess.PIPE,
1103 |             stderr=subprocess.PIPE,
1104 |         )
1105 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
1106 |         if stdout:
1107 |             print(stdout.decode())
1108 |         if stderr:
1109 |             print(stderr.decode())
1110 |         if process.returncode != 0:
1111 |             raise RuntimeError(f"Subprocess exited with code {process.returncode}")
1112 |         if not os.path.exists(results_path):
1113 |             raise RuntimeError("Results file not found")
1114 |         with open(results_path, "rb") as f:
1115 |             payload = pickle.load(f)
1116 |         if "error" in payload:
1117 |             raise RuntimeError(payload["error"])
1118 |         return payload["result"]
1119 |     except subprocess.TimeoutExpired:
1120 |         process.kill()
1121 |         process.wait()
1122 |         raise TimeoutError(f"Program execution timed out after {timeout_seconds}s")
1123 |     finally:
1124 |         for path in (temp_path, results_path):
1125 |             if os.path.exists(path):
1126 |                 os.unlink(path)
1127 | 
1128 | 
1129 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
1130 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
1131 |     nmse_val = float(result.get("nmse_val", float("inf")))
1132 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
1133 |     if not np.isfinite(combined):
1134 |         combined = 0.0
1135 | 
1136 |     return {
1137 |         "equation": str(result.get("equation", "")),
1138 |         "loss": nmse_val,
1139 |         "complexity": float(result.get("complexity", 0.0)),
1140 |         "nmse_train": float(result.get("nmse_train", float("inf"))),
1141 |         "nmse_val": nmse_val,
1142 |         "mean_nmse_val": float(result.get("mean_nmse_val", nmse_val)),
1143 |         "mean_raw_nmse_val": float(result.get("mean_raw_nmse_val", nmse_val)),
1144 |         "combined_score": combined,
1145 |         "fit_score": float(result.get("fit_score", combined)),
1146 |         "parsimony_weight": float(result.get("parsimony_weight", PARSIMONY_WEIGHT)),
1147 |         "parsimony_penalty_factor": float(result.get("parsimony_penalty_factor", 1.0)),
1148 |         "eval_time": float(eval_time),
1149 |         "n_datasets": result.get("n_datasets", 0),
1150 |         "n_successful": result.get("n_successful", 0),
1151 |         "eval_workers": result.get("eval_workers", NUM_WORKERS),
1152 |         "hard_cases": result.get("hard_cases", []),
1153 |         "hard_case_feedback": str(result.get("hard_case_feedback", "")),
1154 |         "per_dataset": result.get("per_dataset", {}),
1155 |         "error": str(result.get("error", "")),
1156 |     }
1157 | 
1158 | 
1159 | def evaluate(program_path: str) -> dict:
1160 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
1161 |     try:
1162 |         start = time.time()
1163 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=3000)
1164 |         metrics = _metrics_from_result(result, time.time() - start)
1165 |         print(
1166 |             "Evaluation: "
1167 |             f"nmse_val={metrics['nmse_val']:.6f}, "
1168 |             f"mean_nmse_val={metrics['mean_nmse_val']:.6f}, "
1169 |             f"mean_raw_nmse_val={metrics['mean_raw_nmse_val']:.6f}, "
1170 |             f"combined_score={metrics['combined_score']:.6f}, "
1171 |             f"n_datasets={metrics['n_datasets']}, "
1172 |             f"n_successful={metrics['n_successful']}, "
1173 |             f"time={metrics['eval_time']:.2f}s"
1174 |         )
1175 |         print(f"Equation template: {metrics['equation']}")
1176 |         if metrics.get("hard_case_feedback"):
1177 |             print(f"Hard-case feedback: {metrics['hard_case_feedback']}")
1178 |         if metrics.get("error"):
1179 |             print(f"Evaluator feedback: {metrics['error']}")
1180 |         return metrics
1181 |     except Exception as exc:
1182 |         print(f"Evaluation failed: {exc}")
1183 |         traceback.print_exc()
1184 |         return {
1185 |             "equation": "",
1186 |             "loss": float("inf"),
1187 |             "complexity": 0.0,
1188 |             "nmse_train": float("inf"),
1189 |             "nmse_val": float("inf"),
1190 |             "mean_nmse_val": float("inf"),
1191 |             "mean_raw_nmse_val": float("inf"),
1192 |             "combined_score": 0.0,
1193 |             "eval_time": 0.0,
1194 |             "n_datasets": 0,
1195 |             "n_successful": 0,
1196 |             "hard_cases": [],
1197 |             "hard_case_feedback": "",
1198 |             "per_dataset": {},
1199 |             "error": str(exc),
1200 |         }
