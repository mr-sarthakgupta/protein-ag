   2 | """Symbolic regression seed for normalized multi-dataset amyloid aggregation kinetics."""
   3 | 
   4 | from __future__ import annotations
   5 | 
   6 | from typing import Any
   7 | 
   8 | import sympy as sp
   9 | from numpy.typing import NDArray
  10 | 
  11 | from pysr_harness.equation_session import (
  12 |     constant_symbols,
  13 |     evaluate_expression,
  14 |     feature_symbols,
  15 | )
  16 | 
  17 | 
  18 | def evaluate_symbolic_candidate(
  19 |     X_train: NDArray,
  20 |     y_train: NDArray,
  21 |     X_val: NDArray,
  22 |     y_val: NDArray,
  23 | ) -> dict[str, Any]:
  24 |     """
  25 |     Propose an equation structure and let the harness fit its constants.
  26 | 
  27 |     This candidate is evaluated independently on each dataset — the same
  28 |     equation template is used everywhere, but constants are fitted separately
  29 |     per dataset.  This allows a single functional form to capture the
  30 |     universal kinetic mechanism while the constants adapt to each protein
  31 |     system's specific rates, concentrations, and timescales.
  32 | 
  33 |     Features: x0 = normalized elapsed time, x1 = m0 initial monomer
  34 |     concentration, x2 = static initial M0 seed/aggregate concentration.
  35 |     Units are ignored by the cleaned-data loader; leading numeric values are
  36 |     used directly.
  37 | 
  38 |     Logistic/sigmoidal template with concentration-dependent rate and
  39 |     half-time — a natural model for nucleation-dependent polymerization:
  40 | 
  41 |         y = c4 / (1 + exp(-c0 * x1^c1 * (x0 - c2 * x1^c3))) + c5
  42 |     """
  43 |     x = feature_symbols(X_train.shape[1])
  44 |     c = constant_symbols(6)
  45 | 
  46 |     time = x[0]
  47 |     parameter = x[1]
  48 | 
  49 |     rate = c[0] * parameter ** c[1]
  50 |     half_time = c[2] * parameter ** c[3]
  51 |     plateau = c[4]
  52 |     baseline = c[5]
  53 | 
  54 |     expression = plateau / (1 + sp.exp(-rate * (time - half_time))) + baseline
  55 | 
  56 |     return evaluate_expression(
  57 |         expression,
  58 |         X_train,
  59 |         y_train,
  60 |         X_val,
  61 |         y_val,
  62 |         constants=c,
  63 |         initial_values=[0.1, 0.5, 10.0, -0.5, 1.0, 0.0],
  64 |     )
  65 | 
  66 | 
  67 | def run_discovery(
  68 |     X_train: NDArray,
  69 |     y_train: NDArray,
  70 |     X_val: NDArray,
  71 |     y_val: NDArray,
  72 | ) -> dict[str, Any]:
  73 |     """Entry point used by the evaluator subprocess."""
  74 |     return evaluate_symbolic_candidate(X_train, y_train, X_val, y_val)
  75 | 
