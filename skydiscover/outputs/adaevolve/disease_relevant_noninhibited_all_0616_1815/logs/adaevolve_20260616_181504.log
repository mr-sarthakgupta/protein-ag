1233 |     import pysr_harness.equation_session as equation_session
1234 |     equation_session.evaluate_expression = evaluate_symbolic_expression
1235 |     equation_session.nmse = _nmse_with_gaussian_smoothed_target
1236 |     spec = importlib.util.spec_from_file_location("program", program_path)
1237 |     program = importlib.util.module_from_spec(spec)
1238 |     spec.loader.exec_module(program)
1239 |     from pysr_harness.equation_session import (
1240 |         single_equation_evaluation,
1241 |         validate_single_equation_result,
1242 |     )
1243 | 
1244 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1245 |         program, "run_discovery", None
1246 |     )
1247 |     if fn is None:
1248 |         return 0.0, "missing evaluate_symbolic_candidate()", ""
1249 |     try:
1250 |         with single_equation_evaluation():
1251 |             result = fn(X_train, y_train, X_val, y_val)
1252 |             validate_single_equation_result(result)
1253 |         return float(result.get("combined_score", 0.0)), None, str(
1254 |             result.get("equation_template", "")
1255 |         )
1256 |     except Exception as exc:
1257 |         return 0.0, str(exc), ""
