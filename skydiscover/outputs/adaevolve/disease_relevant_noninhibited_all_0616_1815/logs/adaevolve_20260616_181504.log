1334 |                     f"{len(templates)} distinct equation templates across datasets. "
1335 |                     "The base equation must be identical for all datasets. "
1336 |                     f"Example templates: {examples}"
1337 |                 ),
1338 |             }
1339 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
1340 |         return {
