1007 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
1008 |     """Evaluate a candidate program across ALL datasets in a subprocess.
1009 | 
1010 |     The subprocess loads every dataset, calls the candidate's
1011 |     evaluate_symbolic_candidate() once per dataset (fitting independent
1012 |     constants each time) using parallel threads, and returns aggregated
1013 |     metrics.
1014 |     """
1015 |     validate_candidate_source(program_path)
1016 |     harness_root = str(BENCHMARK_ROOT)
1017 |     evaluator_path = str(Path(__file__).resolve())
1018 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
1019 |         script = f"""
1020 | import importlib.util
1021 | import os
1022 | import pickle
1023 | import sys
1024 | import traceback
1025 | from concurrent.futures import ThreadPoolExecutor, as_completed
1026 | 
1027 | os.environ.setdefault("OMP_NUM_THREADS", "1")
1028 | os.environ.setdefault("MKL_NUM_THREADS", "1")
1029 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
1030 | 
1031 | import numpy as np
1032 | 
1033 | sys.path.insert(0, {harness_root!r})
1034 | 
1035 | program_path = {program_path!r}
1036 | evaluator_path = {evaluator_path!r}
1037 | results_path = {temp_file.name + ".results"!r}
1038 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
1039 | 
1040 | def _write_payload_and_exit(payload):
1041 |     with open(results_path, "wb") as f:
1042 |         pickle.dump(payload, f)
1043 |     sys.stdout.flush()
1044 |     sys.stderr.flush()
1045 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
1046 |     # interpreter shutdown. The parent only needs the pickle payload.
1047 |     os._exit(0)
1048 | 
1049 | try:
1050 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
1051 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
1052 |     evaluator_spec.loader.exec_module(evaluator)
1053 |     evaluator.validate_candidate_source(program_path)
1054 | 
1055 |     import pysr_harness.equation_session as equation_session
1056 |     equation_session.evaluate_expression = evaluator.evaluate_symbolic_expression
1057 |     equation_session.nmse = evaluator._nmse_with_gaussian_smoothed_target
1058 |     spec = importlib.util.spec_from_file_location("program", program_path)
1059 |     program = importlib.util.module_from_spec(spec)
1060 |     spec.loader.exec_module(program)
1061 |     from pysr_harness.equation_session import (
1062 |         single_equation_evaluation,
1063 |         validate_single_equation_result,
1064 |     )
1065 | 
1066 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1067 |         program, "run_discovery", None
1068 |     )
1069 |     if fn is None:
1070 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
1071 | 
1072 |     datasets = evaluator.load_all_datasets()
1073 | 
1074 |     def _eval_one(args):
1075 |         ds_name, X_train, X_val, y_train, y_val = args
1076 |         try:
1077 |             with single_equation_evaluation():
1078 |                 result = fn(X_train, y_train, X_val, y_val)
1079 |                 validate_single_equation_result(result)
1080 |             ds_nmse = float(result.get("nmse_val", float("inf")))
1081 |             ds_train_nmse = float(result.get("nmse_train", float("inf")))
1082 |             ds_combined = float(result.get("combined_score", 0.0))
1083 |             return ds_name, {{
1084 |                 "nmse_train": ds_train_nmse,
1085 |                 "nmse_val": ds_nmse,
1086 |                 "n_val_points": int(result.get("n_val_points", 0)),
1087 |                 "evaluation_only": bool(result.get("evaluation_only", False)),
1088 |                 "combined_score": ds_combined,
1089 |                 "complexity": float(result.get("complexity", 0.0)),
1090 |                 "equation": str(result.get("equation", "")),
1091 |                 "equation_template": str(result.get("equation_template", "")),
1092 |                 "constants": result.get("constants", {{}}),
1093 |             }}
1094 |         except Exception as exc:
1095 |             return ds_name, {{
1096 |                 "nmse_train": float("inf"),
1097 |                 "nmse_val": float("inf"),
1098 |                 "n_val_points": int(len(y_val)),
1099 |                 "evaluation_only": bool(X_train.shape[0] == 0 and X_val.shape[0] > 0),
1100 |                 "combined_score": 0.0,
1101 |                 "error": str(exc),
1102 |             }}
1103 | 
1104 |     per_dataset_results = {{}}
1105 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1106 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
1107 |         for future in as_completed(futures):
1108 |             ds_name, ds_result = future.result()
1109 |             per_dataset_results[ds_name] = ds_result
1110 | 
1111 |     aggregated = evaluator._aggregate_per_dataset_results(per_dataset_results)
1112 | 
1113 |     _write_payload_and_exit({{"result": aggregated}})
1114 | except Exception as exc:
1115 |     traceback.print_exc()
1116 |     _write_payload_and_exit({{"error": str(exc)}})
1117 | """
1118 |         temp_file.write(script.encode())
1119 |         temp_path = temp_file.name
1120 | 
1121 |     results_path = f"{temp_path}.results"
1122 |     try:
1123 |         process = subprocess.Popen(
1124 |             [sys.executable, temp_path],
1125 |             stdout=subprocess.PIPE,
1126 |             stderr=subprocess.PIPE,
1127 |         )
1128 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
1129 |         if stdout:
1130 |             print(stdout.decode())
1131 |         if stderr:
1132 |             print(stderr.decode())
1133 |         if process.returncode != 0:
1134 |             raise RuntimeError(f"Subprocess exited with code {process.returncode}")
1135 |         if not os.path.exists(results_path):
1136 |             raise RuntimeError("Results file not found")
1137 |         with open(results_path, "rb") as f:
1138 |             payload = pickle.load(f)
1139 |         if "error" in payload:
1140 |             raise RuntimeError(payload["error"])
1141 |         return payload["result"]
1142 |     except subprocess.TimeoutExpired:
1143 |         process.kill()
1144 |         process.wait()
1145 |         raise TimeoutError(f"Program execution timed out after {timeout_seconds}s")
1146 |     finally:
1147 |         for path in (temp_path, results_path):
1148 |             if os.path.exists(path):
1149 |                 os.unlink(path)
