 236 | 
 237 | def _validate_evaluate_expression_data_args(call: ast.Call) -> set[int]:
 238 |     expected = ["X_train", "y_train", "X_val", "y_val"]
 239 |     if len(call.args) < 5:
 240 |         raise ValueError(
 241 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must be called "
 242 |             "as evaluate_expression(expression, X_train, y_train, X_val, y_val, ...)."
 243 |         )
 244 |     actual_data_args = call.args[1:5]
 245 |     if not all(
 246 |         isinstance(arg, ast.Name) and arg.id == expected_name
 247 |         for arg, expected_name in zip(actual_data_args, expected)
 248 |     ):
 249 |         raise ValueError(
 250 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must use the "
 251 |             "canonical data arguments exactly as X_train, y_train, X_val, y_val. "
 252 |             "Do not fit constants on validation labels or reorder the split."
 253 |         )
 254 |     return {id(arg) for arg in call.args[1:5]}
 255 | 
