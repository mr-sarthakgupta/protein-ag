 620 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 621 | PARSIMONY_WEIGHT = float(os.environ.get("SKYDISCOVER_PARSIMONY_WEIGHT", "0.20"))
 622 | PARSIMONY_COMPLEXITY_SCALE = float(
 623 |     os.environ.get("SKYDISCOVER_PARSIMONY_COMPLEXITY_SCALE", "160")
 624 | )
 625 | 
 626 | 
 627 | def _parsimony_penalty_factor(complexity: float) -> float:
 628 |     """Bounded penalty factor for expression complexity."""
 629 |     if not np.isfinite(complexity) or PARSIMONY_COMPLEXITY_SCALE <= 0:
 630 |         return 1.0
 631 |     normalized = min(max(float(complexity), 0.0) / PARSIMONY_COMPLEXITY_SCALE, 1.0)
 632 |     return max(0.0, 1.0 - PARSIMONY_WEIGHT * normalized)
 633 | 
 634 | 
 635 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 636 |     values = np.asarray(values, dtype=float).ravel()
 637 |     if values.size < 3 or sigma <= 0.0:
 638 |         return values
 639 |     radius = max(1, int(round(3.0 * sigma)))
 640 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 641 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 642 |     kernel /= np.sum(kernel)
 643 |     padded = np.pad(values, (radius, radius), mode="edge")
 644 |     return np.convolve(padded, kernel, mode="valid")
 645 | 
 646 | 
 647 | def _curve_smoothed_target(X: np.ndarray, y_true: np.ndarray) -> np.ndarray:
 648 |     """Smooth targets independently for each parameter curve in time order."""
 649 |     X = np.asarray(X, dtype=float)
 650 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 651 |     if X.shape[0] != y_true.shape[0] or X.shape[1] < 2:
 652 |         return _gaussian_smooth_1d(y_true)
 653 | 
 654 |     smoothed = np.empty_like(y_true, dtype=float)
 655 |     for parameter in np.unique(X[:, 1]):
 656 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 657 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 658 |         smoothed_curve = _gaussian_smooth_1d(y_true[ordered_idx])
 659 |         smoothed[ordered_idx] = smoothed_curve
 660 |     return smoothed
 661 | 
 662 | 
 663 | def _normalized_mse_with_reference_variance(
 664 |     y_true: np.ndarray,
 665 |     y_pred: np.ndarray,
 666 |     reference_values: np.ndarray,
 667 | ) -> float:
 668 |     """MSE normalized by full dataset scale, not by a flat validation segment."""
 669 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 670 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 671 |     reference_values = np.asarray(reference_values, dtype=float).reshape(-1)
 672 |     if y_true.shape != y_pred.shape:
 673 |         return float("inf")
 674 |     if not np.all(np.isfinite(y_pred)):
 675 |         return float("inf")
 676 |     var = float(np.var(reference_values))
 677 |     if var <= 0.0:
 678 |         return float(np.mean((y_true - y_pred) ** 2))
 679 |     return float(np.mean((y_true - y_pred) ** 2) / var)
 680 | 
 681 | 
 682 | def _nmse_with_gaussian_smoothed_target(
 683 |     y_true: np.ndarray,
 684 |     y_pred: np.ndarray,
 685 |     X: np.ndarray | None = None,
 686 |     reference_values: np.ndarray | None = None,
 687 | ) -> float:
 688 |     reference = y_true if reference_values is None else reference_values
 689 |     return _normalized_mse_with_reference_variance(y_true, y_pred, reference)
 690 | 
 691 | 
 692 | def evaluate_symbolic_expression(
 693 |     expression: Any,
 694 |     X_train: np.ndarray,
 695 |     y_train: np.ndarray,
 696 |     X_val: np.ndarray,
 697 |     y_val: np.ndarray,
 698 |     *,
 699 |     constants: Any | None = None,
 700 |     initial_values: Any | None = None,
 701 |     max_nfev: int = 300,
 702 | ) -> dict[str, Any]:
 703 |     """Score a proposed expression by directly predicting normalized response."""
 704 |     import sympy as sp
 705 |     from pysr_harness import equation_session
 706 |     from scipy.optimize import least_squares
 707 | 
 708 |     X_train = np.asarray(X_train, dtype=float)
 709 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 710 |     X_val = np.asarray(X_val, dtype=float)
 711 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 712 |     evaluation_only = X_train.shape[0] == 0 and X_val.shape[0] > 0
 713 |     train_only = X_val.shape[0] == 0 and X_train.shape[0] > 0
 714 |     if evaluation_only:
 715 |         X_fit, y_fit = X_val, y_val
 716 |     else:
 717 |         X_fit, y_fit = X_train, y_train
 718 |     y_reference = np.concatenate([y_train, y_val]) if y_train.size else y_val
 719 |     n_features = X_fit.shape[1] if X_fit.shape[0] else X_val.shape[1]
 720 |     feature_names = [f"x{i}" for i in range(n_features)]
 721 |     template = equation_session._as_sympy_expr(expression, feature_names)
 722 |     equation_session._record_scored_template(template)
 723 | 
 724 |     if constants is None:
 725 |         feature_set = set(equation_session.feature_symbols(n_features))
 726 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 727 |     constants = list(constants)
 728 |     equation_session._validate_expression_template(template, constants)
 729 | 
 730 |     if initial_values is None:
 731 |         base_x0 = np.ones(len(constants), dtype=float)
 732 |     else:
 733 |         base_x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 734 |         if base_x0.size != len(constants):
 735 |             raise ValueError("initial_values must match the number of constants")
 736 | 
 737 |     if not constants:
 738 |         fitted_expr = template
 739 |         fitted_constants = {}
 740 |     else:
 741 |         feature_syms = equation_session.feature_symbols(n_features)
 742 |         X_cols = [X_fit[:, i] for i in range(n_features)]
 743 |         compiled = sp.lambdify(feature_syms + constants, template, modules=["numpy"])
 744 | 
 745 |         def residual(theta: np.ndarray) -> np.ndarray:
 746 |             try:
 747 |                 args = X_cols + [float(v) for v in theta]
 748 |                 prediction = np.asarray(compiled(*args), dtype=float).reshape(-1)
 749 |             except Exception:
 750 |                 return np.full_like(y_fit, 1e12, dtype=float)
 751 |             if prediction.shape != y_fit.shape or not np.all(np.isfinite(prediction)):
 752 |                 return np.full_like(y_fit, 1e12, dtype=float)
 753 |             return prediction - y_fit
 754 | 
 755 |         import warnings
 756 | 
 757 |         initial_candidates: list[np.ndarray] = []
 758 |         for scale in EXPRESSION_MULTISTART_SCALES or (1.0,):
 759 |             candidate = base_x0 * float(scale)
 760 |             if not any(np.array_equal(candidate, existing) for existing in initial_candidates):
 761 |                 initial_candidates.append(candidate)
 762 | 
 763 |         best_fit = None
 764 |         best_loss = float("inf")
 765 |         with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 766 |             warnings.simplefilter("ignore", RuntimeWarning)
 767 |             for initial_candidate in initial_candidates:
 768 |                 fit = least_squares(
 769 |                     residual,
 770 |                     initial_candidate,
 771 |                     loss="soft_l1",
 772 |                     max_nfev=max_nfev,
 773 |                 )
 774 |                 fit_residual = residual(fit.x)
 775 |                 fit_loss = float(np.mean(fit_residual**2))
 776 |                 if fit_loss < best_loss:
 777 |                     best_loss = fit_loss
 778 |                     best_fit = fit
 779 | 
 780 |         if best_fit is None:
 781 |             raise RuntimeError("constant fitting did not produce a result")
 782 | 
 783 |         fitted_constants = {
 784 |             str(symbol): float(value) for symbol, value in zip(constants, best_fit.x)
 785 |         }
 786 |         fitted_expr = template.subs(dict(zip(constants, best_fit.x)))
 787 | 
 788 |     y_pred_fit = equation_session._predict(fitted_expr, X_fit, feature_names)
 789 |     y_pred_train = (
 790 |         np.empty(0, dtype=float)
 791 |         if evaluation_only
 792 |         else equation_session._predict(fitted_expr, X_train, feature_names)
 793 |     )
 794 |     y_pred_val = (
 795 |         np.empty(0, dtype=float)
 796 |         if train_only
 797 |         else equation_session._predict(fitted_expr, X_val, feature_names)
 798 |     )
 799 |     nmse_train = (
 800 |         float("nan")
 801 |         if evaluation_only
 802 |         else _nmse_with_gaussian_smoothed_target(
 803 |             y_train, y_pred_train, X_train, y_reference
 804 |         )
 805 |     )
 806 |     nmse_val = (
 807 |         float("nan")
 808 |         if train_only
 809 |         else _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 810 |     )
 811 |     loss = float(np.mean((y_pred_fit - y_fit) ** 2))
 812 | 
 813 |     result = {
 814 |         "equation_template": str(template),
 815 |         "equation": str(fitted_expr),
 816 |         "constants": fitted_constants,
 817 |         "loss": loss,
 818 |         "complexity": equation_session._complexity(template),
 819 |         "nmse_train": nmse_train,
 820 |         "nmse_val": nmse_val,
 821 |         "n_val_points": int(len(y_val)),
 822 |         "evaluation_only": evaluation_only,
 823 |         "train_only": train_only,
 824 |         "combined_score": (
 825 |             0.0
 826 |             if train_only or not np.isfinite(nmse_val)
 827 |             else combined_score_from_nmse(nmse_val)
 828 |         ),
 829 |     }
 830 |     equation_session._record_scorer_result(result)
 831 |     return result
 832 | 
 833 | 
 834 | def _point_weighted_mean(
 835 |     values: list[float],
 836 |     weights: list[int],
 837 | ) -> float:
 838 |     """Average values with one weight per evaluation point."""
 839 |     total_weight = sum(weights)
 840 |     if total_weight <= 0:
 841 |         return float("inf")
 842 |     weighted = sum(
 843 |         float(value) * float(weight)
 844 |         for value, weight in zip(values, weights)
 845 |         if np.isfinite(float(value))
 846 |     )
 847 |     if not np.isfinite(weighted):
 848 |         return float("inf")
 849 |     return float(weighted / total_weight)
 850 | 
 851 | 
 852 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 853 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 854 |     scoring_results = {
 855 |         name: result
 856 |         for name, result in per_dataset_results.items()
 857 |         if int(result.get("n_val_points", 0)) > 0
 858 |     }
 859 |     raw_nmse_vals = [float(r["nmse_val"]) for r in scoring_results.values()]
 860 |     nmse_vals = list(raw_nmse_vals)
 861 |     train_nmse_vals = [
 862 |         float(r["nmse_train"])
 863 |         for r in per_dataset_results.values()
 864 |         if np.isfinite(float(r.get("nmse_train", float("inf"))))
 865 |     ]
 866 |     complexity_vals = []
 867 |     for r in per_dataset_results.values():
 868 |         try:
 869 |             value = float(r.get("complexity", float("nan")))
 870 |         except (TypeError, ValueError):
 871 |             continue
 872 |         if np.isfinite(value):
 873 |             complexity_vals.append(value)
 874 |     aggregate_complexity = float(max(complexity_vals)) if complexity_vals else 0.0
 875 | 
 876 |     violation_errors = sorted(
 877 |         {
 878 |             str(r.get("error"))
 879 |             for r in per_dataset_results.values()
 880 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 881 |         }
 882 |     )
 883 |     failed_datasets = sorted(
 884 |         name
 885 |         for name, result in scoring_results.items()
 886 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 887 |     )
 888 |     templates = sorted(
 889 |         {
 890 |             str(r.get("equation_template"))
 891 |             for r in per_dataset_results.values()
 892 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 893 |         }
 894 |     )
 895 | 
 896 |     eq_template = ""
 897 |     for r in per_dataset_results.values():
 898 |         if r.get("equation"):
 899 |             eq_template = r["equation"]
 900 |             break
 901 | 
 902 |     hard_cases = [
 903 |         {"dataset": name, "nmse_val": float(result["nmse_val"])}
 904 |         for name, result in scoring_results.items()
 905 |         if np.isfinite(float(result.get("nmse_val", float("inf"))))
 906 |     ]
 907 |     hard_cases.sort(key=lambda item: item["nmse_val"], reverse=True)
 908 |     hard_cases = hard_cases[:5]
 909 |     hard_case_feedback = "; ".join(
 910 |         f"{case['dataset']} nmse={case['nmse_val']:.4g}" for case in hard_cases
 911 |     )
 912 | 
 913 |     violation_error = None
 914 |     if violation_errors:
 915 |         violation_error = violation_errors[0]
 916 |     elif failed_datasets:
 917 |         examples = ", ".join(failed_datasets[:3])
 918 |         violation_error = (
 919 |             "Single-equation violation: candidate failed on "
 920 |             f"{len(failed_datasets)}/{len(scoring_results)} validation datasets. "
 921 |             "Failed datasets are not dropped from the aggregate reward. "
 922 |             f"Examples: {examples}"
 923 |         )
 924 |     elif len(templates) > 1:
 925 |         examples = "; ".join(templates[:3])
 926 |         violation_error = (
 927 |             "Single-equation violation: evaluate_symbolic_candidate() produced "
 928 |             f"{len(templates)} distinct equation templates across datasets. "
 929 |             "The base equation must be identical for all datasets; only fitted "
 930 |             f"constants may vary. Example templates: {examples}"
 931 |         )
 932 | 
 933 |     if violation_error:
 934 |         agg_nmse = float("inf")
 935 |         mean_nmse = float("inf")
 936 |         agg_train_nmse = float("inf")
 937 |         agg_combined = 0.0
 938 |         n_successful = 0
 939 |     else:
 940 |         val_point_weights = [
 941 |             int(r.get("n_val_points", 0)) for r in scoring_results.values()
 942 |         ]
 943 |         mean_nmse = _point_weighted_mean(nmse_vals, val_point_weights)
 944 |         raw_mean_nmse = _point_weighted_mean(raw_nmse_vals, val_point_weights)
 945 |         eval_only_results = {
 946 |             name: result
 947 |             for name, result in scoring_results.items()
 948 |             if result.get("evaluation_only")
 949 |         }
 950 |         eval_only_nmse_vals = [
 951 |             float(result["nmse_val"])
 952 |             for result in eval_only_results.values()
 953 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
 954 |         ]
 955 |         eval_only_weights = [
 956 |             int(result.get("n_val_points", 0))
 957 |             for result in eval_only_results.values()
 958 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
 959 |         ]
 960 |         mean_nmse_eval_only = (
 961 |             _point_weighted_mean(eval_only_nmse_vals, eval_only_weights)
 962 |             if eval_only_nmse_vals
 963 |             else float("nan")
 964 |         )
 965 |         agg_nmse = mean_nmse
 966 |         agg_train_nmse = float(np.mean(train_nmse_vals)) if train_nmse_vals else float("inf")
 967 |         raw_combined = (
 968 |             float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
 969 |         )
 970 |         parsimony_factor = _parsimony_penalty_factor(aggregate_complexity)
 971 |         agg_combined = raw_combined * parsimony_factor
 972 |         n_successful = sum(1 for value in nmse_vals if np.isfinite(value))
 973 | 
 974 |     aggregated = {
 975 |         "equation": eq_template,
 976 |         "nmse_train": agg_train_nmse,
 977 |         "nmse_val": agg_nmse,
 978 |         "mean_nmse_val": mean_nmse,
 979 |         "mean_raw_nmse_val": raw_mean_nmse if not violation_error else float("inf"),
 980 |         "combined_score": agg_combined,
 981 |         "fit_score": raw_combined if not violation_error else 0.0,
 982 |         "complexity": aggregate_complexity,
 983 |         "parsimony_weight": PARSIMONY_WEIGHT,
 984 |         "parsimony_penalty_factor": (
 985 |             _parsimony_penalty_factor(aggregate_complexity) if not violation_error else 1.0
 986 |         ),
 987 |         "n_datasets": len(scoring_results),
 988 |         "n_total_datasets": len(per_dataset_results),
 989 |         "n_train_only_datasets": len(per_dataset_results) - len(scoring_results),
 990 |         "n_successful": n_successful,
 991 |         "n_evaluation_only_datasets": len(
 992 |             [name for name, result in per_dataset_results.items() if result.get("evaluation_only")]
 993 |         ),
 994 |         "mean_nmse_eval_only": (
 995 |             mean_nmse_eval_only if not violation_error else float("inf")
 996 |         ),
 997 |         "eval_workers": NUM_WORKERS,
 998 |         "hard_cases": hard_cases,
 999 |         "hard_case_feedback": hard_case_feedback,
1000 |         "per_dataset": per_dataset_results,
1001 |     }
1002 |     if violation_error:
1003 |         aggregated["error"] = violation_error
1004 |     return aggregated
1005 | 
