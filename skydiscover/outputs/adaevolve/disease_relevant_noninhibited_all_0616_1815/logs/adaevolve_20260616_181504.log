1152 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
1153 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
1154 |     nmse_val = float(result.get("nmse_val", float("inf")))
1155 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
1156 |     if not np.isfinite(combined):
1157 |         combined = 0.0
1158 | 
1159 |     return {
1160 |         "equation": str(result.get("equation", "")),
1161 |         "loss": nmse_val,
1162 |         "complexity": float(result.get("complexity", 0.0)),
1163 |         "nmse_train": float(result.get("nmse_train", float("inf"))),
1164 |         "nmse_val": nmse_val,
1165 |         "mean_nmse_val": float(result.get("mean_nmse_val", nmse_val)),
1166 |         "mean_raw_nmse_val": float(result.get("mean_raw_nmse_val", nmse_val)),
1167 |         "combined_score": combined,
1168 |         "fit_score": float(result.get("fit_score", combined)),
1169 |         "parsimony_weight": float(result.get("parsimony_weight", PARSIMONY_WEIGHT)),
1170 |         "parsimony_penalty_factor": float(result.get("parsimony_penalty_factor", 1.0)),
1171 |         "eval_time": float(eval_time),
1172 |         "n_datasets": result.get("n_datasets", 0),
1173 |         "n_successful": result.get("n_successful", 0),
1174 |         "eval_workers": result.get("eval_workers", NUM_WORKERS),
1175 |         "hard_cases": result.get("hard_cases", []),
1176 |         "hard_case_feedback": str(result.get("hard_case_feedback", "")),
1177 |         "per_dataset": result.get("per_dataset", {}),
1178 |         "error": str(result.get("error", "")),
1179 |     }
