 303 | 
 304 | def validate_candidate_source(program_path: str) -> None:
 305 |     """Reject reward-hacking program structure before importing candidate code."""
 306 |     source = Path(program_path).read_text()
 307 |     tree = ast.parse(source, filename=program_path)
 308 |     postponed_annotations = _has_postponed_annotations(tree)
 309 | 
 310 |     for node in tree.body:
 311 |         if _is_module_docstring(node) or _is_main_guard(node):
 312 |             continue
 313 |         if isinstance(node, ast.FunctionDef):
 314 |             _validate_top_level_function(node, postponed_annotations=postponed_annotations)
 315 |             continue
 316 |         if isinstance(node, ast.Import):
 317 |             for alias in node.names:
 318 |                 _validate_plain_import(alias)
 319 |         elif isinstance(node, ast.ImportFrom):
 320 |             module = node.module or ""
 321 |             if module not in _ALLOWED_FROM_IMPORTS:
 322 |                 raise ValueError(
 323 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: from-import '{module}' is not allowed."
 324 |                 )
 325 |             if module == "pysr_harness.equation_session":
 326 |                 aliased = [alias.name for alias in node.names if alias.asname]
 327 |                 if aliased:
 328 |                     raise ValueError(
 329 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: harness imports may not "
 330 |                         f"use aliases: {sorted(aliased)}."
 331 |                     )
 332 |                 imported = {alias.name for alias in node.names}
 333 |                 extra = imported - _ALLOWED_HARNESS_IMPORTS
 334 |                 if extra:
 335 |                     raise ValueError(
 336 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: unsupported harness imports "
 337 |                         f"{sorted(extra)}. Use only feature_symbols, constant_symbols, "
 338 |                         "and evaluate_expression."
 339 |                     )
 340 |         else:
 341 |             raise ValueError(
 342 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level executable code is not "
 343 |                 "allowed in candidate programs. Build and score the equation only "
 344 |                 "inside evaluate_symbolic_candidate()."
 345 |             )
 346 | 
 347 |     eval_fns = [
 348 |         node
 349 |         for node in tree.body
 350 |         if isinstance(node, ast.FunctionDef) and node.name == "evaluate_symbolic_candidate"
 351 |     ]
 352 |     if len(eval_fns) != 1:
 353 |         raise ValueError(
 354 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: program must define exactly one "
 355 |             "evaluate_symbolic_candidate() function."
 356 |         )
 357 |     fn = eval_fns[0]
 358 | 
 359 |     returns = [node for node in ast.walk(fn) if isinstance(node, ast.Return)]
 360 |     if len(returns) != 1:
 361 |         raise ValueError(
 362 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must have "
 363 |             "exactly one return statement."
 364 |         )
 365 |     return_value = returns[0].value
 366 |     if not (
 367 |         isinstance(return_value, ast.Call)
 368 |         and isinstance(return_value.func, ast.Name)
 369 |         and return_value.func.id == "evaluate_expression"
 370 |     ):
 371 |         raise ValueError(
 372 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must directly "
 373 |             "return evaluate_expression(...), with no wrapper or post-processing."
 374 |         )
 375 |     allowed_data_arg_ids = _validate_evaluate_expression_data_args(return_value)
 376 |     allowed_data_arg_ids.update(_allowed_feature_symbols_data_ids(fn))
 377 |     _validate_no_dataset_data_leak(fn, allowed_data_arg_ids)
 378 | 
 379 |     evaluate_calls = 0
 380 |     for node in ast.walk(fn):
 381 |         if isinstance(node, _DISALLOWED_CONTROL_NODES):
 382 |             raise ValueError(
 383 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: control flow, nested definitions, "
 384 |                 "comprehensions, and conditionals are not allowed inside "
 385 |                 "evaluate_symbolic_candidate(). Build one straight-line equation."
 386 |             )
 387 |         if isinstance(node, (ast.Import, ast.ImportFrom)):
 388 |             raise ValueError(
 389 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: imports are not allowed inside "
 390 |                 "evaluate_symbolic_candidate()."
 391 |             )
 392 |         if isinstance(node, (ast.Assign, ast.AnnAssign, ast.AugAssign)):
 393 |             targets = node.targets if isinstance(node, ast.Assign) else [node.target]
 394 |             assigned = set().union(*(_assigned_names(target) for target in targets))
 395 |             protected = assigned & _PROTECTED_NAMES
 396 |             if protected:
 397 |                 raise ValueError(
 398 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: cannot reassign protected scorer "
 399 |                     f"or harness names {sorted(protected)}."
 400 |                 )
 401 |         if isinstance(node, ast.Call):
 402 |             name = _call_name(node.func)
 403 |             if name == "evaluate_expression":
 404 |                 evaluate_calls += 1
 405 |             if name not in _ALLOWED_EVALUATE_CALLS:
 406 |                 raise ValueError(
 407 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: call '{name or type(node.func).__name__}' "
 408 |                     "is not allowed inside evaluate_symbolic_candidate(). Allowed calls "
 409 |                     "are the symbol helpers, evaluate_expression, and basic sp.* math."
 410 |                 )
 411 | 
 412 |     if evaluate_calls != 1:
 413 |         raise ValueError(
 414 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must call "
 415 |             f"evaluate_expression() exactly once; found {evaluate_calls} calls."
 416 |         )
 417 | 
 418 | 
 419 | def _parse_metadata_number(header: str, key: str) -> float | None:
 420 |     """Extract the leading numeric value for a cleaned header field."""
 421 |     match = re.search(
 422 |         rf"(?:^|[\s_]){re.escape(key)}:\s*([-+]?\d+(?:\.\d+)?(?:[eE][-+]?\d+)?)",
 423 |         header,
 424 |     )
 425 |     if match is None:
 426 |         return None
 427 |     return float(match.group(1))
 428 | 
 429 | 
 430 | def _is_x_column(header: str) -> bool:
 431 |     return bool(re.search(r"\s*X\s*$", header.strip()))
 432 | 
 433 | 
 434 | def _is_y_column(header: str) -> bool:
 435 |     return bool(re.search(r"\s*Y\s*$", header.strip()))
 436 | 
 437 | 
 438 | def _remember_curve_ids(X: np.ndarray, curve_ids: np.ndarray) -> np.ndarray:
 439 |     _ARRAY_CURVE_IDS[id(X)] = np.asarray(curve_ids, dtype=int)
 440 |     return X
 441 | 
 442 | 
 443 | def _minmax_normalize(values: np.ndarray) -> np.ndarray:
 444 |     """Normalize one dataset column to 0..1, preserving constants as zeros."""
 445 |     values = np.asarray(values, dtype=float)
 446 |     v_min = float(np.min(values))
 447 |     v_max = float(np.max(values))
 448 |     scale = v_max - v_min
 449 |     if scale <= 0.0:
 450 |         return np.zeros_like(values, dtype=float)
 451 |     return (values - v_min) / scale
 452 | 
 453 | 
 454 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 455 |     """Load cleaned data.tsv and return X=[normalized time, m0, M0], y.
 456 | 
 457 |     Cleaned files store one trajectory per adjacent X/Y column pair. Each
 458 |     column header contains m0, M0, and L0 metadata; only m0 and M0 are exposed
 459 |     as model features. Units are intentionally ignored per the cleaned-data
 460 |     note: the leading numeric value is used as provided.
 461 |     """
 462 |     with data_file.open(newline="") as f:
 463 |         reader = csv.reader(f, delimiter="\t")
 464 |         header = next(reader)
 465 |         rows = [row for row in reader if row]
 466 | 
 467 |     features: list[list[float]] = []
 468 |     targets: list[float] = []
 469 |     curve_ids: list[int] = []
 470 |     curve_id = 0
 471 |     for col_idx in range(len(header) - 1):
 472 |         x_header = header[col_idx]
 473 |         y_header = header[col_idx + 1]
 474 |         if not (_is_x_column(x_header) and _is_y_column(y_header)):
 475 |             continue
 476 |         m0 = _parse_metadata_number(x_header, "m0")
 477 |         seed_m0 = _parse_metadata_number(x_header, "M0")
 478 |         if m0 is None or seed_m0 is None:
 479 |             continue
 480 |         for row in rows:
 481 |             if col_idx + 1 >= len(row):
 482 |                 continue
 483 |             time_value = row[col_idx].strip()
 484 |             response_value = row[col_idx + 1].strip()
 485 |             if (
 486 |                 not time_value
 487 |                 or not response_value
 488 |                 or time_value.lower() == "nan"
 489 |                 or response_value.lower() == "nan"
 490 |             ):
 491 |                 continue
 492 |             features.append([float(time_value), m0, seed_m0])
 493 |             targets.append(float(response_value))
 494 |             curve_ids.append(curve_id)
 495 |         curve_id += 1
 496 | 
 497 |     if not features:
 498 |         raise ValueError(f"No regression samples loaded from {data_file}")
 499 | 
 500 |     X = np.asarray(features, dtype=float)
 501 |     y = np.asarray(targets, dtype=float)
 502 |     time_norm = _minmax_normalize(X[:, 0])
 503 |     monomer_raw = X[:, 1]
 504 |     seed_raw = X[:, 2]
 505 |     y_norm = _minmax_normalize(y)
 506 | 
 507 |     X_out = np.column_stack([time_norm, monomer_raw, seed_raw])
 508 |     return _remember_curve_ids(X_out, np.asarray(curve_ids, dtype=int)), y_norm
 509 | 
 510 | 
 511 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 512 |     """Recursively find all cleaned data.tsv files and return dataset entries."""
 513 |     datasets: list[tuple[str, Path]] = []
 514 |     for dirpath, _dirnames, filenames in os.walk(root):
 515 |         if "data.tsv" in filenames:
 516 |             fit_path = Path(dirpath) / "data.tsv"
 517 |             rel = fit_path.parent.relative_to(root)
 518 |             name = str(rel).replace(os.sep, "/")
 519 |             datasets.append((name, fit_path))
 520 |     datasets.sort(key=lambda x: x[0])
 521 |     return datasets
 522 | 
 523 | 
 524 | def _curve_indices(X: np.ndarray) -> list[np.ndarray]:
 525 |     """Return cleaned-trajectory row indices."""
 526 |     if X.shape[0] == 0:
 527 |         return []
 528 |     curve_ids = _ARRAY_CURVE_IDS.get(id(X))
 529 |     if curve_ids is not None and curve_ids.shape[0] == X.shape[0]:
 530 |         return [np.flatnonzero(curve_ids == curve_id) for curve_id in dict.fromkeys(curve_ids)]
 531 |     return [np.arange(X.shape[0], dtype=int)]
 532 | 
 533 | 
 534 | def _trajectory_preserving_split(
 535 |     X: np.ndarray,
 536 |     y: np.ndarray,
 537 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 538 |     """Split whole cleaned X/Y curves into fit and NMSE-evaluation sets."""
 539 |     curves = _curve_indices(X)
 540 |     rng = np.random.default_rng(RANDOM_STATE)
 541 | 
 542 |     if len(curves) < 3:
 543 |         empty_X = np.empty((0, X.shape[1]), dtype=float)
 544 |         empty_y = np.empty(0, dtype=float)
 545 |         return X, empty_X, y, empty_y
 546 | 
 547 |     shuffled = rng.permutation(len(curves))
 548 |     n_val_curves = min(
 549 |         max(1, int(round(len(curves) * TEST_SIZE))), len(curves) - 1
 550 |     )
 551 |     val_curve_ids = set(int(i) for i in shuffled[:n_val_curves])
 552 | 
 553 |     fit_indices: list[int] = []
 554 |     val_indices: list[int] = []
 555 |     for curve_id, curve_idx in enumerate(curves):
 556 |         if curve_id in val_curve_ids:
 557 |             val_indices.extend(curve_idx.tolist())
 558 |         else:
 559 |             fit_indices.extend(curve_idx.tolist())
 560 | 
 561 |     fit_idx = np.sort(np.asarray(fit_indices, dtype=int))
 562 |     val_idx = np.sort(np.asarray(val_indices, dtype=int))
 563 |     curve_ids = _ARRAY_CURVE_IDS.get(id(X), np.zeros(X.shape[0], dtype=int))
 564 |     X_fit = X[fit_idx]
 565 |     X_val = X[val_idx]
 566 |     _remember_curve_ids(X_fit, curve_ids[fit_idx])
 567 |     _remember_curve_ids(X_val, curve_ids[val_idx])
 568 |     return X_fit, X_val, y[fit_idx], y[val_idx]
 569 | 
 570 | 
 571 | def _evaluation_only_split(
 572 |     X: np.ndarray,
 573 |     y: np.ndarray,
 574 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 575 |     """Hold out an entire dataset for validation-only cross-protein evaluation."""
 576 |     empty_X = np.empty((0, X.shape[1]), dtype=float)
 577 |     empty_y = np.empty(0, dtype=float)
 578 |     _remember_curve_ids(empty_X, np.empty(0, dtype=int))
 579 |     _remember_curve_ids(X, _ARRAY_CURVE_IDS.get(id(X), np.zeros(X.shape[0], dtype=int)))
 580 |     return empty_X, X, empty_y, y
 581 | 
