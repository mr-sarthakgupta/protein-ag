1226 | def _eval_stage1_worker(args):
1227 |     """Module-level worker for stage 1 parallel evaluation."""
1228 |     name, X_train, X_val, y_train, y_val, program_path = args
1229 |     harness_root = str(BENCHMARK_ROOT)
1230 |     if harness_root not in sys.path:
1231 |         sys.path.insert(0, harness_root)
