 583 | def _dataset_name_from_path(data_file: Path, root: Path = DATA_ROOT) -> str:
 584 |     return str(data_file.parent.relative_to(root)).replace(os.sep, "/")
 585 | 
 586 | 
 587 | def load_dataset(
 588 |     data_file: Path,
 589 |     *,
 590 |     dataset_name: str | None = None,
 591 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 592 |     """Load a single data.tsv and return deterministic trajectory-preserving split."""
 593 |     X, y = _load_fit_table(data_file)
 594 |     name = dataset_name or _dataset_name_from_path(data_file)
 595 |     if name in EVALUATION_ONLY_DATASETS:
 596 |         return _evaluation_only_split(X, y)
 597 |     return _trajectory_preserving_split(X, y)
 598 | 
 599 | 
 600 | def load_all_datasets(
 601 |     root: Path = DATA_ROOT,
 602 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 603 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 604 |     entries = discover_datasets(root)
 605 |     results = []
 606 |     for name, path in entries:
 607 |         try:
 608 |             X_train, X_val, y_train, y_val = load_dataset(path, dataset_name=name)
 609 |             results.append((name, X_train, X_val, y_train, y_val))
 610 |         except Exception as exc:
 611 |             print(f"Warning: skipping dataset {name}: {exc}")
 612 |     return results
 613 | 
 614 | 
 615 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 616 | PARSIMONY_WEIGHT = float(os.environ.get("SKYDISCOVER_PARSIMONY_WEIGHT", "0.20"))
 617 | PARSIMONY_COMPLEXITY_SCALE = float(
 618 |     os.environ.get("SKYDISCOVER_PARSIMONY_COMPLEXITY_SCALE", "160")
 619 | )
 620 | 
 621 | 
 622 | def _parsimony_penalty_factor(complexity: float) -> float:
 623 |     """Bounded penalty factor for expression complexity."""
 624 |     if not np.isfinite(complexity) or PARSIMONY_COMPLEXITY_SCALE <= 0:
 625 |         return 1.0
 626 |     normalized = min(max(float(complexity), 0.0) / PARSIMONY_COMPLEXITY_SCALE, 1.0)
 627 |     return max(0.0, 1.0 - PARSIMONY_WEIGHT * normalized)
 628 | 
 629 | 
 630 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 631 |     values = np.asarray(values, dtype=float).ravel()
 632 |     if values.size < 3 or sigma <= 0.0:
 633 |         return values
 634 |     radius = max(1, int(round(3.0 * sigma)))
 635 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 636 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 637 |     kernel /= np.sum(kernel)
 638 |     padded = np.pad(values, (radius, radius), mode="edge")
 639 |     return np.convolve(padded, kernel, mode="valid")
 640 | 
 641 | 
 642 | def _curve_smoothed_target(X: np.ndarray, y_true: np.ndarray) -> np.ndarray:
 643 |     """Smooth targets independently for each parameter curve in time order."""
 644 |     X = np.asarray(X, dtype=float)
 645 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 646 |     if X.shape[0] != y_true.shape[0] or X.shape[1] < 2:
 647 |         return _gaussian_smooth_1d(y_true)
 648 | 
 649 |     smoothed = np.empty_like(y_true, dtype=float)
 650 |     for parameter in np.unique(X[:, 1]):
 651 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 652 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 653 |         smoothed_curve = _gaussian_smooth_1d(y_true[ordered_idx])
 654 |         smoothed[ordered_idx] = smoothed_curve
 655 |     return smoothed
 656 | 
 657 | 
 658 | def _normalized_mse_with_reference_variance(
 659 |     y_true: np.ndarray,
 660 |     y_pred: np.ndarray,
 661 |     reference_values: np.ndarray,
 662 | ) -> float:
 663 |     """MSE normalized by full dataset scale, not by a flat validation segment."""
 664 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 665 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 666 |     reference_values = np.asarray(reference_values, dtype=float).reshape(-1)
 667 |     if y_true.shape != y_pred.shape:
 668 |         return float("inf")
 669 |     if not np.all(np.isfinite(y_pred)):
 670 |         return float("inf")
 671 |     var = float(np.var(reference_values))
 672 |     if var <= 0.0:
 673 |         return float(np.mean((y_true - y_pred) ** 2))
 674 |     return float(np.mean((y_true - y_pred) ** 2) / var)
 675 | 
 676 | 
 677 | def _nmse_with_gaussian_smoothed_target(
 678 |     y_true: np.ndarray,
 679 |     y_pred: np.ndarray,
 680 |     X: np.ndarray | None = None,
 681 |     reference_values: np.ndarray | None = None,
 682 | ) -> float:
 683 |     reference = y_true if reference_values is None else reference_values
 684 |     return _normalized_mse_with_reference_variance(y_true, y_pred, reference)
 685 | 
 686 | 
 687 | def evaluate_symbolic_expression(
 688 |     expression: Any,
 689 |     X_train: np.ndarray,
 690 |     y_train: np.ndarray,
 691 |     X_val: np.ndarray,
 692 |     y_val: np.ndarray,
 693 |     *,
 694 |     constants: Any | None = None,
 695 |     initial_values: Any | None = None,
 696 |     max_nfev: int = 300,
 697 | ) -> dict[str, Any]:
 698 |     """Score a proposed expression by directly predicting normalized response."""
 699 |     import sympy as sp
 700 |     from pysr_harness import equation_session
 701 |     from scipy.optimize import least_squares
 702 | 
 703 |     X_train = np.asarray(X_train, dtype=float)
 704 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 705 |     X_val = np.asarray(X_val, dtype=float)
 706 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 707 |     evaluation_only = X_train.shape[0] == 0 and X_val.shape[0] > 0
 708 |     train_only = X_val.shape[0] == 0 and X_train.shape[0] > 0
 709 |     if evaluation_only:
 710 |         X_fit, y_fit = X_val, y_val
 711 |     else:
 712 |         X_fit, y_fit = X_train, y_train
 713 |     y_reference = np.concatenate([y_train, y_val]) if y_train.size else y_val
 714 |     n_features = X_fit.shape[1] if X_fit.shape[0] else X_val.shape[1]
 715 |     feature_names = [f"x{i}" for i in range(n_features)]
 716 |     template = equation_session._as_sympy_expr(expression, feature_names)
 717 |     equation_session._record_scored_template(template)
 718 | 
 719 |     if constants is None:
 720 |         feature_set = set(equation_session.feature_symbols(n_features))
 721 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 722 |     constants = list(constants)
 723 |     equation_session._validate_expression_template(template, constants)
 724 | 
 725 |     if initial_values is None:
 726 |         x0 = np.ones(len(constants), dtype=float)
 727 |     else:
 728 |         x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 729 |         if x0.size != len(constants):
 730 |             raise ValueError("initial_values must match the number of constants")
 731 | 
 732 |     if not constants:
 733 |         fitted_expr = template
 734 |         fitted_constants = {}
 735 |     else:
 736 |         feature_syms = equation_session.feature_symbols(n_features)
 737 |         X_cols = [X_fit[:, i] for i in range(n_features)]
 738 |         compiled = sp.lambdify(feature_syms + constants, template, modules=["numpy"])
 739 | 
 740 |         def residual(theta: np.ndarray) -> np.ndarray:
 741 |             try:
 742 |                 args = X_cols + [float(v) for v in theta]
 743 |                 prediction = np.asarray(compiled(*args), dtype=float).reshape(-1)
 744 |             except Exception:
 745 |                 return np.full_like(y_fit, 1e12, dtype=float)
 746 |             if prediction.shape != y_fit.shape or not np.all(np.isfinite(prediction)):
 747 |                 return np.full_like(y_fit, 1e12, dtype=float)
 748 |             return prediction - y_fit
 749 | 
 750 |         import warnings
 751 | 
 752 |         with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 753 |             warnings.simplefilter("ignore", RuntimeWarning)
 754 |             fit = least_squares(
 755 |                 residual,
 756 |                 x0,
 757 |                 loss="soft_l1",
 758 |                 max_nfev=max_nfev,
 759 |             )
 760 |         fitted_constants = {
 761 |             str(symbol): float(value) for symbol, value in zip(constants, fit.x)
 762 |         }
 763 |         fitted_expr = template.subs(dict(zip(constants, fit.x)))
 764 | 
 765 |     y_pred_fit = equation_session._predict(fitted_expr, X_fit, feature_names)
 766 |     y_pred_train = (
 767 |         np.empty(0, dtype=float)
 768 |         if evaluation_only
 769 |         else equation_session._predict(fitted_expr, X_train, feature_names)
 770 |     )
 771 |     y_pred_val = (
 772 |         np.empty(0, dtype=float)
 773 |         if train_only
 774 |         else equation_session._predict(fitted_expr, X_val, feature_names)
 775 |     )
 776 |     nmse_train = (
 777 |         float("nan")
 778 |         if evaluation_only
 779 |         else _nmse_with_gaussian_smoothed_target(
 780 |             y_train, y_pred_train, X_train, y_reference
 781 |         )
 782 |     )
 783 |     nmse_val = (
 784 |         float("nan")
 785 |         if train_only
 786 |         else _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 787 |     )
 788 |     loss = float(np.mean((y_pred_fit - y_fit) ** 2))
 789 | 
 790 |     result = {
 791 |         "equation_template": str(template),
 792 |         "equation": str(fitted_expr),
 793 |         "constants": fitted_constants,
 794 |         "loss": loss,
 795 |         "complexity": equation_session._complexity(template),
 796 |         "nmse_train": nmse_train,
 797 |         "nmse_val": nmse_val,
 798 |         "n_val_points": int(len(y_val)),
 799 |         "evaluation_only": evaluation_only,
 800 |         "train_only": train_only,
 801 |         "combined_score": (
 802 |             0.0
 803 |             if train_only or not np.isfinite(nmse_val)
 804 |             else combined_score_from_nmse(nmse_val)
 805 |         ),
 806 |     }
 807 |     equation_session._record_scorer_result(result)
 808 |     return result
 809 | 
 810 | 
 811 | def _point_weighted_mean(
 812 |     values: list[float],
 813 |     weights: list[int],
 814 | ) -> float:
 815 |     """Average values with one weight per evaluation point."""
 816 |     total_weight = sum(weights)
 817 |     if total_weight <= 0:
 818 |         return float("inf")
 819 |     weighted = sum(
 820 |         float(value) * float(weight)
 821 |         for value, weight in zip(values, weights)
 822 |         if np.isfinite(float(value))
 823 |     )
 824 |     if not np.isfinite(weighted):
 825 |         return float("inf")
 826 |     return float(weighted / total_weight)
 827 | 
 828 | 
 829 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 830 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 831 |     scoring_results = {
 832 |         name: result
 833 |         for name, result in per_dataset_results.items()
 834 |         if int(result.get("n_val_points", 0)) > 0
 835 |     }
 836 |     raw_nmse_vals = [float(r["nmse_val"]) for r in scoring_results.values()]
 837 |     nmse_vals = list(raw_nmse_vals)
 838 |     train_nmse_vals = [
 839 |         float(r["nmse_train"])
 840 |         for r in per_dataset_results.values()
 841 |         if np.isfinite(float(r.get("nmse_train", float("inf"))))
 842 |     ]
 843 |     complexity_vals = []
 844 |     for r in per_dataset_results.values():
 845 |         try:
 846 |             value = float(r.get("complexity", float("nan")))
 847 |         except (TypeError, ValueError):
 848 |             continue
 849 |         if np.isfinite(value):
 850 |             complexity_vals.append(value)
 851 |     aggregate_complexity = float(max(complexity_vals)) if complexity_vals else 0.0
 852 | 
 853 |     violation_errors = sorted(
 854 |         {
 855 |             str(r.get("error"))
 856 |             for r in per_dataset_results.values()
 857 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 858 |         }
 859 |     )
 860 |     failed_datasets = sorted(
 861 |         name
 862 |         for name, result in scoring_results.items()
 863 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 864 |     )
 865 |     templates = sorted(
 866 |         {
 867 |             str(r.get("equation_template"))
 868 |             for r in per_dataset_results.values()
 869 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 870 |         }
 871 |     )
 872 | 
 873 |     eq_template = ""
 874 |     for r in per_dataset_results.values():
 875 |         if r.get("equation"):
 876 |             eq_template = r["equation"]
 877 |             break
 878 | 
 879 |     hard_cases = [
 880 |         {"dataset": name, "nmse_val": float(result["nmse_val"])}
 881 |         for name, result in scoring_results.items()
 882 |         if np.isfinite(float(result.get("nmse_val", float("inf"))))
 883 |     ]
 884 |     hard_cases.sort(key=lambda item: item["nmse_val"], reverse=True)
 885 |     hard_cases = hard_cases[:5]
 886 |     hard_case_feedback = "; ".join(
 887 |         f"{case['dataset']} nmse={case['nmse_val']:.4g}" for case in hard_cases
 888 |     )
 889 | 
 890 |     violation_error = None
 891 |     if violation_errors:
 892 |         violation_error = violation_errors[0]
 893 |     elif failed_datasets:
 894 |         examples = ", ".join(failed_datasets[:3])
 895 |         violation_error = (
 896 |             "Single-equation violation: candidate failed on "
 897 |             f"{len(failed_datasets)}/{len(scoring_results)} validation datasets. "
 898 |             "Failed datasets are not dropped from the aggregate reward. "
 899 |             f"Examples: {examples}"
 900 |         )
 901 |     elif len(templates) > 1:
 902 |         examples = "; ".join(templates[:3])
 903 |         violation_error = (
 904 |             "Single-equation violation: evaluate_symbolic_candidate() produced "
 905 |             f"{len(templates)} distinct equation templates across datasets. "
 906 |             "The base equation must be identical for all datasets; only fitted "
 907 |             f"constants may vary. Example templates: {examples}"
 908 |         )
 909 | 
 910 |     if violation_error:
 911 |         agg_nmse = float("inf")
 912 |         mean_nmse = float("inf")
 913 |         agg_train_nmse = float("inf")
 914 |         agg_combined = 0.0
 915 |         n_successful = 0
 916 |     else:
 917 |         val_point_weights = [
 918 |             int(r.get("n_val_points", 0)) for r in scoring_results.values()
 919 |         ]
 920 |         mean_nmse = _point_weighted_mean(nmse_vals, val_point_weights)
 921 |         raw_mean_nmse = _point_weighted_mean(raw_nmse_vals, val_point_weights)
 922 |         eval_only_results = {
 923 |             name: result
 924 |             for name, result in scoring_results.items()
 925 |             if result.get("evaluation_only")
 926 |         }
 927 |         eval_only_nmse_vals = [
 928 |             float(result["nmse_val"])
 929 |             for result in eval_only_results.values()
 930 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
 931 |         ]
 932 |         eval_only_weights = [
 933 |             int(result.get("n_val_points", 0))
 934 |             for result in eval_only_results.values()
 935 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
 936 |         ]
 937 |         mean_nmse_eval_only = (
 938 |             _point_weighted_mean(eval_only_nmse_vals, eval_only_weights)
 939 |             if eval_only_nmse_vals
 940 |             else float("nan")
 941 |         )
 942 |         agg_nmse = mean_nmse
 943 |         agg_train_nmse = float(np.mean(train_nmse_vals)) if train_nmse_vals else float("inf")
 944 |         raw_combined = (
 945 |             float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
 946 |         )
 947 |         parsimony_factor = _parsimony_penalty_factor(aggregate_complexity)
 948 |         agg_combined = raw_combined * parsimony_factor
 949 |         n_successful = sum(1 for value in nmse_vals if np.isfinite(value))
 950 | 
 951 |     aggregated = {
 952 |         "equation": eq_template,
 953 |         "nmse_train": agg_train_nmse,
 954 |         "nmse_val": agg_nmse,
 955 |         "mean_nmse_val": mean_nmse,
 956 |         "mean_raw_nmse_val": raw_mean_nmse if not violation_error else float("inf"),
 957 |         "combined_score": agg_combined,
 958 |         "fit_score": raw_combined if not violation_error else 0.0,
 959 |         "complexity": aggregate_complexity,
 960 |         "parsimony_weight": PARSIMONY_WEIGHT,
 961 |         "parsimony_penalty_factor": (
 962 |             _parsimony_penalty_factor(aggregate_complexity) if not violation_error else 1.0
 963 |         ),
 964 |         "n_datasets": len(scoring_results),
 965 |         "n_total_datasets": len(per_dataset_results),
 966 |         "n_train_only_datasets": len(per_dataset_results) - len(scoring_results),
 967 |         "n_successful": n_successful,
 968 |         "n_evaluation_only_datasets": len(
 969 |             [name for name, result in per_dataset_results.items() if result.get("evaluation_only")]
 970 |         ),
 971 |         "mean_nmse_eval_only": (
 972 |             mean_nmse_eval_only if not violation_error else float("inf")
 973 |         ),
 974 |         "eval_workers": NUM_WORKERS,
 975 |         "hard_cases": hard_cases,
 976 |         "hard_case_feedback": hard_case_feedback,
 977 |         "per_dataset": per_dataset_results,
 978 |     }
 979 |     if violation_error:
 980 |         aggregated["error"] = violation_error
 981 |     return aggregated
