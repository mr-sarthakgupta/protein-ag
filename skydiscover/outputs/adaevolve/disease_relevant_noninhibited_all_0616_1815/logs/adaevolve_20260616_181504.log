# Simulate parsimony penalty for different complexities
# From the scoring: fit_score = 1/(1+nmse), combined = fit_score * parsimony_penalty
# parsimony_penalty_factor at complexity=28 is 0.9650, weight=0.2
# Need to understand the formula

# From the metrics: parsimony_weight=0.2, complexity=28 -> factor=0.9650
# Let's infer the formula
# If factor = 1 - weight * f(complexity), then 0.9650 = 1 - 0.2*f(28)
# f(28) = 0.175, so f(c) = c/160? -> 28/160=0.175. YES!
# factor = 1 - 0.2 * complexity/160 = 1 - complexity/800

for c in [18, 20, 22, 24, 26, 28, 30]:
    factor = 1.0 - 0.2 * c / 160
    # With nmse_val=0.0380:
    fit = 1/(1+0.0380)
    score = fit * factor
    print(f'complexity={c}: parsimony={factor:.4f}, combined={score:.4f} (vs current 0.9297)')
"
