 257 | def _x_train_shape_feature_arg_id(node: ast.AST) -> int | None:
 258 |     if not (
 259 |         isinstance(node, ast.Subscript)
 260 |         and isinstance(node.value, ast.Attribute)
 261 |         and node.value.attr == "shape"
 262 |         and isinstance(node.value.value, ast.Name)
 263 |         and node.value.value.id == "X_train"
 264 |     ):
 265 |         return None
 266 |     slice_node = node.slice
 267 |     if isinstance(slice_node, ast.Constant) and slice_node.value == 1:
 268 |         return id(node.value.value)
 269 |     return None
