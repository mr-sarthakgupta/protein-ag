 276 | 
 277 | def _allowed_feature_symbols_data_ids(fn: ast.FunctionDef) -> set[int]:
 278 |     allowed: set[int] = set()
 279 |     for node in ast.walk(fn):
 280 |         if not (
 281 |             isinstance(node, ast.Call)
 282 |             and isinstance(node.func, ast.Name)
 283 |             and node.func.id == "feature_symbols"
 284 |             and len(node.args) == 1
 285 |         ):
 286 |             continue
 287 |         x_train_id = _x_train_shape_feature_arg_id(node.args[0])
 288 |         if x_train_id is not None:
 289 |             allowed.add(x_train_id)
 290 |     return allowed
 291 | 
 292 | 
 293 | def _validate_no_dataset_data_leak(fn: ast.FunctionDef, allowed_node_ids: set[int]) -> None:
 294 |     for node in ast.walk(fn):
 295 |         if (
 296 |             isinstance(node, ast.Name)
 297 |             and node.id in {"X_train", "y_train", "X_val", "y_val"}
 298 |             and id(node) not in allowed_node_ids
 299 |         ):
 300 |             raise ValueError(
 301 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: dataset array '{node.id}' may only "
 302 |                 "appear in feature_symbols(X_train.shape[1]) or as the canonical "
 303 |                 "evaluate_expression(expression, X_train, y_train, X_val, y_val, ...) "
 304 |                 "arguments. Do not use dataset values to choose expressions, mutate "
 305 |                 "splits, or tune constants/initial values."
 306 |             )
