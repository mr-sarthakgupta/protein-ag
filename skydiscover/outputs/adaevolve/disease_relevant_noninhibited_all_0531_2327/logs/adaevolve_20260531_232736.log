import csv, os
from pathlib import Path

# Look at a few different datasets to understand patterns
base = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')
datasets = []
for dirpath, dirnames, filenames in os.walk(base):
    if 'fit.tsv' in filenames:
        datasets.append(Path(dirpath) / 'fit.tsv')
datasets.sort()
print(f'Total: {len(datasets)} datasets')
for p in datasets[:8]:
    with open(p) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = list(reader)
    n_cols = len(header) - 1
    n_rows = len(rows)
