$ python3 -c "
import csv, os, numpy as np, re
from pathlib import Path

base = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')
datasets = []
for dirpath, dirnames, filenames in os.walk(base):
    if 'fit.tsv' in filenames:
        datasets.append(Path(dirpath) / 'fit.tsv')
datasets.sort()
print(f'Total: {len(datasets)}')

# Understand all datasets
for p in datasets:
    with open(p) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [r for r in reader if r]
    n_cols = len(header) - 1
    times = [float(r[0]) for r in rows]
    # get y values for first curve
    y_vals = [float(r[1]) for r in rows if len(r) > 1 and r[1].strip()]
    y_min, y_max = min(y_vals), max(y_vals)
    # Check x1 type
    params = []
    for h in header[1:]:
        m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.IGNORECASE)
        m2 = re.search(r'(\d+(?:\.\d+)?)\s*mM', h, re.IGNORECASE)
        m3 = re.search(r'pH\s+(\d+(?:\.\d+)?)', h, re.IGNORECASE)
        if m: params.append(float(m.group(1)))
        elif m2: params.append(float(m2.group(1))*1000)
        elif m3: params.append(float(m3.group(1)))
        else: params.append(None)
    has_numeric = all(p is not None for p in params)
    x1_type = 'numeric' if has_numeric else 'sequential'
    # single x1?
    unique_x1 = len(set(str(p) for p in params))
    print(f'{p.parent.name[:35]:35s}: n_curves={n_cols}, x1_type={x1_type}, unique_x1={unique_x1}, y=[{y_min:.2f},{y_max:.2f}]')
"
