import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression, _aggregate_per_dataset_results
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()

x = feature_symbols(2)

def run_full(expr, c, initial, label):
    per_dataset = {}
    for name, X_train, X_val, y_train, y_val in datasets:
        r = evaluate_symbolic_expression(expr, X_train, y_train, X_val, y_val,
            constants=c, initial_values=initial)
        ev_only = (X_train.shape[0] == 0 and X_val.shape[0] > 0)
        per_dataset[name] = {
            'nmse_train': r['nmse_train'], 'nmse_val': r['nmse_val'],
            'n_val_points': r['n_val_points'], 'evaluation_only': ev_only,
            'combined_score': r['combined_score'], 'complexity': r['complexity'],
            'equation': r['equation'], 'equation_template': r['equation_template'],
        }
    agg = _aggregate_per_dataset_results(per_dataset)
    print(f'{label}: nmse={agg[\"nmse_val\"]:.4f}, combined={agg[\"combined_score\"]:.4f}, cx={agg[\"complexity\"]:.0f}')
    print(f'  hard: {agg[\"hard_case_feedback\"][:120]}')

# Current best
c = constant_symbols(7)
rate = c[0] * x[1]**c[1]; ht = c[2] * x[1]**c[3]
g = rate * (x[0] - ht)
expr = c[4] * ((1 + sp.tanh(g)) / 2)**c[5] + c[6]
run_full(expr, c, [5.0, 0.5, 0.5, -0.5, 1.0, 2.0, 0.0], 'Current tanh-Richards 7c cx24')

# Try: rate = c0 + c1*x1^c2 (additive baseline rate)
c = constant_symbols(8)
rate = c[0] + c[1] * x[1]**c[2]; ht = c[3] * x[1]**c[4]
g = rate * (x[0] - ht)
expr2 = c[5] * ((1 + sp.tanh(g)) / 2)**c[6] + c[7]
print(f'additive rate cx={_complexity(expr2)}')
run_full(expr2, c, [1.0, 4.0, 0.5, 0.5, -0.5, 1.0, 2.0, 0.0], 'additive rate 8c')

# Try: half_time = c2 / (x1^c3) - inverse power law (same as c2*x1^(-c3) but cleaner)
# Already covered by negative c3 in current

# Try: Alphasyn improvement - the second hardest. 
# Alphasyn has seed percentage as x1 (3, 5, 10%) - check if power law helps
for name, X_train, X_val, y_train, y_val in datasets:
    if 'Alphasyn' in name:
        print(f'Alphasyn x1 unique: {np.unique(np.concatenate([X_train[:,1], X_val[:,1]]))}')
        break
" 2>/dev/null
