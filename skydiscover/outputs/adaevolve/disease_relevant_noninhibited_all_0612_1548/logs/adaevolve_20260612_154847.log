import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares, curve_fit
import warnings
warnings.filterwarnings('ignore')

datasets = load_all_datasets()
ds = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

name = 'Abeta/Meisl2014/Ab40_sec_IN_HOURS'
X_train, X_val, y_train, y_val = ds[name]

# Get actual half-times per curve
actual_ht = {}
for x1v in np.unique(X_val[:,1]):
    mask = X_val[:,1] == x1v
    x0s = X_val[mask,0]
    ys = y_val[mask]
    sidx = np.argsort(x0s)
    x0s, ys = x0s[sidx], ys[sidx]
    # Interpolate for y=0.5
    idx = np.argmin(np.abs(ys - 0.5))
    if idx > 0 and idx < len(ys)-1:
        # linear interp
        if ys[idx] >= 0.5:
            ht = np.interp(0.5, [ys[idx-1], ys[idx]], [x0s[idx-1], x0s[idx]])
        else:
            ht = np.interp(0.5, [ys[idx], ys[idx+1]], [x0s[idx], x0s[idx+1]])
    else:
        ht = x0s[idx]
    actual_ht[x1v] = ht

x1_arr = np.array(sorted(actual_ht.keys()))
ht_arr = np.array([actual_ht[x] for x in x1_arr])
print('x1, actual_ht, log(x1), log(ht):')
for x1v, ht in zip(x1_arr, ht_arr):
    print(f'  x1={x1v:.1f}, ht={ht:.4f}, log(x1)={np.log(x1v):.3f}, log(ht)={np.log(ht):.3f}')

# Fit power law: ht = a * x1^b
log_x1 = np.log(x1_arr)
log_ht = np.log(ht_arr)
b, log_a = np.polyfit(log_x1, log_ht, 1)
a = np.exp(log_a)
print(f'Power law fit: ht = {a:.4f} * x1^{b:.4f}')
pred_ht = a * x1_arr**b
print(f'Residuals: {(ht_arr - pred_ht).round(4)}')
"
