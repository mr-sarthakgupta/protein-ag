import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets

datasets = load_all_datasets()
# Check all datasets with val points - look at y_start (baseline offset)
print('Dataset | ncurves | x1_range | y_start | y_end | shape')
for name, X_train, X_val, y_train, y_val in datasets:
    if y_val.size == 0:
        continue
    X_all = np.concatenate([X_train, X_val]) if X_train.size else X_val
    y_all = np.concatenate([y_train, y_val]) if y_train.size else y_val
    x1_vals = np.unique(X_all[:,1])
    # Average y_start and y_end across curves
    y_starts, y_ends = [], []
    for x1v in x1_vals:
        mask = X_all[:,1] == x1v
        x0 = X_all[mask, 0]
        y = y_all[mask]
        order = np.argsort(x0)
        ys = y[order]
        y_starts.append(ys[:3].mean())
        y_ends.append(ys[-3:].mean())
    y_s = np.mean(y_starts)
    y_e = np.mean(y_ends)
    print(f'{name[:50]}: nc={len(x1_vals)}, x1=[{x1_vals.min():.0f},{x1_vals.max():.0f}], y0={y_s:.3f}, yend={y_e:.3f}')
" 2>/dev/null
