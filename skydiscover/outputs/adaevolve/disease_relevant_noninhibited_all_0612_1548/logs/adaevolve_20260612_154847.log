import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import curve_fit

datasets = load_all_datasets()
ds = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

def model_orig(X, c0, c1, c2, c3, c4):
    x0v, x1v = X[:,0], X[:,1]
    return c3 * np.tanh(c0 * x0v * x1v**c1 + c2) + c4

# Test lysozyme with different initial values
name = 'lysozyme/Fits/Hasecke2018_7uM_sec'
X_all = ds[name][1]  # only val
y_all = ds[name][3]
var = np.var(y_all)

# Try multiple initial conditions
inits = [
    [5.0, 0.5, -2.5, 0.5, 0.5],
    [10.0, 0.0, -5.0, 0.5, 0.5],   # c1=0 makes x1^c1=1, simplifies
    [10.0, 0.0, -7.0, 0.5, 0.5],
    [8.0, 1.0, -5.0, 0.5, 0.5],
    [5.0, 0.0, -3.5, 0.5, 0.5],
    [15.0, 0.0, -10.0, 0.5, 0.5],
]
for p0 in inits:
    try:
        popt, _ = curve_fit(model_orig, X_all, y_all, p0=p0, maxfev=10000)
        y_pred = model_orig(ds[name][1], *popt)
        nmse = np.mean((y_all - y_pred)**2) / (var + 1e-10)
        print(f'p0={p0} -> NMSE={nmse:.4f}, popt={popt.round(3)}')
    except Exception as e:
        print(f'p0={p0} -> FAILED: {e}')
