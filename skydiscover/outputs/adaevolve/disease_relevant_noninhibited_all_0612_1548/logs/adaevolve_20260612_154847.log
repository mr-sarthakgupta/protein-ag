import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression, _aggregate_per_dataset_results
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()
x = feature_symbols(2)

def run_full(expr, c, initial, label):
    per_dataset = {}
    for name, X_train, X_val, y_train, y_val in datasets:
        r = evaluate_symbolic_expression(expr, X_train, y_train, X_val, y_val,
            constants=c, initial_values=initial)
        ev_only = (X_train.shape[0] == 0 and X_val.shape[0] > 0)
        per_dataset[name] = {
            'nmse_train': r['nmse_train'], 'nmse_val': r['nmse_val'],
            'n_val_points': r['n_val_points'], 'evaluation_only': ev_only,
            'combined_score': r['combined_score'], 'complexity': r['complexity'],
            'equation': r['equation'], 'equation_template': r['equation_template'],
        }
    agg = _aggregate_per_dataset_results(per_dataset)
    print(f'{label}: nmse={agg[\"nmse_val\"]:.5f}, combined={agg[\"combined_score\"]:.5f}, cx={agg[\"complexity\"]:.0f}')
    return agg

# Best Knowles-simple: g = c0*(x0*x1^c1 - c2)
c = constant_symbols(6)
g = c[0] * (x[0] * x[1]**c[1] - c[2])
expr_kn = c[3] * ((1 + sp.tanh(g)) / 2)**c[4] + c[5]

# Try to push NMSE lower by adding back the separate ht exponent
# g = c0*(x0*x1^c1 - c2*x1^c3)  -- 7c, cx=24 (same as current but different factoring)
c7 = constant_symbols(7)
g7 = c7[0] * (x[0] * x[1]**c7[1] - c7[2] * x[1]**c7[3])
expr7 = c7[4] * ((1 + sp.tanh(g7)) / 2)**c7[5] + c7[6]
print(f'expanded cx={_complexity(expr7)}')
run_full(expr7, c7, [5.0, 0.5, 0.5, 0.0, 1.0, 2.0, 0.0], 'expanded 7c cx24')
run_full(expr7, c7, [3.0, 0.5, 0.3, 0.0, 1.0, 1.5, 0.0], 'expanded 7c init2')

# Check: is the Knowles-simple form mathematically equivalent to current when c3=c1?
# Current: c0*x1^c1*(x0 - c2*x1^c3)
# Knowles: c0*(x0*x1^c1 - c2) = c0*x1^c1*x0 - c0*c2
# These differ! Knowles has constant c2 (not x1-dependent half-time)
# So Knowles is: rate=c0*x1^c1, half_time=c2/(c0*x1^c1) -- x1-dependent half-time!

# Let's verify the Knowles form on Alphasyn
for name, X_train, X_val, y_train, y_val in datasets:
    if 'Alphasyn' in name:
        r = evaluate_symbolic_expression(expr_kn, X_train, y_train, X_val, y_val,
            constants=c, initial_values=[3.0, 0.5, 0.3, 1.0, 1.5, 0.0])
        print(f'Alphasyn Knowles: nmse_train={r[\"nmse_train\"]:.5f}, nmse_val={r[\"nmse_val\"]:.5f}')
        break

# Also try: Knowles + Richards exponent as free param (7c, cx=24)
c7b = constant_symbols(7)
g7b = c7b[0] * (x[0] * x[1]**c7b[1] - c7b[2])
expr7b = c7b[3] * ((1 + sp.tanh(g7b)) / 2)**c7b[4] + c7b[5]
print(f'Knowles+Richards cx={_complexity(expr7b)}')
run_full(expr7b, c7b[:6], [3.0, 0.5, 0.3, 1.0, 1.5, 0.0], 'Knowles no-Richards 6c')
run_full(expr7b, c7b, [3.0, 0.5, 0.3, 1.0, 1.5, 0.0, 0.0], 'Knowles+Richards 7c')
" 2>/dev/null
