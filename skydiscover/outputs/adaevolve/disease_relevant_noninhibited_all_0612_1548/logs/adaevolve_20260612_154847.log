 301 | def validate_candidate_source(program_path: str) -> None:
 302 |     """Reject reward-hacking program structure before importing candidate code."""
 303 |     source = Path(program_path).read_text()
 304 |     tree = ast.parse(source, filename=program_path)
 305 |     postponed_annotations = _has_postponed_annotations(tree)
 306 | 
 307 |     for node in tree.body:
 308 |         if _is_module_docstring(node) or _is_main_guard(node):
 309 |             continue
 310 |         if isinstance(node, ast.FunctionDef):
 311 |             _validate_top_level_function(node, postponed_annotations=postponed_annotations)
 312 |             continue
 313 |         if isinstance(node, ast.Import):
 314 |             for alias in node.names:
 315 |                 _validate_plain_import(alias)
 316 |         elif isinstance(node, ast.ImportFrom):
 317 |             module = node.module or ""
 318 |             if module not in _ALLOWED_FROM_IMPORTS:
 319 |                 raise ValueError(
 320 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: from-import '{module}' is not allowed."
 321 |                 )
 322 |             if module == "pysr_harness.equation_session":
 323 |                 aliased = [alias.name for alias in node.names if alias.asname]
 324 |                 if aliased:
 325 |                     raise ValueError(
 326 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: harness imports may not "
 327 |                         f"use aliases: {sorted(aliased)}."
 328 |                     )
 329 |                 imported = {alias.name for alias in node.names}
 330 |                 extra = imported - _ALLOWED_HARNESS_IMPORTS
 331 |                 if extra:
 332 |                     raise ValueError(
 333 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: unsupported harness imports "
 334 |                         f"{sorted(extra)}. Use only feature_symbols, constant_symbols, "
 335 |                         "and evaluate_expression."
 336 |                     )
 337 |         else:
 338 |             raise ValueError(
 339 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level executable code is not "
 340 |                 "allowed in candidate programs. Build and score the equation only "
 341 |                 "inside evaluate_symbolic_candidate()."
 342 |             )
 343 | 
 344 |     eval_fns = [
 345 |         node
 346 |         for node in tree.body
 347 |         if isinstance(node, ast.FunctionDef) and node.name == "evaluate_symbolic_candidate"
 348 |     ]
 349 |     if len(eval_fns) != 1:
 350 |         raise ValueError(
 351 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: program must define exactly one "
 352 |             "evaluate_symbolic_candidate() function."
 353 |         )
 354 |     fn = eval_fns[0]
 355 | 
 356 |     returns = [node for node in ast.walk(fn) if isinstance(node, ast.Return)]
 357 |     if len(returns) != 1:
 358 |         raise ValueError(
 359 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must have "
 360 |             "exactly one return statement."
 361 |         )
 362 |     return_value = returns[0].value
 363 |     if not (
 364 |         isinstance(return_value, ast.Call)
 365 |         and isinstance(return_value.func, ast.Name)
 366 |         and return_value.func.id == "evaluate_expression"
 367 |     ):
 368 |         raise ValueError(
 369 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must directly "
 370 |             "return evaluate_expression(...), with no wrapper or post-processing."
 371 |         )
 372 |     allowed_data_arg_ids = _validate_evaluate_expression_data_args(return_value)
 373 |     allowed_data_arg_ids.update(_allowed_feature_symbols_data_ids(fn))
 374 |     _validate_no_dataset_data_leak(fn, allowed_data_arg_ids)
 375 | 
 376 |     evaluate_calls = 0
 377 |     for node in ast.walk(fn):
 378 |         if isinstance(node, _DISALLOWED_CONTROL_NODES):
 379 |             raise ValueError(
 380 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: control flow, nested definitions, "
 381 |                 "comprehensions, and conditionals are not allowed inside "
 382 |                 "evaluate_symbolic_candidate(). Build one straight-line equation."
 383 |             )
 384 |         if isinstance(node, (ast.Import, ast.ImportFrom)):
 385 |             raise ValueError(
 386 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: imports are not allowed inside "
 387 |                 "evaluate_symbolic_candidate()."
 388 |             )
 389 |         if isinstance(node, (ast.Assign, ast.AnnAssign, ast.AugAssign)):
 390 |             targets = node.targets if isinstance(node, ast.Assign) else [node.target]
 391 |             assigned = set().union(*(_assigned_names(target) for target in targets))
 392 |             protected = assigned & _PROTECTED_NAMES
 393 |             if protected:
 394 |                 raise ValueError(
 395 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: cannot reassign protected scorer "
 396 |                     f"or harness names {sorted(protected)}."
 397 |                 )
 398 |         if isinstance(node, ast.Call):
 399 |             name = _call_name(node.func)
 400 |             if name == "evaluate_expression":
 401 |                 evaluate_calls += 1
 402 |             if name not in _ALLOWED_EVALUATE_CALLS:
 403 |                 raise ValueError(
 404 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: call '{name or type(node.func).__name__}' "
 405 |                     "is not allowed inside evaluate_symbolic_candidate(). Allowed calls "
 406 |                     "are the symbol helpers, evaluate_expression, and basic sp.* math."
 407 |                 )
 408 | 
 409 |     if evaluate_calls != 1:
 410 |         raise ValueError(
 411 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must call "
 412 |             f"evaluate_expression() exactly once; found {evaluate_calls} calls."
 413 |         )
 414 | 
 415 | 
 416 | def _parse_parameter_from_column(column_name: str) -> float | None:
 417 |     """Extract a monomer/protein concentration from a fit.tsv column header.
 418 | 
 419 |     Only concentration-like labels are accepted:
 420 |       - "... : 10uM"  or "10 uM"  -> 10.0
 421 |       - "35uM" (bare, as in Abeta) -> 35.0
 422 |       - "... : 3.95mM"             -> 3950.0  (converted to uM)
 423 |       - "... : 0.3 mg/mL 22uM"    -> 22.0    (prefer uM when both present)
 424 | 
 425 |     Seed percentages, pH values, ng/uL seed-material labels, and generic
 426 |     numeric fallbacks are intentionally ignored so x1 consistently represents
 427 |     the aggregating monomer/protein concentration when available.
 428 |     """
 429 |     text = column_name.strip()
 430 |     # Prefer the human-readable condition after the file-name prefix. Some
 431 |     # filenames contain seed concentrations that should not become x1.
 432 |     condition_text = text.rsplit(":", 1)[-1].strip().strip("\"'")
 433 | 
 434 |     # Prefer an explicit uM value
 435 |     m = re.search(r"(\d+(?:\.\d+)?)\s*uM", condition_text, re.IGNORECASE)
 436 |     if m:
 437 |         return float(m.group(1))
 438 | 
 439 |     # mM -> convert to uM
 440 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mM", condition_text, re.IGNORECASE)
 441 |     if m:
 442 |         return float(m.group(1)) * 1000.0
 443 | 
 444 |     # mg/mL (take the number)
 445 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mg/mL", condition_text, re.IGNORECASE)
 446 |     if m:
 447 |         return float(m.group(1))
 448 | 
 449 |     return None
 450 | 
 451 | 
 452 | def _minmax_normalize(values: np.ndarray) -> np.ndarray:
 453 |     """Normalize one dataset column to 0..1, preserving constants as zeros."""
 454 |     values = np.asarray(values, dtype=float)
 455 |     v_min = float(np.min(values))
 456 |     v_max = float(np.max(values))
 457 |     scale = v_max - v_min
 458 |     if scale <= 0.0:
 459 |         return np.zeros_like(values, dtype=float)
 460 |     return (values - v_min) / scale
 461 | 
 462 | 
 463 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 464 |     """Load a wide fit.tsv and return X=[normalized time, raw parameter], y.
 465 | 
 466 |     The first column is always the time/measurement coordinate. Remaining
 467 |     columns are response curves. The varying parameter is extracted from
 468 |     concentration-like curve headers only; non-concentration columns are skipped.
 469 |     Time is min-max normalized to 0..1, but the parameter column is left in its
 470 |     parsed raw units. The response is normalized globally across the whole
 471 |     fit.tsv to 0..1. Files already rescaled to 0..1 keep that scale.
 472 |     """
 473 |     with data_file.open(newline="") as f:
 474 |         reader = csv.reader(f, delimiter="\t")
 475 |         header = next(reader)
 476 | 
 477 |         response_headers = header[1:]
 478 |         parsed_params = [_parse_parameter_from_column(h) for h in response_headers]
 479 | 
 480 |         features: list[list[float]] = []
 481 |         targets: list[float] = []
 482 |         for row in reader:
 483 |             if not row:
 484 |                 continue
 485 |             measurement_x = float(row[0])
 486 |             for param, value in zip(parsed_params, row[1:]):
 487 |                 if param is None:
 488 |                     continue
 489 |                 if value == "" or value.strip().lower() == "nan":
 490 |                     continue
 491 |                 features.append([measurement_x, param])
 492 |                 targets.append(float(value))
 493 | 
 494 |     if not features:
 495 |         raise ValueError(f"No regression samples loaded from {data_file}")
 496 | 
 497 |     X = np.asarray(features, dtype=float)
 498 |     y = np.asarray(targets, dtype=float)
 499 |     time_norm = _minmax_normalize(X[:, 0])
 500 |     parameter_raw = X[:, 1]
 501 |     y_norm = _minmax_normalize(y)
 502 | 
 503 |     return np.column_stack([time_norm, parameter_raw]), y_norm
 504 | 
 505 | 
 506 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 507 |     """Recursively find all fit.tsv files and return (dataset_name, path) pairs."""
 508 |     datasets: list[tuple[str, Path]] = []
 509 |     for dirpath, _dirnames, filenames in os.walk(root):
 510 |         if "fit.tsv" in filenames:
 511 |             fit_path = Path(dirpath) / "fit.tsv"
 512 |             rel = fit_path.parent.relative_to(root)
 513 |             name = str(rel).replace(os.sep, "/")
 514 |             datasets.append((name, fit_path))
 515 |     datasets.sort(key=lambda x: x[0])
 516 |     return datasets
 517 | 
 518 | 
 519 | def _trajectory_preserving_split(
 520 |     X: np.ndarray,
 521 |     y: np.ndarray,
 522 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 523 |     """Split whole parameter curves into fit (train) and NMSE-evaluation (val) sets."""
 524 |     parameters = np.unique(X[:, 1])
 525 |     rng = np.random.default_rng(RANDOM_STATE)
 526 | 
 527 |     if len(parameters) < 3:
 528 |         empty_X = np.empty((0, X.shape[1]), dtype=float)
 529 |         empty_y = np.empty(0, dtype=float)
 530 |         return X, empty_X, y, empty_y
 531 | 
 532 |     shuffled = parameters[rng.permutation(len(parameters))]
 533 |     n_val_curves = min(
 534 |         max(1, int(round(len(parameters) * TEST_SIZE))), len(parameters) - 1
 535 |     )
 536 |     val_params = {float(p) for p in shuffled[:n_val_curves]}
 537 | 
 538 |     fit_indices: list[int] = []
 539 |     val_indices: list[int] = []
 540 |     for parameter in parameters:
 541 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 542 |         if float(parameter) in val_params:
 543 |             val_indices.extend(curve_idx.tolist())
 544 |         else:
 545 |             fit_indices.extend(curve_idx.tolist())
 546 | 
 547 |     fit_idx = np.sort(np.asarray(fit_indices, dtype=int))
 548 |     val_idx = np.sort(np.asarray(val_indices, dtype=int))
 549 |     return X[fit_idx], X[val_idx], y[fit_idx], y[val_idx]
 550 | 
 551 | 
 552 | def _evaluation_only_split(
 553 |     X: np.ndarray,
 554 |     y: np.ndarray,
 555 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 556 |     """Hold out an entire dataset for validation-only cross-protein evaluation."""
 557 |     empty_X = np.empty((0, X.shape[1]), dtype=float)
 558 |     empty_y = np.empty(0, dtype=float)
 559 |     return empty_X, X, empty_y, y
 560 | 
 561 | 
 562 | def _dataset_name_from_path(data_file: Path, root: Path = DATA_ROOT) -> str:
 563 |     return str(data_file.parent.relative_to(root)).replace(os.sep, "/")
 564 | 
 565 | 
 566 | def load_dataset(
 567 |     data_file: Path,
 568 |     *,
 569 |     dataset_name: str | None = None,
 570 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 571 |     """Load a single fit.tsv and return deterministic trajectory-preserving split."""
 572 |     X, y = _load_fit_table(data_file)
 573 |     name = dataset_name or _dataset_name_from_path(data_file)
 574 |     if name in EVALUATION_ONLY_DATASETS:
 575 |         return _evaluation_only_split(X, y)
 576 |     return _trajectory_preserving_split(X, y)
 577 | 
 578 | 
 579 | def load_all_datasets(
 580 |     root: Path = DATA_ROOT,
 581 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 582 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 583 |     entries = discover_datasets(root)
 584 |     results = []
 585 |     for name, path in entries:
 586 |         try:
 587 |             X_train, X_val, y_train, y_val = load_dataset(path, dataset_name=name)
 588 |             results.append((name, X_train, X_val, y_train, y_val))
 589 |         except Exception as exc:
 590 |             print(f"Warning: skipping dataset {name}: {exc}")
 591 |     return results
