import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()

def fit_and_score(model_fn, x0_init, X_train, y_train, X_val, y_val):
    X_fit = X_val if X_train.size == 0 else X_train
    y_fit = y_train if X_train.size > 0 else y_val
    x0v, x1v = X_fit[:,0], X_fit[:,1]
    def residual(theta):
        pred = model_fn(theta, x0v, x1v)
        if not np.all(np.isfinite(pred)): return np.full_like(y_fit, 1e6)
        return pred - y_fit
    res = least_squares(residual, x0_init, loss='soft_l1', max_nfev=1000)
    pred_val = model_fn(res.x, X_val[:,0], X_val[:,1])
    ref = np.concatenate([y_train, y_val]) if y_train.size else y_val
    nmse = np.mean((pred_val - y_val)**2) / max(np.var(ref), 1e-12)
    return nmse, res.x

# Power law model - key question: is x1^c3 stable for half-time?
# When x1 varies widely (e.g., 344 to 3444 for insulin), x1^c3 can blow up
# Better: use c2/x1^c3 or c2*exp(c3*log(x1)) which is same as power law

# Try: rate = c0 * x1^c1, half_time = c2 / (c0 * x1^c1)^c3
# Or: use log-linear for half_time, power for rate
def m_pow_log_ht(theta, x0, x1):
    c0,c1,c2,c3,c4,c5,c6 = theta
    rate = c0 * np.maximum(x1, 1e-10)**c1
    ht = c2 + c3*np.log(np.maximum(x1, 1e-10))
    return c4 / (1 + np.exp(-rate*(x0-ht)))**np.maximum(c5, 0.01) + c6

# Pure power law (both)
def m_pow(theta, x0, x1):
    c0,c1,c2,c3,c4,c5,c6 = theta
    rate = c0 * np.maximum(x1, 1e-10)**c1
    ht = c2 * np.maximum(x1, 1e-10)**c3
    return c4 / (1 + np.exp(-rate*(x0-ht)))**np.maximum(c5, 0.01) + c6

# Power law without Richards exponent (simpler, complexity~25)
def m_pow_simple(theta, x0, x1):
    c0,c1,c2,c3,c4,c5 = theta
    rate = c0 * np.maximum(x1, 1e-10)**c1
    ht = c2 * np.maximum(x1, 1e-10)**c3
    return c4 / (1 + np.exp(-rate*(x0-ht))) + c5

results = {'pow': [], 'pow_log_ht': [], 'pow_simple': []}
for name, X_train, X_val, y_train, y_val in datasets:
    if y_val.size == 0: continue
    try:
        n1, _ = fit_and_score(m_pow, [0.1,0.5,10.,-0.5,1.,1.,0.], X_train, y_train, X_val, y_val)
        n2, _ = fit_and_score(m_pow_log_ht, [0.1,0.5,0.3,-0.05,1.,1.,0.], X_train, y_train, X_val, y_val)
        n3, _ = fit_and_score(m_pow_simple, [0.1,0.5,10.,-0.5,1.,0.], X_train, y_train, X_val, y_val)
        results['pow'].append((name, n1, len(y_val)))
        results['pow_log_ht'].append((name, n2, len(y_val)))
        results['pow_simple'].append((name, n3, len(y_val)))
    except Exception as e:
        pass

def wmean(r):
    tw = sum(w for _,_,w in r)
    return sum(v*w for _,v,w in r)/tw if tw else float('inf')

for k,v in results.items():
    print(f'{k}: wmean={wmean(v):.4f}')

print()
print('Hard cases pow_simple:')
for name, nmse, nv in sorted(results['pow_simple'], key=lambda x: -x[1])[:5]:
    print(f'  {name[:55]}: {nmse:.4f}')
" 2>/dev/null
