import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares
import sympy as sp

datasets = load_all_datasets()

# Manually fit current best expression on the Abeta Cohen2013 dataset
# to see residuals
for name, X_train, X_val, y_train, y_val in datasets:
    if 'Cohen2013' not in name:
        continue
    # Eval-only dataset: fit on val
    X_fit = X_val
    y_fit = y_val
    x0 = X_fit[:,0]
    x1 = X_fit[:,1]
    
    def model(theta, x0, x1):
        c0,c1,c2,c3,c4,c5,c6 = theta
        rate = c0 + c1*np.log(x1)
        ht = c2 + c3*np.log(x1)
        return c4 / (1 + np.exp(-rate*(x0-ht)))**c5 + c6
    
    def residual(theta):
        pred = model(theta, x0, x1)
        if not np.all(np.isfinite(pred)):
            return np.full_like(y_fit, 1e6)
        return pred - y_fit
    
    x0_init = [10.0, 0.0, 0.3, -0.05, 1.0, 2.0, 0.0]
    res = least_squares(residual, x0_init, loss='soft_l1', max_nfev=1000)
    pred = model(res.x, x0, x1)
    nmse = np.mean((pred - y_fit)**2) / np.var(y_fit)
    print(f'{name}: nmse={nmse:.4f}, constants={[f\"{v:.3f}\" for v in res.x]}')
    
    # Check residuals by concentration
    x1_vals = np.unique(x1)
    for x1v in x1_vals:
        mask = x1 == x1v
        r = pred[mask] - y_fit[mask]
        print(f'  x1={x1v:.1f}: mse={np.mean(r**2):.4f}')
