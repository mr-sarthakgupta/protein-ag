import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()

def test_expr(expr, constants, initial, label):
    results = []
    npts = []
    for name, X_train, X_val, y_train, y_val in datasets:
        if len(y_val) == 0:
            continue
        r = evaluate_symbolic_expression(expr, X_train, y_train, X_val, y_val,
            constants=constants, initial_values=initial)
        results.append((name, r['nmse_val'], len(y_val)))
        npts.append(len(y_val))
    results.sort(key=lambda x: x[1], reverse=True)
    nmse_vals = [v for _, v, _ in results]
    npts2 = [n for _, _, n in results]
    weighted = np.sum([n*v for n,v in zip(npts2, nmse_vals)]) / np.sum(npts2)
    cx = _complexity(expr)
    parsimony = max(0, 1 - 0.2*(cx/160))
    fit_score = 1/(1+weighted)
    combined = fit_score * parsimony
    print(f'{label}: cx={cx}, wmean={weighted:.4f}, combined={combined:.4f}')
    print(f'  top3: {[(n.split(\"/\")[-1][:20], round(v,4)) for n,v,_ in results[:3]]}')

x = feature_symbols(2)

# Try: tanh with additive x1 term in half-time instead of power law
# half_time = c2 + c3*log(x1)  -- log scaling for concentration
c = constant_symbols(7)
rate = c[0] * x[1]**c[1]
ht = c[2] + c[3] * sp.log(x[1])
g = rate * (x[0] - ht)
expr_log = c[4] * ((1 + sp.tanh(g)) / 2)**c[5] + c[6]
test_expr(expr_log, c, [5.0, 0.5, 0.5, -0.3, 1.0, 2.0, 0.0], 'tanh-Richards log ht 7c')

# Try: simpler - just standard logistic with power law, 6c (no Richards exponent)
c = constant_symbols(6)
rate = c[0] * x[1]**c[1]
ht = c[2] * x[1]**c[3]
g = rate * (x[0] - ht)
expr_std = c[4] * (1 + sp.tanh(g)) / 2 + c[5]
test_expr(expr_std, c, [5.0, 0.5, 0.5, -0.5, 1.0, 0.0], 'simple tanh power-law 6c')

# Try: tanh-Richards with c5 fixed to 2 (baked in) - 6 constants
# y = c4 * ((1+tanh(c0*x1^c1*(x0 - c2*x1^c3)))/2)^2 + c5
c = constant_symbols(6)
rate = c[0] * x[1]**c[1]
ht = c[2] * x[1]**c[3]
g = rate * (x[0] - ht)
expr_sq = c[4] * ((1 + sp.tanh(g)) / 2)**2 + c[5]
test_expr(expr_sq, c, [5.0, 0.5, 0.5, -0.5, 1.0, 0.0], 'tanh^2 fixed Richards 6c')

# Try: double sigmoid - two transitions
c = constant_symbols(8)
rate1 = c[0] * x[1]**c[1]
ht1 = c[2] * x[1]**c[3]
rate2 = c[4]
ht2 = c[5]
g1 = rate1 * (x[0] - ht1)
g2 = rate2 * (x[0] - ht2)
expr_double = c[6] * (1 + sp.tanh(g1)) / 2 * (1 + sp.tanh(g2)) / 2 + c[7]
test_expr(expr_double, c, [5.0, 0.5, 0.5, -0.5, 10.0, 0.8, 1.0, 0.0], 'double sigmoid 8c')
