import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np

datasets = load_all_datasets()

for name, Xtr, Xval, ytr, yval in datasets:
    if 'seeded' in name and 'Nielsen' in name:
        # What does a constant prediction give?
        y_mean = yval.mean()
        var = np.var(yval)
        mse_constant = np.mean((yval - y_mean)**2)
        nmse_constant = mse_constant / var
        print(f'Mean y = {y_mean:.4f}, var = {var:.4f}')
        print(f'NMSE with constant (mean): {nmse_constant:.4f}')
        
        # What does a sigmoid fit give (current model nmse=0.6453)?
        # The var-normalized NMSE for a constant = 1.0 (by definition of R^2)
        # But wait - the NMSE here is normalized by full dataset variance
        # For eval-only dataset, reference = val data itself
        # So nmse_constant = mean((y - mean)^2) / var(y) = 1.0
        print(f'Expected NMSE for constant = {1.0:.4f}')
        
        # What about a step function at t=0.1?
        y_pred_step = np.where(Xval[:,0] < 0.15, 0.0, 1.0)
        mse_step = np.mean((yval - y_pred_step)**2)
        nmse_step = mse_step / var
        print(f'NMSE with step at t=0.15: {nmse_step:.4f}')
        
        # What does the current fitted sigmoid look like?
        # It gets 0.6453 - better than constant (1.0) but still bad
        # The data has a rising trend from 0 to 1 overall, but with zeros at later times
        
        # What fraction of points are zero?
        n_zero = np.sum(yval < 0.01)
        print(f'Fraction near-zero: {n_zero}/{len(yval)} = {n_zero/len(yval):.3f}')
        
        # What's the pattern of zeros?
        t = Xval[:,0]; order = np.argsort(t)
        t_s = t[order]; y_s = yval[order]
        zero_times = t_s[y_s < 0.01]
        print(f'Zero times: {zero_times[:15].round(3)}')
        break
" 2>/dev/null
