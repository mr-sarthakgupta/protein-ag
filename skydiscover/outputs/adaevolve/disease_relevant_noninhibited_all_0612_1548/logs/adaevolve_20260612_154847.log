 285 | def _validate_no_dataset_data_leak(fn: ast.FunctionDef, allowed_node_ids: set[int]) -> None:
 286 |     for node in ast.walk(fn):
 287 |         if (
 288 |             isinstance(node, ast.Name)
 289 |             and node.id in {"X_train", "y_train", "X_val", "y_val"}
 290 |             and id(node) not in allowed_node_ids
 291 |         ):
 292 |             raise ValueError(
 293 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: dataset array '{node.id}' may only "
 294 |                 "appear in feature_symbols(X_train.shape[1]) or as the canonical "
 295 |                 "evaluate_expression(expression, X_train, y_train, X_val, y_val, ...) "
 296 |                 "arguments. Do not use dataset values to choose expressions, mutate "
 297 |                 "splits, or tune constants/initial values."
 298 |             )
