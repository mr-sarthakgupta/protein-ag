 579 | def load_all_datasets(
 580 |     root: Path = DATA_ROOT,
 581 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 582 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 583 |     entries = discover_datasets(root)
 584 |     results = []
 585 |     for name, path in entries:
 586 |         try:
 587 |             X_train, X_val, y_train, y_val = load_dataset(path, dataset_name=name)
 588 |             results.append((name, X_train, X_val, y_train, y_val))
 589 |         except Exception as exc:
 590 |             print(f"Warning: skipping dataset {name}: {exc}")
 591 |     return results
