rate = c[0]*parameter**c[1]; ht = c[2]*parameter**c[3]
u = rate*(time-ht)
expr_tanh_rich = c[4] * ((1 + sp.tanh(u))/2)**c[5] + c[6]
print(f'tanh-Richards complexity: {_complexity(expr_tanh_rich)}')

nmses, weights = [], []
for name, Xtr, Xval, ytr, yval in val_datasets:
    r = evaluate_symbolic_expression(expr_tanh_rich, Xtr, ytr, Xval, yval, constants=c,
                                      initial_values=[5.0, 0.5, 0.5, -0.5, 1.0, 2.0, 0.0])
    nv = r.get('nmse_val', float('inf'))
    if np.isfinite(nv): nmses.append(nv); weights.append(len(yval))
wmean = sum(n*w for n,w in zip(nmses,weights))/sum(weights)
print(f'tanh-Richards: wmean_nmse={wmean:.4f} n={len(nmses)}/{len(val_datasets)}')

# Also try: exp(-exp(-c0*x1^c1*(x0-c2*x1^c3))) Gompertz with Richards power
c2 = constant_symbols(7)
rate2 = c2[0]*parameter**c2[1]; ht2 = c2[2]*parameter**c2[3]
u2 = rate2*(time-ht2)
expr_gomp_rich = c2[4] * sp.exp(-sp.exp(-u2))**c2[5] + c2[6]
print(f'Gompertz-Richards complexity: {_complexity(expr_gomp_rich)}')

nmses2, weights2 = [], []
for name, Xtr, Xval, ytr, yval in val_datasets:
    r = evaluate_symbolic_expression(expr_gomp_rich, Xtr, ytr, Xval, yval, constants=c2,
                                      initial_values=[5.0, 0.5, 0.5, -0.5, 1.0, 1.0, 0.0])
    nv = r.get('nmse_val', float('inf'))
    if np.isfinite(nv): nmses2.append(nv); weights2.append(len(yval))
wmean2 = sum(n*w for n,w in zip(nmses2,weights2))/sum(weights2)
print(f'Gompertz-Richards: wmean_nmse={wmean2:.4f} n={len(nmses2)}/{len(val_datasets)}')
