import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression, _aggregate_per_dataset_results
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()
x = feature_symbols(2)

def run_full(expr, c, initial, label):
    per_dataset = {}
    for name, X_train, X_val, y_train, y_val in datasets:
        r = evaluate_symbolic_expression(expr, X_train, y_train, X_val, y_val,
            constants=c, initial_values=initial)
        ev_only = (X_train.shape[0] == 0 and X_val.shape[0] > 0)
        per_dataset[name] = {
            'nmse_train': r['nmse_train'], 'nmse_val': r['nmse_val'],
            'n_val_points': r['n_val_points'], 'evaluation_only': ev_only,
            'combined_score': r['combined_score'], 'complexity': r['complexity'],
            'equation': r['equation'], 'equation_template': r['equation_template'],
        }
    agg = _aggregate_per_dataset_results(per_dataset)
    print(f'{label}: nmse={agg[\"nmse_val\"]:.5f}, combined={agg[\"combined_score\"]:.5f}, cx={agg[\"complexity\"]:.0f}')
    return agg

# Current best
c = constant_symbols(7)
rate = c[0] * x[1]**c[1]; ht = c[2] * x[1]**c[3]
g = rate * (x[0] - ht)
expr_curr = c[4] * ((1 + sp.tanh(g)) / 2)**c[5] + c[6]
run_full(expr_curr, c, [5.0, 0.5, 0.5, -0.5, 1.0, 2.0, 0.0], 'Current cx24')

# Alphasyn has x1 = seed percentage (1,2,3,5,10,20,30,50%)
# Let's look at what the current expression fits for Alphasyn
for name, X_train, X_val, y_train, y_val in datasets:
    if 'Alphasyn' in name:
        r = evaluate_symbolic_expression(expr_curr, X_train, y_train, X_val, y_val,
            constants=c, initial_values=[5.0, 0.5, 0.5, -0.5, 1.0, 2.0, 0.0])
        print(f'Alphasyn: nmse_train={r[\"nmse_train\"]:.5f}, nmse_val={r[\"nmse_val\"]:.5f}')
        print(f'  constants: {r[\"constants\"]}')
        break

# Try: Knowles-style - rate scales as x1^n2, half_time as x1^(-n2/2)
# So c1 = n2, c3 = -n2/2 -> c3 = -c1/2 (linked). But we can't enforce this constraint.
# Instead try: g = c0*(x0*x1^c1 - c2) -- simpler, rate scales with x1^c1
c = constant_symbols(6)
g = c[0] * (x[0] * x[1]**c[1] - c[2])
expr_kn = c[3] * ((1 + sp.tanh(g)) / 2)**c[4] + c[5]
print(f'Knowles-style cx={_complexity(expr_kn)}')
run_full(expr_kn, c, [5.0, 0.5, 0.5, 1.0, 2.0, 0.0], 'Knowles-simple 6c')

# Try: tanh with x1^c1 in rate and x1^c3 in ht, but also an additive x1 term
# rate = c0 * x1^c1, ht = c2 * x1^c3 + c4 (ht has a constant floor)
c = constant_symbols(8)
rate = c[0] * x[1]**c[1]; ht = c[2] * x[1]**c[3] + c[4]
g = rate * (x[0] - ht)
expr_ht2 = c[5] * ((1 + sp.tanh(g)) / 2)**c[6] + c[7]
print(f'ht+floor cx={_complexity(expr_ht2)}')
run_full(expr_ht2, c, [5.0, 0.5, 0.5, -0.5, 0.0, 1.0, 2.0, 0.0], 'ht+floor 8c')
