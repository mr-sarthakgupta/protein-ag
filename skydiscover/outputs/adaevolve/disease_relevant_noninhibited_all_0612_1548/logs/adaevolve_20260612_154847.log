import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression, _aggregate_per_dataset_results
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()
x = feature_symbols(2)

def run_full(expr, c, initial, label):
    per_dataset = {}
    for name, X_train, X_val, y_train, y_val in datasets:
        r = evaluate_symbolic_expression(expr, X_train, y_train, X_val, y_val,
            constants=c, initial_values=initial)
        ev_only = (X_train.shape[0] == 0 and X_val.shape[0] > 0)
        per_dataset[name] = {
            'nmse_train': r['nmse_train'], 'nmse_val': r['nmse_val'],
            'n_val_points': r['n_val_points'], 'evaluation_only': ev_only,
            'combined_score': r['combined_score'], 'complexity': r['complexity'],
            'equation': r['equation'], 'equation_template': r['equation_template'],
        }
    agg = _aggregate_per_dataset_results(per_dataset)
    print(f'{label}: nmse={agg[\"nmse_val\"]:.5f}, combined={agg[\"combined_score\"]:.5f}, cx={agg[\"complexity\"]:.0f}')
    print(f'  hard: {agg[\"hard_case_feedback\"][:100]}')
    return agg

# 3c: (1+tanh(c0*x0*x1^c1 - c2))/2  cx=15
c3 = constant_symbols(3)
g3 = c3[0] * x[0] * x[1]**c3[1] - c3[2]
expr3 = (1 + sp.tanh(g3)) / 2
run_full(expr3, c3, [3.0, 0.5, 1.0], '3c cx15 [BEST]')

# Check per-dataset breakdown for 3c
per_dataset = {}
for name, X_train, X_val, y_train, y_val in datasets:
    r = evaluate_symbolic_expression(expr3, X_train, y_train, X_val, y_val,
        constants=c3, initial_values=[3.0, 0.5, 1.0])
    ev_only = (X_train.shape[0] == 0 and X_val.shape[0] > 0)
    per_dataset[name] = {
        'nmse_train': r['nmse_train'], 'nmse_val': r['nmse_val'],
        'n_val_points': r['n_val_points'], 'evaluation_only': ev_only,
        'combined_score': r['combined_score'], 'complexity': r['complexity'],
        'equation': r['equation'], 'equation_template': r['equation_template'],
    }

# Show all val datasets sorted by nmse
val_results = [(name, r['nmse_val'], r['n_val_points']) for name, r in per_dataset.items() if r['n_val_points'] > 0]
val_results.sort(key=lambda x: x[1], reverse=True)
print('Top 10 hard cases for 3c:')
for name, nmse, n in val_results[:10]:
    print(f'  n={n:4d} nmse={nmse:.5f}  {name}')

# Compare with current on same datasets
c7 = constant_symbols(7)
rate7 = c7[0] * x[1]**c7[1]; ht7 = c7[2] * x[1]**c7[3]
g7 = rate7 * (x[0] - ht7)
expr7 = c7[4] * ((1 + sp.tanh(g7)) / 2)**c7[5] + c7[6]
per_dataset7 = {}
for name, X_train, X_val, y_train, y_val in datasets:
    r = evaluate_symbolic_expression(expr7, X_train, y_train, X_val, y_val,
        constants=c7, initial_values=[5.0, 0.5, 0.5, -0.5, 1.0, 2.0, 0.0])
    ev_only = (X_train.shape[0] == 0 and X_val.shape[0] > 0)
    per_dataset7[name] = {'nmse_val': r['nmse_val'], 'n_val_points': r['n_val_points']}

print('Comparison 3c vs 7c for hard cases:')
for name, nmse3, n in val_results[:10]:
    nmse7 = per_dataset7.get(name, {}).get('nmse_val', float('inf'))
    diff = nmse3 - nmse7
    print(f'  3c={nmse3:.5f} 7c={nmse7:.5f} diff={diff:+.5f}  {name.split(\"/\")[-1]}')
