import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np

datasets = load_all_datasets()

# Simulate current model fit on a few datasets to understand residuals
# Current model: c4 / (1 + exp(-c0*x1^c1 * (x0 - c2*x1^c3)))^c5 + c6
# Check: does the sigmoid midpoint shift significantly with x1?
print('Checking midpoint shift with concentration:')
for name, Xtr, Xval, ytr, yval in datasets:
    if Xval.shape[0] > 0 and len(set(Xval[:,1].tolist())) >= 4:
        x1_vals = sorted(set(Xval[:,1].tolist()))
        midpoints = []
        for x1v in x1_vals:
            idx = Xval[:,1] == x1v
            t = Xval[idx,0]
            y = yval[idx]
            order = np.argsort(t)
            t_s, y_s = t[order], y[order]
            # Find approximate midpoint (y=0.5)
            above = np.where(y_s > 0.5)[0]
            if len(above) > 0:
                midpoints.append((x1v, t_s[above[0]]))
        if len(midpoints) >= 3:
            print(f'{name[:45]}: midpoints={[(round(x,1),round(t,3)) for x,t in midpoints[:5]]}')
" 2>/dev/null
