import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import curve_fit
import warnings
warnings.filterwarnings('ignore')

datasets = load_all_datasets()
ds = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

def model(X, c0, c1, c2, c3, c4):
    x0v, x1v = X[:,0], X[:,1]
    return c3 * np.tanh(c0 * x0v * x1v**c1 + c2) + c4

# Check IAPP and hnRNPA datasets
for dname in ['IAPP/Daval2010/Fits/Daval2010_prim', 'IAPP/Daval2010/Fits/Daval2010_sec', 'hnRNPA/Kim2013/Fits/Kim2013_A1_prim']:
    X_train, X_val, y_train, y_val = ds[dname]
    X_all = np.vstack([X_train, X_val]) if X_train.shape[0]>0 else X_val
    y_all = np.concatenate([y_train, y_val]) if X_train.shape[0]>0 else y_val
    print(f'=== {dname} ===')
    print(f'  x1 unique: {np.unique(X_all[:,1])}')
    print(f'  x0 range: [{X_all[:,0].min():.3f}, {X_all[:,0].max():.3f}]')
    print(f'  y range: [{y_all.min():.3f}, {y_all.max():.3f}]')
    var = np.var(y_all)
    for p0 in [[5.,0.5,-2.5,0.5,0.5],[5.,0.,-2.5,0.5,0.5],[5.,1.,-2.5,0.5,0.5],[10.,0.,-5.,0.5,0.5]]:
        try:
            popt, _ = curve_fit(model, X_all, y_all, p0=p0, maxfev=5000)
            yp = model(X_val, *popt)
            nmse = np.mean((y_val-yp)**2)/(var+1e-10)
            print(f'  p0={p0} -> NMSE={nmse:.4f}')
        except Exception as e:
            print(f'  p0={p0} -> FAILED')
"
