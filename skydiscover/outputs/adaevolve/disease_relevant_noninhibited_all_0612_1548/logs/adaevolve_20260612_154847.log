import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()
x = feature_symbols(2)

def run_full(expr, c, initial, label):
    per_dataset = {}
    for name, X_train, X_val, y_train, y_val in datasets:
        r = evaluate_symbolic_expression(expr, X_train, y_train, X_val, y_val,
            constants=c, initial_values=initial)
        ev_only = (X_train.shape[0] == 0 and X_val.shape[0] > 0)
        per_dataset[name] = {
            'nmse_train': r['nmse_train'], 'nmse_val': r['nmse_val'],
            'n_val_points': r['n_val_points'], 'evaluation_only': ev_only,
            'combined_score': r['combined_score'], 'complexity': r['complexity'],
            'equation': r['equation'], 'equation_template': r['equation_template'],
        }
    agg = _aggregate_per_dataset_results(per_dataset)
    print(f'{label}: nmse={agg[\"nmse_val\"]:.5f}, combined={agg[\"combined_score\"]:.5f}, cx={agg[\"complexity\"]:.0f}')
    return agg

# 3c best: (1+tanh(c0*x0*x1^c1 - c2))/2  cx=15
c3 = constant_symbols(3)
g3 = c3[0] * x[0] * x[1]**c3[1] - c3[2]
expr3 = (1 + sp.tanh(g3)) / 2
run_full(expr3, c3, [3.0, 0.5, 1.0], '3c cx15 [BEST so far]')

# 4c: add amplitude only (cx=17)
c4a = constant_symbols(4)
g4a = c4a[0] * x[0] * x[1]**c4a[1] - c4a[2]
expr4a = c4a[3] * (1 + sp.tanh(g4a)) / 2
print(f'4c-amp cx={_complexity(expr4a)}')
run_full(expr4a, c4a, [3.0, 0.5, 1.0, 1.0], '4c-amp cx17')

# 4c: add offset only (cx=17)
c4b = constant_symbols(4)
g4b = c4b[0] * x[0] * x[1]**c4b[1] - c4b[2]
expr4b = (1 + sp.tanh(g4b)) / 2 + c4b[3]
