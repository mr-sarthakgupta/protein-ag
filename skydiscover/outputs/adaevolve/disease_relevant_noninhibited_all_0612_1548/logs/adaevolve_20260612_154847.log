sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()

# Test current solution on all datasets, collect per-dataset NMSE
x = feature_symbols(2)
c = constant_symbols(7)
time = x[0]
parameter = x[1]
rate = c[0] * parameter ** c[1]
half_time = c[2] * parameter ** c[3]
growth = rate * (time - half_time)
expr = c[4] * ((1 + sp.tanh(growth)) / 2) ** c[5] + c[6]
initial = [5.0, 0.5, 0.5, -0.5, 1.0, 2.0, 0.0]

results = []
for name, X_train, X_val, y_train, y_val in datasets:
    if len(y_val) == 0:
        continue
    r = evaluate_symbolic_expression(expr, X_train, y_train, X_val, y_val,
        constants=c, initial_values=initial)
    results.append((name, r['nmse_val']))

results.sort(key=lambda x: x[1], reverse=True)
print('Top 10 hardest datasets (nmse_val):')
for name, nmse in results[:10]:
    print(f'  {nmse:.4f}  {name}')
print()
print(f'Mean nmse_val: {np.mean([v for _,v in results if np.isfinite(v)]):.4f}')
