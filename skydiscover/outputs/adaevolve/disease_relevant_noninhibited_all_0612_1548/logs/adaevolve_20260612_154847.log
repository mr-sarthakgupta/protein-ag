import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression, _aggregate_per_dataset_results
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()
x = feature_symbols(2)

def run_full(expr, c, initial, label):
    per_dataset = {}
    for name, X_train, X_val, y_train, y_val in datasets:
        r = evaluate_symbolic_expression(expr, X_train, y_train, X_val, y_val,
            constants=c, initial_values=initial)
        ev_only = (X_train.shape[0] == 0 and X_val.shape[0] > 0)
        per_dataset[name] = {
            'nmse_train': r['nmse_train'], 'nmse_val': r['nmse_val'],
            'n_val_points': r['n_val_points'], 'evaluation_only': ev_only,
            'combined_score': r['combined_score'], 'complexity': r['complexity'],
            'equation': r['equation'], 'equation_template': r['equation_template'],
        }
    agg = _aggregate_per_dataset_results(per_dataset)
    print(f'{label}: nmse={agg[\"nmse_val\"]:.5f}, combined={agg[\"combined_score\"]:.5f}, cx={agg[\"complexity\"]:.0f}')

# Current best baseline
c = constant_symbols(7)
rate = c[0] * x[1]**c[1]; ht = c[2] * x[1]**c[3]
g = rate * (x[0] - ht)
expr = c[4] * ((1 + sp.tanh(g)) / 2)**c[5] + c[6]
run_full(expr, c, [5.0, 0.5, 0.5, -0.5, 1.0, 2.0, 0.0], 'Current tanh-Richards')

# Try different initial values for current expression
run_full(expr, c, [10.0, 1.0, 0.5, -1.0, 1.0, 1.5, 0.0], 'tanh-Richards init2')
run_full(expr, c, [3.0, 0.3, 0.3, -0.3, 1.0, 3.0, 0.0], 'tanh-Richards init3')

# Try: x1 enters both rate and half-time via same power
# rate = c0 * x1^c1, half_time = c2 * x1^c1 (shared exponent -> 6c)
c = constant_symbols(6)
rate = c[0] * x[1]**c[1]; ht = c[2] * x[1]**c[1]
g = rate * (x[0] - ht)
expr_shared = c[3] * ((1 + sp.tanh(g)) / 2)**c[4] + c[5]
print(f'shared-exp cx={_complexity(expr_shared)}')
run_full(expr_shared, c, [5.0, 0.5, 0.5, 1.0, 2.0, 0.0], 'shared-exp tanh-Richards 6c')

# Try: half_time = c2 (constant, no x1 dependence) - 6c
c = constant_symbols(6)
rate = c[0] * x[1]**c[1]; ht = c[2]
g = rate * (x[0] - ht)
expr_noht = c[3] * ((1 + sp.tanh(g)) / 2)**c[4] + c[5]
print(f'const-ht cx={_complexity(expr_noht)}')
run_full(expr_noht, c, [5.0, 0.5, 0.5, 1.0, 2.0, 0.0], 'const-ht tanh-Richards 6c')

# Try: x1 only in rate (not half-time) - 5c
c = constant_symbols(5)
rate = c[0] * x[1]**c[1]; ht = c[2]
g = rate * (x[0] - ht)
expr_rate_only = c[3] * ((1 + sp.tanh(g)) / 2)**c[4]
print(f'rate-only cx={_complexity(expr_rate_only)}')
run_full(expr_rate_only, c, [5.0, 0.5, 0.5, 1.0, 2.0], 'rate-only tanh-Richards 5c')
