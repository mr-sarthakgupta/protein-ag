 254 | def _x_train_shape_feature_arg_id(node: ast.AST) -> int | None:
 255 |     if not (
 256 |         isinstance(node, ast.Subscript)
 257 |         and isinstance(node.value, ast.Attribute)
 258 |         and node.value.attr == "shape"
 259 |         and isinstance(node.value.value, ast.Name)
 260 |         and node.value.value.id == "X_train"
 261 |     ):
 262 |         return None
 263 |     slice_node = node.slice
 264 |     if isinstance(slice_node, ast.Constant) and slice_node.value == 1:
 265 |         return id(node.value.value)
 266 |     return None
