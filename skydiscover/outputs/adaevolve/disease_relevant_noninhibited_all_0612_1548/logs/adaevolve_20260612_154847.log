import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import curve_fit
import warnings
warnings.filterwarnings('ignore')

datasets = load_all_datasets()

def model(X, c0, c1, c2, c3, c4):
    x0v, x1v = X[:,0], X[:,1]
    return c3 * np.tanh(c0 * x0v * x1v**c1 + c2) + c4

p0_old = [5.0, 0.5, -2.5, 0.5, 0.5]
p0_new = [5.0, 0.0, -2.5, 0.5, 0.5]

total_old, total_new, total_pts = 0.0, 0.0, 0

for name, X_train, X_val, y_train, y_val in datasets:
    if len(y_val) == 0:
        continue
    X_all = np.vstack([X_train, X_val]) if X_train.shape[0]>0 else X_val
    y_all = np.concatenate([y_train, y_val]) if X_train.shape[0]>0 else y_val
    var = np.var(y_all)
    n = len(y_val)
    
    nmse_old, nmse_new = 999.0, 999.0
    try:
        popt, _ = curve_fit(model, X_all, y_all, p0=p0_old, maxfev=5000)
        y_pred = model(X_val, *popt)
        nmse_old = np.mean((y_val-y_pred)**2)/(var+1e-10)
    except: pass
    try:
        popt2, _ = curve_fit(model, X_all, y_all, p0=p0_new, maxfev=5000)
        y_pred2 = model(X_val, *popt2)
        nmse_new = np.mean((y_val-y_pred2)**2)/(var+1e-10)
    except: pass
    
    total_old += nmse_old * n
    total_new += nmse_new * n
    total_pts += n
    if abs(nmse_old - nmse_new) > 0.001:
        print(f'old={nmse_old:.4f} new={nmse_new:.4f} n={n} | {name}')

print(f'Weighted NMSE: old={total_old/total_pts:.4f}, new={total_new/total_pts:.4f}')
print(f'Total val pts: {total_pts}')
"
