from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np

datasets = load_all_datasets()

for name, Xtr, Xval, ytr, yval in datasets:
    if 'seeded' in name and 'Nielsen' in name:
        t = Xval[:,0]; order = np.argsort(t)
        t_s = t[order]; y_s = yval[order]
        
        # At each unique time, compute mean of non-zero values and zero count
        unique_t = np.unique(t_s)
        print(f'Unique time points: {len(unique_t)}')
        
        # For each time, compute the 3 values
        best_preds = []
        for ti in unique_t:
            idx = t_s == ti
            vals = y_s[idx]
            # Best prediction minimizes MSE = predict mean
            best_preds.extend([vals.mean()] * len(vals))
        
        best_preds = np.array(best_preds)
        var = np.var(y_s)
        mse_oracle = np.mean((y_s - best_preds)**2)
        nmse_oracle = mse_oracle / var
        print(f'Oracle (per-time mean) NMSE: {nmse_oracle:.4f}')
        
        # What if we fit just the two non-zero replicates and ignore zeros?
        # Predict the mean of non-zero values at each time
        nz_preds = []
        for ti in unique_t:
            idx = t_s == ti
            vals = y_s[idx]
            nz_mean = vals[vals > 0.01].mean() if (vals > 0.01).any() else 0
            nz_preds.extend([nz_mean] * len(vals))
        nz_preds = np.array(nz_preds)
        mse_nz = np.mean((y_s - nz_preds)**2)
        nmse_nz = mse_nz / var
        print(f'Non-zero mean prediction NMSE: {nmse_nz:.4f}')
        
        # What does a perfect sigmoid on the non-zero replicates give?
        # The non-zero replicates rise from ~0 to 1
        # Best sigmoid for non-zero: goes to 1 at plateau
        # But zeros will always have large error
        # Fraction of zeros:
        n_zero = (y_s < 0.01).sum()
        print(f'Zero fraction: {n_zero/len(y_s):.3f}')
        # If we predict 0 for zeros and 1 for non-zeros:
        y_pred_01 = np.where(y_s < 0.01, 0.0, 1.0)
        mse_01 = np.mean((y_s - y_pred_01)**2)
        print(f'Binary 0/1 prediction NMSE: {mse_01/var:.4f}')
        break
