c = sp.symbols('c0:7')

# Power law Richards model
rate = c[0] * x1**c[1]
half_time = c[2] * x1**c[3]
growth = sp.exp(-rate * (x0 - half_time))
expression = c[4] / (1 + growth)**c[5] + c[6]
print('Expression:', expression)
print('Complexity:', complexity(expression))
print('Constants: 7 (c0..c6)')
