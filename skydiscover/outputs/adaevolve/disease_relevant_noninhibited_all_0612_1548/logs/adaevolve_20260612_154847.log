import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import curve_fit

datasets = load_all_datasets()
ds = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

# Test: c3*tanh(c0*x1^c1*(x0-c2)) + c4
# This separates rate (c0*x1^c1) from half-time (c2), complexity ~16
def model_sep(X, c0, c1, c2, c3, c4):
    x0v, x1v = X[:,0], X[:,1]
    growth = c0 * x1v**c1 * (x0v - c2)
    return c3 * np.tanh(growth) + c4

# Test on hard datasets + a few normal ones
test_names = [
    'lysozyme/Fits/Hasecke2018_7uM_sec',
    'insulin/Fits/Nielsen2001_seeded_sec',
    'Abeta/Meisl2014/Ab40_sec_IN_HOURS',
    'Alphasyn_Gaspar2017/03uM_seed all',
    'htt/Kar2011/Fits/Kar2011_Q37_sec',
]

for dname in test_names:
    X_train, X_val, y_train, y_val = ds[dname]
    X_all = np.vstack([X_train, X_val]) if X_train.shape[0]>0 else X_val
    y_all = np.concatenate([y_train, y_val]) if X_train.shape[0]>0 else y_val
    var = np.var(y_all)
    try:
        popt, _ = curve_fit(model_sep, X_all, y_all, p0=[5.0, 0.5, 0.5, 0.5, 0.5], maxfev=10000)
        y_pred = model_sep(X_val, *popt)
        nmse = np.mean((y_val - y_pred)**2) / (var + 1e-10)
        print(f'sep model: NMSE={nmse:.4f} | {dname}')
    except Exception as e:
        print(f'sep model FAILED: {e} | {dname}')
"
