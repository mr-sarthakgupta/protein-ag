1182 | def _eval_stage1_worker(args):
1183 |     """Module-level worker for stage 1 parallel evaluation."""
1184 |     name, X_train, X_val, y_train, y_val, program_path = args
1185 |     harness_root = str(BENCHMARK_ROOT)
1186 |     if harness_root not in sys.path:
1187 |         sys.path.insert(0, harness_root)
1188 |     validate_candidate_source(program_path)
1189 |     import pysr_harness.equation_session as equation_session
1190 |     equation_session.evaluate_expression = evaluate_symbolic_expression
1191 |     equation_session.nmse = _nmse_with_gaussian_smoothed_target
1192 |     spec = importlib.util.spec_from_file_location("program", program_path)
1193 |     program = importlib.util.module_from_spec(spec)
1194 |     spec.loader.exec_module(program)
1195 |     from pysr_harness.equation_session import (
1196 |         single_equation_evaluation,
1197 |         validate_single_equation_result,
1198 |     )
1199 | 
1200 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1201 |         program, "run_discovery", None
1202 |     )
1203 |     if fn is None:
1204 |         return 0.0, "missing evaluate_symbolic_candidate()", ""
1205 |     try:
1206 |         with single_equation_evaluation():
1207 |             result = fn(X_train, y_train, X_val, y_val)
1208 |             validate_single_equation_result(result)
1209 |         return float(result.get("combined_score", 0.0)), None, str(
1210 |             result.get("equation_template", "")
1211 |         )
1212 |     except Exception as exc:
1213 |         return 0.0, str(exc), ""
