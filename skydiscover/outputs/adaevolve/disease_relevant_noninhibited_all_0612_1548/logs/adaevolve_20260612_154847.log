import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression, _aggregate_per_dataset_results
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()
x = feature_symbols(2)

def run_full(expr, c, initial, label):
    per_dataset = {}
    for name, X_train, X_val, y_train, y_val in datasets:
        r = evaluate_symbolic_expression(expr, X_train, y_train, X_val, y_val,
            constants=c, initial_values=initial)
        ev_only = (X_train.shape[0] == 0 and X_val.shape[0] > 0)
        per_dataset[name] = {
            'nmse_train': r['nmse_train'], 'nmse_val': r['nmse_val'],
            'n_val_points': r['n_val_points'], 'evaluation_only': ev_only,
            'combined_score': r['combined_score'], 'complexity': r['complexity'],
            'equation': r['equation'], 'equation_template': r['equation_template'],
        }
    agg = _aggregate_per_dataset_results(per_dataset)
    print(f'{label}: nmse={agg[\"nmse_val\"]:.5f}, combined={agg[\"combined_score\"]:.5f}, cx={agg[\"complexity\"]:.0f}')
    return agg

# Best: 4c-exp-rich cx=16 combined=0.95293
c4e = constant_symbols(4)
g4e = c4e[0] * x[0] * x[1]**c4e[1] - c4e[2]
expr4e = 1 / (1 + sp.exp(-g4e))**c4e[3]
run_full(expr4e, c4e, [3.0, 0.5, 1.0, 1.5], '4c-exp-rich cx16 [BEST]')

# 5c: add separate x1 power for offset (half-time)
c5 = constant_symbols(5)
g5 = c5[0] * x[0] * x[1]**c5[1] - c5[2] * x[1]**c5[3]
expr5 = 1 / (1 + sp.exp(-g5))**c5[4]
print(f'5c-exp-x1ht cx={_complexity(expr5)}')
run_full(expr5, c5, [3.0, 0.5, 1.0, 0.0, 1.5], '5c-exp-x1ht cx20')

# 5c: add amplitude
c5b = constant_symbols(5)
g5b = c5b[0] * x[0] * x[1]**c5b[1] - c5b[2]
expr5b = c5b[4] / (1 + sp.exp(-g5b))**c5b[3]
print(f'5c-exp-amp cx={_complexity(expr5b)}')
run_full(expr5b, c5b, [3.0, 0.5, 1.0, 1.5, 1.0], '5c-exp-amp cx18')

# 5c: add offset
c5c = constant_symbols(5)
g5c = c5c[0] * x[0] * x[1]**c5c[1] - c5c[2]
expr5c = 1 / (1 + sp.exp(-g5c))**c5c[3] + c5c[4]
print(f'5c-exp-off cx={_complexity(expr5c)}')
run_full(expr5c, c5c, [3.0, 0.5, 1.0, 1.5, 0.0], '5c-exp-off cx18')

# Try: the argument c0*x0*x1^c1 - c2 with c2 = c2*x1^0 = constant
# vs c0*x0*x1^c1 - c2 with c2 replaced by c2/x1^c3 (inverse power law for half-time)
c5d = constant_symbols(5)
g5d = c5d[0] * x[0] * x[1]**c5d[1] - c5d[2] / x[1]**c5d[3]
expr5d = 1 / (1 + sp.exp(-g5d))**c5d[4]
print(f'5c-exp-invht cx={_complexity(expr5d)}')
run_full(expr5d, c5d, [3.0, 0.5, 1.0, 0.5, 1.5], '5c-exp-invht cx20')
