import sympy as sp

# Count nodes in current Program 3 expression
x0, x1 = sp.symbols('x0 x1')
c0, c1, c2, c3, c4 = sp.symbols('c0 c1 c2 c3 c4')

# Program 3: c3*tanh(c0*x0*x1^c1 + c2) + c4
expr3 = c3 * sp.tanh(c0 * x0 * x1**c1 + c2) + c4
print(f'Program 3 complexity: {sum(1 for _ in sp.preorder_traversal(expr3))}')
print(f'Program 3: {expr3}')

# Try simpler: c0*tanh(c1*x0 + c2) + c3  (no x1 term)
expr_simple = c0 * sp.tanh(c1*x0 + c2) + c3
print(f'Simple (no x1) complexity: {sum(1 for _ in sp.preorder_traversal(expr_simple))}')

# c0*tanh(c1*(x0*x1 + c2)) + c3  - use x0*x1 product directly
expr_prod = c0 * sp.tanh(c1*(x0*x1 + c2)) + c3
print(f'x0*x1 product complexity: {sum(1 for _ in sp.preorder_traversal(expr_prod))}')

# c0*tanh(c1*x0/x1^c2 + c3) + c4 - inverse power law
expr_inv = c0 * sp.tanh(c1*x0*x1**c2 + c3) + c4
print(f'Same as program3 complexity: {sum(1 for _ in sp.preorder_traversal(expr_inv))}')

# c3*tanh(c0*(x0 - c1/x1)) + c4 - explicit half-time
expr_ht = c3 * sp.tanh(c0*(x0 - c1/x1)) + c4
print(f'explicit ht (c1/x1) complexity: {sum(1 for _ in sp.preorder_traversal(expr_ht))}')

# c3*tanh(c0*x0*x1 + c1) + c2 - linear in x1 (no power)
expr_lin = c3 * sp.tanh(c0*x0*x1 + c1) + c2
print(f'linear x1 complexity: {sum(1 for _ in sp.preorder_traversal(expr_lin))}')

# c0*tanh(x0*x1^c1 + c2) + c3  - drop c0 from rate
expr_noc0 = c0 * sp.tanh(x0*x1**c1 + c2) + c3
print(f'no rate constant complexity: {sum(1 for _ in sp.preorder_traversal(expr_noc0))}')
