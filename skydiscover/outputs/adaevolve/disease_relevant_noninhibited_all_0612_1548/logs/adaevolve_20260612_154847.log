1108 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
1109 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
1110 |     nmse_val = float(result.get("nmse_val", float("inf")))
1111 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
1112 |     if not np.isfinite(combined):
1113 |         combined = 0.0
1114 | 
1115 |     return {
1116 |         "equation": str(result.get("equation", "")),
1117 |         "loss": nmse_val,
1118 |         "complexity": float(result.get("complexity", 0.0)),
1119 |         "nmse_train": float(result.get("nmse_train", float("inf"))),
1120 |         "nmse_val": nmse_val,
1121 |         "mean_nmse_val": float(result.get("mean_nmse_val", nmse_val)),
1122 |         "mean_raw_nmse_val": float(result.get("mean_raw_nmse_val", nmse_val)),
1123 |         "combined_score": combined,
1124 |         "fit_score": float(result.get("fit_score", combined)),
1125 |         "parsimony_weight": float(result.get("parsimony_weight", PARSIMONY_WEIGHT)),
1126 |         "parsimony_penalty_factor": float(result.get("parsimony_penalty_factor", 1.0)),
1127 |         "eval_time": float(eval_time),
