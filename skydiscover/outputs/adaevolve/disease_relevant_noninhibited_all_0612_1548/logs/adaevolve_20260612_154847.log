import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares
import warnings
warnings.filterwarnings('ignore')

datasets = load_all_datasets()
ds = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

name = 'insulin/Fits/Nielsen2001_seeded_sec'
X_train, X_val, y_train, y_val = ds[name]
X_fit, y_fit = X_val, y_val

# The data has 3 replicates at each time point
# Let's see what the mean of the 3 replicates looks like
sorted_idx = np.argsort(X_val[:,0])
x0s = X_val[sorted_idx,0]
ys = y_val[sorted_idx]
# Group by x0
unique_x0 = np.unique(x0s)
means = []
for x0v in unique_x0:
    mask = x0s == x0v
    means.append(np.mean(ys[mask]))
means = np.array(means)
print('Mean of 3 replicates (first 20 time points):')
