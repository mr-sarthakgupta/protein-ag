import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()

# Check insulin seeded variance
for name, X_train, X_val, y_train, y_val in datasets:
    if 'seeded' in name and 'insulin' in name:
        print(f'y_val variance: {np.var(y_val):.4f}')
        # At x0~0.5, what spread do we see?
        mid_mask = (X_val[:,0] > 0.48) & (X_val[:,0] < 0.55)
        print(f'y at x0~0.5: {y_val[mid_mask]}')
        print(f'This is stochastic - irreducible noise floor')
        # Best possible NMSE = var(noise)/var(signal)
        # variance of y_val
        print(f'var(y_val)={np.var(y_val):.4f}')
        break

# Test Gompertz form
x = feature_symbols(2)
c = constant_symbols(6)
time = x[0]
parameter = x[1]
rate = c[0] * parameter ** c[1]
half_time = c[2] * parameter ** c[3]
# Gompertz: amplitude * exp(-exp(-rate*(x0 - half_time))) + offset
expr_gompertz = c[4] * sp.exp(-sp.exp(-rate * (time - half_time))) + c[5]
print(f'Gompertz complexity: {_complexity(expr_gompertz)}')

# Test all datasets with Gompertz
results_g = []
for name, X_train, X_val, y_train, y_val in datasets:
    if len(y_val) == 0:
        continue
    r = evaluate_symbolic_expression(expr_gompertz, X_train, y_train, X_val, y_val,
        constants=c, initial_values=[5.0, 0.5, 0.5, -0.5, 1.0, 0.0])
    results_g.append((name, r['nmse_val']))

results_g.sort(key=lambda x: x[1], reverse=True)
print('Gompertz top 5 hard cases:')
for name, nmse in results_g[:5]:
    print(f'  {nmse:.4f}  {name}')
# Weighted mean
n_pts = []
for name, X_train, X_val, y_train, y_val in datasets:
    if len(y_val) > 0:
        n_pts.append(len(y_val))
nmse_vals = [v for _, v in results_g]
weighted = np.sum([n*v for n,v in zip(n_pts, nmse_vals)]) / np.sum(n_pts)
print(f'Gompertz weighted mean nmse_val: {weighted:.4f}')
" 2>/dev/null
