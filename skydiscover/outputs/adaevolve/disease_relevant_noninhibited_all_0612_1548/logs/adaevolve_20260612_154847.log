import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
import numpy as np
from scipy.optimize import least_squares
import warnings
warnings.filterwarnings('ignore')

datasets = load_all_datasets()
ds = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

name = 'Abeta/Meisl2014/Ab40_sec_IN_HOURS'
X_train, X_val, y_train, y_val = ds[name]
X_fit, y_fit = X_val, y_val  # 0 train, fit on val

# Current model
def model_cur(x0v, x1v, c0, c1, c2, c3, c4):
    return c3 * np.tanh(c0 * x0v * x1v**c1 + c2) + c4

x0c = [X_fit[:,0], X_fit[:,1]]
def residual(theta):
    pred = model_cur(*x0c, *theta)
    pred = np.asarray(pred, dtype=float).reshape(-1)
    if not np.all(np.isfinite(pred)): return np.full_like(y_fit, 1e12)
    return pred - y_fit

p0 = [5., 0.5, -2.5, 0.5, 0.5]
with np.errstate(over='ignore', divide='ignore', invalid='ignore'):
    res = least_squares(residual, p0, loss='soft_l1', max_nfev=300)
print(f'Current model constants: {res.x.round(4)}')

# Check per-curve NMSE
var = np.var(y_val)
for x1v in np.unique(X_val[:,1]):
    mask = X_val[:,1] == x1v
    y_pred = model_cur(X_val[mask,0], X_val[mask,1], *res.x)
    nmse = np.mean((y_val[mask] - y_pred)**2) / (var + 1e-10)
    # Also check predicted half-time
    # half_time: c0*x0*x1^c1 + c2 = 0 => x0 = -c2/(c0*x1^c1)
    c0,c1,c2,c3,c4 = res.x
    ht = -c2 / (c0 * x1v**c1)
    print(f'  x1={x1v:.1f}: NMSE={nmse:.4f}, pred_halfTime={ht:.3f}')
"
