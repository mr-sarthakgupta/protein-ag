import sys
sys.path.insert(0, '.')
import sympy as sp
import numpy as np
from disease_relevant_noninhibited_all.evaluator import (
    load_all_datasets, evaluate_symbolic_expression, _aggregate_per_dataset_results
)
import pysr_harness.equation_session as eq_session
from disease_relevant_noninhibited_all.evaluator import _nmse_with_gaussian_smoothed_target
eq_session.evaluate_expression = evaluate_symbolic_expression
eq_session.nmse = _nmse_with_gaussian_smoothed_target

datasets = load_all_datasets()
val_datasets = [(n, Xt, Xv, yt, yv) for n, Xt, Xv, yt, yv in datasets if len(yv) > 0]
# Use 5 largest val datasets for more reliable comparison
test_ds = sorted(val_datasets, key=lambda x: -len(x[4]))[:5]

x0, x1 = sp.symbols('x0 x1')
c0, c1, c2, c3, c4 = sp.symbols('c0 c1 c2 c3 c4')
c5 = sp.Symbol('c5')

def complexity(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

exprs = {
    # Current best
    'curr_15': (c3 * sp.tanh(c0 * x0 * x1**c1 - c2) + c4, [c0,c1,c2,c3,c4], [5.0,0.5,2.5,0.5,0.5]),
    # Try: rate = c0*x1^c1, half_time separate: tanh(rate*(x0-c2*x1^c3)) - more physically motivated
    'phys_17': (c4 * sp.tanh(c0 * x1**c1 * (x0 - c2 * x1**c3)) + c5, [c0,c1,c2,c3,c4,c5], [5.0,0.5,0.5,-0.5,0.5,0.5]),
    # Try: c3*tanh(c0*(x0*x1**c1)**c2 - c4) - power on the product
    # skip - too complex
    # Try: c3*(1 - exp(-c0*x0*x1**c1)) + c4 - exponential growth form (Avrami-like)
    'avrami_14': (c3 * (1 - sp.exp(-c0 * x0 * x1**c1)) + c4, [c0,c1,c2,c3,c4], [0.5,0.5,0.5,0.5,0.5]),
    # Try: c3*tanh(c0*x0*x1**c1 - c2)**2 + c4 - squared tanh
    # skip - asymmetric
    # Try: c3/(1+exp(c2 - c0*x0*x1**c1)) + c4 - logistic
    'logistic_18': (c3/(1+sp.exp(c2 - c0*x0*x1**c1)) + c4, [c0,c1,c2,c3,c4], [5.0,0.5,2.5,1.0,0.0]),
}
for ename, (expr, consts, iv) in exprs.items():
    c = complexity(expr)
    nmses = []
    for name, Xt, Xv, yt, yv in test_ds:
        r = evaluate_symbolic_expression(expr, Xt, yt, Xv, yv, constants=consts, initial_values=iv)
        nmses.append(r['nmse_val'])
    print(f'{ename} (c={c}): mean_nmse={np.mean(nmses):.4f}  per={[round(v,4) for v in nmses]}')
"
