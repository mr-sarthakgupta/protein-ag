 234 | def _validate_evaluate_expression_data_args(call: ast.Call) -> set[int]:
 235 |     expected = ["X_train", "y_train", "X_val", "y_val"]
 236 |     if len(call.args) < 5:
 237 |         raise ValueError(
 238 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must be called "
 239 |             "as evaluate_expression(expression, X_train, y_train, X_val, y_val, ...)."
 240 |         )
 241 |     actual_data_args = call.args[1:5]
 242 |     if not all(
 243 |         isinstance(arg, ast.Name) and arg.id == expected_name
 244 |         for arg, expected_name in zip(actual_data_args, expected)
 245 |     ):
 246 |         raise ValueError(
 247 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must use the "
 248 |             "canonical data arguments exactly as X_train, y_train, X_val, y_val. "
 249 |             "Do not fit constants on validation labels or reorder the split."
 250 |         )
 251 |     return {id(arg) for arg in call.args[1:5]}
