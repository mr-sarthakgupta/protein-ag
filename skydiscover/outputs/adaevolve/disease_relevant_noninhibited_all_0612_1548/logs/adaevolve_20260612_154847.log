1138 | def evaluate(program_path: str) -> dict:
1139 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
1140 |     try:
1141 |         start = time.time()
1142 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=3000)
1143 |         metrics = _metrics_from_result(result, time.time() - start)
1144 |         print(
1145 |             "Evaluation: "
1146 |             f"nmse_val={metrics['nmse_val']:.6f}, "
1147 |             f"mean_nmse_val={metrics['mean_nmse_val']:.6f}, "
1148 |             f"mean_raw_nmse_val={metrics['mean_raw_nmse_val']:.6f}, "
1149 |             f"combined_score={metrics['combined_score']:.6f}, "
1150 |             f"n_datasets={metrics['n_datasets']}, "
1151 |             f"n_successful={metrics['n_successful']}, "
1152 |             f"time={metrics['eval_time']:.2f}s"
1153 |         )
1154 |         print(f"Equation template: {metrics['equation']}")
1155 |         if metrics.get("hard_case_feedback"):
1156 |             print(f"Hard-case feedback: {metrics['hard_case_feedback']}")
1157 |         if metrics.get("error"):
1158 |             print(f"Evaluator feedback: {metrics['error']}")
1159 |         return metrics
1160 |     except Exception as exc:
1161 |         print(f"Evaluation failed: {exc}")
1162 |         traceback.print_exc()
1163 |         return {
1164 |             "equation": "",
1165 |             "loss": float("inf"),
1166 |             "complexity": 0.0,
1167 |             "nmse_train": float("inf"),
1168 |             "nmse_val": float("inf"),
1169 |             "mean_nmse_val": float("inf"),
1170 |             "mean_raw_nmse_val": float("inf"),
1171 |             "combined_score": 0.0,
1172 |             "eval_time": 0.0,
1173 |             "n_datasets": 0,
1174 |             "n_successful": 0,
1175 |             "hard_cases": [],
1176 |             "hard_case_feedback": "",
1177 |             "per_dataset": {},
1178 |             "error": str(exc),
