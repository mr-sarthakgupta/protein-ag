import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression, EVALUATION_ONLY_DATASETS
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()

x = feature_symbols(2)
c = constant_symbols(7)
rate = c[0] * x[1]**c[1]
ht = c[2] * x[1]**c[3]
g = rate * (x[0] - ht)
expr = c[4] * ((1 + sp.tanh(g)) / 2)**c[5] + c[6]
initial = [5.0, 0.5, 0.5, -0.5, 1.0, 2.0, 0.0]

results = []
npts = []
for name, X_train, X_val, y_train, y_val in datasets:
    if len(y_val) == 0:
        continue
    r = evaluate_symbolic_expression(expr, X_train, y_train, X_val, y_val,
        constants=c, initial_values=initial)
    ev_only = (X_train.shape[0] == 0)
    results.append((name, r['nmse_val'], len(y_val), ev_only))
    npts.append(len(y_val))

# Show breakdown
print('All val datasets:')
total_pts = 0
weighted_sum = 0
for name, nmse, n, ev in sorted(results, key=lambda x: x[2], reverse=True)[:15]:
    print(f'  n={n:4d} ev={ev} nmse={nmse:.4f}  {name}')
    total_pts += n
    weighted_sum += n * nmse

print(f'Total val pts: {total_pts}')
print(f'Weighted mean NMSE: {weighted_sum/total_pts:.4f}')
# Show only non-eval-only
non_eval = [(name, nmse, n) for name, nmse, n, ev in results if not ev]
print(f'Non-eval-only datasets: {len(non_eval)}')
w2 = sum(n*v for _,v,n in non_eval) / sum(n for _,v,n in non_eval)
print(f'Non-eval-only weighted NMSE: {w2:.4f}')
" 2>/dev/null
