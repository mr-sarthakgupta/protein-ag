import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression, _aggregate_per_dataset_results
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()
x = feature_symbols(2)

def run_full(expr, c, initial, label):
    per_dataset = {}
    for name, X_train, X_val, y_train, y_val in datasets:
        r = evaluate_symbolic_expression(expr, X_train, y_train, X_val, y_val,
            constants=c, initial_values=initial)
        ev_only = (X_train.shape[0] == 0 and X_val.shape[0] > 0)
        per_dataset[name] = {
            'nmse_train': r['nmse_train'], 'nmse_val': r['nmse_val'],
            'n_val_points': r['n_val_points'], 'evaluation_only': ev_only,
            'combined_score': r['combined_score'], 'complexity': r['complexity'],
            'equation': r['equation'], 'equation_template': r['equation_template'],
        }
    agg = _aggregate_per_dataset_results(per_dataset)
    print(f'{label}: nmse={agg[\"nmse_val\"]:.5f}, combined={agg[\"combined_score\"]:.5f}, cx={agg[\"complexity\"]:.0f}')
    print(f'  hard: {agg[\"hard_case_feedback\"][:110]}')
    return agg

# 3c-Gompertz: exp(-exp(c2 - c0*x0*x1^c1)), cx=13
c3g = constant_symbols(3)
g3g = c3g[0] * x[0] * x[1]**c3g[1]
expr3g = sp.exp(-sp.exp(c3g[2] - g3g))
run_full(expr3g, c3g, [3.0, 0.5, 0.0], 'Gompertz 3c cx13 WINNER')

# Also try 4c Gompertz with offset
c4g = constant_symbols(4)
g4g = c4g[0] * x[0] * x[1]**c4g[1]
expr4g = sp.exp(-sp.exp(c4g[2] - g4g)) + c4g[3]
print(f'4c-Gompertz cx={_complexity(expr4g)}')
run_full(expr4g, c4g, [3.0, 0.5, 0.0, 0.0], '4c-Gompertz with offset')

# 4c Gompertz with amplitude
c4ga = constant_symbols(4)
g4ga = c4ga[0] * x[0] * x[1]**c4ga[1]
expr4ga = c4ga[3] * sp.exp(-sp.exp(c4ga[2] - g4ga))
print(f'4c-Gompertz-amp cx={_complexity(expr4ga)}')
run_full(expr4ga, c4ga, [3.0, 0.5, 0.0, 1.0], '4c-Gompertz with amplitude')

# Confirm equation template
print()
print('Template:', expr3g)
print('Complexity:', _complexity(expr3g))
