g5a = c5a[0] * x[0] * x[1]**c5a[1] - c5a[2]
expr5a = c5a[4] * ((1 + sp.tanh(g5a)) / 2)**c5a[3]
print(f'5c-amp-rich cx={_complexity(expr5a)}')
run_full(expr5a, c5a, [3.0, 0.5, 1.0, 1.5, 1.0], '5c-amp-rich cx19')

# 5c: add offset to 4c-rich
c5b = constant_symbols(5)
g5b = c5b[0] * x[0] * x[1]**c5b[1] - c5b[2]
expr5b = ((1 + sp.tanh(g5b)) / 2)**c5b[3] + c5b[4]
print(f'5c-off-rich cx={_complexity(expr5b)}')
run_full(expr5b, c5b, [3.0, 0.5, 1.0, 1.5, 0.0], '5c-off-rich cx19')

# 5c: separate half-time x1 power
c5c = constant_symbols(5)
g5c = c5c[0] * x[0] * x[1]**c5c[1] - c5c[2] * x[1]**c5c[3]
expr5c = ((1 + sp.tanh(g5c)) / 2)**c5c[4]
print(f'5c-x1ht-rich cx={_complexity(expr5c)}')
run_full(expr5c, c5c, [3.0, 0.5, 1.0, 0.0, 1.5], '5c-x1ht-rich cx21')

# 5c: rate and ht both power law, no Richards
c5d = constant_symbols(5)
g5d = c5d[0] * x[0] * x[1]**c5d[1] - c5d[2] * x[1]**c5d[3]
expr5d = (1 + sp.tanh(g5d)) / 2 + c5d[4]
print(f'5c-x1ht-noR cx={_complexity(expr5d)}')
run_full(expr5d, c5d, [3.0, 0.5, 1.0, 0.0, 0.0], '5c-x1ht-noR cx21')

# 4c: use exp instead of tanh for Richards
c4e = constant_symbols(4)
g4e = c4e[0] * x[0] * x[1]**c4e[1] - c4e[2]
expr4e = 1 / (1 + sp.exp(-g4e))**c4e[3]
print(f'4c-exp-rich cx={_complexity(expr4e)}')
run_full(expr4e, c4e, [3.0, 0.5, 1.0, 1.5], '4c-exp-rich')
