# 4c: amplitude*tanh + offset (cx=17 but different)
c4c = constant_symbols(4)
g4c = c4c[0] * x[0] * x[1]**c4c[1] - c4c[2]
expr4c = c4c[3] * (1 + sp.tanh(g4c)) / 2
print(f'4c-amp2 cx={_complexity(expr4c)}')
