import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()

# Check lysozyme 7uM dataset
for name, X_train, X_val, y_train, y_val in datasets:
    if 'Hasecke' in name and '7uM' in name:
        print(f'Dataset: {name}')
        print(f'X_train shape: {X_train.shape}, X_val shape: {X_val.shape}')
        print(f'x1 unique: {np.unique(X_val[:,1])}')
        print(f'x0 range: {X_val[:,0].min():.3f} to {X_val[:,0].max():.3f}')
        print(f'y_val: {y_val[:10].round(3)}')
        print(f'y_val last: {y_val[-10:].round(3)}')
        print(f'y_val max: {y_val.max():.4f}, min: {y_val.min():.4f}')
        # This is eval-only, so we fit on val
        break

x = feature_symbols(2)

# Test tanh^2 on lysozyme 7uM specifically
c = constant_symbols(6)
rate = c[0] * x[1]**c[1]
ht = c[2] * x[1]**c[3]
g = rate * (x[0] - ht)
expr_sq = c[4] * ((1 + sp.tanh(g)) / 2)**2 + c[5]

for name, X_train, X_val, y_train, y_val in datasets:
    if 'Hasecke' in name and '7uM' in name:
        r = evaluate_symbolic_expression(expr_sq, X_train, y_train, X_val, y_val,
            constants=c, initial_values=[5.0, 0.5, 0.5, -0.5, 1.0, 0.0])
        print(f'tanh^2: nmse={r[\"nmse_val\"]:.4f}, eq={r[\"equation\"]}')
        break

# The issue: when x1 is constant (single curve), x1^c1 is just a constant
# absorbed into c0. So for single-curve datasets, power law is fine.
# But the tanh^2 form might fail if the curve is not well-described by a squared sigmoid.

# Try tanh-Richards with better initial values for the exponent
c = constant_symbols(7)
rate = c[0] * x[1]**c[1]
ht = c[2] * x[1]**c[3]
g = rate * (x[0] - ht)
expr_r = c[4] * ((1 + sp.tanh(g)) / 2)**c[5] + c[6]

for name, X_train, X_val, y_train, y_val in datasets:
    if 'Hasecke' in name and '7uM' in name:
        r = evaluate_symbolic_expression(expr_r, X_train, y_train, X_val, y_val,
            constants=c, initial_values=[5.0, 0.5, 0.5, -0.5, 1.0, 2.0, 0.0])
        print(f'tanh-Richards: nmse={r[\"nmse_val\"]:.4f}, constants={r[\"constants\"]}')
        break
