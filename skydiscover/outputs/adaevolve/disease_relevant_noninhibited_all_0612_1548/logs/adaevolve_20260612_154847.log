1216 | def evaluate_stage1(program_path: str) -> dict:
1217 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
1218 |     try:
1219 |         harness_root = str(BENCHMARK_ROOT)
1220 |         if harness_root not in sys.path:
1221 |             sys.path.insert(0, harness_root)
1222 | 
1223 |         all_datasets = load_all_datasets()
1224 |         scoring_datasets = [
1225 |             dataset
1226 |             for dataset in all_datasets
1227 |             if dataset[0] not in EVALUATION_ONLY_DATASETS and dataset[4].size > 0
1228 |         ]
1229 |         rng = np.random.default_rng(RANDOM_STATE)
1230 |         if len(scoring_datasets) > 8:
1231 |             indices = rng.choice(len(scoring_datasets), size=8, replace=False)
1232 |             subset = [scoring_datasets[i] for i in sorted(indices)]
1233 |         else:
1234 |             subset = scoring_datasets
1235 | 
1236 |         work_items = [
1237 |             (name, X_train, X_val, y_train, y_val, program_path)
1238 |             for name, X_train, X_val, y_train, y_val in subset
1239 |         ]
1240 | 
1241 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1242 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
1243 |             worker_results = [future.result() for future in concurrent.futures.as_completed(futures)]
1244 | 
1245 |         combined_scores = [score for score, _error, _template in worker_results]
1246 |         successful_scores = [score for score in combined_scores if score > 0]
1247 |         errors = sorted({error for _score, error, _template in worker_results if error})
1248 |         violation_errors = sorted(
1249 |             {
1250 |                 error
1251 |                 for _score, error, _template in worker_results
1252 |                 if error and SINGLE_EQUATION_ERROR_PREFIX in error
1253 |             }
1254 |         )
1255 |         if violation_errors:
1256 |             return {
1257 |                 "combined_score": 0.0,
1258 |                 "n_stage1_datasets": len(subset),
1259 |                 "n_stage1_successful": len(successful_scores),
1260 |                 "eval_workers": NUM_WORKERS,
1261 |                 "error": violation_errors[0],
1262 |             }
1263 |         if errors:
1264 |             return {
1265 |                 "combined_score": 0.0,
1266 |                 "n_stage1_datasets": len(subset),
1267 |                 "n_stage1_successful": len(successful_scores),
1268 |                 "eval_workers": NUM_WORKERS,
1269 |                 "error": (
1270 |                     "Single-equation violation: stage 1 candidate failed on "
1271 |                     f"{len(errors)} dataset evaluations. Example: {errors[0]}"
1272 |                 ),
1273 |             }
1274 |         templates = sorted(
1275 |             {
1276 |                 template
1277 |                 for score, _error, template in worker_results
1278 |                 if score > 0 and template
1279 |             }
1280 |         )
1281 |         if len(templates) > 1:
1282 |             examples = "; ".join(templates[:3])
1283 |             return {
1284 |                 "combined_score": 0.0,
1285 |                 "n_stage1_datasets": len(subset),
1286 |                 "n_stage1_successful": len(successful_scores),
1287 |                 "eval_workers": NUM_WORKERS,
1288 |                 "error": (
1289 |                     "Single-equation violation: stage 1 produced "
1290 |                     f"{len(templates)} distinct equation templates across datasets. "
1291 |                     "The base equation must be identical for all datasets. "
1292 |                     f"Example templates: {examples}"
1293 |                 ),
1294 |             }
1295 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
1296 |         return {
1297 |             "combined_score": agg_combined,
1298 |             "n_stage1_datasets": len(subset),
1299 |             "n_stage1_successful": len(successful_scores),
1300 |             "eval_workers": NUM_WORKERS,
1301 |             "stage1_full_selected_datasets": 1.0,
1302 |         }
1303 |     except Exception as exc:
1304 |         print(f"Stage 1 evaluation failed: {exc}")
1305 |         return {"combined_score": 0.0, "error": str(exc)}
