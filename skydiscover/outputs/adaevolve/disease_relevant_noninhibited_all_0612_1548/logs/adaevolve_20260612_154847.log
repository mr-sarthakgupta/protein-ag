import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets
from scipy.optimize import least_squares

datasets = load_all_datasets()

def fit_and_score(model_fn, x0_init, X_train, y_train, X_val, y_val):
    X_fit = X_val if X_train.size == 0 else X_train
    y_fit = y_train if X_train.size > 0 else y_val
    x0v, x1v = X_fit[:,0], X_fit[:,1]
    def residual(theta):
        pred = model_fn(theta, x0v, x1v)
        if not np.all(np.isfinite(pred)): return np.full_like(y_fit, 1e6)
        return pred - y_fit
    res = least_squares(residual, x0_init, loss='soft_l1', max_nfev=1000)
    pred_val = model_fn(res.x, X_val[:,0], X_val[:,1])
    ref = np.concatenate([y_train, y_val]) if y_train.size else y_val
    nmse = np.mean((pred_val - y_val)**2) / max(np.var(ref), 1e-12)
    return nmse, res.x

# The key insight: power law for rate AND half-time is much better
# But the issue is the Richards exponent c5 can blow up for Alphasyn
# Let's check: what happens if we use log1p(x1) instead of x1^c for stability?
# log1p(x1) = log(1+x1) avoids issues with small x1 (x1=0.3 for serum amyloid)

def m_pow(theta, x0, x1):
    c0,c1,c2,c3,c4,c5,c6 = theta
    rate = c0 * np.maximum(x1, 1e-10)**c1
    ht = c2 * np.maximum(x1, 1e-10)**c3
    return c4 / (1 + np.exp(-rate*(x0-ht)))**np.maximum(c5, 0.01) + c6

# Check Alphasyn specifically with different inits
for name, X_train, X_val, y_train, y_val in datasets:
    if 'Alphasyn' not in name: continue
    for init in [[0.1,0.5,10.,-0.5,1.,1.,0.], [1.,0.3,5.,-0.3,1.,2.,0.], [0.5,0.5,2.,-0.4,0.9,1.5,0.05]]:
        n, c = fit_and_score(m_pow, init, X_train, y_train, X_val, y_val)
        print(f'Alphasyn init={init[:3]}: nmse={n:.4f}, c5={c[4]:.3f}, c6={c[5]:.3f}')

# Check: does the Alphasyn issue affect the actual score?
# The evaluator uses a single initial point - let's see what happens
print()
# Compute expected combined score for pow model
results_pow = []
for name, X_train, X_val, y_train, y_val in datasets:
    if y_val.size == 0: continue
    try:
        n, _ = fit_and_score(m_pow, [0.1,0.5,10.,-0.5,1.,1.,0.], X_train, y_train, X_val, y_val)
        results_pow.append((name, n, len(y_val)))
    except: pass

tw = sum(w for _,_,w in results_pow)
wm = sum(v*w for _,v,w in results_pow)/tw
complexity = 25
parsimony = 1.0 - 0.2*(complexity/160.0)
fit_score = 1.0/(1.0+wm)
combined = fit_score * parsimony
print(f'Power model: wmean_nmse={wm:.4f}, complexity={complexity}, parsimony={parsimony:.4f}')
print(f'  fit_score={fit_score:.4f}, combined_score={combined:.4f}')
