 963 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 964 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 965 | 
 966 |     The subprocess loads every dataset, calls the candidate's
 967 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 968 |     constants each time) using parallel threads, and returns aggregated
 969 |     metrics.
 970 |     """
 971 |     validate_candidate_source(program_path)
 972 |     harness_root = str(BENCHMARK_ROOT)
 973 |     evaluator_path = str(Path(__file__).resolve())
 974 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
 975 |         script = f"""
 976 | import importlib.util
 977 | import os
 978 | import pickle
 979 | import sys
 980 | import traceback
 981 | from concurrent.futures import ThreadPoolExecutor, as_completed
 982 | 
 983 | os.environ.setdefault("OMP_NUM_THREADS", "1")
 984 | os.environ.setdefault("MKL_NUM_THREADS", "1")
 985 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
 986 | 
 987 | import numpy as np
 988 | 
 989 | sys.path.insert(0, {harness_root!r})
 990 | 
 991 | program_path = {program_path!r}
 992 | evaluator_path = {evaluator_path!r}
 993 | results_path = {temp_file.name + ".results"!r}
 994 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 995 | 
 996 | def _write_payload_and_exit(payload):
 997 |     with open(results_path, "wb") as f:
 998 |         pickle.dump(payload, f)
 999 |     sys.stdout.flush()
1000 |     sys.stderr.flush()
1001 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
1002 |     # interpreter shutdown. The parent only needs the pickle payload.
1003 |     os._exit(0)
1004 | 
1005 | try:
1006 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
1007 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
1008 |     evaluator_spec.loader.exec_module(evaluator)
1009 |     evaluator.validate_candidate_source(program_path)
1010 | 
1011 |     import pysr_harness.equation_session as equation_session
1012 |     equation_session.evaluate_expression = evaluator.evaluate_symbolic_expression
1013 |     equation_session.nmse = evaluator._nmse_with_gaussian_smoothed_target
1014 |     spec = importlib.util.spec_from_file_location("program", program_path)
1015 |     program = importlib.util.module_from_spec(spec)
1016 |     spec.loader.exec_module(program)
1017 |     from pysr_harness.equation_session import (
1018 |         single_equation_evaluation,
1019 |         validate_single_equation_result,
1020 |     )
1021 | 
1022 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1023 |         program, "run_discovery", None
1024 |     )
1025 |     if fn is None:
1026 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
1027 | 
1028 |     datasets = evaluator.load_all_datasets()
1029 | 
1030 |     def _eval_one(args):
1031 |         ds_name, X_train, X_val, y_train, y_val = args
1032 |         try:
1033 |             with single_equation_evaluation():
1034 |                 result = fn(X_train, y_train, X_val, y_val)
1035 |                 validate_single_equation_result(result)
1036 |             ds_nmse = float(result.get("nmse_val", float("inf")))
1037 |             ds_train_nmse = float(result.get("nmse_train", float("inf")))
1038 |             ds_combined = float(result.get("combined_score", 0.0))
1039 |             return ds_name, {{
1040 |                 "nmse_train": ds_train_nmse,
1041 |                 "nmse_val": ds_nmse,
1042 |                 "n_val_points": int(result.get("n_val_points", 0)),
1043 |                 "evaluation_only": bool(result.get("evaluation_only", False)),
1044 |                 "combined_score": ds_combined,
1045 |                 "complexity": float(result.get("complexity", 0.0)),
1046 |                 "equation": str(result.get("equation", "")),
1047 |                 "equation_template": str(result.get("equation_template", "")),
1048 |                 "constants": result.get("constants", {{}}),
1049 |             }}
1050 |         except Exception as exc:
1051 |             return ds_name, {{
1052 |                 "nmse_train": float("inf"),
1053 |                 "nmse_val": float("inf"),
1054 |                 "n_val_points": int(len(y_val)),
1055 |                 "evaluation_only": bool(X_train.shape[0] == 0 and X_val.shape[0] > 0),
1056 |                 "combined_score": 0.0,
1057 |                 "error": str(exc),
1058 |             }}
1059 | 
1060 |     per_dataset_results = {{}}
1061 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1062 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
1063 |         for future in as_completed(futures):
1064 |             ds_name, ds_result = future.result()
1065 |             per_dataset_results[ds_name] = ds_result
1066 | 
1067 |     aggregated = evaluator._aggregate_per_dataset_results(per_dataset_results)
1068 | 
1069 |     _write_payload_and_exit({{"result": aggregated}})
1070 | except Exception as exc:
1071 |     traceback.print_exc()
1072 |     _write_payload_and_exit({{"error": str(exc)}})
1073 | """
1074 |         temp_file.write(script.encode())
1075 |         temp_path = temp_file.name
1076 | 
1077 |     results_path = f"{temp_path}.results"
1078 |     try:
1079 |         process = subprocess.Popen(
1080 |             [sys.executable, temp_path],
1081 |             stdout=subprocess.PIPE,
1082 |             stderr=subprocess.PIPE,
1083 |         )
1084 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
1085 |         if stdout:
1086 |             print(stdout.decode())
1087 |         if stderr:
1088 |             print(stderr.decode())
1089 |         if process.returncode != 0:
