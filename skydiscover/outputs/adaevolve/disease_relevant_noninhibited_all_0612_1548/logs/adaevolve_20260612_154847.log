import sys
sys.path.insert(0, '.')
import sympy as sp
import numpy as np
from disease_relevant_noninhibited_all.evaluator import (
    load_all_datasets, evaluate_symbolic_expression, _parsimony_penalty_factor
)
import pysr_harness.equation_session as eq_session
from disease_relevant_noninhibited_all.evaluator import _nmse_with_gaussian_smoothed_target
eq_session.evaluate_expression = evaluate_symbolic_expression
eq_session.nmse = _nmse_with_gaussian_smoothed_target

datasets = load_all_datasets()
val_datasets = [(n, Xt, Xv, yt, yv) for n, Xt, Xv, yt, yv in datasets if len(yv) > 0]

x0, x1 = sp.symbols('x0 x1')
c0, c1, c2, c3, c4 = sp.symbols('c0 c1 c2 c3 c4')

def complexity(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

# Key: insulin seeded has x1=344, single curve, noise floor 0.596
# The tanh form with x0*x1^c1 works because x1^c1 adjusts the time scale
# For single-curve datasets, x1 is constant so x1^c1 just becomes a fitted constant
# So for single-curve datasets, the expression reduces to: c3*tanh(c0'*x0 - c2) + c4
# The x1^c1 term only matters for multi-curve datasets

# Can we drop the baseline c4 for simpler form?
# c3*tanh(c0*x0*x1**c1 - c2): complexity=13, 4 constants
expr_13_4c = c3 * sp.tanh(c0 * x0 * x1**c1 - c2)
# c0*tanh(c1*x0*x1**c2 - c3): complexity=13, 4 constants (same)
expr_13_4c_b = c0 * sp.tanh(c1 * x0 * x1**c2 - c3)

# Try: tanh(c0*x0*x1**c1 - c2) + c3: complexity=13, 4 constants (baseline separate from amplitude)
expr_13_4c_c = sp.tanh(c0 * x0 * x1**c1 - c2) + c3

print(f'expr_13_4c: c={complexity(expr_13_4c)}')
print(f'expr_13_4c_b: c={complexity(expr_13_4c_b)}')
print(f'expr_13_4c_c: c={complexity(expr_13_4c_c)}')

test_exprs = {
    'curr_15_5c': (c3 * sp.tanh(c0 * x0 * x1**c1 - c2) + c4, [c0,c1,c2,c3,c4], [5.0,0.5,2.5,0.5,0.5]),
    '4c_ampl_13': (c3 * sp.tanh(c0 * x0 * x1**c1 - c2), [c0,c1,c2,c3], [5.0,0.5,2.5,0.5]),
    '4c_base_13': (sp.tanh(c0 * x0 * x1**c1 - c2) + c3, [c0,c1,c2,c3], [5.0,0.5,2.5,0.0]),
    '4c_alt_13':  (c0 * sp.tanh(c1 * x0 * x1**c2 - c3), [c0,c1,c2,c3], [0.5,5.0,0.5,2.5]),
}

for ename, (expr, consts, iv) in test_exprs.items():
    c = complexity(expr)
    nmses = []
    wts = []
    for name, Xt, Xv, yt, yv in val_datasets:
        r = evaluate_symbolic_expression(expr, Xt, yt, Xv, yv, constants=consts, initial_values=iv)
        nmses.append(r['nmse_val'])
        wts.append(len(yv))
    wt_nmse = np.sum(np.array(nmses)*np.array(wts)) / np.sum(wts)
    parsimony = _parsimony_penalty_factor(c)
    combined = (1/(1+wt_nmse)) * parsimony
    print(f'{ename} (c={c},p={parsimony:.4f}): wt_nmse={wt_nmse:.4f}, combined={combined:.4f}')
    # Show insulin seeded specifically
    for i, (name, Xt, Xv, yt, yv) in enumerate(val_datasets):
        if 'seeded' in name:
            print(f'  insulin_seeded nmse={nmses[i]:.4f}')
            break
"
