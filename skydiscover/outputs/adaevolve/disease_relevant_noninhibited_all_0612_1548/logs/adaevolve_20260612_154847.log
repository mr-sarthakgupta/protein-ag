eq_session.nmse = _nmse_with_gaussian_smoothed_target

datasets = load_all_datasets()
val_datasets = [(n, Xt, Xv, yt, yv) for n, Xt, Xv, yt, yv in datasets if len(yv) > 0]

x0, x1 = sp.symbols('x0 x1')
c0, c1, c2, c3, c4 = sp.symbols('c0 c1 c2 c3 c4')

def complexity(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

# Explore complexity=14 options with 5 constants
# Current: c3*tanh(c0*x0*x1**c1 - c2) + c4 = complexity 15
# Can we get complexity=14 with similar expressiveness?

# Option A: c3*tanh(c0*(x0 - c1)*x1**c2) + c4
# This is rate=c0*x1^c2, half_time=c1 (not x1-dependent)
exprA = c3 * sp.tanh(c0 * (x0 - c1) * x1**c2) + c4
print(f'A: c={complexity(exprA)}, expr={exprA}')

# Option B: c3*tanh(c0*x0*x1**c1) + c2*x0 + c4  -- no, that's different structure
# Option C: c3*tanh((c0*x0 - c1)*x1**c2) + c4
exprC = c3 * sp.tanh((c0*x0 - c1) * x1**c2) + c4
print(f'C: c={complexity(exprC)}, expr={exprC}')

# Option D: (c0*x0*x1**c1 + c2) / (abs(...)) -- not smooth
# Option E: c3*tanh(c0*x0 - c1/x1**c2) + c4 -- inverse power
exprE = c3 * sp.tanh(c0*x0 - c1/x1**c2) + c4
print(f'E: c={complexity(exprE)}, expr={exprE}')

# Option F: c3*sp.tanh(c0*x0*x1**c1 + c2) + c4 -- just sign flip on c2 (same expressiveness)
exprF = c3 * sp.tanh(c0*x0*x1**c1 + c2) + c4
print(f'F: c={complexity(exprF)}, expr={exprF}')

# Option G: c0*sp.tanh(c1*x0*x1**c2 + c3) + c4 -- same as current, just different constant ordering
exprG = c0 * sp.tanh(c1*x0*x1**c2 + c3) + c4
print(f'G: c={complexity(exprG)}, expr={exprG}')

# Option H: c3*tanh(c0*x0/(c1 + x1**c2)) + c4 -- division form
exprH = c3 * sp.tanh(c0*x0/(c1 + x1**c2)) + c4
print(f'H: c={complexity(exprH)}, expr={exprH}')

# Can SymPy simplify the current expression to fewer nodes?
expr_curr = c3 * sp.tanh(c0 * x0 * x1**c1 - c2) + c4
