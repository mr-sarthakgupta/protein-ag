import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all.evaluator import load_all_datasets, EVALUATION_ONLY_DATASETS

datasets = load_all_datasets()
# Check datasets with wide x1 ranges - potential hard cases
for name, X_train, X_val, y_train, y_val in datasets:
    if y_val.size == 0:
        continue
    X_all = np.concatenate([X_train, X_val]) if X_train.size else X_val
    y_all = np.concatenate([y_train, y_val]) if y_train.size else y_val
    x1_vals = np.unique(X_all[:,1])
    # Show shape of y vs x0 for first curve
    mask = X_all[:,1] == x1_vals[0]
    x0 = X_all[mask, 0]
    y = y_all[mask]
    order = np.argsort(x0)
    y_ordered = y[order]
    # Check if monotone increasing (sigmoid) or has other shape
    diff = np.diff(y_ordered)
