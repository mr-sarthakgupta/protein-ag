 216 | def _validate_plain_import(alias: ast.alias) -> None:
 217 |     if alias.name not in _ALLOWED_IMPORTS:
 218 |         raise ValueError(
 219 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: import '{alias.name}' is not allowed. "
 220 |             "Candidates may only import sympy/numpy and the equation harness."
 221 |         )
 222 |     if alias.name == "sympy" and alias.asname != "sp":
 223 |         raise ValueError(
 224 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: sympy must be imported canonically "
 225 |             "as 'import sympy as sp'."
 226 |         )
 227 |     if alias.name == "numpy" and alias.asname not in {None, "np"}:
 228 |         raise ValueError(
 229 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: numpy may only be imported as "
 230 |             "'import numpy' or 'import numpy as np'."
 231 |         )
