import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'disease_relevant_noninhibited_all')
from evaluator import load_all_datasets, evaluate_symbolic_expression, _aggregate_per_dataset_results
import numpy as np
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, _complexity

datasets = load_all_datasets()
x = feature_symbols(2)

def run_full(expr, c, initial, label):
    per_dataset = {}
    for name, X_train, X_val, y_train, y_val in datasets:
        r = evaluate_symbolic_expression(expr, X_train, y_train, X_val, y_val,
            constants=c, initial_values=initial)
        ev_only = (X_train.shape[0] == 0 and X_val.shape[0] > 0)
        per_dataset[name] = {
            'nmse_train': r['nmse_train'], 'nmse_val': r['nmse_val'],
            'n_val_points': r['n_val_points'], 'evaluation_only': ev_only,
            'combined_score': r['combined_score'], 'complexity': r['complexity'],
            'equation': r['equation'], 'equation_template': r['equation_template'],
        }
    agg = _aggregate_per_dataset_results(per_dataset)
    print(f'{label}: nmse={agg[\"nmse_val\"]:.5f}, combined={agg[\"combined_score\"]:.5f}, cx={agg[\"complexity\"]:.0f}')
    print(f'  hard: {agg[\"hard_case_feedback\"][:100]}')
    return agg

# Best: 4c-exp-rich cx=16 combined=0.95293
c4e = constant_symbols(4)
g4e = c4e[0] * x[0] * x[1]**c4e[1] - c4e[2]
expr4e = 1 / (1 + sp.exp(-g4e))**c4e[3]
run_full(expr4e, c4e, [3.0, 0.5, 1.0, 1.5], '4c-exp-rich cx16 [BEST]')

# Show full per-dataset breakdown for best form
per_dataset = {}
for name, X_train, X_val, y_train, y_val in datasets:
    r = evaluate_symbolic_expression(expr4e, X_train, y_train, X_val, y_val,
        constants=c4e, initial_values=[3.0, 0.5, 1.0, 1.5])
    ev_only = (X_train.shape[0] == 0 and X_val.shape[0] > 0)
    per_dataset[name] = {
        'nmse_train': r['nmse_train'], 'nmse_val': r['nmse_val'],
        'n_val_points': r['n_val_points'], 'evaluation_only': ev_only,
        'combined_score': r['combined_score'], 'complexity': r['complexity'],
        'equation': r['equation'], 'equation_template': r['equation_template'],
    }
val_results = [(name, r['nmse_val'], r['n_val_points']) for name, r in per_dataset.items() if r['n_val_points'] > 0]
val_results.sort(key=lambda x: x[1], reverse=True)
print('All val datasets for 4c-exp-rich:')
for name, nmse, n in val_results:
    print(f'  n={n:4d} nmse={nmse:.5f}  {name.split(\"/\")[-1]}')

# Try: cx=15 - can we get one less node?
# 1/(1+exp(-c0*x0*x1^c1))^c2  -- no constant offset (3c, cx=14)
c3x = constant_symbols(3)
g3x = c3x[0] * x[0] * x[1]**c3x[1]
expr3x = 1 / (1 + sp.exp(-g3x))**c3x[2]
print(f'3c-exp-nooff cx={_complexity(expr3x)}')
run_full(expr3x, c3x, [3.0, 0.5, 1.5], '3c-exp-nooff')
