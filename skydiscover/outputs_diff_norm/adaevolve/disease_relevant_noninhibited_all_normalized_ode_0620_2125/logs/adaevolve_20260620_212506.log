   2 | 
   3 | from __future__ import annotations
   4 | 
   5 | from typing import Any
   6 | 
   7 | import sympy as sp
   8 | from numpy.typing import NDArray
   9 | 
  10 | from pysr_harness.equation_session import (
  11 |     constant_symbols,
