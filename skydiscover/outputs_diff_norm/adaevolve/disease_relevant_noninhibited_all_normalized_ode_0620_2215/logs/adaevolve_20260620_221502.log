  15 | 
  16 | 
  17 | def evaluate_symbolic_candidate(
  18 |     X_train: NDArray,
  19 |     y_train: NDArray,
  20 |     X_val: NDArray,
  21 |     y_val: NDArray,
  22 | ) -> dict[str, Any]:
  23 |     """Evaluate the closed-form manual secondary-nucleation solution."""
  24 |     x = feature_symbols(X_train.shape[1])
  25 |     c = constant_symbols(7)
  26 | 
  27 |     time = x[0]
  28 |     m0 = x[1]
  29 |     M0 = x[2]
  30 | 
  31 |     eps = 1.0e-12
  32 |     kappa = c[0] ** 2 + eps
  33 |     lam = c[1] ** 2 + eps
  34 |     seed_term = c[2] ** 2 + eps
  35 |     n2 = c[3] ** 2 + eps
  36 |     nc = c[4] ** 2 + eps
  37 | 
  38 |     mtot = m0 + M0
  39 |     concentration_ratio = M0 / m0
  40 |     exp_kappa_t = sp.exp(kappa * time)
  41 | 
  42 |     Cp = seed_term + concentration_ratio / 2 + lam**2 / (2 * kappa**2)
  43 |     Cm = seed_term - concentration_ratio / 2 - lam**2 / (2 * kappa**2)
  44 |     kinf = kappa * sp.sqrt(
  45 |         2 / (n2 * (n2 + 1))
  46 |         + 2 * lam**2 / (nc * kappa**2)
  47 |         + 2 * concentration_ratio / n2
  48 |         + (2 * seed_term) ** 2
  49 |     )
  50 |     kbarinf = sp.sqrt(kinf**2 - 4 * Cp * Cm * kappa**2)
  51 |     Bp = (kinf + kbarinf) / (2 * kappa)
  52 |     Bm = (kinf - kbarinf) / (2 * kappa)
  53 | 
  54 |     manual_response = 1 - (1 - M0 / mtot) * (
  55 |         ((Bp + Cp) * (Bm + Cp * exp_kappa_t))
  56 |         / ((Bp + Cp * exp_kappa_t) * (Bm + Cp))
  57 |     ) ** (kinf**2 / (kbarinf * kappa)) * sp.exp(-kinf * time)
  58 |     expression = c[5] * manual_response + c[6]
  59 | 
