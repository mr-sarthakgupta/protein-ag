 166 | def _function_annotations(node: ast.FunctionDef) -> list[ast.AST]:
 167 |     annotations: list[ast.AST] = []
 168 |     args = node.args
 169 |     for arg in [*args.posonlyargs, *args.args, *args.kwonlyargs]:
 170 |         if arg.annotation is not None:
 171 |             annotations.append(arg.annotation)
 172 |     if args.vararg is not None and args.vararg.annotation is not None:
 173 |         annotations.append(args.vararg.annotation)
 174 |     if args.kwarg is not None and args.kwarg.annotation is not None:
 175 |         annotations.append(args.kwarg.annotation)
 176 |     if node.returns is not None:
 177 |         annotations.append(node.returns)
 178 |     return annotations
