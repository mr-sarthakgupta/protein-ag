1562 | def evaluate_stage1(program_path: str) -> dict:
1563 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
1564 |     try:
1565 |         harness_root = str(BENCHMARK_ROOT)
1566 |         if harness_root not in sys.path:
1567 |             sys.path.insert(0, harness_root)
1568 | 
1569 |         all_datasets = load_all_datasets()
1570 |         scoring_datasets = [
1571 |             dataset
1572 |             for dataset in all_datasets
1573 |             if dataset[0] not in EVALUATION_ONLY_DATASETS and dataset[4].size > 0
1574 |         ]
1575 |         rng = np.random.default_rng(RANDOM_STATE)
1576 |         if len(scoring_datasets) > 8:
1577 |             indices = rng.choice(len(scoring_datasets), size=8, replace=False)
1578 |             subset = [scoring_datasets[i] for i in sorted(indices)]
1579 |         else:
1580 |             subset = scoring_datasets
1581 | 
1582 |         work_items = [
1583 |             (name, X_train, X_val, y_train, y_val, program_path)
1584 |             for name, X_train, X_val, y_train, y_val in subset
1585 |         ]
1586 | 
1587 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1588 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
1589 |             worker_results = [future.result() for future in concurrent.futures.as_completed(futures)]
1590 | 
1591 |         combined_scores = [score for score, _error, _template in worker_results]
1592 |         successful_scores = [score for score in combined_scores if score > 0]
1593 |         errors = sorted({error for _score, error, _template in worker_results if error})
1594 |         violation_errors = sorted(
1595 |             {
1596 |                 error
1597 |                 for _score, error, _template in worker_results
1598 |                 if error and SINGLE_EQUATION_ERROR_PREFIX in error
1599 |             }
1600 |         )
1601 |         if violation_errors:
1602 |             return {
1603 |                 "combined_score": 0.0,
1604 |                 "n_stage1_datasets": len(subset),
1605 |                 "n_stage1_successful": len(successful_scores),
1606 |                 "eval_workers": NUM_WORKERS,
1607 |                 "error": violation_errors[0],
1608 |             }
1609 |         if errors:
1610 |             return {
1611 |                 "combined_score": 0.0,
1612 |                 "n_stage1_datasets": len(subset),
1613 |                 "n_stage1_successful": len(successful_scores),
1614 |                 "eval_workers": NUM_WORKERS,
1615 |                 "error": (
1616 |                     "Single-equation violation: stage 1 candidate failed on "
1617 |                     f"{len(errors)} dataset evaluations. Example: {errors[0]}"
1618 |                 ),
1619 |             }
1620 |         templates = sorted(
1621 |             {
1622 |                 template
1623 |                 for score, _error, template in worker_results
1624 |                 if score > 0 and template
1625 |             }
1626 |         )
1627 |         if len(templates) > 1:
1628 |             examples = "; ".join(templates[:3])
1629 |             return {
1630 |                 "combined_score": 0.0,
1631 |                 "n_stage1_datasets": len(subset),
1632 |                 "n_stage1_successful": len(successful_scores),
1633 |                 "eval_workers": NUM_WORKERS,
1634 |                 "error": (
1635 |                     "Single-equation violation: stage 1 produced "
1636 |                     f"{len(templates)} distinct equation templates across datasets. "
1637 |                     "The base equation must be identical for all datasets. "
1638 |                     f"Example templates: {examples}"
1639 |                 ),
1640 |             }
1641 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
1642 |         return {
1643 |             "combined_score": agg_combined,
1644 |             "n_stage1_datasets": len(subset),
1645 |             "n_stage1_successful": len(successful_scores),
1646 |             "eval_workers": NUM_WORKERS,
1647 |             "stage1_full_selected_datasets": 1.0,
1648 |         }
1649 |     except Exception as exc:
1650 |         print(f"Stage 1 evaluation failed: {exc}")
1651 |         return {"combined_score": 0.0, "error": str(exc)}
