 902 |             "shape_loss_weight": SHAPE_LOSS_WEIGHT,
 903 |             "n_val_points": int(len(y_val)),
 904 |             "evaluation_only": evaluation_only,
 905 |             "train_only": train_only,
 906 |             "combined_score": (
 907 |                 0.0
