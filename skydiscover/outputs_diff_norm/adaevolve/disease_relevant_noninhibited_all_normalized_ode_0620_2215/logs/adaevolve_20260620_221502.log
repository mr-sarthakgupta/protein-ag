 917 |     fit_residual_scale = float(np.sqrt(fit_reference_var)) if fit_reference_var > 0.0 else 1.0
 918 | 
 919 |     def residual(theta: np.ndarray) -> np.ndarray:
 920 |         try:
 921 |             prediction = _ode_predictions(rhs_fn, X_fit, y_fit, theta)
 922 |         except Exception:
 923 |             return np.full_like(y_fit, 1e12, dtype=float)
 924 |         if prediction.shape != y_fit.shape or not np.all(np.isfinite(prediction)):
 925 |             return np.full_like(y_fit, 1e12, dtype=float)
 926 |         return (prediction - y_fit) / fit_residual_scale
 927 | 
 928 |     initial_candidates: list[np.ndarray] = []
 929 |     for scale in ODE_MULTISTART_SCALES or (1.0,):
 930 |         candidate = base_x0 * float(scale)
 931 |         if not any(np.array_equal(candidate, existing) for existing in initial_candidates):
 932 |             initial_candidates.append(candidate)
 933 | 
 934 |     import warnings
 935 | 
 936 |     best_fit = None
 937 |     best_loss = float("inf")
 938 |     with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 939 |         warnings.simplefilter("ignore", RuntimeWarning)
 940 |         for initial_candidate in initial_candidates:
 941 |             fit = least_squares(
 942 |                 residual,
 943 |                 initial_candidate,
 944 |                 loss="soft_l1",
 945 |                 max_nfev=max_nfev,
 946 |             )
 947 |             fit_residual = residual(fit.x)
 948 |             fit_loss = float(np.mean(fit_residual**2))
 949 |             if fit_loss < best_loss:
 950 |                 best_loss = fit_loss
 951 |                 best_fit = fit
 952 | 
 953 |     if best_fit is None:
 954 |         raise RuntimeError("constant fitting did not produce a result")
