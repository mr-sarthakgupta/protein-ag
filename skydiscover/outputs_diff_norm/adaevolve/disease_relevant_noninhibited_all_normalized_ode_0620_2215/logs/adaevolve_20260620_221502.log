 417 |     if evaluate_calls != 1:
 418 |         raise ValueError(
 419 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must call "
 420 |             f"evaluate_expression() exactly once; found {evaluate_calls} calls."
 421 |         )
 422 | 
 423 | 
 424 | def _parse_metadata_number(header: str, key: str) -> float | None:
 425 |     """Extract the leading numeric value for a cleaned header field."""
 426 |     match = re.search(
 427 |         rf"(?:^|[\s_]){re.escape(key)}:\s*([-+]?\d+(?:\.\d+)?(?:[eE][-+]?\d+)?)",
 428 |         header,
 429 |     )
 430 |     if match is None:
 431 |         return None
 432 |     return float(match.group(1))
 433 | 
 434 | 
 435 | def _is_x_column(header: str) -> bool:
 436 |     return bool(re.search(r"\s*X\s*$", header.strip()))
 437 | 
 438 | 
 439 | def _is_y_column(header: str) -> bool:
 440 |     return bool(re.search(r"\s*Y\s*$", header.strip()))
 441 | 
 442 | 
 443 | def _remember_curve_ids(X: np.ndarray, curve_ids: np.ndarray) -> np.ndarray:
 444 |     _ARRAY_CURVE_IDS[id(X)] = np.asarray(curve_ids, dtype=int)
 445 |     return X
 446 | 
 447 | 
 448 | def _minmax_normalize(values: np.ndarray) -> np.ndarray:
 449 |     """Normalize one dataset column to 0..1, preserving constants as zeros."""
 450 |     values = np.asarray(values, dtype=float)
 451 |     v_min = float(np.min(values))
 452 |     v_max = float(np.max(values))
 453 |     scale = v_max - v_min
 454 |     if scale <= 0.0:
 455 |         return np.zeros_like(values, dtype=float)
 456 |     return (values - v_min) / scale
 457 | 
 458 | 
 459 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 460 |     """Load cleaned data.tsv and return X=[normalized time, m0, M0, c], y.
 461 | 
 462 |     Cleaned files store one trajectory per adjacent X/Y column pair. Each
 463 |     column header contains m0, M0, and L0 metadata; only m0 and M0 are exposed
 464 |     as static ODE features. Units are intentionally ignored per the cleaned-data
 465 |     note: the leading numeric value is used as provided.
 466 |     """
 467 |     with data_file.open(newline="") as f:
 468 |         reader = csv.reader(f, delimiter="\t")
 469 |         header = next(reader)
 470 |         rows = [row for row in reader if row]
 471 | 
 472 |     features: list[list[float]] = []
 473 |     targets: list[float] = []
 474 |     curve_ids: list[int] = []
 475 |     curve_id = 0
 476 |     for col_idx in range(len(header) - 1):
 477 |         x_header = header[col_idx]
 478 |         y_header = header[col_idx + 1]
 479 |         if not (_is_x_column(x_header) and _is_y_column(y_header)):
 480 |             continue
 481 |         m0 = _parse_metadata_number(x_header, "m0")
 482 |         seed_m0 = _parse_metadata_number(x_header, "M0")
 483 |         if m0 is None or seed_m0 is None:
 484 |             continue
 485 |         for row in rows:
 486 |             if col_idx + 1 >= len(row):
 487 |                 continue
 488 |             time_value = row[col_idx].strip()
 489 |             response_value = row[col_idx + 1].strip()
 490 |             if (
 491 |                 not time_value
 492 |                 or not response_value
 493 |                 or time_value.lower() == "nan"
 494 |                 or response_value.lower() == "nan"
 495 |             ):
 496 |                 continue
 497 |             features.append([float(time_value), m0, seed_m0])
 498 |             targets.append(float(response_value))
 499 |             curve_ids.append(curve_id)
 500 |         curve_id += 1
 501 | 
 502 |     if not features:
 503 |         raise ValueError(f"No regression samples loaded from {data_file}")
 504 | 
 505 |     X = np.asarray(features, dtype=float)
 506 |     y = np.asarray(targets, dtype=float)
 507 |     time_norm = _minmax_normalize(X[:, 0])
 508 |     monomer_raw = X[:, 1]
 509 |     seed_raw = X[:, 2]
 510 |     y_norm = _minmax_normalize(y)
 511 | 
 512 |     # x3 is the concentration state c used by ODE RHS templates. During scoring
 513 |     # it is supplied from odeint's dynamic state, not read from candidate code.
 514 |     X_ode = np.column_stack([time_norm, monomer_raw, seed_raw, y_norm])
 515 |     return _remember_curve_ids(X_ode, np.asarray(curve_ids, dtype=int)), y_norm
 516 | 
 517 | 
 518 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 519 |     """Recursively find all cleaned data.tsv files and return dataset entries."""
 520 |     datasets: list[tuple[str, Path]] = []
 521 |     for dirpath, _dirnames, filenames in os.walk(root):
 522 |         if "data.tsv" in filenames:
 523 |             fit_path = Path(dirpath) / "data.tsv"
 524 |             rel = fit_path.parent.relative_to(root)
 525 |             name = str(rel).replace(os.sep, "/")
 526 |             datasets.append((name, fit_path))
 527 |     datasets.sort(key=lambda x: x[0])
 528 |     return datasets
 529 | 
 530 | 
 531 | def _curve_indices(X: np.ndarray) -> list[np.ndarray]:
 532 |     """Return cleaned-trajectory row indices."""
 533 |     if X.shape[0] == 0:
 534 |         return []
 535 |     curve_ids = _ARRAY_CURVE_IDS.get(id(X))
 536 |     if curve_ids is not None and curve_ids.shape[0] == X.shape[0]:
 537 |         return [np.flatnonzero(curve_ids == curve_id) for curve_id in dict.fromkeys(curve_ids)]
 538 |     return [np.arange(X.shape[0], dtype=int)]
 539 | 
 540 | 
 541 | def _trajectory_preserving_split(
 542 |     X: np.ndarray,
 543 |     y: np.ndarray,
 544 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 545 |     """Split whole cleaned X/Y curves into fit and NMSE-evaluation sets."""
 546 |     curves = _curve_indices(X)
 547 |     rng = np.random.default_rng(RANDOM_STATE)
 548 | 
 549 |     if len(curves) < 6:
 550 |         empty_X = np.empty((0, X.shape[1]), dtype=float)
 551 |         empty_y = np.empty(0, dtype=float)
 552 |         return X, empty_X, y, empty_y
 553 | 
 554 |     shuffled = rng.permutation(len(curves))
 555 |     n_val_curves = min(
 556 |         max(1, int(round(len(curves) * TEST_SIZE))), len(curves) - 1
 557 |     )
 558 |     val_curve_ids = set(int(i) for i in shuffled[:n_val_curves])
 559 | 
 560 |     fit_indices: list[int] = []
 561 |     val_indices: list[int] = []
 562 |     for curve_id, curve_idx in enumerate(curves):
 563 |         if curve_id in val_curve_ids:
 564 |             val_indices.extend(curve_idx.tolist())
 565 |         else:
 566 |             fit_indices.extend(curve_idx.tolist())
 567 | 
 568 |     fit_idx = np.sort(np.asarray(fit_indices, dtype=int))
 569 |     val_idx = np.sort(np.asarray(val_indices, dtype=int))
 570 |     curve_ids = _ARRAY_CURVE_IDS.get(id(X), np.zeros(X.shape[0], dtype=int))
 571 |     X_fit = X[fit_idx]
 572 |     X_val = X[val_idx]
 573 |     _remember_curve_ids(X_fit, curve_ids[fit_idx])
 574 |     _remember_curve_ids(X_val, curve_ids[val_idx])
 575 |     return X_fit, X_val, y[fit_idx], y[val_idx]
 576 | 
 577 | 
 578 | def _evaluation_only_split(
 579 |     X: np.ndarray,
 580 |     y: np.ndarray,
 581 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 582 |     """Hold out an entire dataset for validation-only cross-protein evaluation."""
 583 |     empty_X = np.empty((0, X.shape[1]), dtype=float)
 584 |     empty_y = np.empty(0, dtype=float)
 585 |     _remember_curve_ids(empty_X, np.empty(0, dtype=int))
 586 |     _remember_curve_ids(X, _ARRAY_CURVE_IDS.get(id(X), np.zeros(X.shape[0], dtype=int)))
 587 |     return empty_X, X, empty_y, y
 588 | 
