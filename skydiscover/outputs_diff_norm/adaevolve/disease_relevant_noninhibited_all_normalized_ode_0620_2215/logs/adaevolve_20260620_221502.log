1528 | def _eval_stage1_worker(args):
1529 |     """Module-level worker for stage 1 parallel evaluation."""
1530 |     name, X_train, X_val, y_train, y_val, program_path = args
1531 |     harness_root = str(BENCHMARK_ROOT)
1532 |     if harness_root not in sys.path:
1533 |         sys.path.insert(0, harness_root)
1534 |     validate_candidate_source(program_path)
1535 |     import pysr_harness.equation_session as equation_session
1536 |     equation_session.evaluate_expression = evaluate_ode_expression
1537 |     equation_session.nmse = _nmse_with_gaussian_smoothed_target
1538 |     spec = importlib.util.spec_from_file_location("program", program_path)
1539 |     program = importlib.util.module_from_spec(spec)
1540 |     spec.loader.exec_module(program)
1541 |     from pysr_harness.equation_session import (
1542 |         single_equation_evaluation,
1543 |         validate_single_equation_result,
1544 |     )
1545 | 
1546 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1547 |         program, "run_discovery", None
1548 |     )
1549 |     if fn is None:
1550 |         return 0.0, "missing evaluate_symbolic_candidate()", ""
1551 |     try:
1552 |         with single_equation_evaluation():
1553 |             result = fn(X_train, y_train, X_val, y_val)
1554 |             validate_single_equation_result(result)
1555 |         return float(result.get("combined_score", 0.0)), None, str(
1556 |             result.get("equation_template", "")
1557 |         )
1558 |     except Exception as exc:
1559 |         return 0.0, str(exc), ""
