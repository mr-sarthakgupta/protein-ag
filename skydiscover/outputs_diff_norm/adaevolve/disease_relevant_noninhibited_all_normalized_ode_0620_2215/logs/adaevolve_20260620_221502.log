1275 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
1276 |     """Evaluate a candidate program across ALL datasets in a subprocess.
1277 | 
1278 |     The subprocess loads every dataset, calls the candidate's
1279 |     evaluate_symbolic_candidate() once per dataset (fitting independent
1280 |     constants each time) using parallel threads, and returns aggregated
1281 |     metrics.
1282 |     """
1283 |     validate_candidate_source(program_path)
1284 |     harness_root = str(BENCHMARK_ROOT)
1285 |     evaluator_path = str(Path(__file__).resolve())
1286 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
1287 |         script = f"""
1288 | import importlib.util
1289 | import os
1290 | import pickle
1291 | import sys
1292 | import traceback
1293 | from concurrent.futures import ThreadPoolExecutor, as_completed
1294 | 
1295 | os.environ.setdefault("OMP_NUM_THREADS", "1")
1296 | os.environ.setdefault("MKL_NUM_THREADS", "1")
1297 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
1298 | 
1299 | import numpy as np
1300 | 
1301 | sys.path.insert(0, {harness_root!r})
1302 | 
1303 | program_path = {program_path!r}
1304 | evaluator_path = {evaluator_path!r}
1305 | results_path = {temp_file.name + ".results"!r}
1306 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
1307 | 
1308 | def _write_payload_and_exit(payload):
1309 |     with open(results_path, "wb") as f:
1310 |         pickle.dump(payload, f)
1311 |     sys.stdout.flush()
1312 |     sys.stderr.flush()
1313 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
1314 |     # interpreter shutdown. The parent only needs the pickle payload.
1315 |     os._exit(0)
1316 | 
1317 | try:
1318 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
1319 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
1320 |     evaluator_spec.loader.exec_module(evaluator)
1321 |     evaluator.validate_candidate_source(program_path)
1322 | 
1323 |     import pysr_harness.equation_session as equation_session
1324 |     equation_session.evaluate_expression = evaluator.evaluate_ode_expression
1325 |     equation_session.nmse = evaluator._nmse_with_gaussian_smoothed_target
1326 |     spec = importlib.util.spec_from_file_location("program", program_path)
1327 |     program = importlib.util.module_from_spec(spec)
1328 |     spec.loader.exec_module(program)
1329 |     from pysr_harness.equation_session import (
1330 |         single_equation_evaluation,
1331 |         validate_single_equation_result,
1332 |     )
1333 | 
1334 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1335 |         program, "run_discovery", None
1336 |     )
1337 |     if fn is None:
1338 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
1339 | 
1340 |     datasets = evaluator.load_all_datasets()
1341 | 
1342 |     def _eval_one(args):
1343 |         ds_name, X_train, X_val, y_train, y_val = args
1344 |         try:
1345 |             with single_equation_evaluation():
1346 |                 result = fn(X_train, y_train, X_val, y_val)
1347 |                 validate_single_equation_result(result)
1348 |             ds_nmse = float(result.get("nmse_val", float("inf")))
1349 |             ds_train_nmse = float(result.get("nmse_train", float("inf")))
1350 |             ds_combined = float(result.get("combined_score", 0.0))
1351 |             return ds_name, {{
1352 |                 "nmse_train": ds_train_nmse,
1353 |                 "nmse_val": ds_nmse,
1354 |                 "shape_loss_val": float(result.get("shape_loss_val", 0.0)),
1355 |                 "scored_loss_val": float(result.get("scored_loss_val", ds_nmse)),
1356 |                 "n_val_points": int(result.get("n_val_points", 0)),
1357 |                 "evaluation_only": bool(result.get("evaluation_only", False)),
1358 |                 "combined_score": ds_combined,
1359 |                 "equation": str(result.get("equation", "")),
1360 |                 "equation_template": str(result.get("equation_template", "")),
1361 |                 "constants": result.get("constants", {{}}),
1362 |             }}
1363 |         except Exception as exc:
1364 |             return ds_name, {{
1365 |                 "nmse_train": float("inf"),
1366 |                 "nmse_val": float("inf"),
1367 |                 "shape_loss_val": float("inf"),
1368 |                 "scored_loss_val": float("inf"),
1369 |                 "n_val_points": int(len(y_val)),
1370 |                 "evaluation_only": bool(X_train.shape[0] == 0 and X_val.shape[0] > 0),
1371 |                 "combined_score": 0.0,
1372 |                 "error": str(exc),
1373 |             }}
1374 | 
1375 |     per_dataset_results = {{}}
1376 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1377 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
1378 |         for future in as_completed(futures):
1379 |             ds_name, ds_result = future.result()
1380 |             per_dataset_results[ds_name] = ds_result
1381 | 
1382 |     aggregated = evaluator._aggregate_per_dataset_results(per_dataset_results)
1383 | 
1384 |     _write_payload_and_exit({{"result": aggregated}})
1385 | except Exception as exc:
1386 |     traceback.print_exc()
