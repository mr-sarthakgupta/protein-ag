1006 | def _point_weighted_mean(
1007 |     values: list[float],
1008 |     weights: list[int],
1009 | ) -> float:
1010 |     """Average values with one weight per evaluation point."""
1011 |     total_weight = sum(weights)
1012 |     if total_weight <= 0:
1013 |         return float("inf")
1014 |     weighted = sum(
1015 |         float(value) * float(weight)
1016 |         for value, weight in zip(values, weights)
1017 |         if np.isfinite(float(value))
1018 |     )
1019 |     if not np.isfinite(weighted):
1020 |         return float("inf")
1021 |     return float(weighted / total_weight)
