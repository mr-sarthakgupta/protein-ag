 607 | def load_all_datasets(
 608 |     root: Path = DATA_ROOT,
 609 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 610 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 611 |     entries = discover_datasets(root)
 612 |     results = []
 613 |     for name, path in entries:
 614 |         try:
 615 |             X_train, X_val, y_train, y_val = load_dataset(path, dataset_name=name)
 616 |             results.append((name, X_train, X_val, y_train, y_val))
 617 |         except Exception as exc:
 618 |             print(f"Warning: skipping dataset {name}: {exc}")
 619 |     return results
