 590 | def _dataset_name_from_path(data_file: Path, root: Path = DATA_ROOT) -> str:
 591 |     return str(data_file.parent.relative_to(root)).replace(os.sep, "/")
 592 | 
 593 | 
 594 | def load_dataset(
 595 |     data_file: Path,
 596 |     *,
 597 |     dataset_name: str | None = None,
 598 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 599 |     """Load a single data.tsv and return deterministic trajectory-preserving split."""
 600 |     X, y = _load_fit_table(data_file)
 601 |     name = dataset_name or _dataset_name_from_path(data_file)
 602 |     if name in EVALUATION_ONLY_DATASETS:
 603 |         return _evaluation_only_split(X, y)
 604 |     return _trajectory_preserving_split(X, y)
