 621 | 
 622 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 623 | SHAPE_LOSS_WEIGHT = float(os.environ.get("SKYDISCOVER_SHAPE_LOSS_WEIGHT", "0.25"))
 624 | SHAPE_LOSS_WEIGHT = min(max(SHAPE_LOSS_WEIGHT, 0.0), 0.29)
 625 | 
 626 | 
 627 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 628 |     values = np.asarray(values, dtype=float).ravel()
 629 |     if values.size < 5 or sigma <= 0.0:
 630 |         return values
 631 |     radius = max(1, int(round(3.0 * sigma)))
 632 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 633 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 634 |     kernel /= np.sum(kernel)
 635 |     padded = np.pad(values, (radius, radius), mode="edge")
 636 |     return np.convolve(padded, kernel, mode="valid")
 637 | 
 638 | 
 639 | def _curve_smoothed_target(X: np.ndarray, y_true: np.ndarray) -> np.ndarray:
 640 |     """Smooth targets independently for each parameter curve in time order."""
 641 |     X = np.asarray(X, dtype=float)
 642 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 643 |     if X.shape[0] != y_true.shape[0] or X.shape[1] < 2:
 644 |         return _gaussian_smooth_1d(y_true)
 645 | 
 646 |     smoothed = np.empty_like(y_true, dtype=float)
 647 |     for parameter in np.unique(X[:, 1]):
 648 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 649 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 650 |         smoothed_curve = _gaussian_smooth_1d(y_true[ordered_idx])
 651 |         smoothed[ordered_idx] = smoothed_curve
 652 |     return smoothed
 653 | 
 654 | 
 655 | def _normalized_mse_with_reference_variance(
 656 |     y_true: np.ndarray,
 657 |     y_pred: np.ndarray,
 658 |     reference_values: np.ndarray,
 659 | ) -> float:
 660 |     """MSE normalized by full dataset scale, not by a flat validation segment."""
 661 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 662 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 663 |     reference_values = np.asarray(reference_values, dtype=float).reshape(-1)
 664 |     if y_true.shape != y_pred.shape:
 665 |         return float("inf")
 666 |     if not np.all(np.isfinite(y_pred)):
 667 |         return float("inf")
 668 |     var = float(np.var(reference_values))
 669 |     if var <= 0.0:
 670 |         return float(np.mean((y_true - y_pred) ** 2))
 671 |     return float(np.mean((y_true - y_pred) ** 2) / var)
 672 | 
 673 | 
 674 | def _nmse_with_gaussian_smoothed_target(
 675 |     y_true: np.ndarray,
 676 |     y_pred: np.ndarray,
 677 |     X: np.ndarray | None = None,
 678 |     reference_values: np.ndarray | None = None,
 679 | ) -> float:
 680 |     reference = y_true if reference_values is None else reference_values
 681 |     return _normalized_mse_with_reference_variance(y_true, y_pred, reference)
 682 | 
 683 | 
 684 | def _bounded_loss(value: float) -> float:
 685 |     """Map a nonnegative loss to [0, 1), preserving order."""
 686 |     if not np.isfinite(value):
 687 |         return 1.0
 688 |     value = max(float(value), 0.0)
 689 |     return float(value / (1.0 + value))
 690 | 
 691 | 
 692 | def _half_response_time(x: np.ndarray, y: np.ndarray, level: float = 0.5) -> float | None:
 693 |     """Return interpolated normalized time where a curve crosses a response level."""
 694 |     x = np.asarray(x, dtype=float).reshape(-1)
 695 |     y = np.asarray(y, dtype=float).reshape(-1)
 696 |     if x.size < 2 or y.size != x.size:
 697 |         return None
 698 |     order = np.argsort(x)
 699 |     x = x[order]
 700 |     y = y[order]
 701 |     for i in range(y.size - 1):
 702 |         y0 = float(y[i])
 703 |         y1 = float(y[i + 1])
 704 |         if y0 == level:
 705 |             return float(x[i])
 706 |         if (y0 - level) * (y1 - level) <= 0.0 and y0 != y1:
 707 |             fraction = (level - y0) / (y1 - y0)
 708 |             return float(x[i] + fraction * (x[i + 1] - x[i]))
 709 |     if y[-1] == level:
 710 |         return float(x[-1])
 711 |     return None
 712 | 
 713 | 
 714 | def _curve_shape_loss(X: np.ndarray, y_true: np.ndarray, y_pred: np.ndarray) -> float:
 715 |     """Bounded shape mismatch based on curve slopes and half-response timing."""
 716 |     X = np.asarray(X, dtype=float)
 717 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 718 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 719 |     if X.shape[0] != y_true.size or y_true.shape != y_pred.shape or y_true.size < 5:
 720 |         return 0.0
 721 |     if not np.all(np.isfinite(y_pred)):
 722 |         return 1.0
 723 | 
 724 |     curve_ids = _ARRAY_CURVE_IDS.get(id(X))
 725 |     if curve_ids is None or curve_ids.shape[0] != X.shape[0]:
 726 |         curve_ids = np.zeros(X.shape[0], dtype=int)
 727 | 
 728 |     curve_losses: list[float] = []
 729 |     for curve_id in dict.fromkeys(np.asarray(curve_ids, dtype=int)):
 730 |         idx = np.flatnonzero(curve_ids == curve_id)
 731 |         if idx.size < 5:
 732 |             continue
 733 |         order = idx[np.argsort(X[idx, 0])]
 734 |         x = X[order, 0]
 735 |         true_curve = y_true[order]
 736 |         pred_curve = y_pred[order]
 737 |         dx = np.diff(x)
 738 |         valid_dx = np.abs(dx) > 1e-12
 739 |         if not np.any(valid_dx):
 740 |             continue
 741 |         true_slope = np.diff(true_curve)[valid_dx] / dx[valid_dx]
 742 |         pred_slope = np.diff(pred_curve)[valid_dx] / dx[valid_dx]
 743 |         slope_scale = float(np.mean(true_slope**2))
 744 |         slope_raw = float(np.mean((pred_slope - true_slope) ** 2))
 745 |         slope_loss = (
 746 |             _bounded_loss(slope_raw / slope_scale)
 747 |             if slope_scale > 0.0
 748 |             else _bounded_loss(slope_raw)
 749 |         )
 750 | 
 751 |         true_half = _half_response_time(x, true_curve)
 752 |         pred_half = _half_response_time(x, pred_curve)
 753 |         if true_half is None and pred_half is None:
 754 |             timing_loss = 0.0
 755 |         elif true_half is None or pred_half is None:
 756 |             timing_loss = 1.0
 757 |         else:
 758 |             timing_loss = min(abs(float(pred_half) - float(true_half)), 1.0)
 759 | 
 760 |         curve_losses.append(0.7 * slope_loss + 0.3 * timing_loss)
 761 | 
 762 |     if not curve_losses:
 763 |         return 0.0
 764 |     return float(np.mean(curve_losses))
 765 | 
 766 | 
 767 | def _composite_scored_loss(nmse_val: float, shape_loss: float) -> float:
 768 |     if not np.isfinite(nmse_val):
 769 |         return float("inf")
 770 |     bounded_shape = min(max(float(shape_loss), 0.0), 1.0) if np.isfinite(shape_loss) else 1.0
 771 |     return float((1.0 - SHAPE_LOSS_WEIGHT) * float(nmse_val) + SHAPE_LOSS_WEIGHT * bounded_shape)
 772 | 
 773 | 
 774 | def _ode_predictions(
 775 |     rhs_fn: Any,
 776 |     X: np.ndarray,
 777 |     y_known: np.ndarray,
 778 |     theta: np.ndarray,
 779 | ) -> np.ndarray:
 780 |     """Integrate dc/dt=f(t, m0, M0, c) per cleaned X/Y curve."""
 781 |     import warnings
 782 | 
 783 |     from scipy.integrate import odeint
 784 | 
 785 |     X = np.asarray(X, dtype=float)
 786 |     y_known = np.asarray(y_known, dtype=float).reshape(-1)
 787 |     theta = np.asarray(theta, dtype=float).reshape(-1)
 788 |     predictions = np.full_like(y_known, np.nan, dtype=float)
 789 | 
 790 |     for curve_idx in _curve_indices(X):
 791 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 792 |         times = X[ordered_idx, 0]
 793 |         observed = y_known[ordered_idx]
 794 |         static_features = [float(value) for value in X[ordered_idx[0], 1:-1]]
 795 | 
 796 |         if len(ordered_idx) == 1 or float(times[-1] - times[0]) <= 0.0:
 797 |             predictions[ordered_idx] = observed[0]
 798 |             continue
 799 | 
 800 |         def dc_dt(c_state: np.ndarray, time_value: float) -> float:
 801 |             c_value = float(np.asarray(c_state, dtype=float).reshape(-1)[0])
 802 |             value = rhs_fn(float(time_value), *static_features, c_value, *theta)
 803 |             value = float(np.asarray(value, dtype=float).reshape(-1)[0])
 804 |             if not np.isfinite(value):
 805 |                 raise FloatingPointError("non-finite ODE derivative")
 806 |             return value
 807 | 
 808 |         with warnings.catch_warnings():
 809 |             warnings.simplefilter("ignore")
 810 |             integrated = odeint(
 811 |                 dc_dt,
 812 |                 float(observed[0]),
 813 |                 times,
 814 |                 mxstep=1000,
 815 |             )
 816 |         curve_pred = np.asarray(integrated, dtype=float).reshape(-1)
 817 |         if curve_pred.shape != observed.shape or not np.all(np.isfinite(curve_pred)):
 818 |             raise FloatingPointError("non-finite ODE trajectory")
 819 |         predictions[ordered_idx] = curve_pred
 820 | 
 821 |     return predictions
 822 | 
 823 | 
 824 | def evaluate_ode_expression(
 825 |     expression: Any,
 826 |     X_train: np.ndarray,
 827 |     y_train: np.ndarray,
 828 |     X_val: np.ndarray,
 829 |     y_val: np.ndarray,
 830 |     *,
 831 |     constants: Any | None = None,
 832 |     initial_values: Any | None = None,
 833 |     max_nfev: int = 300,
 834 | ) -> dict[str, Any]:
 835 |     """Score a proposed ODE RHS by integrating predicted concentration curves."""
 836 |     import sympy as sp
 837 |     from pysr_harness import equation_session
 838 |     from scipy.optimize import least_squares
 839 | 
 840 |     X_train = np.asarray(X_train, dtype=float)
 841 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 842 |     X_val = np.asarray(X_val, dtype=float)
 843 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 844 |     evaluation_only = X_train.shape[0] == 0 and X_val.shape[0] > 0
 845 |     train_only = X_val.shape[0] == 0 and X_train.shape[0] > 0
 846 |     if evaluation_only:
 847 |         X_fit, y_fit = X_val, y_val
 848 |     else:
 849 |         X_fit, y_fit = X_train, y_train
 850 |     y_reference = np.concatenate([y_train, y_val]) if y_train.size else y_val
 851 |     n_features = X_fit.shape[1] if X_fit.shape[0] else X_val.shape[1]
 852 |     feature_names = [f"x{i}" for i in range(n_features)]
 853 |     template = equation_session._as_sympy_expr(expression, feature_names)
 854 |     equation_session._record_scored_template(template)
 855 | 
 856 |     if constants is None:
 857 |         feature_set = set(equation_session.feature_symbols(n_features))
 858 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 859 |     constants = list(constants)
 860 |     equation_session._validate_expression_template(template, constants)
 861 | 
 862 |     if initial_values is None:
 863 |         base_x0 = np.ones(len(constants), dtype=float)
 864 |     else:
 865 |         base_x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 866 |         if base_x0.size != len(constants):
 867 |             raise ValueError("initial_values must match the number of constants")
 868 | 
 869 |     feature_syms = equation_session.feature_symbols(n_features)
 870 |     rhs_fn = sp.lambdify(feature_syms + constants, template, modules=["numpy"])
 871 | 
 872 |     if not constants:
 873 |         y_pred_fit = _ode_predictions(rhs_fn, X_fit, y_fit, np.asarray([], dtype=float))
 874 |         y_pred_val = _ode_predictions(rhs_fn, X_val, y_val, np.asarray([], dtype=float))
 875 |         nmse_train = (
 876 |             float("nan")
 877 |             if evaluation_only
 878 |             else _nmse_with_gaussian_smoothed_target(
 879 |                 y_train, y_pred_fit, X_train, y_reference
 880 |             )
 881 |         )
 882 |         nmse_val = (
 883 |             float("nan")
 884 |             if train_only
 885 |             else _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 886 |         )
 887 |         shape_loss_val = (
 888 |             float("nan") if train_only else _curve_shape_loss(X_val, y_val, y_pred_val)
 889 |         )
 890 |         scored_loss_val = (
 891 |             float("nan") if train_only else _composite_scored_loss(nmse_val, shape_loss_val)
 892 |         )
 893 |         result = {
 894 |             "equation_template": f"d(c)/dt = {template}",
 895 |             "equation": f"d(c)/dt = {template}",
 896 |             "constants": {},
 897 |             "loss": float(np.mean((y_pred_fit - y_fit) ** 2)),
 898 |             "nmse_train": nmse_train,
 899 |             "nmse_val": nmse_val,
 900 |             "shape_loss_val": shape_loss_val,
