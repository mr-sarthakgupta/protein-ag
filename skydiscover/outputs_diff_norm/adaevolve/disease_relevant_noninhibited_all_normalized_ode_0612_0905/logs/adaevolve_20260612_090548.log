 629 | def _curve_smoothed_target(X: np.ndarray, y_true: np.ndarray) -> np.ndarray:
 630 |     """Smooth targets independently for each parameter curve in time order."""
 631 |     X = np.asarray(X, dtype=float)
 632 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 633 |     if X.shape[0] != y_true.shape[0] or X.shape[1] < 2:
 634 |         return _gaussian_smooth_1d(y_true)
 635 | 
 636 |     smoothed = np.empty_like(y_true, dtype=float)
 637 |     for parameter in np.unique(X[:, 1]):
 638 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 639 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 640 |         smoothed_curve = _gaussian_smooth_1d(y_true[ordered_idx])
 641 |         smoothed[ordered_idx] = smoothed_curve
 642 |     return smoothed
