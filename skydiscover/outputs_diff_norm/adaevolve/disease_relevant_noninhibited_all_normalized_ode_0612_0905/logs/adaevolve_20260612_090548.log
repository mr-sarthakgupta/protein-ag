  60 |         "IAPP/Daval2010/Fits/Daval2010_prim",
  61 |         "IAPP/Daval2010/Fits/Daval2010_sec",
  62 |         "hnRNPA/Kim2013/Fits/Kim2013_A1_prim",
  63 |         "insulin/Fits/Nielsen2001_seeded_sec",
  64 |         "lysozyme/Fits/Hasecke2018_7uM_sec",
  65 |     }
  66 | )
  67 | GAUSSIAN_SMOOTH_SIGMA = float(os.environ.get("SKYDISCOVER_GAUSSIAN_SMOOTH_SIGMA", "1.0"))
  68 | ODE_MULTISTART_SCALES = tuple(
  69 |     float(value)
  70 |     for value in os.environ.get("SKYDISCOVER_ODE_MULTISTART_SCALES", "1.0,0.3,3.0").split(",")
  71 |     if value.strip()
  72 | )
  73 | SINGLE_EQUATION_ERROR_PREFIX = "Single-equation violation"
  74 | _ALLOWED_IMPORTS = {"sympy", "numpy"}
  75 | _ALLOWED_FROM_IMPORTS = {
  76 |     "__future__",
  77 |     "typing",
  78 |     "numpy.typing",
  79 |     "pysr_harness.equation_session",
  80 | }
  81 | _ALLOWED_HARNESS_IMPORTS = {
  82 |     "constant_symbols",
  83 |     "evaluate_expression",
  84 |     "feature_symbols",
  85 | }
  86 | _ALLOWED_EVALUATE_CALLS = {
  87 |     "constant_symbols",
  88 |     "evaluate_expression",
  89 |     "feature_symbols",
  90 |     "sp.exp",
  91 |     "sp.log",
  92 |     "sp.log1p",
  93 |     "sp.sqrt",
  94 |     "sp.sin",
  95 |     "sp.cos",
  96 |     "sp.tan",
  97 |     "sp.tanh",
  98 |     "sp.sinh",
  99 |     "sp.cosh",
 100 | }
 101 | _PROTECTED_NAMES = {
 102 |     "constant_symbols",
 103 |     "evaluate_expression",
 104 |     "feature_symbols",
 105 |     "single_equation_evaluation",
 106 |     "validate_single_equation_result",
 107 | }
 108 | _DISALLOWED_CONTROL_NODES = (
 109 |     ast.AsyncFunctionDef,
 110 |     ast.ClassDef,
 111 |     ast.For,
 112 |     ast.While,
 113 |     ast.If,
 114 |     ast.IfExp,
 115 |     ast.Try,
 116 |     ast.With,
 117 |     ast.AsyncWith,
 118 |     ast.Match,
 119 |     ast.Lambda,
 120 |     ast.ListComp,
 121 |     ast.SetComp,
 122 |     ast.DictComp,
 123 |     ast.GeneratorExp,
 124 | )
