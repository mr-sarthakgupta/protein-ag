 239 | def _validate_evaluate_expression_data_args(call: ast.Call) -> set[int]:
 240 |     expected = ["X_train", "y_train", "X_val", "y_val"]
 241 |     if len(call.args) < 5:
 242 |         raise ValueError(
 243 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must be called "
 244 |             "as evaluate_expression(expression, X_train, y_train, X_val, y_val, ...)."
 245 |         )
 246 |     actual_data_args = call.args[1:5]
 247 |     if not all(
 248 |         isinstance(arg, ast.Name) and arg.id == expected_name
 249 |         for arg, expected_name in zip(actual_data_args, expected)
 250 |     ):
 251 |         raise ValueError(
 252 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must use the "
 253 |             "canonical data arguments exactly as X_train, y_train, X_val, y_val. "
 254 |             "Do not fit constants on validation labels or reorder the split."
 255 |         )
 256 |     return {id(arg) for arg in call.args[1:5]}
