1204 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
1205 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
1206 |     nmse_val = float(result.get("nmse_val", float("inf")))
1207 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
1208 |     if not np.isfinite(combined):
1209 |         combined = 0.0
1210 | 
1211 |     return {
1212 |         "equation": str(result.get("equation", "")),
1213 |         "loss": nmse_val,
1214 |         "complexity": float(result.get("complexity", 0.0)),
1215 |         "nmse_train": float(result.get("nmse_train", float("inf"))),
1216 |         "nmse_val": nmse_val,
1217 |         "mean_nmse_val": float(result.get("mean_nmse_val", nmse_val)),
1218 |         "mean_raw_nmse_val": float(result.get("mean_raw_nmse_val", nmse_val)),
1219 |         "combined_score": combined,
1220 |         "fit_score": float(result.get("fit_score", combined)),
1221 |         "parsimony_weight": float(result.get("parsimony_weight", PARSIMONY_WEIGHT)),
1222 |         "parsimony_penalty_factor": float(result.get("parsimony_penalty_factor", 1.0)),
1223 |         "eval_time": float(eval_time),
1224 |         "n_datasets": result.get("n_datasets", 0),
1225 |         "n_successful": result.get("n_successful", 0),
1226 |         "eval_workers": result.get("eval_workers", NUM_WORKERS),
1227 |         "hard_cases": result.get("hard_cases", []),
1228 |         "hard_case_feedback": str(result.get("hard_case_feedback", "")),
1229 |         "per_dataset": result.get("per_dataset", {}),
1230 |         "error": str(result.get("error", "")),
1231 |     }
