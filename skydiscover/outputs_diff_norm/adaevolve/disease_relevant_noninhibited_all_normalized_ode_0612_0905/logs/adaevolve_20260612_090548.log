 609 | def _parsimony_penalty_factor(complexity: float) -> float:
 610 |     """Bounded penalty factor for expression complexity."""
 611 |     if not np.isfinite(complexity) or PARSIMONY_COMPLEXITY_SCALE <= 0:
 612 |         return 1.0
 613 |     normalized = min(max(float(complexity), 0.0) / PARSIMONY_COMPLEXITY_SCALE, 1.0)
 614 |     return max(0.0, 1.0 - PARSIMONY_WEIGHT * normalized)
