1059 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
1060 |     """Evaluate a candidate program across ALL datasets in a subprocess.
1061 | 
1062 |     The subprocess loads every dataset, calls the candidate's
1063 |     evaluate_symbolic_candidate() once per dataset (fitting independent
1064 |     constants each time) using parallel threads, and returns aggregated
1065 |     metrics.
1066 |     """
1067 |     validate_candidate_source(program_path)
1068 |     harness_root = str(BENCHMARK_ROOT)
1069 |     evaluator_path = str(Path(__file__).resolve())
1070 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
1071 |         script = f"""
1072 | import importlib.util
1073 | import os
1074 | import pickle
1075 | import sys
1076 | import traceback
1077 | from concurrent.futures import ThreadPoolExecutor, as_completed
1078 | 
1079 | os.environ.setdefault("OMP_NUM_THREADS", "1")
1080 | os.environ.setdefault("MKL_NUM_THREADS", "1")
1081 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
1082 | 
1083 | import numpy as np
1084 | 
1085 | sys.path.insert(0, {harness_root!r})
1086 | 
1087 | program_path = {program_path!r}
1088 | evaluator_path = {evaluator_path!r}
1089 | results_path = {temp_file.name + ".results"!r}
1090 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
1091 | 
1092 | def _write_payload_and_exit(payload):
1093 |     with open(results_path, "wb") as f:
1094 |         pickle.dump(payload, f)
1095 |     sys.stdout.flush()
1096 |     sys.stderr.flush()
1097 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
1098 |     # interpreter shutdown. The parent only needs the pickle payload.
1099 |     os._exit(0)
1100 | 
1101 | try:
1102 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
1103 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
1104 |     evaluator_spec.loader.exec_module(evaluator)
1105 |     evaluator.validate_candidate_source(program_path)
1106 | 
1107 |     import pysr_harness.equation_session as equation_session
1108 |     equation_session.evaluate_expression = evaluator.evaluate_ode_expression
1109 |     equation_session.nmse = evaluator._nmse_with_gaussian_smoothed_target
1110 |     spec = importlib.util.spec_from_file_location("program", program_path)
1111 |     program = importlib.util.module_from_spec(spec)
1112 |     spec.loader.exec_module(program)
1113 |     from pysr_harness.equation_session import (
1114 |         single_equation_evaluation,
1115 |         validate_single_equation_result,
1116 |     )
1117 | 
1118 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1119 |         program, "run_discovery", None
1120 |     )
1121 |     if fn is None:
1122 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
1123 | 
1124 |     datasets = evaluator.load_all_datasets()
1125 | 
1126 |     def _eval_one(args):
1127 |         ds_name, X_train, X_val, y_train, y_val = args
1128 |         try:
1129 |             with single_equation_evaluation():
1130 |                 result = fn(X_train, y_train, X_val, y_val)
1131 |                 validate_single_equation_result(result)
1132 |             ds_nmse = float(result.get("nmse_val", float("inf")))
1133 |             ds_train_nmse = float(result.get("nmse_train", float("inf")))
1134 |             ds_combined = float(result.get("combined_score", 0.0))
1135 |             return ds_name, {{
1136 |                 "nmse_train": ds_train_nmse,
1137 |                 "nmse_val": ds_nmse,
1138 |                 "n_val_points": int(result.get("n_val_points", 0)),
1139 |                 "evaluation_only": bool(result.get("evaluation_only", False)),
1140 |                 "combined_score": ds_combined,
1141 |                 "complexity": float(result.get("complexity", 0.0)),
1142 |                 "equation": str(result.get("equation", "")),
1143 |                 "equation_template": str(result.get("equation_template", "")),
1144 |                 "constants": result.get("constants", {{}}),
1145 |             }}
1146 |         except Exception as exc:
1147 |             return ds_name, {{
1148 |                 "nmse_train": float("inf"),
1149 |                 "nmse_val": float("inf"),
1150 |                 "n_val_points": int(len(y_val)),
1151 |                 "evaluation_only": bool(X_train.shape[0] == 0 and X_val.shape[0] > 0),
1152 |                 "combined_score": 0.0,
1153 |                 "error": str(exc),
1154 |             }}
1155 | 
1156 |     per_dataset_results = {{}}
1157 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1158 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
1159 |         for future in as_completed(futures):
1160 |             ds_name, ds_result = future.result()
1161 |             per_dataset_results[ds_name] = ds_result
1162 | 
1163 |     aggregated = evaluator._aggregate_per_dataset_results(per_dataset_results)
1164 | 
1165 |     _write_payload_and_exit({{"result": aggregated}})
1166 | except Exception as exc:
1167 |     traceback.print_exc()
1168 |     _write_payload_and_exit({{"error": str(exc)}})
1169 | """
1170 |         temp_file.write(script.encode())
1171 |         temp_path = temp_file.name
1172 | 
1173 |     results_path = f"{temp_path}.results"
1174 |     try:
1175 |         process = subprocess.Popen(
1176 |             [sys.executable, temp_path],
1177 |             stdout=subprocess.PIPE,
1178 |             stderr=subprocess.PIPE,
1179 |         )
1180 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
1181 |         if stdout:
1182 |             print(stdout.decode())
1183 |         if stderr:
1184 |             print(stderr.decode())
1185 |         if process.returncode != 0:
1186 |             raise RuntimeError(f"Subprocess exited with code {process.returncode}")
1187 |         if not os.path.exists(results_path):
1188 |             raise RuntimeError("Results file not found")
1189 |         with open(results_path, "rb") as f:
1190 |             payload = pickle.load(f)
1191 |         if "error" in payload:
1192 |             raise RuntimeError(payload["error"])
1193 |         return payload["result"]
1194 |     except subprocess.TimeoutExpired:
1195 |         process.kill()
1196 |         process.wait()
1197 |         raise TimeoutError(f"Program execution timed out after {timeout_seconds}s")
1198 |     finally:
1199 |         for path in (temp_path, results_path):
1200 |             if os.path.exists(path):
1201 |                 os.unlink(path)
1202 | 
