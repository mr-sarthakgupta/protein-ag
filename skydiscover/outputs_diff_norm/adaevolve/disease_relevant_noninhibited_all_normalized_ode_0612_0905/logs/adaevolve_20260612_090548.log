1312 | def evaluate_stage1(program_path: str) -> dict:
1313 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
1314 |     try:
1315 |         harness_root = str(BENCHMARK_ROOT)
1316 |         if harness_root not in sys.path:
1317 |             sys.path.insert(0, harness_root)
1318 | 
1319 |         all_datasets = load_all_datasets()
1320 |         scoring_datasets = [
1321 |             dataset
1322 |             for dataset in all_datasets
1323 |             if dataset[0] not in EVALUATION_ONLY_DATASETS and dataset[4].size > 0
1324 |         ]
1325 |         rng = np.random.default_rng(RANDOM_STATE)
1326 |         if len(scoring_datasets) > 8:
1327 |             indices = rng.choice(len(scoring_datasets), size=8, replace=False)
1328 |             subset = [scoring_datasets[i] for i in sorted(indices)]
1329 |         else:
1330 |             subset = scoring_datasets
1331 | 
1332 |         work_items = [
1333 |             (name, X_train, X_val, y_train, y_val, program_path)
1334 |             for name, X_train, X_val, y_train, y_val in subset
1335 |         ]
1336 | 
1337 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1338 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
1339 |             worker_results = [future.result() for future in concurrent.futures.as_completed(futures)]
1340 | 
1341 |         combined_scores = [score for score, _error, _template in worker_results]
1342 |         successful_scores = [score for score in combined_scores if score > 0]
1343 |         errors = sorted({error for _score, error, _template in worker_results if error})
1344 |         violation_errors = sorted(
1345 |             {
1346 |                 error
1347 |                 for _score, error, _template in worker_results
1348 |                 if error and SINGLE_EQUATION_ERROR_PREFIX in error
1349 |             }
1350 |         )
1351 |         if violation_errors:
1352 |             return {
1353 |                 "combined_score": 0.0,
1354 |                 "n_stage1_datasets": len(subset),
1355 |                 "n_stage1_successful": len(successful_scores),
1356 |                 "eval_workers": NUM_WORKERS,
1357 |                 "error": violation_errors[0],
1358 |             }
1359 |         if errors:
1360 |             return {
1361 |                 "combined_score": 0.0,
1362 |                 "n_stage1_datasets": len(subset),
1363 |                 "n_stage1_successful": len(successful_scores),
1364 |                 "eval_workers": NUM_WORKERS,
1365 |                 "error": (
1366 |                     "Single-equation violation: stage 1 candidate failed on "
1367 |                     f"{len(errors)} dataset evaluations. Example: {errors[0]}"
1368 |                 ),
1369 |             }
1370 |         templates = sorted(
1371 |             {
1372 |                 template
1373 |                 for score, _error, template in worker_results
1374 |                 if score > 0 and template
1375 |             }
1376 |         )
1377 |         if len(templates) > 1:
1378 |             examples = "; ".join(templates[:3])
1379 |             return {
1380 |                 "combined_score": 0.0,
1381 |                 "n_stage1_datasets": len(subset),
1382 |                 "n_stage1_successful": len(successful_scores),
1383 |                 "eval_workers": NUM_WORKERS,
1384 |                 "error": (
1385 |                     "Single-equation violation: stage 1 produced "
1386 |                     f"{len(templates)} distinct equation templates across datasets. "
1387 |                     "The base equation must be identical for all datasets. "
1388 |                     f"Example templates: {examples}"
1389 |                 ),
1390 |             }
1391 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
1392 |         return {
1393 |             "combined_score": agg_combined,
1394 |             "n_stage1_datasets": len(subset),
1395 |             "n_stage1_successful": len(successful_scores),
1396 |             "eval_workers": NUM_WORKERS,
1397 |             "stage1_full_selected_datasets": 1.0,
1398 |         }
1399 |     except Exception as exc:
1400 |         print(f"Stage 1 evaluation failed: {exc}")
1401 |         return {"combined_score": 0.0, "error": str(exc)}
