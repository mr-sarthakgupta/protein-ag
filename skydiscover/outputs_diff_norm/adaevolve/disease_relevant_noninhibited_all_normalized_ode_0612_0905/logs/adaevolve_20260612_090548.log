1289 |     program = importlib.util.module_from_spec(spec)
1290 |     spec.loader.exec_module(program)
1291 |     from pysr_harness.equation_session import (
1292 |         single_equation_evaluation,
1293 |         validate_single_equation_result,
1294 |     )
1295 | 
1296 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1297 |         program, "run_discovery", None
1298 |     )
1299 |     if fn is None:
1300 |         return 0.0, "missing evaluate_symbolic_candidate()", ""
1301 |     try:
1302 |         with single_equation_evaluation():
1303 |             result = fn(X_train, y_train, X_val, y_val)
1304 |             validate_single_equation_result(result)
1305 |         return float(result.get("combined_score", 0.0)), None, str(
1306 |             result.get("equation_template", "")
1307 |         )
