 178 | def _validate_top_level_function(node: ast.FunctionDef, *, postponed_annotations: bool) -> None:
 179 |     if node.name in _PROTECTED_NAMES:
 180 |         raise ValueError(
 181 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function '{node.name}' "
 182 |             "shadows a protected scorer or harness name."
 183 |         )
 184 |     if node.decorator_list:
 185 |         raise ValueError(
 186 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function decorators are not "
 187 |             "allowed because decorators execute during candidate import."
 188 |         )
 189 |     if node.args.defaults or node.args.kw_defaults:
 190 |         raise ValueError(
 191 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function default arguments "
 192 |             "are not allowed because defaults execute during candidate import."
 193 |         )
 194 |     if _function_annotations(node) and not postponed_annotations:
 195 |         raise ValueError(
 196 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function annotations require "
 197 |             "'from __future__ import annotations' because annotations otherwise "
 198 |             "execute during candidate import."
 199 |         )
