 421 | def _parse_parameter_from_column(column_name: str) -> float | None:
 422 |     """Extract a monomer/protein concentration from a fit.tsv column header.
 423 | 
 424 |     Only concentration-like labels are accepted:
 425 |       - "... : 10uM"  or "10 uM"  → 10.0
 426 |       - "35uM" (bare, as in Abeta) → 35.0
 427 |       - "... : 3.95mM"             → 3950.0  (converted to uM)
 428 |       - "... : 0.3 mg/mL 22uM"    → 22.0    (prefer uM when both present)
 429 | 
 430 |     Seed percentages, pH values, ng/uL seed-material labels, and generic
 431 |     numeric fallbacks are intentionally ignored so x1 consistently represents
 432 |     the aggregating monomer/protein concentration when available.
 433 |     """
 434 |     text = column_name.strip()
 435 |     # Prefer the human-readable condition after the file-name prefix. Some
 436 |     # filenames contain seed concentrations that should not become x1.
 437 |     condition_text = text.rsplit(":", 1)[-1].strip().strip("\"'")
 438 | 
 439 |     # Prefer an explicit uM value
 440 |     m = re.search(r"(\d+(?:\.\d+)?)\s*uM", condition_text, re.IGNORECASE)
 441 |     if m:
 442 |         return float(m.group(1))
 443 | 
 444 |     # mM → convert to uM
 445 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mM", condition_text, re.IGNORECASE)
 446 |     if m:
 447 |         return float(m.group(1)) * 1000.0
 448 | 
 449 |     # mg/mL (take the number)
 450 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mg/mL", condition_text, re.IGNORECASE)
 451 |     if m:
 452 |         return float(m.group(1))
 453 | 
 454 |     return None
