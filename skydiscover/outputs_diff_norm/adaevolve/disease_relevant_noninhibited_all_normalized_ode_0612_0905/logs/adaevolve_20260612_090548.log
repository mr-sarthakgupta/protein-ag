 617 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 618 |     values = np.asarray(values, dtype=float).ravel()
 619 |     if values.size < 3 or sigma <= 0.0:
 620 |         return values
 621 |     radius = max(1, int(round(3.0 * sigma)))
 622 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 623 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 624 |     kernel /= np.sum(kernel)
 625 |     padded = np.pad(values, (radius, radius), mode="edge")
 626 |     return np.convolve(padded, kernel, mode="valid")
