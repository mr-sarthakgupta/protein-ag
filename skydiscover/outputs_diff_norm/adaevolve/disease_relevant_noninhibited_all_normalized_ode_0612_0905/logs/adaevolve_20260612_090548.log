 421 | def _parse_parameter_from_column(column_name: str) -> float | None:
 422 |     """Extract a monomer/protein concentration from a fit.tsv column header.
 423 | 
 424 |     Only concentration-like labels are accepted:
 425 |       - "... : 10uM"  or "10 uM"  → 10.0
 426 |       - "35uM" (bare, as in Abeta) → 35.0
 427 |       - "... : 3.95mM"             → 3950.0  (converted to uM)
 428 |       - "... : 0.3 mg/mL 22uM"    → 22.0    (prefer uM when both present)
 429 | 
 430 |     Seed percentages, pH values, ng/uL seed-material labels, and generic
 431 |     numeric fallbacks are intentionally ignored so x1 consistently represents
 432 |     the aggregating monomer/protein concentration when available.
 433 |     """
 434 |     text = column_name.strip()
 435 |     # Prefer the human-readable condition after the file-name prefix. Some
 436 |     # filenames contain seed concentrations that should not become x1.
 437 |     condition_text = text.rsplit(":", 1)[-1].strip().strip("\"'")
 438 | 
 439 |     # Prefer an explicit uM value
 440 |     m = re.search(r"(\d+(?:\.\d+)?)\s*uM", condition_text, re.IGNORECASE)
 441 |     if m:
 442 |         return float(m.group(1))
 443 | 
 444 |     # mM → convert to uM
 445 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mM", condition_text, re.IGNORECASE)
 446 |     if m:
 447 |         return float(m.group(1)) * 1000.0
 448 | 
 449 |     # mg/mL (take the number)
 450 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mg/mL", condition_text, re.IGNORECASE)
 451 |     if m:
 452 |         return float(m.group(1))
 453 | 
 454 |     return None
 455 | 
 456 | 
 457 | def _minmax_normalize(values: np.ndarray) -> np.ndarray:
 458 |     """Normalize one dataset column to 0..1, preserving constants as zeros."""
 459 |     values = np.asarray(values, dtype=float)
 460 |     v_min = float(np.min(values))
 461 |     v_max = float(np.max(values))
 462 |     scale = v_max - v_min
 463 |     if scale <= 0.0:
 464 |         return np.zeros_like(values, dtype=float)
 465 |     return (values - v_min) / scale
 466 | 
 467 | 
 468 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 469 |     """Load a wide fit.tsv and return X=[normalized time, raw parameter, c], y.
 470 | 
 471 |     The first column is always the time/measurement coordinate. Remaining
 472 |     columns are response curves. The varying parameter is extracted from
 473 |     concentration-like curve headers only; non-concentration columns are skipped.
 474 |     Time is min-max normalized to 0..1, but the parameter column is left in its
 475 |     parsed raw units. The response is normalized globally across the whole
 476 |     fit.tsv to 0..1. Files already rescaled to 0..1 keep that scale.
 477 |     """
 478 |     with data_file.open(newline="") as f:
 479 |         reader = csv.reader(f, delimiter="\t")
 480 |         header = next(reader)
 481 | 
 482 |         response_headers = header[1:]
 483 |         parsed_params = [_parse_parameter_from_column(h) for h in response_headers]
 484 | 
 485 |         features: list[list[float]] = []
 486 |         targets: list[float] = []
 487 |         for row in reader:
 488 |             if not row:
 489 |                 continue
 490 |             measurement_x = float(row[0])
 491 |             for param, value in zip(parsed_params, row[1:]):
 492 |                 if param is None:
 493 |                     continue
 494 |                 if value == "" or value.strip().lower() == "nan":
 495 |                     continue
 496 |                 features.append([measurement_x, param])
 497 |                 targets.append(float(value))
 498 | 
 499 |     if not features:
 500 |         raise ValueError(f"No regression samples loaded from {data_file}")
 501 | 
 502 |     X = np.asarray(features, dtype=float)
 503 |     y = np.asarray(targets, dtype=float)
 504 |     time_norm = _minmax_normalize(X[:, 0])
 505 |     parameter_raw = X[:, 1]
 506 |     y_norm = _minmax_normalize(y)
 507 | 
 508 |     # x2 is the concentration state c used by ODE RHS templates. During scoring
 509 |     # it is supplied from odeint's dynamic state, not read from candidate code.
 510 |     X_ode = np.column_stack([time_norm, parameter_raw, y_norm])
 511 |     return X_ode, y_norm
 512 | 
 513 | 
 514 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 515 |     """Recursively find all fit.tsv files and return (dataset_name, path) pairs."""
 516 |     datasets: list[tuple[str, Path]] = []
 517 |     for dirpath, _dirnames, filenames in os.walk(root):
 518 |         if "fit.tsv" in filenames:
 519 |             fit_path = Path(dirpath) / "fit.tsv"
 520 |             rel = fit_path.parent.relative_to(root)
 521 |             name = str(rel).replace(os.sep, "/")
 522 |             datasets.append((name, fit_path))
 523 |     datasets.sort(key=lambda x: x[0])
 524 |     return datasets
 525 | 
 526 | 
 527 | def _trajectory_preserving_split(
 528 |     X: np.ndarray,
 529 |     y: np.ndarray,
 530 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 531 |     """Split whole parameter curves into fit (train) and NMSE-evaluation (val) sets."""
 532 |     parameters = np.unique(X[:, 1])
 533 |     rng = np.random.default_rng(RANDOM_STATE)
 534 | 
 535 |     if len(parameters) < 3:
 536 |         empty_X = np.empty((0, X.shape[1]), dtype=float)
 537 |         empty_y = np.empty(0, dtype=float)
 538 |         return X, empty_X, y, empty_y
 539 | 
 540 |     shuffled = parameters[rng.permutation(len(parameters))]
 541 |     n_val_curves = min(
 542 |         max(1, int(round(len(parameters) * TEST_SIZE))), len(parameters) - 1
 543 |     )
 544 |     val_params = {float(p) for p in shuffled[:n_val_curves]}
 545 | 
 546 |     fit_indices: list[int] = []
 547 |     val_indices: list[int] = []
 548 |     for parameter in parameters:
 549 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 550 |         if float(parameter) in val_params:
 551 |             val_indices.extend(curve_idx.tolist())
 552 |         else:
 553 |             fit_indices.extend(curve_idx.tolist())
 554 | 
 555 |     fit_idx = np.sort(np.asarray(fit_indices, dtype=int))
 556 |     val_idx = np.sort(np.asarray(val_indices, dtype=int))
 557 |     return X[fit_idx], X[val_idx], y[fit_idx], y[val_idx]
 558 | 
 559 | 
 560 | def _evaluation_only_split(
 561 |     X: np.ndarray,
 562 |     y: np.ndarray,
 563 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 564 |     """Hold out an entire dataset for validation-only cross-protein evaluation."""
 565 |     empty_X = np.empty((0, X.shape[1]), dtype=float)
 566 |     empty_y = np.empty(0, dtype=float)
 567 |     return empty_X, X, empty_y, y
 568 | 
 569 | 
 570 | def _dataset_name_from_path(data_file: Path, root: Path = DATA_ROOT) -> str:
 571 |     return str(data_file.parent.relative_to(root)).replace(os.sep, "/")
 572 | 
 573 | 
 574 | def load_dataset(
 575 |     data_file: Path,
 576 |     *,
 577 |     dataset_name: str | None = None,
 578 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 579 |     """Load a single fit.tsv and return deterministic trajectory-preserving split."""
 580 |     X, y = _load_fit_table(data_file)
 581 |     name = dataset_name or _dataset_name_from_path(data_file)
 582 |     if name in EVALUATION_ONLY_DATASETS:
 583 |         return _evaluation_only_split(X, y)
 584 |     return _trajectory_preserving_split(X, y)
 585 | 
 586 | 
 587 | def load_all_datasets(
 588 |     root: Path = DATA_ROOT,
 589 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 590 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 591 |     entries = discover_datasets(root)
 592 |     results = []
 593 |     for name, path in entries:
 594 |         try:
 595 |             X_train, X_val, y_train, y_val = load_dataset(path, dataset_name=name)
 596 |             results.append((name, X_train, X_val, y_train, y_val))
 597 |         except Exception as exc:
 598 |             print(f"Warning: skipping dataset {name}: {exc}")
 599 |     return results
