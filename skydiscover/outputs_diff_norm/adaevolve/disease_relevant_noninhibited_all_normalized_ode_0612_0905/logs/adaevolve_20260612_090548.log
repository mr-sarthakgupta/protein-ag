 468 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 469 |     """Load a wide fit.tsv and return X=[normalized time, raw parameter, c], y.
 470 | 
 471 |     The first column is always the time/measurement coordinate. Remaining
 472 |     columns are response curves. The varying parameter is extracted from
 473 |     concentration-like curve headers only; non-concentration columns are skipped.
 474 |     Time is min-max normalized to 0..1, but the parameter column is left in its
 475 |     parsed raw units. The response is normalized globally across the whole
 476 |     fit.tsv to 0..1. Files already rescaled to 0..1 keep that scale.
 477 |     """
 478 |     with data_file.open(newline="") as f:
 479 |         reader = csv.reader(f, delimiter="\t")
 480 |         header = next(reader)
 481 | 
 482 |         response_headers = header[1:]
 483 |         parsed_params = [_parse_parameter_from_column(h) for h in response_headers]
 484 | 
 485 |         features: list[list[float]] = []
 486 |         targets: list[float] = []
 487 |         for row in reader:
 488 |             if not row:
 489 |                 continue
 490 |             measurement_x = float(row[0])
 491 |             for param, value in zip(parsed_params, row[1:]):
 492 |                 if param is None:
 493 |                     continue
 494 |                 if value == "" or value.strip().lower() == "nan":
 495 |                     continue
 496 |                 features.append([measurement_x, param])
 497 |                 targets.append(float(value))
 498 | 
 499 |     if not features:
 500 |         raise ValueError(f"No regression samples loaded from {data_file}")
 501 | 
 502 |     X = np.asarray(features, dtype=float)
 503 |     y = np.asarray(targets, dtype=float)
 504 |     time_norm = _minmax_normalize(X[:, 0])
 505 |     parameter_raw = X[:, 1]
 506 |     y_norm = _minmax_normalize(y)
 507 | 
 508 |     # x2 is the concentration state c used by ODE RHS templates. During scoring
 509 |     # it is supplied from odeint's dynamic state, not read from candidate code.
 510 |     X_ode = np.column_stack([time_norm, parameter_raw, y_norm])
 511 |     return X_ode, y_norm
