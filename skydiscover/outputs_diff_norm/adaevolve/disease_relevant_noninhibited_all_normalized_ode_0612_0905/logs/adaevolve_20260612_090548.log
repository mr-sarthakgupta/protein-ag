 126 | 
 127 | def _is_module_docstring(node: ast.AST) -> bool:
 128 |     return (
 129 |         isinstance(node, ast.Expr)
 130 |         and isinstance(node.value, ast.Constant)
 131 |         and isinstance(node.value.value, str)
 132 |     )
 133 | 
 134 | 
 135 | def _is_main_guard(node: ast.AST) -> bool:
 136 |     if not isinstance(node, ast.If):
 137 |         return False
 138 |     if node.orelse:
 139 |         return False
 140 |     test = node.test
 141 |     if not isinstance(test, ast.Compare) or len(test.ops) != 1 or len(test.comparators) != 1:
 142 |         return False
 143 |     if not isinstance(test.ops[0], ast.Eq):
 144 |         return False
 145 |     left = test.left
 146 |     right = test.comparators[0]
 147 |     return (
 148 |         isinstance(left, ast.Name)
 149 |         and left.id == "__name__"
 150 |         and isinstance(right, ast.Constant)
 151 |         and right.value == "__main__"
 152 |     )
 153 | 
 154 | 
 155 | def _has_postponed_annotations(tree: ast.Module) -> bool:
 156 |     for node in tree.body:
 157 |         if isinstance(node, ast.ImportFrom) and node.module == "__future__":
 158 |             if any(alias.name == "annotations" for alias in node.names):
 159 |                 return True
 160 |     return False
 161 | 
 162 | 
 163 | def _function_annotations(node: ast.FunctionDef) -> list[ast.AST]:
 164 |     annotations: list[ast.AST] = []
 165 |     args = node.args
 166 |     for arg in [*args.posonlyargs, *args.args, *args.kwonlyargs]:
 167 |         if arg.annotation is not None:
 168 |             annotations.append(arg.annotation)
 169 |     if args.vararg is not None and args.vararg.annotation is not None:
 170 |         annotations.append(args.vararg.annotation)
 171 |     if args.kwarg is not None and args.kwarg.annotation is not None:
 172 |         annotations.append(args.kwarg.annotation)
 173 |     if node.returns is not None:
 174 |         annotations.append(node.returns)
 175 |     return annotations
 176 | 
 177 | 
 178 | def _validate_top_level_function(node: ast.FunctionDef, *, postponed_annotations: bool) -> None:
 179 |     if node.name in _PROTECTED_NAMES:
 180 |         raise ValueError(
 181 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function '{node.name}' "
 182 |             "shadows a protected scorer or harness name."
 183 |         )
 184 |     if node.decorator_list:
 185 |         raise ValueError(
 186 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function decorators are not "
 187 |             "allowed because decorators execute during candidate import."
 188 |         )
 189 |     if node.args.defaults or node.args.kw_defaults:
 190 |         raise ValueError(
 191 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function default arguments "
 192 |             "are not allowed because defaults execute during candidate import."
 193 |         )
 194 |     if _function_annotations(node) and not postponed_annotations:
 195 |         raise ValueError(
 196 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function annotations require "
 197 |             "'from __future__ import annotations' because annotations otherwise "
 198 |             "execute during candidate import."
 199 |         )
 200 | 
 201 | 
 202 | def _call_name(func: ast.AST) -> str:
 203 |     if isinstance(func, ast.Name):
 204 |         return func.id
 205 |     if isinstance(func, ast.Attribute) and isinstance(func.value, ast.Name):
 206 |         return f"{func.value.id}.{func.attr}"
 207 |     return ""
 208 | 
 209 | 
 210 | def _assigned_names(target: ast.AST) -> set[str]:
 211 |     if isinstance(target, ast.Name):
 212 |         return {target.id}
 213 |     if isinstance(target, (ast.Tuple, ast.List)):
 214 |         names: set[str] = set()
 215 |         for elt in target.elts:
 216 |             names.update(_assigned_names(elt))
 217 |         return names
 218 |     return set()
 219 | 
 220 | 
 221 | def _validate_plain_import(alias: ast.alias) -> None:
 222 |     if alias.name not in _ALLOWED_IMPORTS:
 223 |         raise ValueError(
 224 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: import '{alias.name}' is not allowed. "
 225 |             "Candidates may only import sympy/numpy and the equation harness."
 226 |         )
 227 |     if alias.name == "sympy" and alias.asname != "sp":
 228 |         raise ValueError(
 229 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: sympy must be imported canonically "
 230 |             "as 'import sympy as sp'."
 231 |         )
 232 |     if alias.name == "numpy" and alias.asname not in {None, "np"}:
 233 |         raise ValueError(
 234 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: numpy may only be imported as "
 235 |             "'import numpy' or 'import numpy as np'."
 236 |         )
 237 | 
 238 | 
 239 | def _validate_evaluate_expression_data_args(call: ast.Call) -> set[int]:
 240 |     expected = ["X_train", "y_train", "X_val", "y_val"]
 241 |     if len(call.args) < 5:
 242 |         raise ValueError(
 243 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must be called "
 244 |             "as evaluate_expression(expression, X_train, y_train, X_val, y_val, ...)."
 245 |         )
 246 |     actual_data_args = call.args[1:5]
 247 |     if not all(
 248 |         isinstance(arg, ast.Name) and arg.id == expected_name
 249 |         for arg, expected_name in zip(actual_data_args, expected)
 250 |     ):
 251 |         raise ValueError(
 252 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must use the "
 253 |             "canonical data arguments exactly as X_train, y_train, X_val, y_val. "
 254 |             "Do not fit constants on validation labels or reorder the split."
 255 |         )
 256 |     return {id(arg) for arg in call.args[1:5]}
 257 | 
 258 | 
 259 | def _x_train_shape_feature_arg_id(node: ast.AST) -> int | None:
 260 |     if not (
 261 |         isinstance(node, ast.Subscript)
 262 |         and isinstance(node.value, ast.Attribute)
 263 |         and node.value.attr == "shape"
 264 |         and isinstance(node.value.value, ast.Name)
 265 |         and node.value.value.id == "X_train"
 266 |     ):
 267 |         return None
 268 |     slice_node = node.slice
 269 |     if isinstance(slice_node, ast.Constant) and slice_node.value == 1:
 270 |         return id(node.value.value)
 271 |     return None
 272 | 
 273 | 
 274 | def _allowed_feature_symbols_data_ids(fn: ast.FunctionDef) -> set[int]:
 275 |     allowed: set[int] = set()
 276 |     for node in ast.walk(fn):
 277 |         if not (
 278 |             isinstance(node, ast.Call)
 279 |             and isinstance(node.func, ast.Name)
 280 |             and node.func.id == "feature_symbols"
 281 |             and len(node.args) == 1
 282 |         ):
 283 |             continue
 284 |         x_train_id = _x_train_shape_feature_arg_id(node.args[0])
 285 |         if x_train_id is not None:
 286 |             allowed.add(x_train_id)
 287 |     return allowed
 288 | 
 289 | 
 290 | def _validate_no_dataset_data_leak(fn: ast.FunctionDef, allowed_node_ids: set[int]) -> None:
 291 |     for node in ast.walk(fn):
 292 |         if (
 293 |             isinstance(node, ast.Name)
 294 |             and node.id in {"X_train", "y_train", "X_val", "y_val"}
 295 |             and id(node) not in allowed_node_ids
 296 |         ):
 297 |             raise ValueError(
 298 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: dataset array '{node.id}' may only "
 299 |                 "appear in feature_symbols(X_train.shape[1]) or as the canonical "
 300 |                 "evaluate_expression(expression, X_train, y_train, X_val, y_val, ...) "
 301 |                 "arguments. Do not use dataset values to choose expressions, mutate "
 302 |                 "splits, or tune constants/initial values."
 303 |             )
 304 | 
 305 | 
 306 | def validate_candidate_source(program_path: str) -> None:
 307 |     """Reject reward-hacking program structure before importing candidate code."""
 308 |     source = Path(program_path).read_text()
 309 |     tree = ast.parse(source, filename=program_path)
 310 |     postponed_annotations = _has_postponed_annotations(tree)
 311 | 
 312 |     for node in tree.body:
 313 |         if _is_module_docstring(node) or _is_main_guard(node):
 314 |             continue
 315 |         if isinstance(node, ast.FunctionDef):
 316 |             _validate_top_level_function(node, postponed_annotations=postponed_annotations)
 317 |             continue
 318 |         if isinstance(node, ast.Import):
 319 |             for alias in node.names:
 320 |                 _validate_plain_import(alias)
 321 |         elif isinstance(node, ast.ImportFrom):
 322 |             module = node.module or ""
 323 |             if module not in _ALLOWED_FROM_IMPORTS:
 324 |                 raise ValueError(
 325 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: from-import '{module}' is not allowed."
 326 |                 )
 327 |             if module == "pysr_harness.equation_session":
 328 |                 aliased = [alias.name for alias in node.names if alias.asname]
 329 |                 if aliased:
 330 |                     raise ValueError(
 331 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: harness imports may not "
 332 |                         f"use aliases: {sorted(aliased)}."
 333 |                     )
 334 |                 imported = {alias.name for alias in node.names}
 335 |                 extra = imported - _ALLOWED_HARNESS_IMPORTS
 336 |                 if extra:
 337 |                     raise ValueError(
 338 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: unsupported harness imports "
 339 |                         f"{sorted(extra)}. Use only feature_symbols, constant_symbols, "
 340 |                         "and evaluate_expression."
 341 |                     )
 342 |         else:
 343 |             raise ValueError(
 344 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level executable code is not "
 345 |                 "allowed in candidate programs. Build and score the equation only "
 346 |                 "inside evaluate_symbolic_candidate()."
 347 |             )
 348 | 
 349 |     eval_fns = [
 350 |         node
 351 |         for node in tree.body
 352 |         if isinstance(node, ast.FunctionDef) and node.name == "evaluate_symbolic_candidate"
 353 |     ]
 354 |     if len(eval_fns) != 1:
 355 |         raise ValueError(
 356 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: program must define exactly one "
 357 |             "evaluate_symbolic_candidate() function."
 358 |         )
 359 |     fn = eval_fns[0]
 360 | 
 361 |     returns = [node for node in ast.walk(fn) if isinstance(node, ast.Return)]
 362 |     if len(returns) != 1:
 363 |         raise ValueError(
 364 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must have "
 365 |             "exactly one return statement."
 366 |         )
 367 |     return_value = returns[0].value
 368 |     if not (
 369 |         isinstance(return_value, ast.Call)
 370 |         and isinstance(return_value.func, ast.Name)
 371 |         and return_value.func.id == "evaluate_expression"
 372 |     ):
 373 |         raise ValueError(
 374 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must directly "
 375 |             "return evaluate_expression(...), with no wrapper or post-processing."
 376 |         )
 377 |     allowed_data_arg_ids = _validate_evaluate_expression_data_args(return_value)
 378 |     allowed_data_arg_ids.update(_allowed_feature_symbols_data_ids(fn))
 379 |     _validate_no_dataset_data_leak(fn, allowed_data_arg_ids)
 380 | 
 381 |     evaluate_calls = 0
 382 |     for node in ast.walk(fn):
 383 |         if isinstance(node, _DISALLOWED_CONTROL_NODES):
 384 |             raise ValueError(
 385 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: control flow, nested definitions, "
 386 |                 "comprehensions, and conditionals are not allowed inside "
 387 |                 "evaluate_symbolic_candidate(). Build one straight-line equation."
 388 |             )
 389 |         if isinstance(node, (ast.Import, ast.ImportFrom)):
 390 |             raise ValueError(
 391 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: imports are not allowed inside "
 392 |                 "evaluate_symbolic_candidate()."
 393 |             )
 394 |         if isinstance(node, (ast.Assign, ast.AnnAssign, ast.AugAssign)):
 395 |             targets = node.targets if isinstance(node, ast.Assign) else [node.target]
 396 |             assigned = set().union(*(_assigned_names(target) for target in targets))
 397 |             protected = assigned & _PROTECTED_NAMES
 398 |             if protected:
 399 |                 raise ValueError(
 400 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: cannot reassign protected scorer "
 401 |                     f"or harness names {sorted(protected)}."
 402 |                 )
 403 |         if isinstance(node, ast.Call):
 404 |             name = _call_name(node.func)
 405 |             if name == "evaluate_expression":
 406 |                 evaluate_calls += 1
 407 |             if name not in _ALLOWED_EVALUATE_CALLS:
 408 |                 raise ValueError(
 409 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: call '{name or type(node.func).__name__}' "
 410 |                     "is not allowed inside evaluate_symbolic_candidate(). Allowed calls "
 411 |                     "are the symbol helpers, evaluate_expression, and basic sp.* math."
 412 |                 )
 413 | 
 414 |     if evaluate_calls != 1:
 415 |         raise ValueError(
 416 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must call "
 417 |             f"evaluate_expression() exactly once; found {evaluate_calls} calls."
 418 |         )
 419 | 
 420 | 
 421 | def _parse_parameter_from_column(column_name: str) -> float | None:
 422 |     """Extract a monomer/protein concentration from a fit.tsv column header.
 423 | 
 424 |     Only concentration-like labels are accepted:
 425 |       - "... : 10uM"  or "10 uM"  → 10.0
 426 |       - "35uM" (bare, as in Abeta) → 35.0
 427 |       - "... : 3.95mM"             → 3950.0  (converted to uM)
 428 |       - "... : 0.3 mg/mL 22uM"    → 22.0    (prefer uM when both present)
 429 | 
 430 |     Seed percentages, pH values, ng/uL seed-material labels, and generic
 431 |     numeric fallbacks are intentionally ignored so x1 consistently represents
 432 |     the aggregating monomer/protein concentration when available.
 433 |     """
 434 |     text = column_name.strip()
 435 |     # Prefer the human-readable condition after the file-name prefix. Some
 436 |     # filenames contain seed concentrations that should not become x1.
 437 |     condition_text = text.rsplit(":", 1)[-1].strip().strip("\"'")
 438 | 
 439 |     # Prefer an explicit uM value
 440 |     m = re.search(r"(\d+(?:\.\d+)?)\s*uM", condition_text, re.IGNORECASE)
 441 |     if m:
 442 |         return float(m.group(1))
 443 | 
 444 |     # mM → convert to uM
 445 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mM", condition_text, re.IGNORECASE)
 446 |     if m:
 447 |         return float(m.group(1)) * 1000.0
 448 | 
 449 |     # mg/mL (take the number)
 450 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mg/mL", condition_text, re.IGNORECASE)
 451 |     if m:
 452 |         return float(m.group(1))
 453 | 
 454 |     return None
 455 | 
 456 | 
 457 | def _minmax_normalize(values: np.ndarray) -> np.ndarray:
 458 |     """Normalize one dataset column to 0..1, preserving constants as zeros."""
 459 |     values = np.asarray(values, dtype=float)
 460 |     v_min = float(np.min(values))
 461 |     v_max = float(np.max(values))
 462 |     scale = v_max - v_min
 463 |     if scale <= 0.0:
 464 |         return np.zeros_like(values, dtype=float)
 465 |     return (values - v_min) / scale
 466 | 
 467 | 
 468 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 469 |     """Load a wide fit.tsv and return X=[normalized time, raw parameter, c], y.
 470 | 
 471 |     The first column is always the time/measurement coordinate. Remaining
 472 |     columns are response curves. The varying parameter is extracted from
 473 |     concentration-like curve headers only; non-concentration columns are skipped.
 474 |     Time is min-max normalized to 0..1, but the parameter column is left in its
 475 |     parsed raw units. The response is normalized globally across the whole
 476 |     fit.tsv to 0..1. Files already rescaled to 0..1 keep that scale.
 477 |     """
 478 |     with data_file.open(newline="") as f:
 479 |         reader = csv.reader(f, delimiter="\t")
 480 |         header = next(reader)
 481 | 
 482 |         response_headers = header[1:]
 483 |         parsed_params = [_parse_parameter_from_column(h) for h in response_headers]
 484 | 
 485 |         features: list[list[float]] = []
 486 |         targets: list[float] = []
 487 |         for row in reader:
 488 |             if not row:
 489 |                 continue
 490 |             measurement_x = float(row[0])
 491 |             for param, value in zip(parsed_params, row[1:]):
 492 |                 if param is None:
 493 |                     continue
 494 |                 if value == "" or value.strip().lower() == "nan":
 495 |                     continue
 496 |                 features.append([measurement_x, param])
 497 |                 targets.append(float(value))
 498 | 
 499 |     if not features:
 500 |         raise ValueError(f"No regression samples loaded from {data_file}")
 501 | 
 502 |     X = np.asarray(features, dtype=float)
 503 |     y = np.asarray(targets, dtype=float)
 504 |     time_norm = _minmax_normalize(X[:, 0])
 505 |     parameter_raw = X[:, 1]
 506 |     y_norm = _minmax_normalize(y)
 507 | 
 508 |     # x2 is the concentration state c used by ODE RHS templates. During scoring
 509 |     # it is supplied from odeint's dynamic state, not read from candidate code.
 510 |     X_ode = np.column_stack([time_norm, parameter_raw, y_norm])
 511 |     return X_ode, y_norm
 512 | 
 513 | 
 514 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 515 |     """Recursively find all fit.tsv files and return (dataset_name, path) pairs."""
 516 |     datasets: list[tuple[str, Path]] = []
 517 |     for dirpath, _dirnames, filenames in os.walk(root):
 518 |         if "fit.tsv" in filenames:
 519 |             fit_path = Path(dirpath) / "fit.tsv"
 520 |             rel = fit_path.parent.relative_to(root)
 521 |             name = str(rel).replace(os.sep, "/")
 522 |             datasets.append((name, fit_path))
 523 |     datasets.sort(key=lambda x: x[0])
 524 |     return datasets
 525 | 
 526 | 
 527 | def _trajectory_preserving_split(
 528 |     X: np.ndarray,
 529 |     y: np.ndarray,
 530 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 531 |     """Split whole parameter curves into fit (train) and NMSE-evaluation (val) sets."""
 532 |     parameters = np.unique(X[:, 1])
 533 |     rng = np.random.default_rng(RANDOM_STATE)
 534 | 
 535 |     if len(parameters) < 3:
 536 |         empty_X = np.empty((0, X.shape[1]), dtype=float)
 537 |         empty_y = np.empty(0, dtype=float)
 538 |         return X, empty_X, y, empty_y
 539 | 
 540 |     shuffled = parameters[rng.permutation(len(parameters))]
 541 |     n_val_curves = min(
 542 |         max(1, int(round(len(parameters) * TEST_SIZE))), len(parameters) - 1
 543 |     )
 544 |     val_params = {float(p) for p in shuffled[:n_val_curves]}
 545 | 
 546 |     fit_indices: list[int] = []
 547 |     val_indices: list[int] = []
 548 |     for parameter in parameters:
 549 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 550 |         if float(parameter) in val_params:
 551 |             val_indices.extend(curve_idx.tolist())
 552 |         else:
 553 |             fit_indices.extend(curve_idx.tolist())
 554 | 
 555 |     fit_idx = np.sort(np.asarray(fit_indices, dtype=int))
 556 |     val_idx = np.sort(np.asarray(val_indices, dtype=int))
 557 |     return X[fit_idx], X[val_idx], y[fit_idx], y[val_idx]
 558 | 
 559 | 
 560 | def _evaluation_only_split(
 561 |     X: np.ndarray,
 562 |     y: np.ndarray,
 563 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 564 |     """Hold out an entire dataset for validation-only cross-protein evaluation."""
 565 |     empty_X = np.empty((0, X.shape[1]), dtype=float)
 566 |     empty_y = np.empty(0, dtype=float)
 567 |     return empty_X, X, empty_y, y
 568 | 
 569 | 
 570 | def _dataset_name_from_path(data_file: Path, root: Path = DATA_ROOT) -> str:
 571 |     return str(data_file.parent.relative_to(root)).replace(os.sep, "/")
 572 | 
 573 | 
 574 | def load_dataset(
 575 |     data_file: Path,
 576 |     *,
 577 |     dataset_name: str | None = None,
 578 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 579 |     """Load a single fit.tsv and return deterministic trajectory-preserving split."""
 580 |     X, y = _load_fit_table(data_file)
 581 |     name = dataset_name or _dataset_name_from_path(data_file)
 582 |     if name in EVALUATION_ONLY_DATASETS:
 583 |         return _evaluation_only_split(X, y)
 584 |     return _trajectory_preserving_split(X, y)
 585 | 
 586 | 
 587 | def load_all_datasets(
 588 |     root: Path = DATA_ROOT,
 589 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 590 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 591 |     entries = discover_datasets(root)
 592 |     results = []
 593 |     for name, path in entries:
 594 |         try:
 595 |             X_train, X_val, y_train, y_val = load_dataset(path, dataset_name=name)
 596 |             results.append((name, X_train, X_val, y_train, y_val))
 597 |         except Exception as exc:
 598 |             print(f"Warning: skipping dataset {name}: {exc}")
 599 |     return results
 600 | 
 601 | 
 602 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 603 | PARSIMONY_WEIGHT = float(os.environ.get("SKYDISCOVER_PARSIMONY_WEIGHT", "0.20"))
 604 | PARSIMONY_COMPLEXITY_SCALE = float(
 605 |     os.environ.get("SKYDISCOVER_PARSIMONY_COMPLEXITY_SCALE", "160")
 606 | )
 607 | 
 608 | 
 609 | def _parsimony_penalty_factor(complexity: float) -> float:
 610 |     """Bounded penalty factor for expression complexity."""
 611 |     if not np.isfinite(complexity) or PARSIMONY_COMPLEXITY_SCALE <= 0:
 612 |         return 1.0
 613 |     normalized = min(max(float(complexity), 0.0) / PARSIMONY_COMPLEXITY_SCALE, 1.0)
 614 |     return max(0.0, 1.0 - PARSIMONY_WEIGHT * normalized)
 615 | 
 616 | 
 617 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 618 |     values = np.asarray(values, dtype=float).ravel()
 619 |     if values.size < 3 or sigma <= 0.0:
 620 |         return values
 621 |     radius = max(1, int(round(3.0 * sigma)))
 622 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 623 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 624 |     kernel /= np.sum(kernel)
 625 |     padded = np.pad(values, (radius, radius), mode="edge")
 626 |     return np.convolve(padded, kernel, mode="valid")
 627 | 
 628 | 
 629 | def _curve_smoothed_target(X: np.ndarray, y_true: np.ndarray) -> np.ndarray:
 630 |     """Smooth targets independently for each parameter curve in time order."""
 631 |     X = np.asarray(X, dtype=float)
 632 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 633 |     if X.shape[0] != y_true.shape[0] or X.shape[1] < 2:
 634 |         return _gaussian_smooth_1d(y_true)
 635 | 
 636 |     smoothed = np.empty_like(y_true, dtype=float)
 637 |     for parameter in np.unique(X[:, 1]):
 638 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 639 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 640 |         smoothed_curve = _gaussian_smooth_1d(y_true[ordered_idx])
 641 |         smoothed[ordered_idx] = smoothed_curve
 642 |     return smoothed
 643 | 
 644 | 
 645 | def _normalized_mse_with_reference_variance(
 646 |     y_true: np.ndarray,
 647 |     y_pred: np.ndarray,
 648 |     reference_values: np.ndarray,
 649 | ) -> float:
 650 |     """MSE normalized by full dataset scale, not by a flat validation segment."""
 651 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 652 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 653 |     reference_values = np.asarray(reference_values, dtype=float).reshape(-1)
 654 |     if y_true.shape != y_pred.shape:
 655 |         return float("inf")
 656 |     if not np.all(np.isfinite(y_pred)):
 657 |         return float("inf")
 658 |     var = float(np.var(reference_values))
 659 |     if var <= 0.0:
 660 |         return float(np.mean((y_true - y_pred) ** 2))
 661 |     return float(np.mean((y_true - y_pred) ** 2) / var)
 662 | 
 663 | 
 664 | def _nmse_with_gaussian_smoothed_target(
 665 |     y_true: np.ndarray,
 666 |     y_pred: np.ndarray,
 667 |     X: np.ndarray | None = None,
 668 |     reference_values: np.ndarray | None = None,
 669 | ) -> float:
 670 |     reference = y_true if reference_values is None else reference_values
 671 |     return _normalized_mse_with_reference_variance(y_true, y_pred, reference)
 672 | 
 673 | 
 674 | def _ode_predictions(
 675 |     rhs_fn: Any,
 676 |     X: np.ndarray,
 677 |     y_known: np.ndarray,
 678 |     theta: np.ndarray,
 679 | ) -> np.ndarray:
 680 |     """Integrate dc/dt=f(t, parameter, c) per parameter curve on one split."""
 681 |     import warnings
 682 | 
 683 |     from scipy.integrate import odeint
 684 | 
 685 |     X = np.asarray(X, dtype=float)
 686 |     y_known = np.asarray(y_known, dtype=float).reshape(-1)
 687 |     theta = np.asarray(theta, dtype=float).reshape(-1)
 688 |     predictions = np.full_like(y_known, np.nan, dtype=float)
 689 | 
 690 |     for parameter in np.unique(X[:, 1]):
 691 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 692 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 693 |         times = X[ordered_idx, 0]
 694 |         observed = y_known[ordered_idx]
 695 | 
 696 |         if len(ordered_idx) == 1 or float(times[-1] - times[0]) <= 0.0:
 697 |             predictions[ordered_idx] = observed[0]
 698 |             continue
 699 | 
 700 |         def dc_dt(c_state: np.ndarray, time_value: float) -> float:
 701 |             c_value = float(np.asarray(c_state, dtype=float).reshape(-1)[0])
 702 |             value = rhs_fn(float(time_value), float(parameter), c_value, *theta)
 703 |             value = float(np.asarray(value, dtype=float).reshape(-1)[0])
 704 |             if not np.isfinite(value):
 705 |                 raise FloatingPointError("non-finite ODE derivative")
 706 |             return value
 707 | 
 708 |         with warnings.catch_warnings():
 709 |             warnings.simplefilter("ignore")
 710 |             integrated = odeint(
 711 |                 dc_dt,
 712 |                 float(observed[0]),
 713 |                 times,
 714 |                 mxstep=1000,
 715 |             )
 716 |         curve_pred = np.asarray(integrated, dtype=float).reshape(-1)
 717 |         if curve_pred.shape != observed.shape or not np.all(np.isfinite(curve_pred)):
 718 |             raise FloatingPointError("non-finite ODE trajectory")
 719 |         predictions[ordered_idx] = curve_pred
 720 | 
 721 |     return predictions
 722 | 
 723 | 
 724 | def evaluate_ode_expression(
 725 |     expression: Any,
 726 |     X_train: np.ndarray,
 727 |     y_train: np.ndarray,
 728 |     X_val: np.ndarray,
 729 |     y_val: np.ndarray,
 730 |     *,
 731 |     constants: Any | None = None,
 732 |     initial_values: Any | None = None,
 733 |     max_nfev: int = 300,
 734 | ) -> dict[str, Any]:
 735 |     """Score a proposed ODE RHS by integrating predicted concentration curves."""
 736 |     import sympy as sp
 737 |     from pysr_harness import equation_session
 738 |     from scipy.optimize import least_squares
 739 | 
 740 |     X_train = np.asarray(X_train, dtype=float)
 741 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 742 |     X_val = np.asarray(X_val, dtype=float)
 743 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 744 |     evaluation_only = X_train.shape[0] == 0 and X_val.shape[0] > 0
 745 |     train_only = X_val.shape[0] == 0 and X_train.shape[0] > 0
 746 |     if evaluation_only:
 747 |         X_fit, y_fit = X_val, y_val
 748 |     else:
 749 |         X_fit, y_fit = X_train, y_train
 750 |     y_reference = np.concatenate([y_train, y_val]) if y_train.size else y_val
 751 |     n_features = X_fit.shape[1] if X_fit.shape[0] else X_val.shape[1]
 752 |     feature_names = [f"x{i}" for i in range(n_features)]
 753 |     template = equation_session._as_sympy_expr(expression, feature_names)
 754 |     equation_session._record_scored_template(template)
 755 | 
 756 |     if constants is None:
 757 |         feature_set = set(equation_session.feature_symbols(n_features))
 758 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 759 |     constants = list(constants)
 760 |     equation_session._validate_expression_template(template, constants)
 761 | 
 762 |     if initial_values is None:
 763 |         base_x0 = np.ones(len(constants), dtype=float)
 764 |     else:
 765 |         base_x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 766 |         if base_x0.size != len(constants):
 767 |             raise ValueError("initial_values must match the number of constants")
 768 | 
 769 |     feature_syms = equation_session.feature_symbols(n_features)
 770 |     rhs_fn = sp.lambdify(feature_syms + constants, template, modules=["numpy"])
 771 | 
 772 |     if not constants:
 773 |         y_pred_fit = _ode_predictions(rhs_fn, X_fit, y_fit, np.asarray([], dtype=float))
 774 |         y_pred_val = _ode_predictions(rhs_fn, X_val, y_val, np.asarray([], dtype=float))
 775 |         nmse_train = (
 776 |             float("nan")
 777 |             if evaluation_only
 778 |             else _nmse_with_gaussian_smoothed_target(
 779 |                 y_train, y_pred_fit, X_train, y_reference
 780 |             )
 781 |         )
 782 |         nmse_val = (
 783 |             float("nan")
 784 |             if train_only
 785 |             else _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 786 |         )
 787 |         result = {
 788 |             "equation_template": f"d(c)/dt = {template}",
 789 |             "equation": f"d(c)/dt = {template}",
 790 |             "constants": {},
 791 |             "loss": float(np.mean((y_pred_fit - y_fit) ** 2)),
 792 |             "complexity": equation_session._complexity(template),
 793 |             "nmse_train": nmse_train,
 794 |             "nmse_val": nmse_val,
 795 |             "n_val_points": int(len(y_val)),
 796 |             "evaluation_only": evaluation_only,
 797 |             "train_only": train_only,
 798 |             "combined_score": (
 799 |                 0.0
 800 |                 if train_only or not np.isfinite(nmse_val)
 801 |                 else combined_score_from_nmse(nmse_val)
 802 |             ),
 803 |         }
 804 |         equation_session._record_scorer_result(result)
 805 |         return result
 806 | 
 807 |     def residual(theta: np.ndarray) -> np.ndarray:
 808 |         try:
 809 |             prediction = _ode_predictions(rhs_fn, X_fit, y_fit, theta)
 810 |         except Exception:
 811 |             return np.full_like(y_fit, 1e12, dtype=float)
 812 |         if prediction.shape != y_fit.shape or not np.all(np.isfinite(prediction)):
 813 |             return np.full_like(y_fit, 1e12, dtype=float)
 814 |         return prediction - y_fit
 815 | 
 816 |     initial_candidates: list[np.ndarray] = []
 817 |     for scale in ODE_MULTISTART_SCALES or (1.0,):
 818 |         candidate = base_x0 * float(scale)
 819 |         if not any(np.array_equal(candidate, existing) for existing in initial_candidates):
 820 |             initial_candidates.append(candidate)
 821 | 
 822 |     import warnings
 823 | 
 824 |     best_fit = None
 825 |     best_loss = float("inf")
 826 |     with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 827 |         warnings.simplefilter("ignore", RuntimeWarning)
 828 |         for initial_candidate in initial_candidates:
 829 |             fit = least_squares(
 830 |                 residual,
 831 |                 initial_candidate,
 832 |                 loss="soft_l1",
 833 |                 max_nfev=max_nfev,
 834 |             )
 835 |             fit_residual = residual(fit.x)
 836 |             fit_loss = float(np.mean(fit_residual**2))
 837 |             if fit_loss < best_loss:
 838 |                 best_loss = fit_loss
 839 |                 best_fit = fit
 840 | 
 841 |     if best_fit is None:
 842 |         raise RuntimeError("constant fitting did not produce a result")
 843 | 
 844 |     fitted_constants = {
 845 |         str(symbol): float(value) for symbol, value in zip(constants, best_fit.x)
 846 |     }
 847 |     substitutions = dict(zip(constants, best_fit.x))
 848 |     fitted_expr = template.subs(substitutions)
 849 |     y_pred_fit = _ode_predictions(rhs_fn, X_fit, y_fit, best_fit.x)
 850 |     y_pred_val = _ode_predictions(rhs_fn, X_val, y_val, best_fit.x)
 851 |     nmse_train = (
 852 |         float("nan")
 853 |         if evaluation_only
 854 |         else _nmse_with_gaussian_smoothed_target(
 855 |             y_train, y_pred_fit, X_train, y_reference
 856 |         )
 857 |     )
 858 |     nmse_val = (
 859 |         float("nan")
 860 |         if train_only
 861 |         else _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 862 |     )
 863 |     loss = float(np.mean((y_pred_fit - y_fit) ** 2))
 864 | 
 865 |     result = {
 866 |         "equation_template": f"d(c)/dt = {template}",
 867 |         "equation": f"d(c)/dt = {fitted_expr}",
 868 |         "constants": fitted_constants,
 869 |         "loss": loss,
 870 |         "complexity": equation_session._complexity(template),
 871 |         "nmse_train": nmse_train,
 872 |         "nmse_val": nmse_val,
 873 |         "n_val_points": int(len(y_val)),
 874 |         "evaluation_only": evaluation_only,
 875 |         "train_only": train_only,
 876 |         "combined_score": (
 877 |             0.0
 878 |             if train_only or not np.isfinite(nmse_val)
 879 |             else combined_score_from_nmse(nmse_val)
 880 |         ),
 881 |     }
 882 |     equation_session._record_scorer_result(result)
 883 |     return result
 884 | 
 885 | 
 886 | def _point_weighted_mean(
 887 |     values: list[float],
 888 |     weights: list[int],
 889 | ) -> float:
 890 |     """Average values with one weight per evaluation point."""
 891 |     total_weight = sum(weights)
 892 |     if total_weight <= 0:
 893 |         return float("inf")
 894 |     weighted = sum(
 895 |         float(value) * float(weight)
 896 |         for value, weight in zip(values, weights)
 897 |         if np.isfinite(float(value))
 898 |     )
 899 |     if not np.isfinite(weighted):
 900 |         return float("inf")
 901 |     return float(weighted / total_weight)
 902 | 
 903 | 
 904 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 905 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 906 |     scoring_results = {
 907 |         name: result
 908 |         for name, result in per_dataset_results.items()
 909 |         if int(result.get("n_val_points", 0)) > 0
 910 |     }
 911 |     raw_nmse_vals = [float(r["nmse_val"]) for r in scoring_results.values()]
 912 |     nmse_vals = list(raw_nmse_vals)
 913 |     train_nmse_vals = [
 914 |         float(r["nmse_train"])
 915 |         for r in per_dataset_results.values()
 916 |         if np.isfinite(float(r.get("nmse_train", float("inf"))))
 917 |     ]
 918 |     complexity_vals = []
 919 |     for r in per_dataset_results.values():
 920 |         try:
 921 |             value = float(r.get("complexity", float("nan")))
 922 |         except (TypeError, ValueError):
 923 |             continue
 924 |         if np.isfinite(value):
 925 |             complexity_vals.append(value)
 926 |     aggregate_complexity = float(max(complexity_vals)) if complexity_vals else 0.0
 927 | 
 928 |     violation_errors = sorted(
 929 |         {
 930 |             str(r.get("error"))
 931 |             for r in per_dataset_results.values()
 932 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 933 |         }
 934 |     )
 935 |     failed_datasets = sorted(
 936 |         name
 937 |         for name, result in scoring_results.items()
 938 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 939 |     )
 940 |     templates = sorted(
 941 |         {
 942 |             str(r.get("equation_template"))
 943 |             for r in per_dataset_results.values()
 944 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 945 |         }
 946 |     )
 947 | 
 948 |     eq_template = ""
 949 |     for r in per_dataset_results.values():
 950 |         if r.get("equation"):
 951 |             eq_template = r["equation"]
 952 |             break
 953 | 
 954 |     hard_cases = [
 955 |         {"dataset": name, "nmse_val": float(result["nmse_val"])}
 956 |         for name, result in scoring_results.items()
 957 |         if np.isfinite(float(result.get("nmse_val", float("inf"))))
 958 |     ]
 959 |     hard_cases.sort(key=lambda item: item["nmse_val"], reverse=True)
 960 |     hard_cases = hard_cases[:5]
 961 |     hard_case_feedback = "; ".join(
 962 |         f"{case['dataset']} nmse={case['nmse_val']:.4g}" for case in hard_cases
 963 |     )
 964 | 
 965 |     violation_error = None
 966 |     if violation_errors:
 967 |         violation_error = violation_errors[0]
 968 |     elif failed_datasets:
 969 |         examples = ", ".join(failed_datasets[:3])
 970 |         violation_error = (
 971 |             "Single-equation violation: candidate failed on "
 972 |             f"{len(failed_datasets)}/{len(scoring_results)} validation datasets. "
 973 |             "Failed datasets are not dropped from the aggregate reward. "
 974 |             f"Examples: {examples}"
 975 |         )
 976 |     elif len(templates) > 1:
 977 |         examples = "; ".join(templates[:3])
 978 |         violation_error = (
 979 |             "Single-equation violation: evaluate_symbolic_candidate() produced "
 980 |             f"{len(templates)} distinct equation templates across datasets. "
 981 |             "The base equation must be identical for all datasets; only fitted "
 982 |             f"constants may vary. Example templates: {examples}"
 983 |         )
 984 | 
 985 |     if violation_error:
 986 |         agg_nmse = float("inf")
 987 |         mean_nmse = float("inf")
 988 |         agg_train_nmse = float("inf")
 989 |         agg_combined = 0.0
 990 |         n_successful = 0
 991 |     else:
 992 |         val_point_weights = [
 993 |             int(r.get("n_val_points", 0)) for r in scoring_results.values()
 994 |         ]
 995 |         mean_nmse = _point_weighted_mean(nmse_vals, val_point_weights)
 996 |         raw_mean_nmse = _point_weighted_mean(raw_nmse_vals, val_point_weights)
 997 |         eval_only_results = {
 998 |             name: result
 999 |             for name, result in scoring_results.items()
1000 |             if result.get("evaluation_only")
1001 |         }
1002 |         eval_only_nmse_vals = [
1003 |             float(result["nmse_val"])
1004 |             for result in eval_only_results.values()
1005 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
1006 |         ]
1007 |         eval_only_weights = [
1008 |             int(result.get("n_val_points", 0))
1009 |             for result in eval_only_results.values()
1010 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
1011 |         ]
1012 |         mean_nmse_eval_only = (
1013 |             _point_weighted_mean(eval_only_nmse_vals, eval_only_weights)
1014 |             if eval_only_nmse_vals
1015 |             else float("nan")
1016 |         )
1017 |         agg_nmse = mean_nmse
1018 |         agg_train_nmse = float(np.mean(train_nmse_vals)) if train_nmse_vals else float("inf")
1019 |         raw_combined = (
1020 |             float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
1021 |         )
1022 |         parsimony_factor = _parsimony_penalty_factor(aggregate_complexity)
1023 |         agg_combined = raw_combined * parsimony_factor
1024 |         n_successful = sum(1 for value in nmse_vals if np.isfinite(value))
1025 | 
1026 |     aggregated = {
1027 |         "equation": eq_template,
1028 |         "nmse_train": agg_train_nmse,
1029 |         "nmse_val": agg_nmse,
1030 |         "mean_nmse_val": mean_nmse,
1031 |         "mean_raw_nmse_val": raw_mean_nmse if not violation_error else float("inf"),
1032 |         "combined_score": agg_combined,
1033 |         "fit_score": raw_combined if not violation_error else 0.0,
1034 |         "complexity": aggregate_complexity,
1035 |         "parsimony_weight": PARSIMONY_WEIGHT,
1036 |         "parsimony_penalty_factor": (
1037 |             _parsimony_penalty_factor(aggregate_complexity) if not violation_error else 1.0
1038 |         ),
1039 |         "n_datasets": len(scoring_results),
1040 |         "n_total_datasets": len(per_dataset_results),
1041 |         "n_train_only_datasets": len(per_dataset_results) - len(scoring_results),
1042 |         "n_successful": n_successful,
1043 |         "n_evaluation_only_datasets": len(
1044 |             [name for name, result in per_dataset_results.items() if result.get("evaluation_only")]
1045 |         ),
1046 |         "mean_nmse_eval_only": (
1047 |             mean_nmse_eval_only if not violation_error else float("inf")
1048 |         ),
1049 |         "eval_workers": NUM_WORKERS,
1050 |         "hard_cases": hard_cases,
1051 |         "hard_case_feedback": hard_case_feedback,
1052 |         "per_dataset": per_dataset_results,
1053 |     }
1054 |     if violation_error:
1055 |         aggregated["error"] = violation_error
1056 |     return aggregated
1057 | 
