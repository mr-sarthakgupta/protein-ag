 155 | def _has_postponed_annotations(tree: ast.Module) -> bool:
 156 |     for node in tree.body:
 157 |         if isinstance(node, ast.ImportFrom) and node.module == "__future__":
 158 |             if any(alias.name == "annotations" for alias in node.names):
 159 |                 return True
 160 |     return False
