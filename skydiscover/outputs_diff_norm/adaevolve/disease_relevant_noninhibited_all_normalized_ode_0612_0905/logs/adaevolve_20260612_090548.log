1243 |             f"mean_nmse_val={metrics['mean_nmse_val']:.6f}, "
1244 |             f"mean_raw_nmse_val={metrics['mean_raw_nmse_val']:.6f}, "
1245 |             f"combined_score={metrics['combined_score']:.6f}, "
1246 |             f"n_datasets={metrics['n_datasets']}, "
1247 |             f"n_successful={metrics['n_successful']}, "
1248 |             f"time={metrics['eval_time']:.2f}s"
1249 |         )
1250 |         print(f"Equation template: {metrics['equation']}")
