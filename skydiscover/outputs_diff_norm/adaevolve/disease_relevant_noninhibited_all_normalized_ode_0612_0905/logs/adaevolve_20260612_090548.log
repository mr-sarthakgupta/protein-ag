1279 |     """Module-level worker for stage 1 parallel evaluation."""
1280 |     name, X_train, X_val, y_train, y_val, program_path = args
1281 |     harness_root = str(BENCHMARK_ROOT)
1282 |     if harness_root not in sys.path:
1283 |         sys.path.insert(0, harness_root)
1284 |     validate_candidate_source(program_path)
