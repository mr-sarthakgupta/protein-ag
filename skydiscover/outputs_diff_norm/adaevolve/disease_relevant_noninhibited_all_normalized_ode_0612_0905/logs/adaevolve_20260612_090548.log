 696 |         if len(ordered_idx) == 1 or float(times[-1] - times[0]) <= 0.0:
 697 |             predictions[ordered_idx] = observed[0]
 698 |             continue
 699 | 
 700 |         def dc_dt(c_state: np.ndarray, time_value: float) -> float:
 701 |             c_value = float(np.asarray(c_state, dtype=float).reshape(-1)[0])
 702 |             value = rhs_fn(float(time_value), float(parameter), c_value, *theta)
