1234 | def evaluate(program_path: str) -> dict:
1235 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
1236 |     try:
1237 |         start = time.time()
1238 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=3000)
1239 |         metrics = _metrics_from_result(result, time.time() - start)
1240 |         print(
1241 |             "Evaluation: "
1242 |             f"nmse_val={metrics['nmse_val']:.6f}, "
1243 |             f"mean_nmse_val={metrics['mean_nmse_val']:.6f}, "
1244 |             f"mean_raw_nmse_val={metrics['mean_raw_nmse_val']:.6f}, "
1245 |             f"combined_score={metrics['combined_score']:.6f}, "
1246 |             f"n_datasets={metrics['n_datasets']}, "
1247 |             f"n_successful={metrics['n_successful']}, "
1248 |             f"time={metrics['eval_time']:.2f}s"
1249 |         )
1250 |         print(f"Equation template: {metrics['equation']}")
1251 |         if metrics.get("hard_case_feedback"):
