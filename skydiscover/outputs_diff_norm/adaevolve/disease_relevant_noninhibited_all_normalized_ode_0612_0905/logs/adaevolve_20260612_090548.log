 645 | def _normalized_mse_with_reference_variance(
 646 |     y_true: np.ndarray,
 647 |     y_pred: np.ndarray,
 648 |     reference_values: np.ndarray,
 649 | ) -> float:
 650 |     """MSE normalized by full dataset scale, not by a flat validation segment."""
 651 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 652 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 653 |     reference_values = np.asarray(reference_values, dtype=float).reshape(-1)
 654 |     if y_true.shape != y_pred.shape:
 655 |         return float("inf")
 656 |     if not np.all(np.isfinite(y_pred)):
 657 |         return float("inf")
 658 |     var = float(np.var(reference_values))
 659 |     if var <= 0.0:
 660 |         return float(np.mean((y_true - y_pred) ** 2))
 661 |     return float(np.mean((y_true - y_pred) ** 2) / var)
 662 | 
