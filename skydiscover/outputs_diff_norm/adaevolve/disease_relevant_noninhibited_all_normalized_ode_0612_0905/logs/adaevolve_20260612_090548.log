 608 | 
 609 | def _parsimony_penalty_factor(complexity: float) -> float:
 610 |     """Bounded penalty factor for expression complexity."""
 611 |     if not np.isfinite(complexity) or PARSIMONY_COMPLEXITY_SCALE <= 0:
 612 |         return 1.0
 613 |     normalized = min(max(float(complexity), 0.0) / PARSIMONY_COMPLEXITY_SCALE, 1.0)
 614 |     return max(0.0, 1.0 - PARSIMONY_WEIGHT * normalized)
 615 | 
 616 | 
 617 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 618 |     values = np.asarray(values, dtype=float).ravel()
 619 |     if values.size < 3 or sigma <= 0.0:
 620 |         return values
 621 |     radius = max(1, int(round(3.0 * sigma)))
 622 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 623 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 624 |     kernel /= np.sum(kernel)
 625 |     padded = np.pad(values, (radius, radius), mode="edge")
 626 |     return np.convolve(padded, kernel, mode="valid")
 627 | 
 628 | 
 629 | def _curve_smoothed_target(X: np.ndarray, y_true: np.ndarray) -> np.ndarray:
 630 |     """Smooth targets independently for each parameter curve in time order."""
 631 |     X = np.asarray(X, dtype=float)
 632 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 633 |     if X.shape[0] != y_true.shape[0] or X.shape[1] < 2:
 634 |         return _gaussian_smooth_1d(y_true)
 635 | 
 636 |     smoothed = np.empty_like(y_true, dtype=float)
 637 |     for parameter in np.unique(X[:, 1]):
 638 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 639 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 640 |         smoothed_curve = _gaussian_smooth_1d(y_true[ordered_idx])
 641 |         smoothed[ordered_idx] = smoothed_curve
 642 |     return smoothed
 643 | 
 644 | 
 645 | def _normalized_mse_with_reference_variance(
 646 |     y_true: np.ndarray,
 647 |     y_pred: np.ndarray,
 648 |     reference_values: np.ndarray,
 649 | ) -> float:
 650 |     """MSE normalized by full dataset scale, not by a flat validation segment."""
 651 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 652 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 653 |     reference_values = np.asarray(reference_values, dtype=float).reshape(-1)
 654 |     if y_true.shape != y_pred.shape:
 655 |         return float("inf")
 656 |     if not np.all(np.isfinite(y_pred)):
 657 |         return float("inf")
 658 |     var = float(np.var(reference_values))
 659 |     if var <= 0.0:
 660 |         return float(np.mean((y_true - y_pred) ** 2))
 661 |     return float(np.mean((y_true - y_pred) ** 2) / var)
 662 | 
 663 | 
 664 | def _nmse_with_gaussian_smoothed_target(
 665 |     y_true: np.ndarray,
 666 |     y_pred: np.ndarray,
 667 |     X: np.ndarray | None = None,
 668 |     reference_values: np.ndarray | None = None,
 669 | ) -> float:
 670 |     reference = y_true if reference_values is None else reference_values
 671 |     return _normalized_mse_with_reference_variance(y_true, y_pred, reference)
 672 | 
 673 | 
 674 | def _ode_predictions(
 675 |     rhs_fn: Any,
 676 |     X: np.ndarray,
 677 |     y_known: np.ndarray,
 678 |     theta: np.ndarray,
 679 | ) -> np.ndarray:
 680 |     """Integrate dc/dt=f(t, parameter, c) per parameter curve on one split."""
 681 |     import warnings
 682 | 
 683 |     from scipy.integrate import odeint
 684 | 
 685 |     X = np.asarray(X, dtype=float)
 686 |     y_known = np.asarray(y_known, dtype=float).reshape(-1)
 687 |     theta = np.asarray(theta, dtype=float).reshape(-1)
 688 |     predictions = np.full_like(y_known, np.nan, dtype=float)
 689 | 
 690 |     for parameter in np.unique(X[:, 1]):
 691 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 692 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 693 |         times = X[ordered_idx, 0]
 694 |         observed = y_known[ordered_idx]
 695 | 
 696 |         if len(ordered_idx) == 1 or float(times[-1] - times[0]) <= 0.0:
 697 |             predictions[ordered_idx] = observed[0]
 698 |             continue
 699 | 
 700 |         def dc_dt(c_state: np.ndarray, time_value: float) -> float:
 701 |             c_value = float(np.asarray(c_state, dtype=float).reshape(-1)[0])
 702 |             value = rhs_fn(float(time_value), float(parameter), c_value, *theta)
 703 |             value = float(np.asarray(value, dtype=float).reshape(-1)[0])
 704 |             if not np.isfinite(value):
 705 |                 raise FloatingPointError("non-finite ODE derivative")
 706 |             return value
 707 | 
 708 |         with warnings.catch_warnings():
 709 |             warnings.simplefilter("ignore")
 710 |             integrated = odeint(
 711 |                 dc_dt,
 712 |                 float(observed[0]),
 713 |                 times,
 714 |                 mxstep=1000,
 715 |             )
 716 |         curve_pred = np.asarray(integrated, dtype=float).reshape(-1)
 717 |         if curve_pred.shape != observed.shape or not np.all(np.isfinite(curve_pred)):
 718 |             raise FloatingPointError("non-finite ODE trajectory")
 719 |         predictions[ordered_idx] = curve_pred
 720 | 
 721 |     return predictions
 722 | 
 723 | 
 724 | def evaluate_ode_expression(
 725 |     expression: Any,
 726 |     X_train: np.ndarray,
 727 |     y_train: np.ndarray,
 728 |     X_val: np.ndarray,
 729 |     y_val: np.ndarray,
 730 |     *,
 731 |     constants: Any | None = None,
 732 |     initial_values: Any | None = None,
 733 |     max_nfev: int = 300,
 734 | ) -> dict[str, Any]:
 735 |     """Score a proposed ODE RHS by integrating predicted concentration curves."""
 736 |     import sympy as sp
 737 |     from pysr_harness import equation_session
 738 |     from scipy.optimize import least_squares
 739 | 
 740 |     X_train = np.asarray(X_train, dtype=float)
 741 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 742 |     X_val = np.asarray(X_val, dtype=float)
 743 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 744 |     evaluation_only = X_train.shape[0] == 0 and X_val.shape[0] > 0
 745 |     train_only = X_val.shape[0] == 0 and X_train.shape[0] > 0
 746 |     if evaluation_only:
 747 |         X_fit, y_fit = X_val, y_val
 748 |     else:
 749 |         X_fit, y_fit = X_train, y_train
 750 |     y_reference = np.concatenate([y_train, y_val]) if y_train.size else y_val
 751 |     n_features = X_fit.shape[1] if X_fit.shape[0] else X_val.shape[1]
 752 |     feature_names = [f"x{i}" for i in range(n_features)]
 753 |     template = equation_session._as_sympy_expr(expression, feature_names)
 754 |     equation_session._record_scored_template(template)
 755 | 
 756 |     if constants is None:
 757 |         feature_set = set(equation_session.feature_symbols(n_features))
 758 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 759 |     constants = list(constants)
 760 |     equation_session._validate_expression_template(template, constants)
 761 | 
 762 |     if initial_values is None:
 763 |         base_x0 = np.ones(len(constants), dtype=float)
 764 |     else:
 765 |         base_x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 766 |         if base_x0.size != len(constants):
 767 |             raise ValueError("initial_values must match the number of constants")
 768 | 
 769 |     feature_syms = equation_session.feature_symbols(n_features)
 770 |     rhs_fn = sp.lambdify(feature_syms + constants, template, modules=["numpy"])
 771 | 
 772 |     if not constants:
 773 |         y_pred_fit = _ode_predictions(rhs_fn, X_fit, y_fit, np.asarray([], dtype=float))
 774 |         y_pred_val = _ode_predictions(rhs_fn, X_val, y_val, np.asarray([], dtype=float))
 775 |         nmse_train = (
 776 |             float("nan")
 777 |             if evaluation_only
 778 |             else _nmse_with_gaussian_smoothed_target(
 779 |                 y_train, y_pred_fit, X_train, y_reference
 780 |             )
 781 |         )
 782 |         nmse_val = (
 783 |             float("nan")
 784 |             if train_only
 785 |             else _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 786 |         )
 787 |         result = {
 788 |             "equation_template": f"d(c)/dt = {template}",
 789 |             "equation": f"d(c)/dt = {template}",
 790 |             "constants": {},
 791 |             "loss": float(np.mean((y_pred_fit - y_fit) ** 2)),
 792 |             "complexity": equation_session._complexity(template),
 793 |             "nmse_train": nmse_train,
 794 |             "nmse_val": nmse_val,
 795 |             "n_val_points": int(len(y_val)),
 796 |             "evaluation_only": evaluation_only,
 797 |             "train_only": train_only,
 798 |             "combined_score": (
 799 |                 0.0
 800 |                 if train_only or not np.isfinite(nmse_val)
 801 |                 else combined_score_from_nmse(nmse_val)
 802 |             ),
 803 |         }
 804 |         equation_session._record_scorer_result(result)
 805 |         return result
 806 | 
 807 |     def residual(theta: np.ndarray) -> np.ndarray:
 808 |         try:
 809 |             prediction = _ode_predictions(rhs_fn, X_fit, y_fit, theta)
 810 |         except Exception:
 811 |             return np.full_like(y_fit, 1e12, dtype=float)
 812 |         if prediction.shape != y_fit.shape or not np.all(np.isfinite(prediction)):
 813 |             return np.full_like(y_fit, 1e12, dtype=float)
 814 |         return prediction - y_fit
 815 | 
 816 |     initial_candidates: list[np.ndarray] = []
 817 |     for scale in ODE_MULTISTART_SCALES or (1.0,):
 818 |         candidate = base_x0 * float(scale)
 819 |         if not any(np.array_equal(candidate, existing) for existing in initial_candidates):
 820 |             initial_candidates.append(candidate)
 821 | 
 822 |     import warnings
 823 | 
 824 |     best_fit = None
 825 |     best_loss = float("inf")
 826 |     with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 827 |         warnings.simplefilter("ignore", RuntimeWarning)
 828 |         for initial_candidate in initial_candidates:
 829 |             fit = least_squares(
 830 |                 residual,
 831 |                 initial_candidate,
 832 |                 loss="soft_l1",
 833 |                 max_nfev=max_nfev,
 834 |             )
 835 |             fit_residual = residual(fit.x)
 836 |             fit_loss = float(np.mean(fit_residual**2))
 837 |             if fit_loss < best_loss:
 838 |                 best_loss = fit_loss
 839 |                 best_fit = fit
 840 | 
 841 |     if best_fit is None:
 842 |         raise RuntimeError("constant fitting did not produce a result")
 843 | 
 844 |     fitted_constants = {
 845 |         str(symbol): float(value) for symbol, value in zip(constants, best_fit.x)
 846 |     }
 847 |     substitutions = dict(zip(constants, best_fit.x))
 848 |     fitted_expr = template.subs(substitutions)
 849 |     y_pred_fit = _ode_predictions(rhs_fn, X_fit, y_fit, best_fit.x)
 850 |     y_pred_val = _ode_predictions(rhs_fn, X_val, y_val, best_fit.x)
 851 |     nmse_train = (
 852 |         float("nan")
 853 |         if evaluation_only
 854 |         else _nmse_with_gaussian_smoothed_target(
 855 |             y_train, y_pred_fit, X_train, y_reference
 856 |         )
 857 |     )
 858 |     nmse_val = (
 859 |         float("nan")
 860 |         if train_only
 861 |         else _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 862 |     )
 863 |     loss = float(np.mean((y_pred_fit - y_fit) ** 2))
 864 | 
 865 |     result = {
 866 |         "equation_template": f"d(c)/dt = {template}",
 867 |         "equation": f"d(c)/dt = {fitted_expr}",
 868 |         "constants": fitted_constants,
 869 |         "loss": loss,
 870 |         "complexity": equation_session._complexity(template),
 871 |         "nmse_train": nmse_train,
 872 |         "nmse_val": nmse_val,
 873 |         "n_val_points": int(len(y_val)),
 874 |         "evaluation_only": evaluation_only,
 875 |         "train_only": train_only,
 876 |         "combined_score": (
 877 |             0.0
 878 |             if train_only or not np.isfinite(nmse_val)
 879 |             else combined_score_from_nmse(nmse_val)
 880 |         ),
 881 |     }
 882 |     equation_session._record_scorer_result(result)
 883 |     return result
 884 | 
 885 | 
 886 | def _point_weighted_mean(
 887 |     values: list[float],
 888 |     weights: list[int],
 889 | ) -> float:
 890 |     """Average values with one weight per evaluation point."""
 891 |     total_weight = sum(weights)
 892 |     if total_weight <= 0:
 893 |         return float("inf")
 894 |     weighted = sum(
 895 |         float(value) * float(weight)
 896 |         for value, weight in zip(values, weights)
 897 |         if np.isfinite(float(value))
 898 |     )
 899 |     if not np.isfinite(weighted):
 900 |         return float("inf")
 901 |     return float(weighted / total_weight)
 902 | 
 903 | 
 904 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 905 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 906 |     scoring_results = {
 907 |         name: result
 908 |         for name, result in per_dataset_results.items()
 909 |         if int(result.get("n_val_points", 0)) > 0
 910 |     }
 911 |     raw_nmse_vals = [float(r["nmse_val"]) for r in scoring_results.values()]
 912 |     nmse_vals = list(raw_nmse_vals)
 913 |     train_nmse_vals = [
 914 |         float(r["nmse_train"])
 915 |         for r in per_dataset_results.values()
 916 |         if np.isfinite(float(r.get("nmse_train", float("inf"))))
 917 |     ]
 918 |     complexity_vals = []
 919 |     for r in per_dataset_results.values():
 920 |         try:
 921 |             value = float(r.get("complexity", float("nan")))
 922 |         except (TypeError, ValueError):
 923 |             continue
 924 |         if np.isfinite(value):
 925 |             complexity_vals.append(value)
 926 |     aggregate_complexity = float(max(complexity_vals)) if complexity_vals else 0.0
 927 | 
 928 |     violation_errors = sorted(
 929 |         {
 930 |             str(r.get("error"))
 931 |             for r in per_dataset_results.values()
 932 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 933 |         }
 934 |     )
 935 |     failed_datasets = sorted(
 936 |         name
 937 |         for name, result in scoring_results.items()
 938 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 939 |     )
 940 |     templates = sorted(
 941 |         {
 942 |             str(r.get("equation_template"))
 943 |             for r in per_dataset_results.values()
 944 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 945 |         }
 946 |     )
 947 | 
 948 |     eq_template = ""
 949 |     for r in per_dataset_results.values():
 950 |         if r.get("equation"):
 951 |             eq_template = r["equation"]
 952 |             break
 953 | 
 954 |     hard_cases = [
 955 |         {"dataset": name, "nmse_val": float(result["nmse_val"])}
 956 |         for name, result in scoring_results.items()
 957 |         if np.isfinite(float(result.get("nmse_val", float("inf"))))
 958 |     ]
 959 |     hard_cases.sort(key=lambda item: item["nmse_val"], reverse=True)
 960 |     hard_cases = hard_cases[:5]
 961 |     hard_case_feedback = "; ".join(
 962 |         f"{case['dataset']} nmse={case['nmse_val']:.4g}" for case in hard_cases
 963 |     )
 964 | 
 965 |     violation_error = None
 966 |     if violation_errors:
 967 |         violation_error = violation_errors[0]
 968 |     elif failed_datasets:
 969 |         examples = ", ".join(failed_datasets[:3])
 970 |         violation_error = (
 971 |             "Single-equation violation: candidate failed on "
 972 |             f"{len(failed_datasets)}/{len(scoring_results)} validation datasets. "
 973 |             "Failed datasets are not dropped from the aggregate reward. "
 974 |             f"Examples: {examples}"
 975 |         )
 976 |     elif len(templates) > 1:
 977 |         examples = "; ".join(templates[:3])
 978 |         violation_error = (
 979 |             "Single-equation violation: evaluate_symbolic_candidate() produced "
 980 |             f"{len(templates)} distinct equation templates across datasets. "
 981 |             "The base equation must be identical for all datasets; only fitted "
 982 |             f"constants may vary. Example templates: {examples}"
 983 |         )
 984 | 
 985 |     if violation_error:
 986 |         agg_nmse = float("inf")
 987 |         mean_nmse = float("inf")
 988 |         agg_train_nmse = float("inf")
 989 |         agg_combined = 0.0
 990 |         n_successful = 0
 991 |     else:
 992 |         val_point_weights = [
 993 |             int(r.get("n_val_points", 0)) for r in scoring_results.values()
 994 |         ]
 995 |         mean_nmse = _point_weighted_mean(nmse_vals, val_point_weights)
 996 |         raw_mean_nmse = _point_weighted_mean(raw_nmse_vals, val_point_weights)
 997 |         eval_only_results = {
 998 |             name: result
 999 |             for name, result in scoring_results.items()
1000 |             if result.get("evaluation_only")
1001 |         }
1002 |         eval_only_nmse_vals = [
1003 |             float(result["nmse_val"])
1004 |             for result in eval_only_results.values()
1005 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
1006 |         ]
1007 |         eval_only_weights = [
1008 |             int(result.get("n_val_points", 0))
1009 |             for result in eval_only_results.values()
1010 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
1011 |         ]
1012 |         mean_nmse_eval_only = (
1013 |             _point_weighted_mean(eval_only_nmse_vals, eval_only_weights)
1014 |             if eval_only_nmse_vals
1015 |             else float("nan")
1016 |         )
1017 |         agg_nmse = mean_nmse
1018 |         agg_train_nmse = float(np.mean(train_nmse_vals)) if train_nmse_vals else float("inf")
1019 |         raw_combined = (
1020 |             float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
1021 |         )
1022 |         parsimony_factor = _parsimony_penalty_factor(aggregate_complexity)
1023 |         agg_combined = raw_combined * parsimony_factor
1024 |         n_successful = sum(1 for value in nmse_vals if np.isfinite(value))
1025 | 
1026 |     aggregated = {
1027 |         "equation": eq_template,
1028 |         "nmse_train": agg_train_nmse,
1029 |         "nmse_val": agg_nmse,
1030 |         "mean_nmse_val": mean_nmse,
1031 |         "mean_raw_nmse_val": raw_mean_nmse if not violation_error else float("inf"),
1032 |         "combined_score": agg_combined,
1033 |         "fit_score": raw_combined if not violation_error else 0.0,
1034 |         "complexity": aggregate_complexity,
1035 |         "parsimony_weight": PARSIMONY_WEIGHT,
1036 |         "parsimony_penalty_factor": (
1037 |             _parsimony_penalty_factor(aggregate_complexity) if not violation_error else 1.0
1038 |         ),
1039 |         "n_datasets": len(scoring_results),
1040 |         "n_total_datasets": len(per_dataset_results),
1041 |         "n_train_only_datasets": len(per_dataset_results) - len(scoring_results),
1042 |         "n_successful": n_successful,
1043 |         "n_evaluation_only_datasets": len(
1044 |             [name for name, result in per_dataset_results.items() if result.get("evaluation_only")]
1045 |         ),
1046 |         "mean_nmse_eval_only": (
1047 |             mean_nmse_eval_only if not violation_error else float("inf")
1048 |         ),
1049 |         "eval_workers": NUM_WORKERS,
1050 |         "hard_cases": hard_cases,
1051 |         "hard_case_feedback": hard_case_feedback,
1052 |         "per_dataset": per_dataset_results,
1053 |     }
1054 |     if violation_error:
1055 |         aggregated["error"] = violation_error
1056 |     return aggregated
1057 | 
