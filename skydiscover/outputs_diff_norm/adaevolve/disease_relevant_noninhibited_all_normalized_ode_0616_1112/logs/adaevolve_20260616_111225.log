from pysr_harness.equation_session import constant_symbols, feature_symbols, evaluate_expression
ds=load_all_datasets()
def run(Xt,Xv,yt,yv,kind):
    if kind=='cur':
        c=constant_symbols(4); x=feature_symbols(3); p,cc=x[1],x[2]
        e=(c[0]+c[1]*cc)*(1+c[2]*p)*(c[3]-cc); iv=[0.5,1.0,0.0,1.0]
    else:
        c=constant_symbols(3); x=feature_symbols(3); p,cc=x[1],x[2]
        e=(c[0]+c[1]*cc)*(c[2]-cc); iv=[0.5,1.0,1.0]
    return evaluate_expression(e,Xt,yt,Xv,yv,constants=c,initial_values=iv).get('nmse_val')
for (n,Xt,Xv,yt,yv) in ds:
    if len(Xt)>0 and len(Xv)>0:
        a=run(Xt,Xv,yt,yv,'cur')
        if a is not None and a>0.01:
            b=run(Xt,Xv,yt,yv,'B')
            print('%-40s cur=%.4f B=%.4f nval=%d'%(n[-40:],a,b,len(Xv)))
