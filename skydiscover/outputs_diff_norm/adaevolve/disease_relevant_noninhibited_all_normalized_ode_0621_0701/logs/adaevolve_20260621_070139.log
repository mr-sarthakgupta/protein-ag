 101 |         "pow": (-1, 1),
 102 |         "max": (-1, -1),
 103 |         "min": (-1, -1),
 104 |         "muladd": (-1, -1, 1),
 105 |         "clamp": (-1, 1, 1),
 106 |     }
 107 | 
 108 | 
