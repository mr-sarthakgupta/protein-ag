 139 | def _has_postponed_annotations(tree: ast.Module) -> bool:
 140 |     for node in tree.body:
 141 |         if isinstance(node, ast.ImportFrom) and node.module == "__future__":
 142 |             if any(alias.name == "annotations" for alias in node.names):
 143 |                 return True
 144 |     return False
