 588 | 
 589 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 590 | PARSIMONY_WEIGHT = float(os.environ.get("SKYDISCOVER_PARSIMONY_WEIGHT", "0.20"))
 591 | PARSIMONY_COMPLEXITY_SCALE = float(
 592 |     os.environ.get("SKYDISCOVER_PARSIMONY_COMPLEXITY_SCALE", "160")
 593 | )
 594 | 
 595 | 
 596 | def _parsimony_penalty_factor(complexity: float) -> float:
 597 |     """Bounded penalty factor for expression complexity."""
 598 |     if not np.isfinite(complexity) or PARSIMONY_COMPLEXITY_SCALE <= 0:
 599 |         return 1.0
 600 |     normalized = min(max(float(complexity), 0.0) / PARSIMONY_COMPLEXITY_SCALE, 1.0)
 601 |     return max(0.0, 1.0 - PARSIMONY_WEIGHT * normalized)
 602 | 
 603 | 
 604 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 605 |     values = np.asarray(values, dtype=float).ravel()
 606 |     if values.size < 3 or sigma <= 0.0:
 607 |         return values
 608 |     radius = max(1, int(round(3.0 * sigma)))
 609 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 610 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 611 |     kernel /= np.sum(kernel)
 612 |     padded = np.pad(values, (radius, radius), mode="edge")
 613 |     return np.convolve(padded, kernel, mode="valid")
 614 | 
 615 | 
 616 | def _curve_smoothed_target(X: np.ndarray, y_true: np.ndarray) -> np.ndarray:
 617 |     """Smooth targets independently for each parameter curve in time order."""
 618 |     X = np.asarray(X, dtype=float)
 619 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 620 |     if X.shape[0] != y_true.shape[0] or X.shape[1] < 2:
 621 |         return _gaussian_smooth_1d(y_true)
 622 | 
 623 |     smoothed = np.empty_like(y_true, dtype=float)
 624 |     for parameter in np.unique(X[:, 1]):
 625 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 626 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 627 |         smoothed_curve = _gaussian_smooth_1d(y_true[ordered_idx])
 628 |         smoothed[ordered_idx] = smoothed_curve
 629 |     return smoothed
 630 | 
 631 | 
 632 | def _normalized_mse_with_reference_variance(
 633 |     y_true: np.ndarray,
 634 |     y_pred: np.ndarray,
 635 |     reference_values: np.ndarray,
 636 | ) -> float:
 637 |     """MSE normalized by full dataset scale, not by a flat validation segment."""
 638 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 639 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 640 |     reference_values = np.asarray(reference_values, dtype=float).reshape(-1)
 641 |     if y_true.shape != y_pred.shape:
 642 |         return float("inf")
 643 |     if not np.all(np.isfinite(y_pred)):
 644 |         return float("inf")
 645 |     var = float(np.var(reference_values))
 646 |     if var <= 0.0:
 647 |         return float(np.mean((y_true - y_pred) ** 2))
 648 |     return float(np.mean((y_true - y_pred) ** 2) / var)
 649 | 
 650 | 
 651 | def _nmse_with_gaussian_smoothed_target(
 652 |     y_true: np.ndarray,
 653 |     y_pred: np.ndarray,
 654 |     X: np.ndarray | None = None,
 655 |     reference_values: np.ndarray | None = None,
 656 | ) -> float:
 657 |     reference = y_true if reference_values is None else reference_values
 658 |     raw_loss = _normalized_mse_with_reference_variance(y_true, y_pred, reference)
 659 |     smooth_target = _curve_smoothed_target(X, y_true) if X is not None else _gaussian_smooth_1d(y_true)
 660 |     smooth_loss = _normalized_mse_with_reference_variance(smooth_target, y_pred, reference)
 661 |     return float((raw_loss + smooth_loss) / 2.0)
 662 | 
 663 | 
 664 | def _ode_predictions(
 665 |     rhs_fn: Any,
 666 |     X: np.ndarray,
 667 |     y_known: np.ndarray,
 668 |     theta: np.ndarray,
 669 | ) -> np.ndarray:
 670 |     """Integrate dc/dt=f(t, parameter, c) per parameter curve on one split."""
 671 |     import warnings
 672 | 
 673 |     from scipy.integrate import odeint
 674 | 
 675 |     X = np.asarray(X, dtype=float)
 676 |     y_known = np.asarray(y_known, dtype=float).reshape(-1)
 677 |     theta = np.asarray(theta, dtype=float).reshape(-1)
 678 |     predictions = np.full_like(y_known, np.nan, dtype=float)
 679 | 
 680 |     for parameter in np.unique(X[:, 1]):
 681 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 682 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 683 |         times = X[ordered_idx, 0]
 684 |         observed = y_known[ordered_idx]
 685 | 
 686 |         if len(ordered_idx) == 1 or float(times[-1] - times[0]) <= 0.0:
 687 |             predictions[ordered_idx] = observed[0]
 688 |             continue
 689 | 
 690 |         def dc_dt(c_state: np.ndarray, time_value: float) -> float:
 691 |             c_value = float(np.asarray(c_state, dtype=float).reshape(-1)[0])
 692 |             value = rhs_fn(float(time_value), float(parameter), c_value, *theta)
 693 |             value = float(np.asarray(value, dtype=float).reshape(-1)[0])
 694 |             if not np.isfinite(value):
 695 |                 raise FloatingPointError("non-finite ODE derivative")
 696 |             return value
 697 | 
 698 |         with warnings.catch_warnings():
 699 |             warnings.simplefilter("ignore")
 700 |             integrated = odeint(
 701 |                 dc_dt,
 702 |                 float(observed[0]),
 703 |                 times,
 704 |                 mxstep=1000,
 705 |             )
 706 |         curve_pred = np.asarray(integrated, dtype=float).reshape(-1)
 707 |         if curve_pred.shape != observed.shape or not np.all(np.isfinite(curve_pred)):
 708 |             raise FloatingPointError("non-finite ODE trajectory")
 709 |         predictions[ordered_idx] = curve_pred
 710 | 
 711 |     return predictions
 712 | 
 713 | 
 714 | def evaluate_ode_expression(
 715 |     expression: Any,
 716 |     X_train: np.ndarray,
 717 |     y_train: np.ndarray,
 718 |     X_val: np.ndarray,
 719 |     y_val: np.ndarray,
 720 |     *,
 721 |     constants: Any | None = None,
 722 |     initial_values: Any | None = None,
 723 |     max_nfev: int = 300,
 724 | ) -> dict[str, Any]:
 725 |     """Score a proposed ODE RHS by integrating predicted concentration curves."""
 726 |     import sympy as sp
 727 |     from pysr_harness import equation_session
 728 |     from scipy.optimize import least_squares
 729 | 
 730 |     X_train = np.asarray(X_train, dtype=float)
 731 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 732 |     X_val = np.asarray(X_val, dtype=float)
 733 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 734 |     y_reference = np.concatenate([y_train, y_val])
 735 |     feature_names = [f"x{i}" for i in range(X_train.shape[1])]
 736 |     template = equation_session._as_sympy_expr(expression, feature_names)
 737 |     equation_session._record_scored_template(template)
 738 | 
 739 |     if constants is None:
 740 |         feature_set = set(equation_session.feature_symbols(X_train.shape[1]))
 741 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 742 |     constants = list(constants)
 743 |     equation_session._validate_expression_template(template, constants)
 744 | 
 745 |     if initial_values is None:
 746 |         base_x0 = np.ones(len(constants), dtype=float)
 747 |     else:
 748 |         base_x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 749 |         if base_x0.size != len(constants):
 750 |             raise ValueError("initial_values must match the number of constants")
 751 | 
 752 |     feature_syms = equation_session.feature_symbols(X_train.shape[1])
 753 |     rhs_fn = sp.lambdify(feature_syms + constants, template, modules=["numpy"])
 754 | 
 755 |     if not constants:
 756 |         y_pred_train = _ode_predictions(rhs_fn, X_train, y_train, np.asarray([], dtype=float))
 757 |         y_pred_val = _ode_predictions(rhs_fn, X_val, y_val, np.asarray([], dtype=float))
 758 |         nmse_train = _nmse_with_gaussian_smoothed_target(
 759 |             y_train, y_pred_train, X_train, y_reference
 760 |         )
 761 |         nmse_val = _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 762 |         result = {
 763 |             "equation_template": f"d(c)/dt = {template}",
 764 |             "equation": f"d(c)/dt = {template}",
 765 |             "constants": {},
 766 |             "loss": float(np.mean((y_pred_train - y_train) ** 2)),
 767 |             "complexity": equation_session._complexity(template),
 768 |             "nmse_train": nmse_train,
 769 |             "nmse_val": nmse_val,
 770 |             "combined_score": combined_score_from_nmse(nmse_val),
 771 |         }
 772 |         equation_session._record_scorer_result(result)
 773 |         return result
 774 | 
 775 |     def residual(theta: np.ndarray) -> np.ndarray:
 776 |         try:
 777 |             prediction = _ode_predictions(rhs_fn, X_train, y_train, theta)
 778 |         except Exception:
 779 |             return np.full_like(y_train, 1e12, dtype=float)
 780 |         if prediction.shape != y_train.shape or not np.all(np.isfinite(prediction)):
 781 |             return np.full_like(y_train, 1e12, dtype=float)
 782 |         return prediction - y_train
 783 | 
 784 |     initial_candidates: list[np.ndarray] = []
 785 |     for scale in ODE_MULTISTART_SCALES or (1.0,):
 786 |         candidate = base_x0 * float(scale)
 787 |         if not any(np.array_equal(candidate, existing) for existing in initial_candidates):
 788 |             initial_candidates.append(candidate)
 789 | 
 790 |     import warnings
 791 | 
 792 |     best_fit = None
 793 |     best_loss = float("inf")
 794 |     with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 795 |         warnings.simplefilter("ignore", RuntimeWarning)
 796 |         for initial_candidate in initial_candidates:
 797 |             fit = least_squares(
 798 |                 residual,
 799 |                 initial_candidate,
 800 |                 loss="soft_l1",
 801 |                 max_nfev=max_nfev,
 802 |             )
 803 |             fit_residual = residual(fit.x)
 804 |             fit_loss = float(np.mean(fit_residual**2))
 805 |             if fit_loss < best_loss:
 806 |                 best_loss = fit_loss
 807 |                 best_fit = fit
 808 | 
 809 |     if best_fit is None:
 810 |         raise RuntimeError("constant fitting did not produce a result")
 811 | 
 812 |     fitted_constants = {
 813 |         str(symbol): float(value) for symbol, value in zip(constants, best_fit.x)
 814 |     }
 815 |     substitutions = dict(zip(constants, best_fit.x))
 816 |     fitted_expr = template.subs(substitutions)
 817 |     y_pred_train = _ode_predictions(rhs_fn, X_train, y_train, best_fit.x)
 818 |     y_pred_val = _ode_predictions(rhs_fn, X_val, y_val, best_fit.x)
 819 |     nmse_train = _nmse_with_gaussian_smoothed_target(
 820 |         y_train, y_pred_train, X_train, y_reference
 821 |     )
 822 |     nmse_val = _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 823 |     loss = float(np.mean((y_pred_train - y_train) ** 2))
 824 | 
 825 |     result = {
 826 |         "equation_template": f"d(c)/dt = {template}",
 827 |         "equation": f"d(c)/dt = {fitted_expr}",
 828 |         "constants": fitted_constants,
 829 |         "loss": loss,
 830 |         "complexity": equation_session._complexity(template),
 831 |         "nmse_train": nmse_train,
 832 |         "nmse_val": nmse_val,
 833 |         "combined_score": combined_score_from_nmse(nmse_val),
 834 |     }
 835 |     equation_session._record_scorer_result(result)
 836 |     return result
