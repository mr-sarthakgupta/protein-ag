1107 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
1108 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
1109 |     nmse_val = float(result.get("nmse_val", float("inf")))
1110 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
1111 |     if not np.isfinite(combined):
1112 |         combined = 0.0
1113 | 
1114 |     return {
1115 |         "equation": str(result.get("equation", "")),
1116 |         "loss": nmse_val,
1117 |         "complexity": float(result.get("complexity", 0.0)),
1118 |         "nmse_train": float(result.get("nmse_train", float("inf"))),
1119 |         "nmse_val": nmse_val,
1120 |         "mean_nmse_val": float(result.get("mean_nmse_val", nmse_val)),
1121 |         "mean_raw_nmse_val": float(result.get("mean_raw_nmse_val", nmse_val)),
1122 |         "combined_score": combined,
1123 |         "fit_score": float(result.get("fit_score", combined)),
1124 |         "parsimony_weight": float(result.get("parsimony_weight", PARSIMONY_WEIGHT)),
1125 |         "parsimony_penalty_factor": float(result.get("parsimony_penalty_factor", 1.0)),
1126 |         "eval_time": float(eval_time),
1127 |         "n_datasets": result.get("n_datasets", 0),
1128 |         "n_successful": result.get("n_successful", 0),
1129 |         "eval_workers": result.get("eval_workers", NUM_WORKERS),
1130 |         "hard_cases": result.get("hard_cases", []),
1131 |         "hard_case_feedback": str(result.get("hard_case_feedback", "")),
1132 |         "hard_case_tail_nmse": float(result.get("hard_case_tail_nmse", 0.0)),
1133 |         "hard_case_tail_weight": float(result.get("hard_case_tail_weight", HARD_CASE_TAIL_WEIGHT)),
1134 |         "per_dataset_nmse_cap": float(result.get("per_dataset_nmse_cap", PER_DATASET_NMSE_CAP)),
1135 |         "per_dataset": result.get("per_dataset", {}),
1136 |         "error": str(result.get("error", "")),
