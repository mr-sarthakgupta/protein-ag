1187 | def _eval_stage1_worker(args):
1188 |     """Module-level worker for stage 1 parallel evaluation."""
1189 |     name, X_train, X_val, y_train, y_val, program_path = args
1190 |     harness_root = str(BENCHMARK_ROOT)
1191 |     if harness_root not in sys.path:
1192 |         sys.path.insert(0, harness_root)
1193 |     validate_candidate_source(program_path)
1194 |     import pysr_harness.equation_session as equation_session
1195 |     equation_session.evaluate_expression = evaluate_ode_expression
1196 |     equation_session.nmse = _nmse_with_gaussian_smoothed_target
1197 |     spec = importlib.util.spec_from_file_location("program", program_path)
1198 |     program = importlib.util.module_from_spec(spec)
1199 |     spec.loader.exec_module(program)
1200 |     from pysr_harness.equation_session import (
1201 |         single_equation_evaluation,
1202 |         validate_single_equation_result,
1203 |     )
1204 | 
1205 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1206 |         program, "run_discovery", None
1207 |     )
1208 |     if fn is None:
1209 |         return 0.0, "missing evaluate_symbolic_candidate()", ""
1210 |     try:
1211 |         with single_equation_evaluation():
1212 |             result = fn(X_train, y_train, X_val, y_val)
1213 |             validate_single_equation_result(result)
1214 |         return float(result.get("combined_score", 0.0)), None, str(
1215 |             result.get("equation_template", "")
1216 |         )
1217 |     except Exception as exc:
1218 |         return 0.0, str(exc), ""
