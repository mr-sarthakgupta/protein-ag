import sympy as sp
x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2, c3 = sp.symbols('c0 c1 c2 c3')

def complexity(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

# Second-order depletion
e1 = (c0 + c1*x2) * (1 + c2*x1) * (1 - x2)**2
print('(c0+c1*x2)*(1+c2*x1)*(1-x2)^2 complexity=', complexity(e1))

# What about (c0 + c1*x2^2) * (1+c2*x1) * (1-x2)?
e2 = (c0 + c1*x2**2) * (1 + c2*x1) * (1 - x2)
print('(c0+c1*x2^2)*(1+c2*x1)*(1-x2) complexity=', complexity(e2))

# x2*(1-x2) logistic core + primary nucleation c0*(1-x2):
# (c0 + c1*x2) * (1-x2) * (1 + c2*x1) -- same as current

# What about adding x0 (time) to help with lag phase?
# c0*(1+c1*x0)*(1+c2*x1)*(1-x2) -- time-linear modulation
e3 = c0*(1 + c1*x0)*(1 + c2*x1)*(1 - x2)
print('c0*(1+c1*x0)*(1+c2*x1)*(1-x2) complexity=', complexity(e3))

# What about c0*x2*(1-x2)*(1+c1*x1) + c2*(1-x2)?
# = (c2 + c0*x2*(1+c1*x1)) * (1-x2)
e4 = (c2 + c0*x2*(1 + c1*x1)) * (1 - x2)
print('(c2+c0*x2*(1+c1*x1))*(1-x2) complexity=', complexity(e4))

# Most promising: 4-constant form with separate primary/secondary x1 modulation
# dc/dt = (c0 + c1*x1) * (1-x2) + c2*x2*(1 + c3*x1) * (1-x2)
# = ((c0+c1*x1) + c2*x2*(1+c3*x1)) * (1-x2)
e5 = ((c0 + c1*x1) + c2*x2*(1 + c3*x1)) * (1 - x2)
print('4c separate primary/secondary x1: complexity=', complexity(e5))

# Parsimony scores
fit = 0.9616
for cx in [16, 17, 18, 19, 20, 21]:
    p = 1.0 - 0.2*(cx/160)
    cs = fit * p
    print(f'  c={cx}: parsimony={p:.4f}, combined={cs:.4f} (need nmse < {1/p/fit - 1:.4f} to beat 0.9424)')
