 745 |             "arguments": "{\"command\": \"python3 -c \\\"\\nimport numpy as np, os, csv\\nfrom scipy.integrate import odeint\\nfrom scipy.optimize import least_squares\\n\\npath = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'\\n\\ndef minmax(v):\\n    mn, mx = v.min(), v.max()\\n    if mx - mn <= 0: return np.zeros_like(v)\\n    return (v - mn) / (mx - mn)\\n\\ndef parse_param(h):\\n    import re\\n    text = h.strip()\\n    for pat, scale in [(r'(\\\\d+(?:\\\\.\\\\d+)?)\\\\s*uM', 1), (r'(\\\\d+(?:\\\\.\\\\d+)?)\\\\s*mM', 1000),\\n                       (r'(\\\\d+(?:\\\\.\\\\d+)?)\\\\s*mg/mL', 1), (r'(\\\\d+(?:\\\\.\\\\d+)?)\\\\s*ng/ul', 1),\\n                       (r'pH\\\\s+(\\\\d+(?:\\\\.\\\\d+)?)', 1), (r'(\\\\d+(?:\\\\.\\\\d+)?)\\\\s*%', 1),\\n                       (r':\\\\s*(\\\\d+(?:\\\\.\\\\d+)?)\\\\s*$', 1)]:\\n        m = re.search(pat, text, re.I)\\n        if m: return float(m.group(1)) * scale\\n    return None\\n\\ndef load_dataset(fpath):\\n    with open(fpath) as f:\\n        reader = csv.reader(f, delimiter='\\\\t')\\n        header = next(reader)\\n        rows = [r for r in reader if r]\\n    params_raw = [parse_param(h) for h in header[1:]]\\n    if all(p is not None for p in params_raw):\\n        params = [float(p) for p in params_raw]\\n    else:\\n        params = [float(i+1) for i in range(len(header)-1)]\\n    feats, tgts = [], []\\n    for row in rows:\\n        t = float(row[0])\\n        for param, val in zip(params, row[1:]):\\n            if val and val.strip().lower() != 'nan':\\n                feats.append([t, param])\\n                tgts.append(float(val))\\n    X = np.array(feats); y = np.array(tgts)\\n    X_norm = np.column_stack([minmax(X[:,i]) for i in range(X.shape[1])])\\n    y_norm = minmax(y)\\n    return np.column_stack([X_norm, y_norm]), y_norm\\n\\ndef fit_ode(fpath, rhs_fn, n_params, inits):\\n    X, y = load_dataset(fpath)\\n    def residual(theta):\\n        preds = np.zeros(len(y))\\n        for param in np.unique(X[:,1]):\\n            idx = np.flatnonzero(X[:,1]==param)\\n            ord_idx = idx[np.argsort(X[idx,0])]\\n            ts = X[ord_idx, 0]; y0 = y[ord_idx[0]]\\n            try:\\n                sol = odeint(rhs_fn, y0, ts, args=(param,)+tuple(theta)).ravel()\\n                if np.all(np.isfinite(sol)): preds[ord_idx] = sol\\n                else: return np.full(len(y), 1e6)\\n            except: return np.full(len(y), 1e6)\\n        return preds - y\\n    best = None; best_loss = np.inf\\n    for init in inits:\\n        try:\\n            fit = least_squares(residual, init, loss='soft_l1', max_nfev=300)\\n            loss = np.mean(fit.fun**2)\\n            if loss < best_loss: best_loss = loss; best = fit\\n        except: pass\\n    if best is None: return np.inf\\n    var = np.var(y)\\n    return best_loss / var if var > 0 else best_loss\\n\\n# Current: (c0 + c1*x2)*(1+c2*x1)*(1-x2)\\ndef rhs_current(x2, t, param, c0, c1, c2):\\n    return (c0 + c1*x2) * (1 + c2*param) * (1 - x2)\\n\\n# Alt 1: c0*(1-x2) + c1*x2*(1-x2) -- same as current but no x1 term\\ndef rhs_no_x1(x2, t, param, c0, c1):\\n    return (c0 + c1*x2) * (1 - x2)\\n\\n# Alt 2: c0*(1+c1*x1)*x2*(1-x2) -- purely autocatalytic, x1-modulated\\ndef rhs_pure_auto(x2, t, param, c0, c1):\\n    return c0 * (1 + c1*param) * x2 * (1 - x2)\\n\\ndatasets = []\\nfor dirpath, _, filenames in os.walk(path):\\n    if 'fit.tsv' in filenames:\\n        rel = os.path.relpath(dirpath, path)\\n        datasets.append((rel, os.path.join(dirpath, 'fit.tsv')))\\ndatasets.sort()\\n\\nnmse_curr, nmse_nox1, nmse_auto = [], [], []\\nfor name, fpath in datasets:\\n    nc = fit_ode(fpath, rhs_current, 3, [[0.1,10.,2.],[0.3,5.,1.],[0.01,30.,0.]])\\n    nn = fit_ode(fpath, rhs_no_x1, 2, [[0.1,10.],[0.3,5.],[0.01,30.]])\\n    na = fit_ode(fpath, rhs_pure_auto, 2, [[10.,2.],[5.,1.],[30.,0.]])\\n    nmse_curr.append(nc); nmse_nox1.append(nn); nmse_auto.append(na)\\n\\nprint(f'Mean NMSE - current(3c): {np.mean(nmse_curr):.4f}')\\nprint(f'Mean NMSE - no_x1(2c):  {np.mean(nmse_nox1):.4f}')\\nprint(f'Mean NMSE - pure_auto(2c): {np.mean(nmse_auto):.4f}')\\n# Top 5 hardest for each\\nfor label, nmses in [('current', nmse_curr), ('no_x1', nmse_nox1)]:\\n    top5 = sorted(zip(nmses, [d[0] for d in datasets]), reverse=True)[:3]\\n    print(f'Top 3 hard ({label}): {[(f\\\\\\\"{n:.3f}\\\\\\\", name[-30:]) for n, name in top5]}')\\n\\\" 2>/dev/null\\n\"}"
