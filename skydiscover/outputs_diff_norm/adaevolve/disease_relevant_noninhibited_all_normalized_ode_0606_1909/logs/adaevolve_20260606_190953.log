 966 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 967 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 968 | 
 969 |     The subprocess loads every dataset, calls the candidate's
 970 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 971 |     constants each time) using parallel threads, and returns aggregated
 972 |     metrics.
 973 |     """
 974 |     validate_candidate_source(program_path)
 975 |     harness_root = str(BENCHMARK_ROOT)
 976 |     evaluator_path = str(Path(__file__).resolve())
 977 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
 978 |         script = f"""
 979 | import importlib.util
 980 | import os
 981 | import pickle
 982 | import sys
 983 | import traceback
 984 | from concurrent.futures import ThreadPoolExecutor, as_completed
 985 | 
 986 | os.environ.setdefault("OMP_NUM_THREADS", "1")
 987 | os.environ.setdefault("MKL_NUM_THREADS", "1")
 988 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
 989 | 
 990 | import numpy as np
 991 | 
 992 | sys.path.insert(0, {harness_root!r})
 993 | 
 994 | program_path = {program_path!r}
 995 | evaluator_path = {evaluator_path!r}
 996 | results_path = {temp_file.name + ".results"!r}
 997 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 998 | 
 999 | def _write_payload_and_exit(payload):
1000 |     with open(results_path, "wb") as f:
1001 |         pickle.dump(payload, f)
1002 |     sys.stdout.flush()
1003 |     sys.stderr.flush()
1004 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
1005 |     # interpreter shutdown. The parent only needs the pickle payload.
1006 |     os._exit(0)
1007 | 
1008 | try:
1009 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
1010 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
1011 |     evaluator_spec.loader.exec_module(evaluator)
1012 |     evaluator.validate_candidate_source(program_path)
1013 | 
1014 |     import pysr_harness.equation_session as equation_session
1015 |     equation_session.evaluate_expression = evaluator.evaluate_ode_expression
1016 |     equation_session.nmse = evaluator._nmse_with_gaussian_smoothed_target
1017 |     spec = importlib.util.spec_from_file_location("program", program_path)
1018 |     program = importlib.util.module_from_spec(spec)
1019 |     spec.loader.exec_module(program)
1020 |     from pysr_harness.equation_session import (
1021 |         single_equation_evaluation,
1022 |         validate_single_equation_result,
1023 |     )
1024 | 
1025 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1026 |         program, "run_discovery", None
1027 |     )
1028 |     if fn is None:
1029 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
1030 | 
1031 |     datasets = evaluator.load_all_datasets()
1032 | 
1033 |     def _eval_one(args):
1034 |         ds_name, X_train, X_val, y_train, y_val = args
1035 |         try:
1036 |             with single_equation_evaluation():
1037 |                 result = fn(X_train, y_train, X_val, y_val)
1038 |                 validate_single_equation_result(result)
1039 |             ds_nmse = float(result.get("nmse_val", float("inf")))
1040 |             ds_train_nmse = float(result.get("nmse_train", float("inf")))
1041 |             ds_combined = float(result.get("combined_score", 0.0))
1042 |             return ds_name, {{
1043 |                 "nmse_train": ds_train_nmse,
1044 |                 "nmse_val": ds_nmse,
1045 |                 "combined_score": ds_combined,
1046 |                 "complexity": float(result.get("complexity", 0.0)),
1047 |                 "equation": str(result.get("equation", "")),
1048 |                 "equation_template": str(result.get("equation_template", "")),
1049 |                 "constants": result.get("constants", {{}}),
1050 |             }}
1051 |         except Exception as exc:
1052 |             return ds_name, {{
1053 |                 "nmse_train": float("inf"),
1054 |                 "nmse_val": float("inf"),
1055 |                 "combined_score": 0.0,
1056 |                 "error": str(exc),
1057 |             }}
1058 | 
1059 |     per_dataset_results = {{}}
1060 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1061 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
1062 |         for future in as_completed(futures):
1063 |             ds_name, ds_result = future.result()
1064 |             per_dataset_results[ds_name] = ds_result
1065 | 
1066 |     aggregated = evaluator._aggregate_per_dataset_results(per_dataset_results)
1067 | 
1068 |     _write_payload_and_exit({{"result": aggregated}})
1069 | except Exception as exc:
1070 |     traceback.print_exc()
1071 |     _write_payload_and_exit({{"error": str(exc)}})
1072 | """
1073 |         temp_file.write(script.encode())
1074 |         temp_path = temp_file.name
1075 | 
1076 |     results_path = f"{temp_path}.results"
1077 |     try:
1078 |         process = subprocess.Popen(
1079 |             [sys.executable, temp_path],
1080 |             stdout=subprocess.PIPE,
1081 |             stderr=subprocess.PIPE,
1082 |         )
1083 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
1084 |         if stdout:
1085 |             print(stdout.decode())
1086 |         if stderr:
1087 |             print(stderr.decode())
1088 |         if process.returncode != 0:
1089 |             raise RuntimeError(f"Subprocess exited with code {process.returncode}")
1090 |         if not os.path.exists(results_path):
1091 |             raise RuntimeError("Results file not found")
1092 |         with open(results_path, "rb") as f:
1093 |             payload = pickle.load(f)
1094 |         if "error" in payload:
1095 |             raise RuntimeError(payload["error"])
1096 |         return payload["result"]
1097 |     except subprocess.TimeoutExpired:
1098 |         process.kill()
1099 |         process.wait()
1100 |         raise TimeoutError(f"Program execution timed out after {timeout_seconds}s")
1101 |     finally:
1102 |         for path in (temp_path, results_path):
1103 |             if os.path.exists(path):
1104 |                 os.unlink(path)
1105 | 
1106 | 
1107 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
1108 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
1109 |     nmse_val = float(result.get("nmse_val", float("inf")))
1110 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
1111 |     if not np.isfinite(combined):
1112 |         combined = 0.0
1113 | 
1114 |     return {
1115 |         "equation": str(result.get("equation", "")),
1116 |         "loss": nmse_val,
1117 |         "complexity": float(result.get("complexity", 0.0)),
1118 |         "nmse_train": float(result.get("nmse_train", float("inf"))),
1119 |         "nmse_val": nmse_val,
1120 |         "mean_nmse_val": float(result.get("mean_nmse_val", nmse_val)),
1121 |         "mean_raw_nmse_val": float(result.get("mean_raw_nmse_val", nmse_val)),
1122 |         "combined_score": combined,
1123 |         "fit_score": float(result.get("fit_score", combined)),
1124 |         "parsimony_weight": float(result.get("parsimony_weight", PARSIMONY_WEIGHT)),
1125 |         "parsimony_penalty_factor": float(result.get("parsimony_penalty_factor", 1.0)),
1126 |         "eval_time": float(eval_time),
1127 |         "n_datasets": result.get("n_datasets", 0),
1128 |         "n_successful": result.get("n_successful", 0),
1129 |         "eval_workers": result.get("eval_workers", NUM_WORKERS),
1130 |         "hard_cases": result.get("hard_cases", []),
1131 |         "hard_case_feedback": str(result.get("hard_case_feedback", "")),
1132 |         "hard_case_tail_nmse": float(result.get("hard_case_tail_nmse", 0.0)),
1133 |         "hard_case_tail_weight": float(result.get("hard_case_tail_weight", HARD_CASE_TAIL_WEIGHT)),
1134 |         "per_dataset_nmse_cap": float(result.get("per_dataset_nmse_cap", PER_DATASET_NMSE_CAP)),
1135 |         "per_dataset": result.get("per_dataset", {}),
1136 |         "error": str(result.get("error", "")),
1137 |     }
1138 | 
1139 | 
1140 | def evaluate(program_path: str) -> dict:
1141 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
1142 |     try:
1143 |         start = time.time()
1144 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=3000)
1145 |         metrics = _metrics_from_result(result, time.time() - start)
1146 |         print(
1147 |             "Evaluation: "
1148 |             f"nmse_val={metrics['nmse_val']:.6f}, "
1149 |             f"mean_nmse_val={metrics['mean_nmse_val']:.6f}, "
1150 |             f"mean_raw_nmse_val={metrics['mean_raw_nmse_val']:.6f}, "
1151 |             f"combined_score={metrics['combined_score']:.6f}, "
1152 |             f"n_datasets={metrics['n_datasets']}, "
1153 |             f"n_successful={metrics['n_successful']}, "
1154 |             f"time={metrics['eval_time']:.2f}s"
1155 |         )
1156 |         print(f"Equation template: {metrics['equation']}")
1157 |         if metrics.get("hard_case_feedback"):
1158 |             print(f"Hard-case feedback: {metrics['hard_case_feedback']}")
1159 |         if metrics.get("error"):
1160 |             print(f"Evaluator feedback: {metrics['error']}")
1161 |         return metrics
1162 |     except Exception as exc:
1163 |         print(f"Evaluation failed: {exc}")
1164 |         traceback.print_exc()
1165 |         return {
1166 |             "equation": "",
1167 |             "loss": float("inf"),
1168 |             "complexity": 0.0,
1169 |             "nmse_train": float("inf"),
1170 |             "nmse_val": float("inf"),
1171 |             "mean_nmse_val": float("inf"),
1172 |             "mean_raw_nmse_val": float("inf"),
1173 |             "combined_score": 0.0,
1174 |             "eval_time": 0.0,
1175 |             "n_datasets": 0,
1176 |             "n_successful": 0,
1177 |             "hard_cases": [],
1178 |             "hard_case_feedback": "",
1179 |             "hard_case_tail_nmse": 0.0,
1180 |             "hard_case_tail_weight": HARD_CASE_TAIL_WEIGHT,
1181 |             "per_dataset_nmse_cap": PER_DATASET_NMSE_CAP,
1182 |             "per_dataset": {},
1183 |             "error": str(exc),
1184 |         }
