import sympy as sp
x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2 = sp.symbols('c0 c1 c2')

def complexity(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

# The candidate: c0*(c1+x2)*(1+c2*x1)*(1-x2)
e = c0*(c1 + x2)*(1 + c2*x1)*(1 - x2)
print('c0*(c1+x2)*(1+c2*x1)*(1-x2):')
print('  complexity=', complexity(e))
print('  expanded:', sp.expand(e))
print()

# Compare spans:
# Current (c0+c1*x2)*(1+c2*x1)*(1-x2):
# Basis: {(1-x2), x1*(1-x2), x2*(1-x2), x1*x2*(1-x2)}
# Coefficients: {c0, c0*c2, c1, c1*c2}
# 3 free parameters -> 4 coefficients with constraint: coeff(x1*(1-x2))/coeff((1-x2)) = coeff(x1*x2*(1-x2))/coeff(x2*(1-x2))
# i.e. c2 = c2 (same ratio for both primary and secondary)

# New c0*(c1+x2)*(1+c2*x1)*(1-x2):
# Basis: {(1-x2), x1*(1-x2), x2*(1-x2), x1*x2*(1-x2)}
# Coefficients: {c0*c1, c0*c1*c2, c0, c0*c2}
# Same constraint: coeff(x1*(1-x2))/coeff((1-x2)) = coeff(x1*x2*(1-x2))/coeff(x2*(1-x2)) = c2
# SAME constraint! Both forms impose: x1 modulation ratio is same for primary and secondary
# So they span EXACTLY the same subspace!

# The difference is purely parameterization:
# Current: c0 = primary rate, c1 = secondary rate, c2 = x1 modulation
# New: c0 = secondary rate, c0*c1 = primary rate, c2 = x1 modulation
# New form: c1 = primary/secondary ratio (dimensionless)

# So if we map: c0_new = c1_old, c1_new = c0_old/c1_old, c2_new = c2_old
# The fit quality should be IDENTICAL given a good optimizer
# But the parameterization of new form may be better conditioned

# Parsimony gain: 16 -> 15
p_old = 1.0 - 0.2*(16/160)
p_new = 1.0 - 0.2*(15/160)
print(f'Parsimony old (c=16): {p_old:.4f}')
print(f'Parsimony new (c=15): {p_new:.4f}')
print(f'Score improvement if nmse same: {0.9616*p_new - 0.9616*p_old:.4f}')
print(f'New combined score if nmse=0.0399: {(1/(1+0.0399))*p_new:.4f}')
"
