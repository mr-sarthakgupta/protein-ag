 194 | def _assigned_names(target: ast.AST) -> set[str]:
 195 |     if isinstance(target, ast.Name):
 196 |         return {target.id}
 197 |     if isinstance(target, (ast.Tuple, ast.List)):
 198 |         names: set[str] = set()
 199 |         for elt in target.elts:
 200 |             names.update(_assigned_names(elt))
 201 |         return names
 202 |     return set()
