 166 |             "shadows a protected scorer or harness name."
 167 |         )
 168 |     if node.decorator_list:
 169 |         raise ValueError(
 170 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function decorators are not "
 171 |             "allowed because decorators execute during candidate import."
 172 |         )
 173 |     if node.args.defaults or node.args.kw_defaults:
 174 |         raise ValueError(
 175 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function default arguments "
 176 |             "are not allowed because defaults execute during candidate import."
 177 |         )
 178 |     if _function_annotations(node) and not postponed_annotations:
 179 |         raise ValueError(
 180 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level function annotations require "
 181 |             "'from __future__ import annotations' because annotations otherwise "
 182 |             "execute during candidate import."
 183 |         )
