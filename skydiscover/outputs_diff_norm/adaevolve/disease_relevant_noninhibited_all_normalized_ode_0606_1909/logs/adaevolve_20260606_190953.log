 664 | def _ode_predictions(
 665 |     rhs_fn: Any,
 666 |     X: np.ndarray,
 667 |     y_known: np.ndarray,
 668 |     theta: np.ndarray,
 669 | ) -> np.ndarray:
 670 |     """Integrate dc/dt=f(t, parameter, c) per parameter curve on one split."""
 671 |     import warnings
 672 | 
 673 |     from scipy.integrate import odeint
 674 | 
 675 |     X = np.asarray(X, dtype=float)
 676 |     y_known = np.asarray(y_known, dtype=float).reshape(-1)
 677 |     theta = np.asarray(theta, dtype=float).reshape(-1)
 678 |     predictions = np.full_like(y_known, np.nan, dtype=float)
 679 | 
 680 |     for parameter in np.unique(X[:, 1]):
 681 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 682 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 683 |         times = X[ordered_idx, 0]
 684 |         observed = y_known[ordered_idx]
 685 | 
 686 |         if len(ordered_idx) == 1 or float(times[-1] - times[0]) <= 0.0:
 687 |             predictions[ordered_idx] = observed[0]
 688 |             continue
 689 | 
 690 |         def dc_dt(c_state: np.ndarray, time_value: float) -> float:
 691 |             c_value = float(np.asarray(c_state, dtype=float).reshape(-1)[0])
 692 |             value = rhs_fn(float(time_value), float(parameter), c_value, *theta)
 693 |             value = float(np.asarray(value, dtype=float).reshape(-1)[0])
 694 |             if not np.isfinite(value):
 695 |                 raise FloatingPointError("non-finite ODE derivative")
 696 |             return value
 697 | 
 698 |         with warnings.catch_warnings():
 699 |             warnings.simplefilter("ignore")
 700 |             integrated = odeint(
 701 |                 dc_dt,
 702 |                 float(observed[0]),
 703 |                 times,
 704 |                 mxstep=1000,
 705 |             )
 706 |         curve_pred = np.asarray(integrated, dtype=float).reshape(-1)
 707 |         if curve_pred.shape != observed.shape or not np.all(np.isfinite(curve_pred)):
 708 |             raise FloatingPointError("non-finite ODE trajectory")
 709 |         predictions[ordered_idx] = curve_pred
 710 | 
 711 |     return predictions
