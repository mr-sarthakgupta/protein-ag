 147 | def _function_annotations(node: ast.FunctionDef) -> list[ast.AST]:
 148 |     annotations: list[ast.AST] = []
 149 |     args = node.args
 150 |     for arg in [*args.posonlyargs, *args.args, *args.kwonlyargs]:
 151 |         if arg.annotation is not None:
 152 |             annotations.append(arg.annotation)
 153 |     if args.vararg is not None and args.vararg.annotation is not None:
 154 |         annotations.append(args.vararg.annotation)
 155 |     if args.kwarg is not None and args.kwarg.annotation is not None:
 156 |         annotations.append(args.kwarg.annotation)
 157 |     if node.returns is not None:
 158 |         annotations.append(node.returns)
 159 |     return annotations
