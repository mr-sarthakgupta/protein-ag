 966 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 967 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 968 | 
 969 |     The subprocess loads every dataset, calls the candidate's
 970 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 971 |     constants each time) using parallel threads, and returns aggregated
 972 |     metrics.
 973 |     """
 974 |     validate_candidate_source(program_path)
 975 |     harness_root = str(BENCHMARK_ROOT)
 976 |     evaluator_path = str(Path(__file__).resolve())
 977 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
 978 |         script = f"""
 979 | import importlib.util
 980 | import os
 981 | import pickle
 982 | import sys
 983 | import traceback
 984 | from concurrent.futures import ThreadPoolExecutor, as_completed
 985 | 
 986 | os.environ.setdefault("OMP_NUM_THREADS", "1")
 987 | os.environ.setdefault("MKL_NUM_THREADS", "1")
 988 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
 989 | 
 990 | import numpy as np
 991 | 
 992 | sys.path.insert(0, {harness_root!r})
 993 | 
 994 | program_path = {program_path!r}
 995 | evaluator_path = {evaluator_path!r}
 996 | results_path = {temp_file.name + ".results"!r}
 997 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 998 | 
 999 | def _write_payload_and_exit(payload):
1000 |     with open(results_path, "wb") as f:
1001 |         pickle.dump(payload, f)
1002 |     sys.stdout.flush()
1003 |     sys.stderr.flush()
