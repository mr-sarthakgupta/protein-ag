       for param in np.unique(X[:,1]):\\n            idx = np.flatnonzero(X[:,1]==param)\\n            ord_idx = idx[np.argsort(X[idx,0])]\\n            ts = X[ord_idx, 0]; y0 = y[ord_idx[0]]\\n            try:\\n                sol = odeint(rhs_fn, y0, ts, args=(param,)+tuple(theta)).ravel()\\n                if np.all(np.isfinite(sol)): preds[ord_idx] = sol\\n                else: return np.full(len(y), 1e6)\\n            except: return np.full(len(y), 1e6)\\n        return preds - y\\n    best = None; best_loss = np.inf\\n    for init in inits:\\n        try:\\n            fit = least_squares(residual, init, loss='soft_l1', max_nfev=400)\\n            loss = np.mean(fit.fun**2)\\n            if loss < best_loss: best_loss = loss; best = fit\\n        except: pass\\n    if best is None: return np.inf\\n    var = np.var(y)\\n    return best_loss / var if var > 0 else best_loss\\n\\n# Current: (c0 + c1*x2)*(1+c2*x1)*(1-x2)\\ndef rhs_current(x2, t, p, c0, c1, c2):\\n    return (c0 + c1*x2) * (1 + c2*p) * (1 - x2)\\n\\n# Cross-term: (c0 + c1*x2 + c3*p*x2)*(1+c2*p)*(1-x2)\\n# = (c0 + (c1 + c3*p)*x2)*(1+c2*p)*(1-x2)\\n# This adds a p-dependent autocatalytic modulation\\ndef rhs_cross(x2, t, p, c0, c1, c2, c3):\\n    return (c0 + c1*x2 + c3*p*x2) * (1 + c2*p) * (1 - x2)\\n\\n# Simpler cross: (c0 + c1*x2)*(1 + c2*x1 + c3*x1*x2)*(1-x2)\\n# x1 modulates both primary and secondary differently\\ndef rhs_cross2(x2, t, p, c0, c1, c2, c3):\\n    return (c0 + c1*x2) * (1 + c2*p + c3*p*x2) * (1 - x2)\\n\\ndatasets = []\\nfor dirpath, _, filenames in os.walk(path):\\n    if 'fit.tsv' in filenames:\\n        rel = os.path.relpath(dirpath, path)\\n        datasets.append((rel, os.path.join(dirpath, 'fit.tsv')))\\ndatasets.sort()\\n\\ninits_curr = [[0.1,10.,2.],[0.01,30.,0.],[0.3,5.,1.]]\\ninits_cross = [[0.1,10.,2.,1.],[0.01,30.,0.,5.],[0.1,5.,1.,2.]]\\n\\nnmse_curr, nmse_cross, nmse_cross2 = [], [], []\\nfor name, fpath in datasets:\\n    nc = fit_ode(fpath, rhs_current, inits_curr)\\n    nx = fit_ode(fpath, rhs_cross, inits_cross)\\n    nx2 = fit_ode(fpath, rhs_cross2, inits_cross)\\n    nmse_curr.append(nc); nmse_cross.append(nx); nmse_cross2.append(nx2)\\n\\nprint(f'Mean NMSE - current(3c,c16): {np.mean(nmse_curr):.5f}')\\nprint(f'Mean NMSE - cross(4c):       {np.mean(nmse_cross):.5f}')\\nprint(f'Mean NMSE - cross2(4c):      {np.mean(nmse_cross2):.5f}')\\n\\n# Parsimony: current c=16, cross ~c=20, cross2 ~c=21\\n# combined_score = (1/(1+nmse)) * parsimony_factor\\n# parsimony_factor = 1 - 0.2*(c/160)\\ndef score(nmse, c):\\n    return (1/(1+nmse)) * (1 - 0.2*min(c/160, 1))\\nprint()\\nprint(f'Est combined_score - current(c=16): {score(np.mean(nmse_curr), 16):.5f}')\\nprint(f'Est combined_score - cross(c=20):   {score(np.mean(nmse_cross), 20):.5f}')\\nprint(f'Est combined_score - cross2(c=21):  {score(np.mean(nmse_cross2), 21):.5f}')\\n\\\" 2>/dev/null\\n\"}"
