 111 | def _is_module_docstring(node: ast.AST) -> bool:
 112 |     return (
 113 |         isinstance(node, ast.Expr)
 114 |         and isinstance(node.value, ast.Constant)
 115 |         and isinstance(node.value.value, str)
 116 |     )
