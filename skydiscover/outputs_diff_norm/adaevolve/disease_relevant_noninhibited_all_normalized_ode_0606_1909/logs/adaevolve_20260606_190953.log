import sympy as sp
x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2, c3 = sp.symbols('c0 c1 c2 c3')

def complexity(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

# Reparameterized: c0*(c1 + x2)*(1+c2*x1)*(1-x2)
# = c0*c1*(1+c2*x1)*(1-x2) + c0*x2*(1+c2*x1)*(1-x2)
# Same span as current but c1 = c0_old/c1_old ratio
e1 = c0*(c1 + x2)*(1 + c2*x1)*(1 - x2)
print('c0*(c1+x2)*(1+c2*x1)*(1-x2) complexity=', complexity(e1))
print('  Expands to:', sp.expand(e1))

# Current
e_curr = (c0 + c1*x2)*(1 + c2*x1)*(1 - x2)
print('Current complexity=', complexity(e_curr))

# Are they the same span?
# Current: span{(1-x2), x1*(1-x2), x2*(1-x2), x1*x2*(1-x2)}
# New: c0*c1*(1-x2) + c0*c1*c2*x1*(1-x2) + c0*x2*(1-x2) + c0*c2*x1*x2*(1-x2)
# Both have the same 4 basis functions - just different parameterization
# But new has c0*c1 as coefficient of (1-x2) and c0 as coefficient of x2*(1-x2)
# This forces the ratio: primary/secondary = c1 (a single constant)
# This is LESS flexible: current has independent c0, c1 for primary/secondary

# What about the Finke-Watzky 2-step model?
# dc/dt = c0*(1-x2) + c1*x2*(1-x2)  -- no x1 modulation
e_fw = c0*(1-x2) + c1*x2*(1-x2)
print('FW 2-step (no x1): complexity=', complexity(e_fw))

# FW with x1: (c0 + c1*x1)*(1-x2) + c2*x2*(1-x2)
e_fw2 = (c0 + c1*x1)*(1-x2) + c2*x2*(1-x2)
print('FW with x1 on primary: complexity=', complexity(e_fw2))
print('  Expands to:', sp.expand(e_fw2))

# Current vs FW with x1 on primary:
# Current has: c0*(1-x2) + c0*c2*x1*(1-x2) + c1*x2*(1-x2) + c1*c2*x1*x2*(1-x2)
# FW2 has: c0*(1-x2) + c1*x1*(1-x2) + c2*x2*(1-x2)
# FW2 lacks x1*x2*(1-x2) cross term but has INDEPENDENT c0, c1 for primary nucleation
# This is actually a DIFFERENT functional form - might fit better on some datasets

# What about using x0 (time) for the lag?
# The lag phase in amyloid is due to nucleation being slow initially
# Adding time directly: c0*x0*(1-x2) would give increasing rate with time
# This is NOT physical (rate should depend on state, not absolute time)
# But in normalized form, x0 is normalized time [0,1]

# The real question: what causes the hard_case_tail_nmse = 0.3525?
# Hard cases likely have unusual shapes - maybe seeded or very fast aggregation
print()
print('Analysis: hard cases likely need different nucleation structure')
print('Try: (c0 + c1*x1)*(1-x2) + c2*x2*(1-x2) -- independent primary/secondary x1 modulation')
print('  This has x1 on primary nucleation only (physically: concentration affects nucleation rate)')
print('  vs current: x1 modulates both primary AND secondary (cross-term)')
"
