1047 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
1048 |     """Evaluate a candidate program across ALL datasets in a subprocess.
1049 | 
1050 |     The subprocess loads every dataset, calls the candidate's
1051 |     evaluate_symbolic_candidate() once per dataset (fitting independent
1052 |     constants each time) using parallel threads, and returns aggregated
1053 |     metrics.
1054 |     """
1055 |     validate_candidate_source(program_path)
1056 |     harness_root = str(BENCHMARK_ROOT)
1057 |     evaluator_path = str(Path(__file__).resolve())
1058 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
1059 |         script = f"""
1060 | import importlib.util
1061 | import os
1062 | import pickle
1063 | import sys
1064 | import traceback
1065 | from concurrent.futures import ThreadPoolExecutor, as_completed
1066 | 
1067 | os.environ.setdefault("OMP_NUM_THREADS", "1")
1068 | os.environ.setdefault("MKL_NUM_THREADS", "1")
1069 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
1070 | 
1071 | import numpy as np
1072 | 
1073 | sys.path.insert(0, {harness_root!r})
1074 | 
1075 | program_path = {program_path!r}
1076 | evaluator_path = {evaluator_path!r}
1077 | results_path = {temp_file.name + ".results"!r}
1078 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
1079 | 
1080 | def _write_payload_and_exit(payload):
1081 |     with open(results_path, "wb") as f:
1082 |         pickle.dump(payload, f)
1083 |     sys.stdout.flush()
1084 |     sys.stderr.flush()
1085 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
1086 |     # interpreter shutdown. The parent only needs the pickle payload.
1087 |     os._exit(0)
1088 | 
1089 | try:
1090 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
1091 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
1092 |     evaluator_spec.loader.exec_module(evaluator)
1093 |     evaluator.validate_candidate_source(program_path)
1094 | 
1095 |     import pysr_harness.equation_session as equation_session
1096 |     equation_session.evaluate_expression = evaluator.evaluate_ode_expression
1097 |     equation_session.nmse = evaluator._nmse_with_gaussian_smoothed_target
1098 |     spec = importlib.util.spec_from_file_location("program", program_path)
1099 |     program = importlib.util.module_from_spec(spec)
1100 |     spec.loader.exec_module(program)
1101 |     from pysr_harness.equation_session import (
1102 |         single_equation_evaluation,
1103 |         validate_single_equation_result,
1104 |     )
1105 | 
1106 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1107 |         program, "run_discovery", None
1108 |     )
1109 |     if fn is None:
1110 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
1111 | 
1112 |     datasets = evaluator.load_all_datasets()
1113 | 
1114 |     def _eval_one(args):
1115 |         ds_name, X_train, X_val, y_train, y_val = args
1116 |         try:
1117 |             with single_equation_evaluation():
1118 |                 result = fn(X_train, y_train, X_val, y_val)
1119 |                 validate_single_equation_result(result)
1120 |             ds_nmse = float(result.get("nmse_val", float("inf")))
1121 |             ds_train_nmse = float(result.get("nmse_train", float("inf")))
1122 |             ds_combined = float(result.get("combined_score", 0.0))
1123 |             return ds_name, {{
1124 |                 "nmse_train": ds_train_nmse,
1125 |                 "nmse_val": ds_nmse,
1126 |                 "n_val_points": int(result.get("n_val_points", 0)),
1127 |                 "combined_score": ds_combined,
1128 |                 "complexity": float(result.get("complexity", 0.0)),
1129 |                 "equation": str(result.get("equation", "")),
1130 |                 "equation_template": str(result.get("equation_template", "")),
1131 |                 "constants": result.get("constants", {{}}),
1132 |             }}
1133 |         except Exception as exc:
1134 |             return ds_name, {{
1135 |                 "nmse_train": float("inf"),
1136 |                 "nmse_val": float("inf"),
1137 |                 "combined_score": 0.0,
1138 |                 "error": str(exc),
1139 |             }}
1140 | 
1141 |     per_dataset_results = {{}}
1142 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1143 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
1144 |         for future in as_completed(futures):
1145 |             ds_name, ds_result = future.result()
1146 |             per_dataset_results[ds_name] = ds_result
1147 | 
1148 |     aggregated = evaluator._aggregate_per_dataset_results(per_dataset_results)
1149 | 
1150 |     _write_payload_and_exit({{"result": aggregated}})
1151 | except Exception as exc:
1152 |     traceback.print_exc()
1153 |     _write_payload_and_exit({{"error": str(exc)}})
1154 | """
1155 |         temp_file.write(script.encode())
1156 |         temp_path = temp_file.name
1157 | 
1158 |     results_path = f"{temp_path}.results"
1159 |     try:
1160 |         process = subprocess.Popen(
1161 |             [sys.executable, temp_path],
1162 |             stdout=subprocess.PIPE,
1163 |             stderr=subprocess.PIPE,
1164 |         )
1165 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
1166 |         if stdout:
1167 |             print(stdout.decode())
1168 |         if stderr:
1169 |             print(stderr.decode())
1170 |         if process.returncode != 0:
1171 |             raise RuntimeError(f"Subprocess exited with code {process.returncode}")
1172 |         if not os.path.exists(results_path):
1173 |             raise RuntimeError("Results file not found")
1174 |         with open(results_path, "rb") as f:
1175 |             payload = pickle.load(f)
1176 |         if "error" in payload:
1177 |             raise RuntimeError(payload["error"])
1178 |         return payload["result"]
1179 |     except subprocess.TimeoutExpired:
1180 |         process.kill()
1181 |         process.wait()
1182 |         raise TimeoutError(f"Program execution timed out after {timeout_seconds}s")
1183 |     finally:
1184 |         for path in (temp_path, results_path):
1185 |             if os.path.exists(path):
1186 |                 os.unlink(path)
1187 | 
1188 | 
1189 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
1190 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
1191 |     nmse_val = float(result.get("nmse_val", float("inf")))
1192 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
1193 |     if not np.isfinite(combined):
1194 |         combined = 0.0
1195 | 
1196 |     return {
1197 |         "equation": str(result.get("equation", "")),
1198 |         "loss": nmse_val,
1199 |         "complexity": float(result.get("complexity", 0.0)),
1200 |         "nmse_train": float(result.get("nmse_train", float("inf"))),
1201 |         "nmse_val": nmse_val,
1202 |         "mean_nmse_val": float(result.get("mean_nmse_val", nmse_val)),
1203 |         "mean_raw_nmse_val": float(result.get("mean_raw_nmse_val", nmse_val)),
1204 |         "combined_score": combined,
1205 |         "fit_score": float(result.get("fit_score", combined)),
1206 |         "parsimony_weight": float(result.get("parsimony_weight", PARSIMONY_WEIGHT)),
1207 |         "parsimony_penalty_factor": float(result.get("parsimony_penalty_factor", 1.0)),
1208 |         "eval_time": float(eval_time),
1209 |         "n_datasets": result.get("n_datasets", 0),
1210 |         "n_successful": result.get("n_successful", 0),
1211 |         "eval_workers": result.get("eval_workers", NUM_WORKERS),
1212 |         "hard_cases": result.get("hard_cases", []),
1213 |         "hard_case_feedback": str(result.get("hard_case_feedback", "")),
1214 |         "hard_case_tail_nmse": float(result.get("hard_case_tail_nmse", 0.0)),
1215 |         "hard_case_tail_weight": float(result.get("hard_case_tail_weight", HARD_CASE_TAIL_WEIGHT)),
1216 |         "per_dataset_nmse_cap": float(result.get("per_dataset_nmse_cap", PER_DATASET_NMSE_CAP)),
1217 |         "per_dataset": result.get("per_dataset", {}),
1218 |         "error": str(result.get("error", "")),
1219 |     }
1220 | 
1221 | 
1222 | def evaluate(program_path: str) -> dict:
1223 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
1224 |     try:
1225 |         start = time.time()
1226 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=3000)
1227 |         metrics = _metrics_from_result(result, time.time() - start)
1228 |         print(
1229 |             "Evaluation: "
1230 |             f"nmse_val={metrics['nmse_val']:.6f}, "
1231 |             f"mean_nmse_val={metrics['mean_nmse_val']:.6f}, "
1232 |             f"mean_raw_nmse_val={metrics['mean_raw_nmse_val']:.6f}, "
1233 |             f"combined_score={metrics['combined_score']:.6f}, "
1234 |             f"n_datasets={metrics['n_datasets']}, "
1235 |             f"n_successful={metrics['n_successful']}, "
1236 |             f"time={metrics['eval_time']:.2f}s"
1237 |         )
1238 |         print(f"Equation template: {metrics['equation']}")
1239 |         if metrics.get("hard_case_feedback"):
1240 |             print(f"Hard-case feedback: {metrics['hard_case_feedback']}")
1241 |         if metrics.get("error"):
1242 |             print(f"Evaluator feedback: {metrics['error']}")
1243 |         return metrics
1244 |     except Exception as exc:
1245 |         print(f"Evaluation failed: {exc}")
1246 |         traceback.print_exc()
1247 |         return {
1248 |             "equation": "",
1249 |             "loss": float("inf"),
1250 |             "complexity": 0.0,
1251 |             "nmse_train": float("inf"),
1252 |             "nmse_val": float("inf"),
1253 |             "mean_nmse_val": float("inf"),
1254 |             "mean_raw_nmse_val": float("inf"),
1255 |             "combined_score": 0.0,
1256 |             "eval_time": 0.0,
1257 |             "n_datasets": 0,
1258 |             "n_successful": 0,
1259 |             "hard_cases": [],
1260 |             "hard_case_feedback": "",
1261 |             "hard_case_tail_nmse": 0.0,
1262 |             "hard_case_tail_weight": HARD_CASE_TAIL_WEIGHT,
1263 |             "per_dataset_nmse_cap": PER_DATASET_NMSE_CAP,
1264 |             "per_dataset": {},
1265 |             "error": str(exc),
1266 |         }
