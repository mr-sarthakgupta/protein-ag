1269 | def _eval_stage1_worker(args):
1270 |     """Module-level worker for stage 1 parallel evaluation."""
1271 |     name, X_train, X_val, y_train, y_val, program_path = args
1272 |     harness_root = str(BENCHMARK_ROOT)
1273 |     if harness_root not in sys.path:
1274 |         sys.path.insert(0, harness_root)
1275 |     validate_candidate_source(program_path)
1276 |     import pysr_harness.equation_session as equation_session
1277 |     equation_session.evaluate_expression = evaluate_ode_expression
1278 |     equation_session.nmse = _nmse_with_gaussian_smoothed_target
1279 |     spec = importlib.util.spec_from_file_location("program", program_path)
