 453 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 454 |     """Load a wide fit.tsv and return X=[normalized time, raw parameter, c], y.
 455 | 
 456 |     The first column is always the time/measurement coordinate. Remaining
 457 |     columns are response curves. The varying parameter is extracted from
 458 |     concentration-like curve headers only; non-concentration columns are skipped.
 459 |     Time is min-max normalized to 0..1, but the parameter column is left in its
 460 |     parsed raw units. The response is normalized globally across the whole
 461 |     fit.tsv to 0..1. Files already rescaled to 0..1 keep that scale.
 462 |     """
 463 |     with data_file.open(newline="") as f:
 464 |         reader = csv.reader(f, delimiter="\t")
 465 |         header = next(reader)
 466 | 
 467 |         response_headers = header[1:]
 468 |         parsed_params = [_parse_parameter_from_column(h) for h in response_headers]
 469 | 
 470 |         features: list[list[float]] = []
 471 |         targets: list[float] = []
 472 |         for row in reader:
 473 |             if not row:
 474 |                 continue
 475 |             measurement_x = float(row[0])
 476 |             for param, value in zip(parsed_params, row[1:]):
 477 |                 if param is None:
 478 |                     continue
 479 |                 if value == "" or value.strip().lower() == "nan":
 480 |                     continue
 481 |                 features.append([measurement_x, param])
 482 |                 targets.append(float(value))
 483 | 
 484 |     if not features:
 485 |         raise ValueError(f"No regression samples loaded from {data_file}")
 486 | 
 487 |     X = np.asarray(features, dtype=float)
 488 |     y = np.asarray(targets, dtype=float)
 489 |     time_norm = _minmax_normalize(X[:, 0])
 490 |     parameter_raw = X[:, 1]
 491 |     y_norm = _minmax_normalize(y)
 492 | 
 493 |     # x2 is the concentration state c used by ODE RHS templates. During scoring
 494 |     # it is supplied from odeint's dynamic state, not read from candidate code.
 495 |     X_ode = np.column_stack([time_norm, parameter_raw, y_norm])
 496 |     return X_ode, y_norm
 497 | 
