import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols

datasets = load_all_datasets()
for name, X_train, X_val, y_train, y_val in datasets:
    if 'seeded' in name:
        print(f'Dataset: {name}')
        # Check how _ode_predictions handles this
        # It groups by unique x1, sorts by time, uses observed[0] as init
        params = np.unique(X_train[:,1])
        for p in params:
            curve_idx = np.flatnonzero(X_train[:,1] == p)
            ordered_idx = curve_idx[np.argsort(X_train[curve_idx, 0])]
            times = X_train[ordered_idx, 0]
            observed = y_train[ordered_idx]
