import sympy as sp

def complexity(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2, c3, c4 = sp.symbols('c0 c1 c2 c3 c4')

# All must have seed (nonzero at x2=0) and complexity <= 13
# Current: c0*x1^c1*(x2+c2)*(c3-x2) -- comp=13
curr = c0 * x1**c1 * (x2+c2) * (c3-x2)
print(f'Current: comp={complexity(curr)}')

# Variant: x1-scaled seed -- c0*(x1^c1*x2 + c2)*(1-x2)
# This makes nucleation rate c2 independent of x1, elongation scales as x1^c1
v1 = c0 * (x1**c1 * x2 + c2) * (1 - x2)
print(f'c0*(x1^c1*x2+c2)*(1-x2): comp={complexity(v1)}  {v1}')

# Variant: c0*(x1^c1*x2 + c2)*(c3-x2) -- float plateau version
v2 = c0 * (x1**c1 * x2 + c2) * (c3 - x2)
print(f'c0*(x1^c1*x2+c2)*(c3-x2): comp={complexity(v2)}  {v2}')

# Variant: c0*x1*(x2+c1)*(c2-x2) -- linear x1, float plateau (3c)
v3 = c0 * x1 * (x2+c1) * (c2-x2)
print(f'c0*x1*(x2+c1)*(c2-x2): comp={complexity(v3)}  {v3}')

# Variant: c0*x1*(x2+c1)*(1-x2) -- linear x1, fixed plateau (3c)  
v4 = c0 * x1 * (x2+c1) * (1-x2)
print(f'c0*x1*(x2+c1)*(1-x2): comp={complexity(v4)}  {v4}')

# Variant: c0*(x1+c1)^c2*(x2+c3)*(1-x2) -- shifted x1 power, 4c
v5 = c0 * (x1+c1)**c2 * (x2+c3) * (1-x2)
print(f'c0*(x1+c1)^c2*(x2+c3)*(1-x2): comp={complexity(v5)}  {v5}')

# Score projections
print()
for label, comp, nmse in [
    ('Current (4c, c=13)', 13, 0.0140),
    ('v1 (3c, c=14)', complexity(v1), 0.0135),
    ('v2 (4c, c=15)', complexity(v2), 0.0130),
    ('v3 linear x1 (3c)', complexity(v3), 0.0130),
    ('v4 linear x1 (3c)', complexity(v4), 0.0130),
    ('v4 linear x1 same nmse', complexity(v4), 0.0140),
    ('v4 linear x1 worse', complexity(v4), 0.0160),
]:
    parsimony = 1 - 0.2*(comp/160)
    fit = 1/(1+nmse)
    score = fit * parsimony
    print(f'  {label}: comp={comp}, nmse={nmse:.4f} -> score={score:.4f} (delta={score-0.9702:+.4f})')
"
