 148 | def _function_annotations(node: ast.FunctionDef) -> list[ast.AST]:
 149 |     annotations: list[ast.AST] = []
 150 |     args = node.args
 151 |     for arg in [*args.posonlyargs, *args.args, *args.kwonlyargs]:
 152 |         if arg.annotation is not None:
 153 |             annotations.append(arg.annotation)
 154 |     if args.vararg is not None and args.vararg.annotation is not None:
 155 |         annotations.append(args.vararg.annotation)
 156 |     if args.kwarg is not None and args.kwarg.annotation is not None:
 157 |         annotations.append(args.kwarg.annotation)
 158 |     if node.returns is not None:
 159 |         annotations.append(node.returns)
