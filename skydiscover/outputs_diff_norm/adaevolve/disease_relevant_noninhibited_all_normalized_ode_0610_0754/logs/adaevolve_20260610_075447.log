import sympy as sp

def complexity(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2, c3 = sp.symbols('c0 c1 c2 c3')

# Finke-Watzky: nucleation + autocatalytic growth
# dc/dt = c0 + c1*x2  (simplest, no x1 dependence)
fw_simple = c0 + c1*x2
# dc/dt = c0*x1^c1 + c2*x2  (nucleation scales with conc, growth linear)
fw1 = c0*x1**c1 + c2*x2
# dc/dt = c0*x1^c1 + c2*x1^c1*x2 = c0*x1^c1*(1 + c2*x2)
fw2 = c0*x1**c1*(1 + c2*x2)
# dc/dt = c0*x1^c1*(c2 + x2)  -- same structure as Program1 without plateau!
fw3 = c0*x1**c1*(c2 + x2)
# Finke-Watzky with saturation: dc/dt = (c0 + c1*x2)*(1-x2)
fw4 = (c0 + c1*x2)*(1-x2)
# FW with x1: dc/dt = (c0*x1^c1 + c2*x2)*(1-x2)
fw5 = (c0*x1**c1 + c2*x2)*(1-x2)
# FW with x1 and float plateau: dc/dt = (c0*x1^c1 + c2*x2)*(c3-x2)
fw6 = (c0*x1**c1 + c2*x2)*(c3-x2)
# FW: dc/dt = c0*x1^c1*(1 + c2*x2)*(1-x2)
fw7 = c0*x1**c1*(1 + c2*x2)*(1-x2)

for name, expr in [
    ('FW simple', fw_simple),
    ('FW1: c0*x1^c1 + c2*x2', fw1),
    ('FW2: c0*x1^c1*(1+c2*x2)', fw2),
    ('FW3: c0*x1^c1*(c2+x2)', fw3),
    ('FW4: (c0+c1*x2)*(1-x2)', fw4),
    ('FW5: (c0*x1^c1+c2*x2)*(1-x2)', fw5),
    ('FW6: (c0*x1^c1+c2*x2)*(c3-x2)', fw6),
    ('FW7: c0*x1^c1*(1+c2*x2)*(1-x2)', fw7),
]:
    comp = complexity(expr)
    parsimony = 1 - 0.2*(comp/160)
    score_same = (1/(1+0.0140)) * parsimony
    score_better = (1/(1+0.0120)) * parsimony
    score_worse = (1/(1+0.0160)) * parsimony
    print(f'  comp={comp:2d}  {name}')
    print(f'    same={score_same:.4f}  better={score_better:.4f}  worse={score_worse:.4f}')
"
