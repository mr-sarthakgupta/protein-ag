 442 | def _minmax_normalize(values: np.ndarray) -> np.ndarray:
 443 |     """Normalize one dataset column to 0..1, preserving constants as zeros."""
 444 |     values = np.asarray(values, dtype=float)
 445 |     v_min = float(np.min(values))
 446 |     v_max = float(np.max(values))
 447 |     scale = v_max - v_min
 448 |     if scale <= 0.0:
 449 |         return np.zeros_like(values, dtype=float)
