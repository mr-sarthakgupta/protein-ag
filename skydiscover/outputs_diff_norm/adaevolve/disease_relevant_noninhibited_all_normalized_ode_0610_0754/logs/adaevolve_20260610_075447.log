1303 | def evaluate_stage1(program_path: str) -> dict:
1304 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
1305 |     try:
1306 |         harness_root = str(BENCHMARK_ROOT)
1307 |         if harness_root not in sys.path:
1308 |             sys.path.insert(0, harness_root)
1309 | 
1310 |         all_datasets = load_all_datasets()
1311 |         rng = np.random.default_rng(RANDOM_STATE)
1312 |         if len(all_datasets) > 8:
1313 |             indices = rng.choice(len(all_datasets), size=8, replace=False)
1314 |             subset = [all_datasets[i] for i in sorted(indices)]
1315 |         else:
1316 |             subset = all_datasets
1317 | 
1318 |         work_items = [
1319 |             (name, X_train, X_val, y_train, y_val, program_path)
1320 |             for name, X_train, X_val, y_train, y_val in subset
1321 |         ]
1322 | 
1323 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1324 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
1325 |             worker_results = [future.result() for future in concurrent.futures.as_completed(futures)]
1326 | 
1327 |         combined_scores = [score for score, _error, _template in worker_results]
1328 |         successful_scores = [score for score in combined_scores if score > 0]
1329 |         errors = sorted({error for _score, error, _template in worker_results if error})
1330 |         violation_errors = sorted(
1331 |             {
1332 |                 error
1333 |                 for _score, error, _template in worker_results
1334 |                 if error and SINGLE_EQUATION_ERROR_PREFIX in error
1335 |             }
1336 |         )
1337 |         if violation_errors:
1338 |             return {
1339 |                 "combined_score": 0.0,
1340 |                 "n_stage1_datasets": len(subset),
1341 |                 "n_stage1_successful": len(successful_scores),
1342 |                 "eval_workers": NUM_WORKERS,
1343 |                 "error": violation_errors[0],
1344 |             }
1345 |         if errors:
1346 |             return {
1347 |                 "combined_score": 0.0,
1348 |                 "n_stage1_datasets": len(subset),
1349 |                 "n_stage1_successful": len(successful_scores),
1350 |                 "eval_workers": NUM_WORKERS,
1351 |                 "error": (
1352 |                     "Single-equation violation: stage 1 candidate failed on "
1353 |                     f"{len(errors)} dataset evaluations. Example: {errors[0]}"
1354 |                 ),
1355 |             }
1356 |         templates = sorted(
1357 |             {
1358 |                 template
1359 |                 for score, _error, template in worker_results
1360 |                 if score > 0 and template
1361 |             }
1362 |         )
1363 |         if len(templates) > 1:
1364 |             examples = "; ".join(templates[:3])
1365 |             return {
1366 |                 "combined_score": 0.0,
1367 |                 "n_stage1_datasets": len(subset),
1368 |                 "n_stage1_successful": len(successful_scores),
1369 |                 "eval_workers": NUM_WORKERS,
1370 |                 "error": (
1371 |                     "Single-equation violation: stage 1 produced "
1372 |                     f"{len(templates)} distinct equation templates across datasets. "
1373 |                     "The base equation must be identical for all datasets. "
1374 |                     f"Example templates: {examples}"
1375 |                 ),
1376 |             }
1377 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
1378 |         return {
1379 |             "combined_score": agg_combined,
1380 |             "n_stage1_datasets": len(subset),
1381 |             "n_stage1_successful": len(successful_scores),
1382 |             "eval_workers": NUM_WORKERS,
1383 |             "stage1_full_selected_datasets": 1.0,
1384 |         }
1385 |     except Exception as exc:
1386 |         print(f"Stage 1 evaluation failed: {exc}")
1387 |         return {"combined_score": 0.0, "error": str(exc)}
