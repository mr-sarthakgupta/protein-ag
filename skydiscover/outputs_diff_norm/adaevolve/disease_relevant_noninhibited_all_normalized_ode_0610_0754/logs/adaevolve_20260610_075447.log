 842 | 
 843 |     initial_candidates: list[np.ndarray] = []
 844 |     for scale in ODE_MULTISTART_SCALES or (1.0,):
 845 |         candidate = base_x0 * float(scale)
 846 |         if not any(np.array_equal(candidate, existing) for existing in initial_candidates):
 847 |             initial_candidates.append(candidate)
 848 | 
 849 |     import warnings
 850 | 
 851 |     best_fit = None
 852 |     best_loss = float("inf")
 853 |     with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 854 |         warnings.simplefilter("ignore", RuntimeWarning)
 855 |         for initial_candidate in initial_candidates:
 856 |             fit = least_squares(
 857 |                 residual,
 858 |                 initial_candidate,
 859 |                 loss="soft_l1",
 860 |                 max_nfev=max_nfev,
 861 |             )
