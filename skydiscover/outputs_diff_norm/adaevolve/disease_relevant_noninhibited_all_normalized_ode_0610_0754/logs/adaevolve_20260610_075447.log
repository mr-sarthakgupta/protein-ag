 899 | def _point_weighted_mean(
 900 |     values: list[float],
 901 |     weights: list[int],
 902 | ) -> float:
 903 |     """Average values with one weight per evaluation point."""
 904 |     total_weight = sum(weights)
 905 |     if total_weight <= 0:
 906 |         return float("inf")
 907 |     weighted = sum(
 908 |         float(value) * float(weight)
 909 |         for value, weight in zip(values, weights)
 910 |         if np.isfinite(float(value))
 911 |     )
 912 |     if not np.isfinite(weighted):
 913 |         return float("inf")
 914 |     return float(weighted / total_weight)
 915 | 
 916 | 
 917 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 918 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 919 |     raw_nmse_vals = [float(r["nmse_val"]) for r in per_dataset_results.values()]
 920 |     nmse_vals = [min(value, PER_DATASET_NMSE_CAP) for value in raw_nmse_vals]
 921 |     train_nmse_vals = [
 922 |         float(r["nmse_train"])
 923 |         for r in per_dataset_results.values()
 924 |         if np.isfinite(float(r.get("nmse_train", float("inf"))))
 925 |     ]
 926 |     complexity_vals = []
 927 |     for r in per_dataset_results.values():
 928 |         try:
 929 |             value = float(r.get("complexity", float("nan")))
 930 |         except (TypeError, ValueError):
 931 |             continue
 932 |         if np.isfinite(value):
 933 |             complexity_vals.append(value)
 934 |     aggregate_complexity = float(max(complexity_vals)) if complexity_vals else 0.0
 935 | 
 936 |     violation_errors = sorted(
 937 |         {
 938 |             str(r.get("error"))
 939 |             for r in per_dataset_results.values()
 940 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 941 |         }
 942 |     )
 943 |     failed_datasets = sorted(
 944 |         name
 945 |         for name, result in per_dataset_results.items()
 946 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 947 |     )
 948 |     templates = sorted(
 949 |         {
 950 |             str(r.get("equation_template"))
 951 |             for r in per_dataset_results.values()
 952 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 953 |         }
 954 |     )
 955 | 
 956 |     eq_template = ""
 957 |     for r in per_dataset_results.values():
 958 |         if r.get("equation"):
 959 |             eq_template = r["equation"]
 960 |             break
 961 | 
 962 |     hard_cases = [
 963 |         {"dataset": name, "nmse_val": float(result["nmse_val"])}
 964 |         for name, result in per_dataset_results.items()
 965 |         if np.isfinite(float(result.get("nmse_val", float("inf"))))
 966 |     ]
 967 |     hard_cases.sort(key=lambda item: item["nmse_val"], reverse=True)
 968 |     hard_cases = hard_cases[:5]
 969 |     hard_case_feedback = "; ".join(
 970 |         f"{case['dataset']} nmse={case['nmse_val']:.4g}" for case in hard_cases
 971 |     )
 972 |     hard_case_tail_nmse = (
 973 |         float(np.mean([case["nmse_val"] for case in hard_cases[:HARD_CASE_TAIL_COUNT]]))
 974 |         if hard_cases and HARD_CASE_TAIL_COUNT > 0
 975 |         else 0.0
 976 |     )
 977 | 
 978 |     violation_error = None
 979 |     if violation_errors:
 980 |         violation_error = violation_errors[0]
 981 |     elif failed_datasets:
 982 |         examples = ", ".join(failed_datasets[:3])
 983 |         violation_error = (
 984 |             "Single-equation violation: candidate failed on "
 985 |             f"{len(failed_datasets)}/{len(per_dataset_results)} datasets. "
 986 |             "Failed datasets are not dropped from the aggregate reward. "
 987 |             f"Examples: {examples}"
 988 |         )
 989 |     elif len(templates) > 1:
 990 |         examples = "; ".join(templates[:3])
 991 |         violation_error = (
 992 |             "Single-equation violation: evaluate_symbolic_candidate() produced "
 993 |             f"{len(templates)} distinct equation templates across datasets. "
 994 |             "The base equation must be identical for all datasets; only fitted "
 995 |             f"constants may vary. Example templates: {examples}"
 996 |         )
 997 | 
 998 |     if violation_error:
 999 |         agg_nmse = float("inf")
1000 |         mean_nmse = float("inf")
1001 |         agg_train_nmse = float("inf")
1002 |         agg_combined = 0.0
1003 |         n_successful = 0
1004 |     else:
1005 |         val_point_weights = [
1006 |             int(r.get("n_val_points", 0)) for r in per_dataset_results.values()
1007 |         ]
1008 |         mean_nmse = _point_weighted_mean(nmse_vals, val_point_weights)
1009 |         raw_mean_nmse = _point_weighted_mean(raw_nmse_vals, val_point_weights)
1010 |         agg_nmse = mean_nmse + HARD_CASE_TAIL_WEIGHT * hard_case_tail_nmse
1011 |         agg_train_nmse = float(np.mean(train_nmse_vals)) if train_nmse_vals else float("inf")
1012 |         raw_combined = (
1013 |             float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
1014 |         )
1015 |         parsimony_factor = _parsimony_penalty_factor(aggregate_complexity)
1016 |         agg_combined = raw_combined * parsimony_factor
1017 |         n_successful = sum(1 for value in nmse_vals if np.isfinite(value))
1018 | 
1019 |     aggregated = {
1020 |         "equation": eq_template,
1021 |         "nmse_train": agg_train_nmse,
1022 |         "nmse_val": agg_nmse,
1023 |         "mean_nmse_val": mean_nmse,
1024 |         "mean_raw_nmse_val": raw_mean_nmse if not violation_error else float("inf"),
1025 |         "combined_score": agg_combined,
1026 |         "fit_score": raw_combined if not violation_error else 0.0,
1027 |         "complexity": aggregate_complexity,
1028 |         "parsimony_weight": PARSIMONY_WEIGHT,
1029 |         "parsimony_penalty_factor": (
1030 |             _parsimony_penalty_factor(aggregate_complexity) if not violation_error else 1.0
1031 |         ),
1032 |         "n_datasets": len(per_dataset_results),
1033 |         "n_successful": n_successful,
1034 |         "eval_workers": NUM_WORKERS,
1035 |         "hard_cases": hard_cases,
1036 |         "hard_case_feedback": hard_case_feedback,
1037 |         "hard_case_tail_nmse": hard_case_tail_nmse,
1038 |         "hard_case_tail_weight": HARD_CASE_TAIL_WEIGHT,
1039 |         "per_dataset_nmse_cap": PER_DATASET_NMSE_CAP,
1040 |         "per_dataset": per_dataset_results,
1041 |     }
1042 |     if violation_error:
1043 |         aggregated["error"] = violation_error
1044 |     return aggregated
1045 | 
