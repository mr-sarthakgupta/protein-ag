import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all_normalized_ode.evaluator import load_all_datasets, evaluate_ode_expression
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, single_equation_evaluation, validate_single_equation_result

datasets = load_all_datasets()
results = []
for name, X_train, X_val, y_train, y_val in datasets:
    x = feature_symbols(3)
    c = constant_symbols(3)
    parameter = x[1]
    concentration = x[2]
    rate = c[0] + c[1] * parameter
    growth = (concentration + c[2]) * (1 - concentration)
    expression = rate * growth
    try:
        with single_equation_evaluation():
            r = evaluate_ode_expression(expression, X_train, y_train, X_val, y_val, constants=c, initial_values=[1.0, 0.0, 0.01])
        results.append((r['nmse_val'], name))
    except Exception as e:
        results.append((99.0, name + ' ERR:' + str(e)[:40]))
results.sort(reverse=True)
print('Top 5 hardest:')
for nmse, name in results[:5]:
    print(f'  {nmse:.4f}  {name}')
print('Mean NMSE val:', np.mean([r[0] for r in results]))
" 2>&1 | grep -v Warning
