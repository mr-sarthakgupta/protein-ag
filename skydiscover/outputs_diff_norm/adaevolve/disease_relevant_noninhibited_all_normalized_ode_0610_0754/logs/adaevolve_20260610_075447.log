1047 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
1048 |     """Evaluate a candidate program across ALL datasets in a subprocess.
1049 | 
1050 |     The subprocess loads every dataset, calls the candidate's
1051 |     evaluate_symbolic_candidate() once per dataset (fitting independent
1052 |     constants each time) using parallel threads, and returns aggregated
1053 |     metrics.
1054 |     """
1055 |     validate_candidate_source(program_path)
1056 |     harness_root = str(BENCHMARK_ROOT)
1057 |     evaluator_path = str(Path(__file__).resolve())
1058 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
1059 |         script = f"""
1060 | import importlib.util
1061 | import os
1062 | import pickle
1063 | import sys
1064 | import traceback
1065 | from concurrent.futures import ThreadPoolExecutor, as_completed
1066 | 
1067 | os.environ.setdefault("OMP_NUM_THREADS", "1")
1068 | os.environ.setdefault("MKL_NUM_THREADS", "1")
1069 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
1070 | 
1071 | import numpy as np
1072 | 
1073 | sys.path.insert(0, {harness_root!r})
1074 | 
1075 | program_path = {program_path!r}
1076 | evaluator_path = {evaluator_path!r}
1077 | results_path = {temp_file.name + ".results"!r}
1078 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
1079 | 
1080 | def _write_payload_and_exit(payload):
1081 |     with open(results_path, "wb") as f:
1082 |         pickle.dump(payload, f)
