import sympy as sp

def complexity(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2, c3 = sp.symbols('c0 c1 c2 c3')

# Since x1 IS normalized (0->1), linear x1 IS viable!
# But 8 datasets start at x2=0, so seed is essential.

# Key candidates with complexity < 13 AND seed term:
candidates = [
    # Linear x1, 3 constants, with seed
    ('c0*x1*(x2+c1)*(1-x2)', c0*x1*(x2+c1)*(1-x2)),
    ('c0*x1*(x2+c1)*(c2-x2)', c0*x1*(x2+c1)*(c2-x2)),
    # Linear x1, 2 constants, with seed  
    ('c0*x1*(x2+c1)', c0*x1*(x2+c1)),
    # Power x1, 3 constants, with seed (fixed plateau)
    ('c0*x1^c1*(x2+c2)*(1-x2)', c0*x1**c1*(x2+c2)*(1-x2)),  # Program1
    # Current best
    ('c0*x1^c1*(x2+c2)*(c3-x2)', c0*x1**c1*(x2+c2)*(c3-x2)),
    # Simpler: (c0+c1*x1)*(x2+c2)*(1-x2) -- linear x1 offset, 3 constants
    ('(c0+c1*x1)*(x2+c2)*(1-x2)', (c0+c1*x1)*(x2+c2)*(1-x2)),
    # c0*x1*(x2+c1)^2*(1-x2) -- quadratic seed
    ('c0*x1*(x2+c1)^2*(1-x2)', c0*x1*(x2+c1)**2*(1-x2)),
]

print('Complexity analysis (x1 normalized 0->1):')
for name, expr in candidates:
    comp = complexity(expr)
    parsimony = 1 - 0.2*(comp/160)
    # If NMSE=0.0140 (same as current):
    score_same = (1/(1+0.0140)) * parsimony
    # If NMSE=0.0160 (worse):
    score_worse = (1/(1+0.0160)) * parsimony
    # If NMSE=0.0120 (better):
    score_better = (1/(1+0.0120)) * parsimony
    print(f'  comp={comp:2d}  {name}')
    print(f'         same_nmse={score_same:.4f}  worse={score_worse:.4f}  better={score_better:.4f}  (vs 0.9702)')
