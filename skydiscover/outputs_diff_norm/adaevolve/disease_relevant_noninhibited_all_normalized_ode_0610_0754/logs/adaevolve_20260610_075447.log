 512 | def _place_non_overlapping_blocks(
 513 |     n_points: int,
 514 |     block_sizes: list[int],
 515 |     rng: np.random.Generator,
 516 | ) -> set[int] | None:
 517 |     """Place contiguous blocks at random non-overlapping positions."""
 518 |     val_local: set[int] = set()
 519 |     for block_size in block_sizes:
 520 |         valid_starts = [
 521 |             start
 522 |             for start in range(0, n_points - block_size + 1)
 523 |             if not set(range(start, start + block_size)) & val_local
 524 |         ]
 525 |         if not valid_starts:
 526 |             return None
 527 |         start = int(valid_starts[int(rng.integers(len(valid_starts)))])
 528 |         val_local.update(range(start, start + block_size))
 529 |     return val_local
 530 | 
 531 | 
 532 | def _scatter_points(
 533 |     available: list[int],
 534 |     n_scatter: int,
 535 |     rng: np.random.Generator,
 536 | ) -> set[int]:
 537 |     """Pick scattered validation points from unused curve indices."""
 538 |     if n_scatter <= 0 or not available:
 539 |         return set()
 540 |     chosen = rng.choice(np.asarray(available, dtype=int), size=n_scatter, replace=False)
 541 |     return {int(index) for index in np.atleast_1d(chosen)}
 542 | 
 543 | 
 544 | def _contiguous_point_holdout(
 545 |     ordered_idx: np.ndarray,
 546 |     rng: np.random.Generator,
 547 | ) -> tuple[list[int], list[int]]:
 548 |     """Hold out ~TEST_SIZE points as 10-point blocks plus scattered remainder."""
 549 |     n_points = len(ordered_idx)
 550 |     if n_points == 1:
 551 |         idx = ordered_idx.tolist()
 552 |         return idx, idx
 553 | 
 554 |     n_val = min(max(1, int(round(n_points * TEST_SIZE))), n_points - 1)
 555 |     n_full_blocks = n_val // CONTIGUOUS_VAL_BLOCK_SIZE
 556 |     remainder = n_val % CONTIGUOUS_VAL_BLOCK_SIZE
 557 | 
 558 |     if n_full_blocks == 0:
 559 |         val_local = _scatter_points(list(range(n_points)), n_val, rng)
 560 |     else:
 561 |         block_sizes = [CONTIGUOUS_VAL_BLOCK_SIZE] * n_full_blocks
 562 |         placement_order = list(block_sizes)
 563 |         rng.shuffle(placement_order)
 564 |         val_local = _place_non_overlapping_blocks(n_points, placement_order, rng)
 565 |         if val_local is None:
 566 |             val_local = _scatter_points(list(range(n_points)), n_val, rng)
 567 |         elif remainder > 0:
 568 |             available = [index for index in range(n_points) if index not in val_local]
 569 |             val_local |= _scatter_points(available, remainder, rng)
 570 | 
 571 |     val_indices = [int(ordered_idx[i]) for i in sorted(val_local)]
 572 |     fit_indices = [int(ordered_idx[i]) for i in range(n_points) if i not in val_local]
 573 |     return fit_indices, val_indices
 574 | 
 575 | 
 576 | def _trajectory_preserving_split(
 577 |     X: np.ndarray,
 578 |     y: np.ndarray,
 579 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 580 |     """Split curves/points into fit (train) and NMSE-evaluation (val) sets."""
 581 |     parameters = np.unique(X[:, 1])
 582 |     rng = np.random.default_rng(RANDOM_STATE)
 583 | 
 584 |     if len(parameters) >= 3:
 585 |         shuffled = parameters[rng.permutation(len(parameters))]
 586 |         n_val_curves = min(
 587 |             max(1, int(round(len(parameters) * TEST_SIZE))), len(parameters) - 1
 588 |         )
 589 |         val_params = {float(p) for p in shuffled[:n_val_curves]}
 590 | 
 591 |         fit_indices: list[int] = []
 592 |         val_indices: list[int] = []
 593 |         for parameter in parameters:
 594 |             curve_idx = np.flatnonzero(X[:, 1] == parameter)
 595 |             if float(parameter) in val_params:
 596 |                 val_indices.extend(curve_idx.tolist())
 597 |                 continue
 598 | 
 599 |             if len(curve_idx) == 1:
 600 |                 fit_indices.extend(curve_idx.tolist())
 601 |                 continue
 602 | 
 603 |             ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 604 |             curve_fit, curve_val = _contiguous_point_holdout(ordered_idx, rng)
 605 |             fit_indices.extend(curve_fit)
 606 |             val_indices.extend(curve_val)
 607 | 
 608 |         fit_idx = np.sort(np.asarray(fit_indices, dtype=int))
 609 |         val_idx = np.sort(np.asarray(val_indices, dtype=int))
 610 |         return X[fit_idx], X[val_idx], y[fit_idx], y[val_idx]
 611 | 
 612 |     train_indices: list[int] = []
 613 |     val_indices: list[int] = []
 614 |     for parameter in parameters:
 615 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 616 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 617 |         curve_fit, curve_val = _contiguous_point_holdout(ordered_idx, rng)
 618 |         train_indices.extend(curve_fit)
 619 |         val_indices.extend(curve_val)
 620 | 
 621 |     train_idx = np.sort(np.asarray(train_indices, dtype=int))
 622 |     val_idx = np.sort(np.asarray(val_indices, dtype=int))
 623 |     return X[train_idx], X[val_idx], y[train_idx], y[val_idx]
 624 | 
 625 | 
 626 | def load_dataset(data_file: Path) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 627 |     """Load a single fit.tsv and return deterministic trajectory-preserving split."""
 628 |     X, y = _load_fit_table(data_file)
 629 |     return _trajectory_preserving_split(X, y)
 630 | 
