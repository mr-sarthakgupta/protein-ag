 647 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 648 | PARSIMONY_WEIGHT = float(os.environ.get("SKYDISCOVER_PARSIMONY_WEIGHT", "0.20"))
 649 | PARSIMONY_COMPLEXITY_SCALE = float(
 650 |     os.environ.get("SKYDISCOVER_PARSIMONY_COMPLEXITY_SCALE", "160")
 651 | )
 652 | 
 653 | 
 654 | def _parsimony_penalty_factor(complexity: float) -> float:
 655 |     """Bounded penalty factor for expression complexity."""
 656 |     if not np.isfinite(complexity) or PARSIMONY_COMPLEXITY_SCALE <= 0:
 657 |         return 1.0
 658 |     normalized = min(max(float(complexity), 0.0) / PARSIMONY_COMPLEXITY_SCALE, 1.0)
 659 |     return max(0.0, 1.0 - PARSIMONY_WEIGHT * normalized)
 660 | 
 661 | 
 662 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 663 |     values = np.asarray(values, dtype=float).ravel()
 664 |     if values.size < 3 or sigma <= 0.0:
 665 |         return values
 666 |     radius = max(1, int(round(3.0 * sigma)))
 667 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 668 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 669 |     kernel /= np.sum(kernel)
 670 |     padded = np.pad(values, (radius, radius), mode="edge")
 671 |     return np.convolve(padded, kernel, mode="valid")
 672 | 
 673 | 
 674 | def _curve_smoothed_target(X: np.ndarray, y_true: np.ndarray) -> np.ndarray:
 675 |     """Smooth targets independently for each parameter curve in time order."""
 676 |     X = np.asarray(X, dtype=float)
 677 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 678 |     if X.shape[0] != y_true.shape[0] or X.shape[1] < 2:
 679 |         return _gaussian_smooth_1d(y_true)
 680 | 
 681 |     smoothed = np.empty_like(y_true, dtype=float)
 682 |     for parameter in np.unique(X[:, 1]):
 683 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 684 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 685 |         smoothed_curve = _gaussian_smooth_1d(y_true[ordered_idx])
 686 |         smoothed[ordered_idx] = smoothed_curve
 687 |     return smoothed
 688 | 
 689 | 
 690 | def _normalized_mse_with_reference_variance(
 691 |     y_true: np.ndarray,
 692 |     y_pred: np.ndarray,
 693 |     reference_values: np.ndarray,
 694 | ) -> float:
 695 |     """MSE normalized by full dataset scale, not by a flat validation segment."""
 696 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 697 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 698 |     reference_values = np.asarray(reference_values, dtype=float).reshape(-1)
 699 |     if y_true.shape != y_pred.shape:
 700 |         return float("inf")
 701 |     if not np.all(np.isfinite(y_pred)):
 702 |         return float("inf")
 703 |     var = float(np.var(reference_values))
 704 |     if var <= 0.0:
 705 |         return float(np.mean((y_true - y_pred) ** 2))
 706 |     return float(np.mean((y_true - y_pred) ** 2) / var)
 707 | 
 708 | 
 709 | def _nmse_with_gaussian_smoothed_target(
 710 |     y_true: np.ndarray,
 711 |     y_pred: np.ndarray,
 712 |     X: np.ndarray | None = None,
 713 |     reference_values: np.ndarray | None = None,
 714 | ) -> float:
 715 |     reference = y_true if reference_values is None else reference_values
 716 |     raw_loss = _normalized_mse_with_reference_variance(y_true, y_pred, reference)
 717 |     smooth_target = _curve_smoothed_target(X, y_true) if X is not None else _gaussian_smooth_1d(y_true)
 718 |     smooth_loss = _normalized_mse_with_reference_variance(smooth_target, y_pred, reference)
 719 |     return float((raw_loss + smooth_loss) / 2.0)
 720 | 
 721 | 
 722 | def _ode_predictions(
 723 |     rhs_fn: Any,
 724 |     X: np.ndarray,
 725 |     y_known: np.ndarray,
 726 |     theta: np.ndarray,
 727 | ) -> np.ndarray:
 728 |     """Integrate dc/dt=f(t, parameter, c) per parameter curve on one split."""
 729 |     import warnings
 730 | 
 731 |     from scipy.integrate import odeint
 732 | 
 733 |     X = np.asarray(X, dtype=float)
 734 |     y_known = np.asarray(y_known, dtype=float).reshape(-1)
 735 |     theta = np.asarray(theta, dtype=float).reshape(-1)
 736 |     predictions = np.full_like(y_known, np.nan, dtype=float)
 737 | 
 738 |     for parameter in np.unique(X[:, 1]):
 739 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 740 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 741 |         times = X[ordered_idx, 0]
 742 |         observed = y_known[ordered_idx]
 743 | 
 744 |         if len(ordered_idx) == 1 or float(times[-1] - times[0]) <= 0.0:
 745 |             predictions[ordered_idx] = observed[0]
 746 |             continue
 747 | 
 748 |         def dc_dt(c_state: np.ndarray, time_value: float) -> float:
 749 |             c_value = float(np.asarray(c_state, dtype=float).reshape(-1)[0])
 750 |             value = rhs_fn(float(time_value), float(parameter), c_value, *theta)
 751 |             value = float(np.asarray(value, dtype=float).reshape(-1)[0])
 752 |             if not np.isfinite(value):
 753 |                 raise FloatingPointError("non-finite ODE derivative")
 754 |             return value
 755 | 
 756 |         with warnings.catch_warnings():
 757 |             warnings.simplefilter("ignore")
 758 |             integrated = odeint(
 759 |                 dc_dt,
 760 |                 float(observed[0]),
 761 |                 times,
 762 |                 mxstep=1000,
 763 |             )
 764 |         curve_pred = np.asarray(integrated, dtype=float).reshape(-1)
 765 |         if curve_pred.shape != observed.shape or not np.all(np.isfinite(curve_pred)):
 766 |             raise FloatingPointError("non-finite ODE trajectory")
 767 |         predictions[ordered_idx] = curve_pred
 768 | 
 769 |     return predictions
 770 | 
 771 | 
 772 | def evaluate_ode_expression(
 773 |     expression: Any,
 774 |     X_train: np.ndarray,
 775 |     y_train: np.ndarray,
 776 |     X_val: np.ndarray,
 777 |     y_val: np.ndarray,
 778 |     *,
 779 |     constants: Any | None = None,
 780 |     initial_values: Any | None = None,
 781 |     max_nfev: int = 300,
 782 | ) -> dict[str, Any]:
 783 |     """Score a proposed ODE RHS by integrating predicted concentration curves."""
 784 |     import sympy as sp
 785 |     from pysr_harness import equation_session
 786 |     from scipy.optimize import least_squares
 787 | 
 788 |     X_train = np.asarray(X_train, dtype=float)
 789 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 790 |     X_val = np.asarray(X_val, dtype=float)
 791 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 792 |     y_reference = np.concatenate([y_train, y_val])
 793 |     feature_names = [f"x{i}" for i in range(X_train.shape[1])]
 794 |     template = equation_session._as_sympy_expr(expression, feature_names)
 795 |     equation_session._record_scored_template(template)
 796 | 
 797 |     if constants is None:
 798 |         feature_set = set(equation_session.feature_symbols(X_train.shape[1]))
 799 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 800 |     constants = list(constants)
 801 |     equation_session._validate_expression_template(template, constants)
 802 | 
 803 |     if initial_values is None:
 804 |         base_x0 = np.ones(len(constants), dtype=float)
 805 |     else:
 806 |         base_x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 807 |         if base_x0.size != len(constants):
 808 |             raise ValueError("initial_values must match the number of constants")
 809 | 
 810 |     feature_syms = equation_session.feature_symbols(X_train.shape[1])
 811 |     rhs_fn = sp.lambdify(feature_syms + constants, template, modules=["numpy"])
 812 | 
 813 |     if not constants:
 814 |         y_pred_train = _ode_predictions(rhs_fn, X_train, y_train, np.asarray([], dtype=float))
 815 |         y_pred_val = _ode_predictions(rhs_fn, X_val, y_val, np.asarray([], dtype=float))
 816 |         nmse_train = _nmse_with_gaussian_smoothed_target(
 817 |             y_train, y_pred_train, X_train, y_reference
 818 |         )
 819 |         nmse_val = _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 820 |         result = {
 821 |             "equation_template": f"d(c)/dt = {template}",
 822 |             "equation": f"d(c)/dt = {template}",
 823 |             "constants": {},
 824 |             "loss": float(np.mean((y_pred_train - y_train) ** 2)),
 825 |             "complexity": equation_session._complexity(template),
 826 |             "nmse_train": nmse_train,
 827 |             "nmse_val": nmse_val,
 828 |             "n_val_points": int(len(y_val)),
 829 |             "combined_score": combined_score_from_nmse(nmse_val),
 830 |         }
 831 |         equation_session._record_scorer_result(result)
 832 |         return result
 833 | 
 834 |     def residual(theta: np.ndarray) -> np.ndarray:
 835 |         try:
 836 |             prediction = _ode_predictions(rhs_fn, X_train, y_train, theta)
 837 |         except Exception:
 838 |             return np.full_like(y_train, 1e12, dtype=float)
 839 |         if prediction.shape != y_train.shape or not np.all(np.isfinite(prediction)):
 840 |             return np.full_like(y_train, 1e12, dtype=float)
 841 |         return prediction - y_train
 842 | 
 843 |     initial_candidates: list[np.ndarray] = []
 844 |     for scale in ODE_MULTISTART_SCALES or (1.0,):
 845 |         candidate = base_x0 * float(scale)
 846 |         if not any(np.array_equal(candidate, existing) for existing in initial_candidates):
 847 |             initial_candidates.append(candidate)
 848 | 
 849 |     import warnings
 850 | 
 851 |     best_fit = None
 852 |     best_loss = float("inf")
 853 |     with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 854 |         warnings.simplefilter("ignore", RuntimeWarning)
 855 |         for initial_candidate in initial_candidates:
 856 |             fit = least_squares(
 857 |                 residual,
 858 |                 initial_candidate,
 859 |                 loss="soft_l1",
 860 |                 max_nfev=max_nfev,
 861 |             )
 862 |             fit_residual = residual(fit.x)
 863 |             fit_loss = float(np.mean(fit_residual**2))
 864 |             if fit_loss < best_loss:
 865 |                 best_loss = fit_loss
 866 |                 best_fit = fit
 867 | 
 868 |     if best_fit is None:
 869 |         raise RuntimeError("constant fitting did not produce a result")
 870 | 
 871 |     fitted_constants = {
 872 |         str(symbol): float(value) for symbol, value in zip(constants, best_fit.x)
 873 |     }
 874 |     substitutions = dict(zip(constants, best_fit.x))
 875 |     fitted_expr = template.subs(substitutions)
 876 |     y_pred_train = _ode_predictions(rhs_fn, X_train, y_train, best_fit.x)
 877 |     y_pred_val = _ode_predictions(rhs_fn, X_val, y_val, best_fit.x)
 878 |     nmse_train = _nmse_with_gaussian_smoothed_target(
 879 |         y_train, y_pred_train, X_train, y_reference
 880 |     )
 881 |     nmse_val = _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 882 |     loss = float(np.mean((y_pred_train - y_train) ** 2))
 883 | 
 884 |     result = {
 885 |         "equation_template": f"d(c)/dt = {template}",
 886 |         "equation": f"d(c)/dt = {fitted_expr}",
 887 |         "constants": fitted_constants,
 888 |         "loss": loss,
 889 |         "complexity": equation_session._complexity(template),
 890 |         "nmse_train": nmse_train,
 891 |         "nmse_val": nmse_val,
 892 |         "n_val_points": int(len(y_val)),
 893 |         "combined_score": combined_score_from_nmse(nmse_val),
 894 |     }
 895 |     equation_session._record_scorer_result(result)
 896 |     return result
