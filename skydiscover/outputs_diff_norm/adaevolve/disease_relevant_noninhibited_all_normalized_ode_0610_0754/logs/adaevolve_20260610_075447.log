 512 | def _place_non_overlapping_blocks(
 513 |     n_points: int,
 514 |     block_sizes: list[int],
 515 |     rng: np.random.Generator,
 516 | ) -> set[int] | None:
 517 |     """Place contiguous blocks at random non-overlapping positions."""
 518 |     val_local: set[int] = set()
 519 |     for block_size in block_sizes:
 520 |         valid_starts = [
 521 |             start
 522 |             for start in range(0, n_points - block_size + 1)
 523 |             if not set(range(start, start + block_size)) & val_local
 524 |         ]
 525 |         if not valid_starts:
 526 |             return None
 527 |         start = int(valid_starts[int(rng.integers(len(valid_starts)))])
 528 |         val_local.update(range(start, start + block_size))
 529 |     return val_local
 530 | 
