import os, glob, pandas as pd, numpy as np
base = '/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited/'
tsv_files = glob.glob(os.path.join(base, '**', 'fit.tsv'), recursive=True)

# Check min values of first row (initial conditions) across all datasets
exact_zero = []
near_zero = []
for f in tsv_files:
    df = pd.read_csv(f, sep='\t')
    # First row values (initial concentrations)
    first_row = df.iloc[0, 1:].values
    min_val = float(np.min(first_row))
    name = f.replace(base, '').replace('/fit.tsv', '')
    if min_val == 0.0:
        exact_zero.append((name, min_val))
    elif min_val < 1e-4:
        near_zero.append((name, min_val))

print(f'Exact zero initial: {len(exact_zero)}')
for n, v in exact_zero[:5]:
    print(f'  {n}: {v}')
print(f'Near zero (<1e-4) initial: {len(near_zero)}')
for n, v in near_zero[:5]:
    print(f'  {n}: {v}')
print(f'Total datasets: {len(tsv_files)}')
"
