import sympy as sp

def complexity(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2, c3 = sp.symbols('c0 c1 c2 c3')

# Goal: complexity <= 11, has seed (nonzero at x2=0), has saturation, uses x1^power
# The minimum structure needed: x1^c1 * seed * plateau
# x1^c1 costs 3 nodes (x1, c1, Pow)
# seed costs at least 3 more (x2+c2 = Add, x2, c2) = 3
# plateau costs at least 3 more (1-x2 = Add, 1, x2 or c3-x2) = 3
# c0 * ... costs 2 (Mul, c0)
# Total minimum: 2 + 3 + 3 + 3 = 11 nodes
# But the outer Mul connecting all pieces adds more...

# Let's verify: c0*x1^c1*(x2+c2)*(1-x2)
p1 = c0*x1**c1*(x2+c2)*(1-x2)
print(f'Program1: comp={complexity(p1)}')  # should be 13

# Can we achieve complexity=11 with seed+plateau?
# Try: c0*(x1^c1+c2)*(1-x2) -- x1-dependent seed, linear plateau
v1 = c0*(x1**c1+c2)*(1-x2)
print(f'c0*(x1^c1+c2)*(1-x2): comp={complexity(v1)}')

# Try: c0*x1^c1*(x2+c2) -- no plateau, comp=?
v2 = c0*x1**c1*(x2+c2)
print(f'c0*x1^c1*(x2+c2): comp={complexity(v2)}')

# Try: c0*x1^c1*x2*(1-x2) -- no seed, comp=?
v3 = c0*x1**c1*x2*(1-x2)
print(f'c0*x1^c1*x2*(1-x2): comp={complexity(v3)}')

# What about: c0*(x2+c1)*(c2-x2) -- no x1, comp=?
v4 = c0*(x2+c1)*(c2-x2)
print(f'c0*(x2+c1)*(c2-x2): comp={complexity(v4)}')

# What about: c0*x1*(x2+c1)*(1-x2) -- linear x1, comp=?
v5 = c0*x1*(x2+c1)*(1-x2)
print(f'c0*x1*(x2+c1)*(1-x2): comp={complexity(v5)}')

# What about: c0*(x1+c1)*x2*(1-x2) -- linear shifted x1, no seed
v6 = c0*(x1+c1)*x2*(1-x2)
print(f'c0*(x1+c1)*x2*(1-x2): comp={complexity(v6)}')

# What about: c0*x1^c1*(x2+c2)*(c3-x2) but with c3=1 absorbed?
# The floating plateau c3 IS the key difference from Program1

# Score projections for complexity=11 forms
print()
print('Score projections for complexity=11 with seed+plateau:')
for label, comp, nmse_val in [
    ('Current (comp=13)', 13, 0.0140),
    ('comp=11 same NMSE', 11, 0.0140),
    ('comp=11 NMSE=0.018', 11, 0.0180),
    ('comp=11 NMSE=0.020', 11, 0.0200),
    ('comp=11 NMSE=0.025', 11, 0.0250),
    ('comp=9 same NMSE', 9, 0.0140),
    ('comp=9 NMSE=0.030', 9, 0.0300),
]:
    parsimony = 1 - 0.2*(comp/160)
