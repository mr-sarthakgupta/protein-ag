    # New: Bernoulli-like
    ('c0*x1^c1*(x2+c2)/(c3+x2)', c0*x1**c1*(x2+c2)/(c3+x2)),
    # New: log form
    ('c0*x1^c1*(c2-sp.log(x2+c3))', c0*x1**c1*(c2-sp.log(x2+c3))),
    # New: sqrt
    ('c0*x1^c1*sp.sqrt(x2+c2)*(c3-x2)', c0*x1**c1*sp.sqrt(x2+c2)*(c3-x2)),
]

print('Complexity=13 candidates:')
