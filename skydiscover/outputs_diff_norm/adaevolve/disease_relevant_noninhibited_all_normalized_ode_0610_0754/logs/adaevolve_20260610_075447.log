 405 | 
 406 | def _parse_parameter_from_column(column_name: str) -> float | None:
 407 |     """Extract a monomer/protein concentration from a fit.tsv column header.
 408 | 
 409 |     Only concentration-like labels are accepted:
 410 |       - "... : 10uM"  or "10 uM"  → 10.0
 411 |       - "35uM" (bare, as in Abeta) → 35.0
 412 |       - "... : 3.95mM"             → 3950.0  (converted to uM)
 413 |       - "... : 0.3 mg/mL 22uM"    → 22.0    (prefer uM when both present)
 414 | 
 415 |     Seed percentages, pH values, ng/uL seed-material labels, and generic
 416 |     numeric fallbacks are intentionally ignored so x1 consistently represents
 417 |     the aggregating monomer/protein concentration when available.
 418 |     """
 419 |     text = column_name.strip()
 420 |     # Prefer the human-readable condition after the file-name prefix. Some
 421 |     # filenames contain seed concentrations that should not become x1.
 422 |     condition_text = text.rsplit(":", 1)[-1].strip().strip("\"'")
 423 | 
 424 |     # Prefer an explicit uM value
 425 |     m = re.search(r"(\d+(?:\.\d+)?)\s*uM", condition_text, re.IGNORECASE)
 426 |     if m:
 427 |         return float(m.group(1))
 428 | 
 429 |     # mM → convert to uM
 430 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mM", condition_text, re.IGNORECASE)
 431 |     if m:
 432 |         return float(m.group(1)) * 1000.0
 433 | 
 434 |     # mg/mL (take the number)
 435 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mg/mL", condition_text, re.IGNORECASE)
 436 |     if m:
 437 |         return float(m.group(1))
 438 | 
 439 |     return None
 440 | 
 441 | 
 442 | def _minmax_normalize(values: np.ndarray) -> np.ndarray:
 443 |     """Normalize one dataset column to 0..1, preserving constants as zeros."""
 444 |     values = np.asarray(values, dtype=float)
 445 |     v_min = float(np.min(values))
 446 |     v_max = float(np.max(values))
 447 |     scale = v_max - v_min
 448 |     if scale <= 0.0:
 449 |         return np.zeros_like(values, dtype=float)
 450 |     return (values - v_min) / scale
 451 | 
 452 | 
 453 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 454 |     """Load a wide fit.tsv and return X=[normalized time, raw parameter, c], y.
 455 | 
 456 |     The first column is always the time/measurement coordinate. Remaining
 457 |     columns are response curves. The varying parameter is extracted from
 458 |     concentration-like curve headers only; non-concentration columns are skipped.
 459 |     Time is min-max normalized to 0..1, but the parameter column is left in its
 460 |     parsed raw units. The response is normalized globally across the whole
 461 |     fit.tsv to 0..1. Files already rescaled to 0..1 keep that scale.
 462 |     """
 463 |     with data_file.open(newline="") as f:
 464 |         reader = csv.reader(f, delimiter="\t")
 465 |         header = next(reader)
 466 | 
 467 |         response_headers = header[1:]
 468 |         parsed_params = [_parse_parameter_from_column(h) for h in response_headers]
 469 | 
 470 |         features: list[list[float]] = []
 471 |         targets: list[float] = []
 472 |         for row in reader:
 473 |             if not row:
 474 |                 continue
 475 |             measurement_x = float(row[0])
 476 |             for param, value in zip(parsed_params, row[1:]):
 477 |                 if param is None:
 478 |                     continue
 479 |                 if value == "" or value.strip().lower() == "nan":
 480 |                     continue
 481 |                 features.append([measurement_x, param])
 482 |                 targets.append(float(value))
 483 | 
 484 |     if not features:
 485 |         raise ValueError(f"No regression samples loaded from {data_file}")
 486 | 
 487 |     X = np.asarray(features, dtype=float)
 488 |     y = np.asarray(targets, dtype=float)
 489 |     time_norm = _minmax_normalize(X[:, 0])
 490 |     parameter_raw = X[:, 1]
 491 |     y_norm = _minmax_normalize(y)
 492 | 
 493 |     # x2 is the concentration state c used by ODE RHS templates. During scoring
 494 |     # it is supplied from odeint's dynamic state, not read from candidate code.
 495 |     X_ode = np.column_stack([time_norm, parameter_raw, y_norm])
 496 |     return X_ode, y_norm
 497 | 
 498 | 
 499 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 500 |     """Recursively find all fit.tsv files and return (dataset_name, path) pairs."""
 501 |     datasets: list[tuple[str, Path]] = []
 502 |     for dirpath, _dirnames, filenames in os.walk(root):
 503 |         if "fit.tsv" in filenames:
 504 |             fit_path = Path(dirpath) / "fit.tsv"
 505 |             rel = fit_path.parent.relative_to(root)
 506 |             name = str(rel).replace(os.sep, "/")
 507 |             datasets.append((name, fit_path))
 508 |     datasets.sort(key=lambda x: x[0])
 509 |     return datasets
 510 | 
 511 | 
 512 | def _place_non_overlapping_blocks(
 513 |     n_points: int,
 514 |     block_sizes: list[int],
 515 |     rng: np.random.Generator,
 516 | ) -> set[int] | None:
 517 |     """Place contiguous blocks at random non-overlapping positions."""
 518 |     val_local: set[int] = set()
 519 |     for block_size in block_sizes:
 520 |         valid_starts = [
 521 |             start
 522 |             for start in range(0, n_points - block_size + 1)
 523 |             if not set(range(start, start + block_size)) & val_local
 524 |         ]
 525 |         if not valid_starts:
 526 |             return None
 527 |         start = int(valid_starts[int(rng.integers(len(valid_starts)))])
 528 |         val_local.update(range(start, start + block_size))
 529 |     return val_local
 530 | 
 531 | 
 532 | def _scatter_points(
 533 |     available: list[int],
 534 |     n_scatter: int,
 535 |     rng: np.random.Generator,
 536 | ) -> set[int]:
 537 |     """Pick scattered validation points from unused curve indices."""
 538 |     if n_scatter <= 0 or not available:
 539 |         return set()
 540 |     chosen = rng.choice(np.asarray(available, dtype=int), size=n_scatter, replace=False)
 541 |     return {int(index) for index in np.atleast_1d(chosen)}
 542 | 
 543 | 
 544 | def _contiguous_point_holdout(
 545 |     ordered_idx: np.ndarray,
 546 |     rng: np.random.Generator,
 547 | ) -> tuple[list[int], list[int]]:
 548 |     """Hold out ~TEST_SIZE points as 10-point blocks plus scattered remainder."""
 549 |     n_points = len(ordered_idx)
 550 |     if n_points == 1:
 551 |         idx = ordered_idx.tolist()
 552 |         return idx, idx
 553 | 
 554 |     n_val = min(max(1, int(round(n_points * TEST_SIZE))), n_points - 1)
 555 |     n_full_blocks = n_val // CONTIGUOUS_VAL_BLOCK_SIZE
 556 |     remainder = n_val % CONTIGUOUS_VAL_BLOCK_SIZE
 557 | 
 558 |     if n_full_blocks == 0:
 559 |         val_local = _scatter_points(list(range(n_points)), n_val, rng)
 560 |     else:
 561 |         block_sizes = [CONTIGUOUS_VAL_BLOCK_SIZE] * n_full_blocks
 562 |         placement_order = list(block_sizes)
 563 |         rng.shuffle(placement_order)
 564 |         val_local = _place_non_overlapping_blocks(n_points, placement_order, rng)
 565 |         if val_local is None:
 566 |             val_local = _scatter_points(list(range(n_points)), n_val, rng)
 567 |         elif remainder > 0:
 568 |             available = [index for index in range(n_points) if index not in val_local]
 569 |             val_local |= _scatter_points(available, remainder, rng)
 570 | 
 571 |     val_indices = [int(ordered_idx[i]) for i in sorted(val_local)]
 572 |     fit_indices = [int(ordered_idx[i]) for i in range(n_points) if i not in val_local]
 573 |     return fit_indices, val_indices
 574 | 
 575 | 
 576 | def _trajectory_preserving_split(
 577 |     X: np.ndarray,
 578 |     y: np.ndarray,
 579 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 580 |     """Split curves/points into fit (train) and NMSE-evaluation (val) sets."""
 581 |     parameters = np.unique(X[:, 1])
 582 |     rng = np.random.default_rng(RANDOM_STATE)
 583 | 
 584 |     if len(parameters) >= 3:
 585 |         shuffled = parameters[rng.permutation(len(parameters))]
 586 |         n_val_curves = min(
 587 |             max(1, int(round(len(parameters) * TEST_SIZE))), len(parameters) - 1
 588 |         )
 589 |         val_params = {float(p) for p in shuffled[:n_val_curves]}
 590 | 
 591 |         fit_indices: list[int] = []
 592 |         val_indices: list[int] = []
 593 |         for parameter in parameters:
 594 |             curve_idx = np.flatnonzero(X[:, 1] == parameter)
 595 |             if float(parameter) in val_params:
 596 |                 val_indices.extend(curve_idx.tolist())
 597 |                 continue
 598 | 
 599 |             if len(curve_idx) == 1:
 600 |                 fit_indices.extend(curve_idx.tolist())
 601 |                 continue
 602 | 
 603 |             ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 604 |             curve_fit, curve_val = _contiguous_point_holdout(ordered_idx, rng)
 605 |             fit_indices.extend(curve_fit)
 606 |             val_indices.extend(curve_val)
 607 | 
 608 |         fit_idx = np.sort(np.asarray(fit_indices, dtype=int))
 609 |         val_idx = np.sort(np.asarray(val_indices, dtype=int))
 610 |         return X[fit_idx], X[val_idx], y[fit_idx], y[val_idx]
 611 | 
 612 |     train_indices: list[int] = []
 613 |     val_indices: list[int] = []
 614 |     for parameter in parameters:
 615 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 616 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 617 |         curve_fit, curve_val = _contiguous_point_holdout(ordered_idx, rng)
 618 |         train_indices.extend(curve_fit)
 619 |         val_indices.extend(curve_val)
 620 | 
 621 |     train_idx = np.sort(np.asarray(train_indices, dtype=int))
 622 |     val_idx = np.sort(np.asarray(val_indices, dtype=int))
 623 |     return X[train_idx], X[val_idx], y[train_idx], y[val_idx]
 624 | 
 625 | 
 626 | def load_dataset(data_file: Path) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 627 |     """Load a single fit.tsv and return deterministic trajectory-preserving split."""
 628 |     X, y = _load_fit_table(data_file)
 629 |     return _trajectory_preserving_split(X, y)
 630 | 
