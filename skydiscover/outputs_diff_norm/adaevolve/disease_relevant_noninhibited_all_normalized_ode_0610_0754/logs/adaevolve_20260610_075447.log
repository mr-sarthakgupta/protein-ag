 120 | def _is_main_guard(node: ast.AST) -> bool:
 121 |     if not isinstance(node, ast.If):
 122 |         return False
 123 |     if node.orelse:
 124 |         return False
 125 |     test = node.test
 126 |     if not isinstance(test, ast.Compare) or len(test.ops) != 1 or len(test.comparators) != 1:
 127 |         return False
 128 |     if not isinstance(test.ops[0], ast.Eq):
 129 |         return False
 130 |     left = test.left
 131 |     right = test.comparators[0]
 132 |     return (
 133 |         isinstance(left, ast.Name)
 134 |         and left.id == "__name__"
 135 |         and isinstance(right, ast.Constant)
 136 |         and right.value == "__main__"
