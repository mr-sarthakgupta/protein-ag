            print(f'  First 6 times: {times[:6]}')
            # The ODE will start from observed[0] and try to predict all points
            # But the data has 3 interleaved curves!
            unique_t = np.unique(times)
            counts = [np.sum(times==t) for t in unique_t[:3]]
            print(f'  Points per time step (first 3): {counts}')
