 411 |       - "35uM" (bare, as in Abeta) → 35.0
 412 |       - "... : 3.95mM"             → 3950.0  (converted to uM)
 413 |       - "... : 0.3 mg/mL 22uM"    → 22.0    (prefer uM when both present)
 414 | 
 415 |     Seed percentages, pH values, ng/uL seed-material labels, and generic
 416 |     numeric fallbacks are intentionally ignored so x1 consistently represents
 417 |     the aggregating monomer/protein concentration when available.
 418 |     """
 419 |     text = column_name.strip()
 420 |     # Prefer the human-readable condition after the file-name prefix. Some
 421 |     # filenames contain seed concentrations that should not become x1.
 422 |     condition_text = text.rsplit(":", 1)[-1].strip().strip("\"'")
 423 | 
 424 |     # Prefer an explicit uM value
 425 |     m = re.search(r"(\d+(?:\.\d+)?)\s*uM", condition_text, re.IGNORECASE)
 426 |     if m:
 427 |         return float(m.group(1))
 428 | 
 429 |     # mM → convert to uM
 430 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mM", condition_text, re.IGNORECASE)
 431 |     if m:
 432 |         return float(m.group(1)) * 1000.0
 433 | 
 434 |     # mg/mL (take the number)
 435 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mg/mL", condition_text, re.IGNORECASE)
 436 |     if m:
 437 |         return float(m.group(1))
 438 | 
 439 |     return None
