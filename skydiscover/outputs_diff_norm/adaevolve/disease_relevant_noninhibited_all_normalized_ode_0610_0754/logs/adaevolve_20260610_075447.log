 315 |                     raise ValueError(
 316 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: harness imports may not "
 317 |                         f"use aliases: {sorted(aliased)}."
 318 |                     )
 319 |                 imported = {alias.name for alias in node.names}
 320 |                 extra = imported - _ALLOWED_HARNESS_IMPORTS
 321 |                 if extra:
 322 |                     raise ValueError(
 323 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: unsupported harness imports "
 324 |                         f"{sorted(extra)}. Use only feature_symbols, constant_symbols, "
 325 |                         "and evaluate_expression."
 326 |                     )
 327 |         else:
 328 |             raise ValueError(
 329 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level executable code is not "
 330 |                 "allowed in candidate programs. Build and score the equation only "
 331 |                 "inside evaluate_symbolic_candidate()."
 332 |             )
 333 | 
 334 |     eval_fns = [
 335 |         node
 336 |         for node in tree.body
 337 |         if isinstance(node, ast.FunctionDef) and node.name == "evaluate_symbolic_candidate"
 338 |     ]
 339 |     if len(eval_fns) != 1:
 340 |         raise ValueError(
