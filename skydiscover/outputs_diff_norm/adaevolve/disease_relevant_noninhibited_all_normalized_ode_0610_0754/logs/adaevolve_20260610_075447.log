import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all_normalized_ode.evaluator import load_all_datasets, evaluate_ode_expression
import sympy as sp
from pysr_harness.equation_session import feature_symbols, constant_symbols, single_equation_evaluation

datasets = load_all_datasets()

# Test c0 * x1^c1 * (c + c2) * (1 - c) - power law concentration dependence
results = []
for name, X_train, X_val, y_train, y_val in datasets:
    x = feature_symbols(3)
    c = constant_symbols(3)
    conc = x[2]
    param = x[1]
    expr = c[0] * (param ** c[1]) * (conc + c[2]) * (1 - conc)
    try:
        with single_equation_evaluation():
            r = evaluate_ode_expression(expr, X_train, y_train, X_val, y_val, constants=c, initial_values=[1.0, 1.0, 0.01])
        results.append((r['nmse_val'], name, r['complexity']))
    except Exception as e:
        results.append((99.0, name + ' ERR:'+str(e)[:30], 0))

results.sort(reverse=True)
print('Power-law x1^c1 - Top 5 hardest:')
for nmse, name, cx in results[:5]:
    print(f'  {nmse:.4f}  {name}  cx={cx}')
print('Mean NMSE:', np.mean([r[0] for r in results]))
