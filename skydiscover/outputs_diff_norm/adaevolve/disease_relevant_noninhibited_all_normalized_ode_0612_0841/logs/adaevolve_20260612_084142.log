 904 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 905 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 906 |     raw_nmse_vals = [float(r["nmse_val"]) for r in per_dataset_results.values()]
 907 |     nmse_vals = list(raw_nmse_vals)
 908 |     train_nmse_vals = [
 909 |         float(r["nmse_train"])
 910 |         for r in per_dataset_results.values()
 911 |         if np.isfinite(float(r.get("nmse_train", float("inf"))))
 912 |     ]
 913 |     complexity_vals = []
 914 |     for r in per_dataset_results.values():
 915 |         try:
 916 |             value = float(r.get("complexity", float("nan")))
 917 |         except (TypeError, ValueError):
 918 |             continue
 919 |         if np.isfinite(value):
 920 |             complexity_vals.append(value)
 921 |     aggregate_complexity = float(max(complexity_vals)) if complexity_vals else 0.0
 922 | 
 923 |     violation_errors = sorted(
 924 |         {
 925 |             str(r.get("error"))
 926 |             for r in per_dataset_results.values()
 927 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 928 |         }
 929 |     )
 930 |     failed_datasets = sorted(
 931 |         name
 932 |         for name, result in per_dataset_results.items()
 933 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 934 |     )
 935 |     templates = sorted(
 936 |         {
 937 |             str(r.get("equation_template"))
 938 |             for r in per_dataset_results.values()
 939 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 940 |         }
 941 |     )
 942 | 
 943 |     eq_template = ""
 944 |     for r in per_dataset_results.values():
 945 |         if r.get("equation"):
 946 |             eq_template = r["equation"]
 947 |             break
 948 | 
 949 |     hard_cases = [
 950 |         {"dataset": name, "nmse_val": float(result["nmse_val"])}
 951 |         for name, result in per_dataset_results.items()
 952 |         if np.isfinite(float(result.get("nmse_val", float("inf"))))
 953 |     ]
 954 |     hard_cases.sort(key=lambda item: item["nmse_val"], reverse=True)
 955 |     hard_cases = hard_cases[:5]
 956 |     hard_case_feedback = "; ".join(
 957 |         f"{case['dataset']} nmse={case['nmse_val']:.4g}" for case in hard_cases
 958 |     )
 959 | 
 960 |     violation_error = None
 961 |     if violation_errors:
 962 |         violation_error = violation_errors[0]
 963 |     elif failed_datasets:
 964 |         examples = ", ".join(failed_datasets[:3])
 965 |         violation_error = (
 966 |             "Single-equation violation: candidate failed on "
 967 |             f"{len(failed_datasets)}/{len(per_dataset_results)} datasets. "
 968 |             "Failed datasets are not dropped from the aggregate reward. "
 969 |             f"Examples: {examples}"
 970 |         )
 971 |     elif len(templates) > 1:
 972 |         examples = "; ".join(templates[:3])
 973 |         violation_error = (
 974 |             "Single-equation violation: evaluate_symbolic_candidate() produced "
 975 |             f"{len(templates)} distinct equation templates across datasets. "
 976 |             "The base equation must be identical for all datasets; only fitted "
 977 |             f"constants may vary. Example templates: {examples}"
 978 |         )
 979 | 
 980 |     if violation_error:
 981 |         agg_nmse = float("inf")
 982 |         mean_nmse = float("inf")
 983 |         agg_train_nmse = float("inf")
 984 |         agg_combined = 0.0
 985 |         n_successful = 0
 986 |     else:
 987 |         val_point_weights = [
 988 |             int(r.get("n_val_points", 0)) for r in per_dataset_results.values()
 989 |         ]
 990 |         mean_nmse = _point_weighted_mean(nmse_vals, val_point_weights)
 991 |         raw_mean_nmse = _point_weighted_mean(raw_nmse_vals, val_point_weights)
 992 |         eval_only_results = {
 993 |             name: result
 994 |             for name, result in per_dataset_results.items()
 995 |             if result.get("evaluation_only")
 996 |         }
 997 |         eval_only_nmse_vals = [
 998 |             float(result["nmse_val"])
 999 |             for result in eval_only_results.values()
1000 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
1001 |         ]
1002 |         eval_only_weights = [
1003 |             int(result.get("n_val_points", 0))
1004 |             for result in eval_only_results.values()
1005 |             if np.isfinite(float(result.get("nmse_val", float("inf"))))
1006 |         ]
1007 |         mean_nmse_eval_only = (
1008 |             _point_weighted_mean(eval_only_nmse_vals, eval_only_weights)
1009 |             if eval_only_nmse_vals
1010 |             else float("nan")
1011 |         )
1012 |         agg_nmse = mean_nmse
1013 |         agg_train_nmse = float(np.mean(train_nmse_vals)) if train_nmse_vals else float("inf")
1014 |         raw_combined = (
1015 |             float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
1016 |         )
1017 |         parsimony_factor = _parsimony_penalty_factor(aggregate_complexity)
1018 |         agg_combined = raw_combined * parsimony_factor
1019 |         n_successful = sum(1 for value in nmse_vals if np.isfinite(value))
1020 | 
1021 |     aggregated = {
1022 |         "equation": eq_template,
1023 |         "nmse_train": agg_train_nmse,
1024 |         "nmse_val": agg_nmse,
1025 |         "mean_nmse_val": mean_nmse,
1026 |         "mean_raw_nmse_val": raw_mean_nmse if not violation_error else float("inf"),
1027 |         "combined_score": agg_combined,
1028 |         "fit_score": raw_combined if not violation_error else 0.0,
1029 |         "complexity": aggregate_complexity,
1030 |         "parsimony_weight": PARSIMONY_WEIGHT,
1031 |         "parsimony_penalty_factor": (
1032 |             _parsimony_penalty_factor(aggregate_complexity) if not violation_error else 1.0
1033 |         ),
1034 |         "n_datasets": len(per_dataset_results),
1035 |         "n_successful": n_successful,
1036 |         "n_evaluation_only_datasets": len(
1037 |             [name for name, result in per_dataset_results.items() if result.get("evaluation_only")]
1038 |         ),
1039 |         "mean_nmse_eval_only": (
1040 |             mean_nmse_eval_only if not violation_error else float("inf")
1041 |         ),
1042 |         "eval_workers": NUM_WORKERS,
1043 |         "hard_cases": hard_cases,
1044 |         "hard_case_feedback": hard_case_feedback,
1045 |         "per_dataset": per_dataset_results,
1046 |     }
1047 |     if violation_error:
1048 |         aggregated["error"] = violation_error
1049 |     return aggregated
1050 | 
