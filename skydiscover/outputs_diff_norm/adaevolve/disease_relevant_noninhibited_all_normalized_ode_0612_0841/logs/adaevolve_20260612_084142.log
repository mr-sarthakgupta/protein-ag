1052 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
1053 |     """Evaluate a candidate program across ALL datasets in a subprocess.
1054 | 
1055 |     The subprocess loads every dataset, calls the candidate's
1056 |     evaluate_symbolic_candidate() once per dataset (fitting independent
1057 |     constants each time) using parallel threads, and returns aggregated
1058 |     metrics.
1059 |     """
1060 |     validate_candidate_source(program_path)
1061 |     harness_root = str(BENCHMARK_ROOT)
1062 |     evaluator_path = str(Path(__file__).resolve())
1063 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
1064 |         script = f"""
1065 | import importlib.util
1066 | import os
1067 | import pickle
1068 | import sys
1069 | import traceback
1070 | from concurrent.futures import ThreadPoolExecutor, as_completed
1071 | 
1072 | os.environ.setdefault("OMP_NUM_THREADS", "1")
1073 | os.environ.setdefault("MKL_NUM_THREADS", "1")
1074 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
1075 | 
1076 | import numpy as np
1077 | 
1078 | sys.path.insert(0, {harness_root!r})
1079 | 
1080 | program_path = {program_path!r}
1081 | evaluator_path = {evaluator_path!r}
1082 | results_path = {temp_file.name + ".results"!r}
1083 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
1084 | 
1085 | def _write_payload_and_exit(payload):
1086 |     with open(results_path, "wb") as f:
1087 |         pickle.dump(payload, f)
1088 |     sys.stdout.flush()
1089 |     sys.stderr.flush()
1090 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
1091 |     # interpreter shutdown. The parent only needs the pickle payload.
1092 |     os._exit(0)
1093 | 
1094 | try:
1095 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
1096 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
1097 |     evaluator_spec.loader.exec_module(evaluator)
1098 |     evaluator.validate_candidate_source(program_path)
1099 | 
1100 |     import pysr_harness.equation_session as equation_session
1101 |     equation_session.evaluate_expression = evaluator.evaluate_ode_expression
1102 |     equation_session.nmse = evaluator._nmse_with_gaussian_smoothed_target
1103 |     spec = importlib.util.spec_from_file_location("program", program_path)
1104 |     program = importlib.util.module_from_spec(spec)
1105 |     spec.loader.exec_module(program)
1106 |     from pysr_harness.equation_session import (
1107 |         single_equation_evaluation,
1108 |         validate_single_equation_result,
1109 |     )
1110 | 
1111 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1112 |         program, "run_discovery", None
1113 |     )
1114 |     if fn is None:
1115 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
1116 | 
1117 |     datasets = evaluator.load_all_datasets()
1118 | 
1119 |     def _eval_one(args):
1120 |         ds_name, X_train, X_val, y_train, y_val = args
1121 |         try:
1122 |             with single_equation_evaluation():
1123 |                 result = fn(X_train, y_train, X_val, y_val)
1124 |                 validate_single_equation_result(result)
1125 |             ds_nmse = float(result.get("nmse_val", float("inf")))
1126 |             ds_train_nmse = float(result.get("nmse_train", float("inf")))
1127 |             ds_combined = float(result.get("combined_score", 0.0))
1128 |             return ds_name, {{
1129 |                 "nmse_train": ds_train_nmse,
