import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all_normalized_ode.evaluator import load_all_datasets, evaluate_ode_expression
from pysr_harness.equation_session import _complexity
import sympy as sp

datasets = load_all_datasets()
ds_map = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2 = sp.symbols('c0 c1 c2')

hard = ['Alphasyn_Gaspar2017/03uM_seed all', 'insulin/Fits/Nielsen2001_seeded_sec',
        'serum amyloid/Ye2011/Fits/Ye2011_sec', 'Abeta/Meisl2014/Ab40_sec_IN_HOURS']

def score_hard(expr, consts, iv, label):
    nmses = []
    for name in hard:
        X_train, X_val, y_train, y_val = ds_map[name]
        r = evaluate_ode_expression(expr, X_train, y_train, X_val, y_val, constants=consts, initial_values=iv)
        nmses.append(r['nmse_val'])
    c = _complexity(expr)
    print(f'{label}(c={c}): hard_mean={np.mean(nmses):.4f}  per={[f\"{v:.4f}\" for v in nmses]}')

# Current baseline
score_hard((1-x2)*(c2+(c0+c1*x1)*x2), [c0,c1,c2], [1.0,0.5,0.1], 'current')

# Try using x1 in a way that captures the nonlinearity at lower complexity
# Idea: use c1*(x1+x1*x2) -- x1 modulates both primary and secondary
score_hard((1-x2)*(c2+c0*x2+c1*x1*x2), [c0,c1,c2], [1.0,0.5,0.1], 'x1_elong_only')

# Idea: x1 enters via (c0+c1*x1)*(1+x2)*(1-x2) -- different saturation
score_hard((c0+c1*x1)*(1-x2**2), [c0,c1,c2], [1.0,0.5,0.1], 'diff_sat_1mx2sq')

# Idea: use x2*(x1+x2) as the growth driver
score_hard((1-x2)*(c2+(c0+c1*(x1+x2))*x2), [c0,c1,c2], [1.0,0.5,0.1], 'x1_plus_x2')

# Idea: c0*(x1+x2)*(1-x2) + c1*x2*(1-x2)
score_hard((1-x2)*(c0*(x1+x2)+c1*x2), [c0,c1,c2], [1.0,0.5,0.1], 'x1_x2_sum')

# Idea: (1-x2)*(c2+c0*x2*(1+c1*x1)) -- factored differently
score_hard((1-x2)*c2*(1+c0*x1*x2+c1*x2), [c0,c1,c2], [1.0,0.5,0.1], 'factored_c2')
" 2>/dev/null
