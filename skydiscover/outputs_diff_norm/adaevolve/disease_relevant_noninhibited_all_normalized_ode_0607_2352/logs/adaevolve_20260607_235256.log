import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all_normalized_ode.evaluator import load_all_datasets, evaluate_ode_expression
import sympy as sp

datasets = load_all_datasets()
ds_map = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2 = sp.symbols('c0 c1 c2')

hard = ['Alphasyn_Gaspar2017/03uM_seed all', 'insulin/Fits/Nielsen2001_seeded_sec',
        'serum amyloid/Ye2011/Fits/Ye2011_sec', 'Abeta/Meisl2014/Ab40_sec_IN_HOURS']

def score_hard(expr, consts, iv, label):
    nmses = []
    for name in hard:
        X_train, X_val, y_train, y_val = ds_map[name]
        r = evaluate_ode_expression(expr, X_train, y_train, X_val, y_val, constants=consts, initial_values=iv)
        nmses.append(r['nmse_val'])
    compl = r['complexity']
    print(f'{label}: hard_mean={np.mean(nmses):.4f} c={int(compl)}  per={[f\"{v:.4f}\" for v in nmses]}')

score_hard((1-x2)*(c2+(c0+c1*x1)*x2), [c0,c1,c2], [1.0,0.5,0.1], 'current(c=15)')
score_hard((1-x2)*(c2+(c0+c1*sp.sqrt(x1))*x2), [c0,c1,c2], [1.0,0.5,0.1], 'sqrt_x1(c=17)')
# x1*(2-x1): concave quadratic, maps [0,1]->[0,1], similar shape to sqrt
score_hard((1-x2)*(c2+(c0+c1*x1*(2-x1))*x2), [c0,c1,c2], [1.0,0.5,0.1], 'x1(2-x1)(c=17)')
# Can we fold sqrt into fewer nodes? Try sp.sqrt(x1+x2) - unlikely useful
# What about x1/(x1+c2) - Michaelis-Menten saturation of x1
score_hard((1-x2)*(c2+c0*x1/(x1+c1)*x2), [c0,c1,c2], [5.0,0.5,0.1], 'MM_x1(c=15?)')
# Separate x1-dep elongation and x1-indep: same as current, just reordered
# What about: (c0+c1*x1)*(1-x2)*(c2+x2) -- product form with c2 offset
score_hard((c0+c1*x1)*(1-x2)*(c2+x2), [c0,c1,c2], [1.0,0.5,0.1], 'product(c=14)')
" 2>/dev/null
