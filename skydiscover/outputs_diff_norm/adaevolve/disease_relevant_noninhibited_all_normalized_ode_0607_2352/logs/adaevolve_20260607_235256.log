import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all_normalized_ode.evaluator import load_all_datasets, evaluate_ode_expression, _ode_predictions
import sympy as sp

datasets = load_all_datasets()
ds_map = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2 = sp.symbols('c0 c1 c2')

name = 'insulin/Fits/Nielsen2001_seeded_sec'
X_train, X_val, y_train, y_val = ds_map[name]

# Fit with current expression and examine trajectory
expr = (1-x2)*(c2+(c0+c1*x1)*x2)
r = evaluate_ode_expression(expr, X_train, y_train, X_val, y_val, constants=[c0,c1,c2], initial_values=[1.0,0.5,0.1])
print(f'Fitted: c0={r[\"constants\"][\"c0\"]:.4f}, c1={r[\"constants\"][\"c1\"]:.4f}, c2={r[\"constants\"][\"c2\"]:.4f}')

# Build rhs and predict manually
theta = np.array([r['constants']['c0'], r['constants']['c1'], r['constants']['c2']])
rhs = sp.lambdify([x0,x1,x2,c0,c1,c2], expr, modules=['numpy'])

# Show predictions at val time points
from scipy.integrate import odeint
import warnings
param = np.unique(X_val[:,1])[0]
idx_v = np.where(X_val[:,1]==param)[0]
idx_v = idx_v[np.argsort(X_val[idx_v,0])]
t_v = X_val[idx_v,0]
y_v = y_val[idx_v]

def dc_dt(c_state, t):
    v = rhs(t, param, float(c_state[0]), *theta)
    return [v]

with warnings.catch_warnings():
    warnings.simplefilter('ignore')
    pred = odeint(dc_dt, [y_v[0]], t_v, mxstep=1000)

pred = pred.ravel()
print('t, y_true, y_pred:')
for i in range(0, len(t_v), 5):
    print(f'  t={t_v[i]:.3f}  y={y_v[i]:.4f}  pred={pred[i]:.4f}  diff={y_v[i]-pred[i]:.4f}')
print(f'Val NMSE check: {np.mean((y_v-pred)**2)/np.var(np.concatenate([y_train,y_val])):.4f}')
