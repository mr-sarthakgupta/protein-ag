 119 | def _is_main_guard(node: ast.AST) -> bool:
 120 |     if not isinstance(node, ast.If):
 121 |         return False
 122 |     if node.orelse:
 123 |         return False
 124 |     test = node.test
 125 |     if not isinstance(test, ast.Compare) or len(test.ops) != 1 or len(test.comparators) != 1:
 126 |         return False
 127 |     if not isinstance(test.ops[0], ast.Eq):
 128 |         return False
 129 |     left = test.left
 130 |     right = test.comparators[0]
 131 |     return (
 132 |         isinstance(left, ast.Name)
 133 |         and left.id == "__name__"
 134 |         and isinstance(right, ast.Constant)
 135 |         and right.value == "__main__"
 136 |     )
