 571 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 572 | PARSIMONY_WEIGHT = float(os.environ.get("SKYDISCOVER_PARSIMONY_WEIGHT", "0.20"))
 573 | PARSIMONY_COMPLEXITY_SCALE = float(
 574 |     os.environ.get("SKYDISCOVER_PARSIMONY_COMPLEXITY_SCALE", "160")
 575 | )
 576 | 
 577 | 
 578 | def _parsimony_penalty_factor(complexity: float) -> float:
 579 |     """Bounded penalty factor for expression complexity."""
 580 |     if not np.isfinite(complexity) or PARSIMONY_COMPLEXITY_SCALE <= 0:
 581 |         return 1.0
 582 |     normalized = min(max(float(complexity), 0.0) / PARSIMONY_COMPLEXITY_SCALE, 1.0)
 583 |     return max(0.0, 1.0 - PARSIMONY_WEIGHT * normalized)
 584 | 
 585 | 
 586 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 587 |     values = np.asarray(values, dtype=float).ravel()
 588 |     if values.size < 3 or sigma <= 0.0:
 589 |         return values
 590 |     radius = max(1, int(round(3.0 * sigma)))
 591 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 592 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 593 |     kernel /= np.sum(kernel)
 594 |     padded = np.pad(values, (radius, radius), mode="edge")
 595 |     return np.convolve(padded, kernel, mode="valid")
 596 | 
 597 | 
 598 | def _curve_smoothed_target(X: np.ndarray, y_true: np.ndarray) -> np.ndarray:
 599 |     """Smooth targets independently for each parameter curve in time order."""
 600 |     X = np.asarray(X, dtype=float)
 601 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 602 |     if X.shape[0] != y_true.shape[0] or X.shape[1] < 2:
 603 |         return _gaussian_smooth_1d(y_true)
 604 | 
 605 |     smoothed = np.empty_like(y_true, dtype=float)
 606 |     for parameter in np.unique(X[:, 1]):
 607 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 608 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 609 |         smoothed_curve = _gaussian_smooth_1d(y_true[ordered_idx])
 610 |         smoothed[ordered_idx] = smoothed_curve
 611 |     return smoothed
 612 | 
 613 | 
 614 | def _normalized_mse_with_reference_variance(
 615 |     y_true: np.ndarray,
 616 |     y_pred: np.ndarray,
 617 |     reference_values: np.ndarray,
 618 | ) -> float:
 619 |     """MSE normalized by full dataset scale, not by a flat validation segment."""
 620 |     y_true = np.asarray(y_true, dtype=float).reshape(-1)
 621 |     y_pred = np.asarray(y_pred, dtype=float).reshape(-1)
 622 |     reference_values = np.asarray(reference_values, dtype=float).reshape(-1)
 623 |     if y_true.shape != y_pred.shape:
 624 |         return float("inf")
 625 |     if not np.all(np.isfinite(y_pred)):
 626 |         return float("inf")
 627 |     var = float(np.var(reference_values))
 628 |     if var <= 0.0:
 629 |         return float(np.mean((y_true - y_pred) ** 2))
 630 |     return float(np.mean((y_true - y_pred) ** 2) / var)
 631 | 
 632 | 
 633 | def _nmse_with_gaussian_smoothed_target(
 634 |     y_true: np.ndarray,
 635 |     y_pred: np.ndarray,
 636 |     X: np.ndarray | None = None,
 637 |     reference_values: np.ndarray | None = None,
 638 | ) -> float:
 639 |     reference = y_true if reference_values is None else reference_values
 640 |     raw_loss = _normalized_mse_with_reference_variance(y_true, y_pred, reference)
 641 |     smooth_target = _curve_smoothed_target(X, y_true) if X is not None else _gaussian_smooth_1d(y_true)
 642 |     smooth_loss = _normalized_mse_with_reference_variance(smooth_target, y_pred, reference)
 643 |     return float((raw_loss + smooth_loss) / 2.0)
 644 | 
 645 | 
 646 | def _ode_predictions(
 647 |     rhs_fn: Any,
 648 |     X: np.ndarray,
 649 |     y_known: np.ndarray,
 650 |     theta: np.ndarray,
 651 | ) -> np.ndarray:
 652 |     """Integrate dc/dt=f(t, parameter, c) per parameter curve on one split."""
 653 |     import warnings
 654 | 
 655 |     from scipy.integrate import odeint
 656 | 
 657 |     X = np.asarray(X, dtype=float)
 658 |     y_known = np.asarray(y_known, dtype=float).reshape(-1)
 659 |     theta = np.asarray(theta, dtype=float).reshape(-1)
 660 |     predictions = np.full_like(y_known, np.nan, dtype=float)
 661 | 
 662 |     for parameter in np.unique(X[:, 1]):
 663 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 664 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 665 |         times = X[ordered_idx, 0]
 666 |         observed = y_known[ordered_idx]
 667 | 
 668 |         if len(ordered_idx) == 1 or float(times[-1] - times[0]) <= 0.0:
 669 |             predictions[ordered_idx] = observed[0]
 670 |             continue
 671 | 
 672 |         def dc_dt(c_state: np.ndarray, time_value: float) -> float:
 673 |             c_value = float(np.asarray(c_state, dtype=float).reshape(-1)[0])
 674 |             value = rhs_fn(float(time_value), float(parameter), c_value, *theta)
 675 |             value = float(np.asarray(value, dtype=float).reshape(-1)[0])
 676 |             if not np.isfinite(value):
 677 |                 raise FloatingPointError("non-finite ODE derivative")
 678 |             return value
 679 | 
 680 |         with warnings.catch_warnings():
 681 |             warnings.simplefilter("ignore")
 682 |             integrated = odeint(
 683 |                 dc_dt,
 684 |                 float(observed[0]),
 685 |                 times,
 686 |                 mxstep=1000,
 687 |             )
 688 |         curve_pred = np.asarray(integrated, dtype=float).reshape(-1)
 689 |         if curve_pred.shape != observed.shape or not np.all(np.isfinite(curve_pred)):
 690 |             raise FloatingPointError("non-finite ODE trajectory")
 691 |         predictions[ordered_idx] = curve_pred
 692 | 
 693 |     return predictions
 694 | 
 695 | 
 696 | def evaluate_ode_expression(
 697 |     expression: Any,
 698 |     X_train: np.ndarray,
 699 |     y_train: np.ndarray,
 700 |     X_val: np.ndarray,
 701 |     y_val: np.ndarray,
 702 |     *,
 703 |     constants: Any | None = None,
 704 |     initial_values: Any | None = None,
 705 |     max_nfev: int = 300,
 706 | ) -> dict[str, Any]:
 707 |     """Score a proposed ODE RHS by integrating predicted concentration curves."""
 708 |     import sympy as sp
 709 |     from pysr_harness import equation_session
 710 |     from scipy.optimize import least_squares
 711 | 
 712 |     X_train = np.asarray(X_train, dtype=float)
 713 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 714 |     X_val = np.asarray(X_val, dtype=float)
 715 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 716 |     y_reference = np.concatenate([y_train, y_val])
 717 |     feature_names = [f"x{i}" for i in range(X_train.shape[1])]
 718 |     template = equation_session._as_sympy_expr(expression, feature_names)
 719 |     equation_session._record_scored_template(template)
 720 | 
 721 |     if constants is None:
 722 |         feature_set = set(equation_session.feature_symbols(X_train.shape[1]))
 723 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 724 |     constants = list(constants)
 725 |     equation_session._validate_expression_template(template, constants)
 726 | 
 727 |     if initial_values is None:
 728 |         base_x0 = np.ones(len(constants), dtype=float)
 729 |     else:
 730 |         base_x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 731 |         if base_x0.size != len(constants):
 732 |             raise ValueError("initial_values must match the number of constants")
 733 | 
 734 |     feature_syms = equation_session.feature_symbols(X_train.shape[1])
 735 |     rhs_fn = sp.lambdify(feature_syms + constants, template, modules=["numpy"])
 736 | 
 737 |     if not constants:
 738 |         y_pred_train = _ode_predictions(rhs_fn, X_train, y_train, np.asarray([], dtype=float))
 739 |         y_pred_val = _ode_predictions(rhs_fn, X_val, y_val, np.asarray([], dtype=float))
 740 |         nmse_train = _nmse_with_gaussian_smoothed_target(
 741 |             y_train, y_pred_train, X_train, y_reference
 742 |         )
 743 |         nmse_val = _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 744 |         result = {
 745 |             "equation_template": f"d(c)/dt = {template}",
 746 |             "equation": f"d(c)/dt = {template}",
 747 |             "constants": {},
 748 |             "loss": float(np.mean((y_pred_train - y_train) ** 2)),
 749 |             "complexity": equation_session._complexity(template),
 750 |             "nmse_train": nmse_train,
 751 |             "nmse_val": nmse_val,
 752 |             "combined_score": combined_score_from_nmse(nmse_val),
 753 |         }
 754 |         equation_session._record_scorer_result(result)
 755 |         return result
 756 | 
 757 |     def residual(theta: np.ndarray) -> np.ndarray:
 758 |         try:
 759 |             prediction = _ode_predictions(rhs_fn, X_train, y_train, theta)
 760 |         except Exception:
 761 |             return np.full_like(y_train, 1e12, dtype=float)
 762 |         if prediction.shape != y_train.shape or not np.all(np.isfinite(prediction)):
 763 |             return np.full_like(y_train, 1e12, dtype=float)
 764 |         return prediction - y_train
 765 | 
 766 |     initial_candidates: list[np.ndarray] = []
 767 |     for scale in ODE_MULTISTART_SCALES or (1.0,):
 768 |         candidate = base_x0 * float(scale)
 769 |         if not any(np.array_equal(candidate, existing) for existing in initial_candidates):
 770 |             initial_candidates.append(candidate)
 771 | 
 772 |     import warnings
 773 | 
 774 |     best_fit = None
 775 |     best_loss = float("inf")
 776 |     with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 777 |         warnings.simplefilter("ignore", RuntimeWarning)
 778 |         for initial_candidate in initial_candidates:
 779 |             fit = least_squares(
 780 |                 residual,
 781 |                 initial_candidate,
 782 |                 loss="soft_l1",
 783 |                 max_nfev=max_nfev,
 784 |             )
 785 |             fit_residual = residual(fit.x)
 786 |             fit_loss = float(np.mean(fit_residual**2))
 787 |             if fit_loss < best_loss:
 788 |                 best_loss = fit_loss
 789 |                 best_fit = fit
 790 | 
 791 |     if best_fit is None:
 792 |         raise RuntimeError("constant fitting did not produce a result")
 793 | 
 794 |     fitted_constants = {
 795 |         str(symbol): float(value) for symbol, value in zip(constants, best_fit.x)
 796 |     }
 797 |     substitutions = dict(zip(constants, best_fit.x))
 798 |     fitted_expr = template.subs(substitutions)
 799 |     y_pred_train = _ode_predictions(rhs_fn, X_train, y_train, best_fit.x)
 800 |     y_pred_val = _ode_predictions(rhs_fn, X_val, y_val, best_fit.x)
 801 |     nmse_train = _nmse_with_gaussian_smoothed_target(
 802 |         y_train, y_pred_train, X_train, y_reference
 803 |     )
 804 |     nmse_val = _nmse_with_gaussian_smoothed_target(y_val, y_pred_val, X_val, y_reference)
 805 |     loss = float(np.mean((y_pred_train - y_train) ** 2))
 806 | 
 807 |     result = {
 808 |         "equation_template": f"d(c)/dt = {template}",
 809 |         "equation": f"d(c)/dt = {fitted_expr}",
 810 |         "constants": fitted_constants,
 811 |         "loss": loss,
 812 |         "complexity": equation_session._complexity(template),
 813 |         "nmse_train": nmse_train,
 814 |         "nmse_val": nmse_val,
 815 |         "combined_score": combined_score_from_nmse(nmse_val),
 816 |     }
 817 |     equation_session._record_scorer_result(result)
 818 |     return result
 819 | 
