1169 | def _eval_stage1_worker(args):
1170 |     """Module-level worker for stage 1 parallel evaluation."""
1171 |     name, X_train, X_val, y_train, y_val, program_path = args
1172 |     harness_root = str(BENCHMARK_ROOT)
1173 |     if harness_root not in sys.path:
1174 |         sys.path.insert(0, harness_root)
