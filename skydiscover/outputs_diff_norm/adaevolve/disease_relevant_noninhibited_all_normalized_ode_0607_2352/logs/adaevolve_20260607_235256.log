 452 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 453 |     """Load a wide fit.tsv and return X=[normalized time, raw parameter, c], y.
 454 | 
 455 |     The first column is always the time/measurement coordinate. Remaining
 456 |     columns are response curves. The varying parameter is extracted from
 457 |     concentration-like curve headers only; non-concentration columns are skipped.
 458 |     Time is min-max normalized to 0..1, but the parameter column is left in its
 459 |     parsed raw units. The response is normalized globally across the whole
 460 |     fit.tsv to 0..1. Files already rescaled to 0..1 keep that scale.
 461 |     """
 462 |     with data_file.open(newline="") as f:
 463 |         reader = csv.reader(f, delimiter="\t")
 464 |         header = next(reader)
 465 | 
 466 |         response_headers = header[1:]
 467 |         parsed_params = [_parse_parameter_from_column(h) for h in response_headers]
 468 | 
 469 |         features: list[list[float]] = []
 470 |         targets: list[float] = []
 471 |         for row in reader:
 472 |             if not row:
 473 |                 continue
 474 |             measurement_x = float(row[0])
 475 |             for param, value in zip(parsed_params, row[1:]):
 476 |                 if param is None:
 477 |                     continue
 478 |                 if value == "" or value.strip().lower() == "nan":
 479 |                     continue
 480 |                 features.append([measurement_x, param])
 481 |                 targets.append(float(value))
 482 | 
 483 |     if not features:
 484 |         raise ValueError(f"No regression samples loaded from {data_file}")
 485 | 
 486 |     X = np.asarray(features, dtype=float)
 487 |     y = np.asarray(targets, dtype=float)
 488 |     time_norm = _minmax_normalize(X[:, 0])
 489 |     parameter_raw = X[:, 1]
 490 |     y_norm = _minmax_normalize(y)
 491 | 
 492 |     # x2 is the concentration state c used by ODE RHS templates. During scoring
 493 |     # it is supplied from odeint's dynamic state, not read from candidate code.
 494 |     X_ode = np.column_stack([time_norm, parameter_raw, y_norm])
 495 |     return X_ode, y_norm
