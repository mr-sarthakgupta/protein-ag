1114 |         "hard_case_tail_nmse": float(result.get("hard_case_tail_nmse", 0.0)),
1115 |         "hard_case_tail_weight": float(result.get("hard_case_tail_weight", HARD_CASE_TAIL_WEIGHT)),
1116 |         "per_dataset_nmse_cap": float(result.get("per_dataset_nmse_cap", PER_DATASET_NMSE_CAP)),
1117 |         "per_dataset": result.get("per_dataset", {}),
