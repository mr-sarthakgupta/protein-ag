sys.path.insert(0, '.')
from disease_relevant_noninhibited_all_normalized_ode.evaluator import load_all_datasets, evaluate_ode_expression, _ode_predictions
import sympy as sp

datasets = load_all_datasets()
ds_map = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2 = sp.symbols('c0 c1 c2')

name = 'insulin/Fits/Nielsen2001_seeded_sec'
X_train, X_val, y_train, y_val = ds_map[name]
print(f'Train: {X_train.shape}, Val: {X_val.shape}')
print(f'Train t range: [{X_train[:,0].min():.3f}, {X_train[:,0].max():.3f}]')
print(f'Val t range: [{X_val[:,0].min():.3f}, {X_val[:,0].max():.3f}]')
print(f'Train y range: [{y_train.min():.4f}, {y_train.max():.4f}]')
print(f'Val y range: [{y_val.min():.4f}, {y_val.max():.4f}]')
print(f'x1 unique: {np.unique(X_train[:,1])}')

# Show the data shape - is it monotonically increasing?
idx = np.argsort(X_train[:,0])
t_tr = X_train[idx,0]
