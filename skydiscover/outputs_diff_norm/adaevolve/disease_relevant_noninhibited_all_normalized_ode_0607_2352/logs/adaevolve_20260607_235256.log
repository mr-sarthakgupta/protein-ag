1106 |         "parsimony_weight": float(result.get("parsimony_weight", PARSIMONY_WEIGHT)),
1107 |         "parsimony_penalty_factor": float(result.get("parsimony_penalty_factor", 1.0)),
1108 |         "eval_time": float(eval_time),
1109 |         "n_datasets": result.get("n_datasets", 0),
1110 |         "n_successful": result.get("n_successful", 0),
1111 |         "eval_workers": result.get("eval_workers", NUM_WORKERS),
1112 |         "hard_cases": result.get("hard_cases", []),
