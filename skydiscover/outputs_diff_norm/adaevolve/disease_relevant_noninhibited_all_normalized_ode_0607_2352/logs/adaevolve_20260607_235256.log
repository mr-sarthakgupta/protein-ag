 511 | def _trajectory_preserving_split(
 512 |     X: np.ndarray,
 513 |     y: np.ndarray,
 514 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 515 |     """Split by full parameter curves, using late-time holdout for <3 curves."""
 516 |     parameters = np.unique(X[:, 1])
 517 |     rng = np.random.default_rng(RANDOM_STATE)
 518 | 
 519 |     if len(parameters) >= 3:
 520 |         shuffled = parameters[rng.permutation(len(parameters))]
 521 |         n_val = min(max(1, int(round(len(parameters) * TEST_SIZE))), len(parameters) - 1)
 522 |         val_params = set(float(p) for p in shuffled[:n_val])
 523 |         val_mask = np.array([float(p) in val_params for p in X[:, 1]], dtype=bool)
 524 |         train_idx = np.flatnonzero(~val_mask)
 525 |         val_idx = np.flatnonzero(val_mask)
 526 |         return X[train_idx], X[val_idx], y[train_idx], y[val_idx]
 527 | 
 528 |     train_indices: list[int] = []
 529 |     val_indices: list[int] = []
 530 |     for parameter in parameters:
 531 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 532 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 533 |         if len(ordered_idx) == 1:
 534 |             train_indices.extend(ordered_idx.tolist())
 535 |             val_indices.extend(ordered_idx.tolist())
 536 |             continue
 537 | 
 538 |         split = int(round(len(ordered_idx) * (1.0 - TEST_SIZE)))
 539 |         split = min(max(split, 1), len(ordered_idx) - 1)
 540 |         train_indices.extend(ordered_idx[:split].tolist())
 541 |         # Include the last training point so validation integration starts from
 542 |         # the known boundary state before predicting the held-out late segment.
 543 |         val_indices.extend(ordered_idx[split - 1 :].tolist())
 544 | 
 545 |     train_idx = np.sort(np.asarray(train_indices, dtype=int))
 546 |     val_idx = np.sort(np.asarray(val_indices, dtype=int))
 547 |     return X[train_idx], X[val_idx], y[train_idx], y[val_idx]
 548 | 
 549 | 
 550 | def load_dataset(data_file: Path) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 551 |     """Load a single fit.tsv and return deterministic trajectory-preserving split."""
 552 |     X, y = _load_fit_table(data_file)
 553 |     return _trajectory_preserving_split(X, y)
