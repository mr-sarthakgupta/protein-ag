1176 |     import pysr_harness.equation_session as equation_session
1177 |     equation_session.evaluate_expression = evaluate_ode_expression
1178 |     equation_session.nmse = _nmse_with_gaussian_smoothed_target
1179 |     spec = importlib.util.spec_from_file_location("program", program_path)
1180 |     program = importlib.util.module_from_spec(spec)
1181 |     spec.loader.exec_module(program)
1182 |     from pysr_harness.equation_session import (
1183 |         single_equation_evaluation,
1184 |         validate_single_equation_result,
1185 |     )
1186 | 
1187 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1188 |         program, "run_discovery", None
1189 |     )
1190 |     if fn is None:
1191 |         return 0.0, "missing evaluate_symbolic_candidate()", ""
1192 |     try:
