 186 | def _call_name(func: ast.AST) -> str:
 187 |     if isinstance(func, ast.Name):
 188 |         return func.id
 189 |     if isinstance(func, ast.Attribute) and isinstance(func.value, ast.Name):
 190 |         return f"{func.value.id}.{func.attr}"
 191 |     return ""
 192 | 
 193 | 
 194 | def _assigned_names(target: ast.AST) -> set[str]:
 195 |     if isinstance(target, ast.Name):
 196 |         return {target.id}
 197 |     if isinstance(target, (ast.Tuple, ast.List)):
 198 |         names: set[str] = set()
 199 |         for elt in target.elts:
 200 |             names.update(_assigned_names(elt))
 201 |         return names
 202 |     return set()
 203 | 
 204 | 
 205 | def _validate_plain_import(alias: ast.alias) -> None:
 206 |     if alias.name not in _ALLOWED_IMPORTS:
 207 |         raise ValueError(
 208 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: import '{alias.name}' is not allowed. "
 209 |             "Candidates may only import sympy/numpy and the equation harness."
 210 |         )
 211 |     if alias.name == "sympy" and alias.asname != "sp":
 212 |         raise ValueError(
 213 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: sympy must be imported canonically "
 214 |             "as 'import sympy as sp'."
 215 |         )
 216 |     if alias.name == "numpy" and alias.asname not in {None, "np"}:
 217 |         raise ValueError(
 218 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: numpy may only be imported as "
 219 |             "'import numpy' or 'import numpy as np'."
 220 |         )
 221 | 
 222 | 
 223 | def _validate_evaluate_expression_data_args(call: ast.Call) -> set[int]:
 224 |     expected = ["X_train", "y_train", "X_val", "y_val"]
 225 |     if len(call.args) < 5:
 226 |         raise ValueError(
 227 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must be called "
 228 |             "as evaluate_expression(expression, X_train, y_train, X_val, y_val, ...)."
 229 |         )
 230 |     actual_data_args = call.args[1:5]
 231 |     if not all(
 232 |         isinstance(arg, ast.Name) and arg.id == expected_name
 233 |         for arg, expected_name in zip(actual_data_args, expected)
 234 |     ):
 235 |         raise ValueError(
 236 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_expression() must use the "
 237 |             "canonical data arguments exactly as X_train, y_train, X_val, y_val. "
 238 |             "Do not fit constants on validation labels or reorder the split."
 239 |         )
 240 |     return {id(arg) for arg in call.args[1:5]}
 241 | 
 242 | 
 243 | def _x_train_shape_feature_arg_id(node: ast.AST) -> int | None:
 244 |     if not (
 245 |         isinstance(node, ast.Subscript)
 246 |         and isinstance(node.value, ast.Attribute)
 247 |         and node.value.attr == "shape"
 248 |         and isinstance(node.value.value, ast.Name)
 249 |         and node.value.value.id == "X_train"
 250 |     ):
 251 |         return None
 252 |     slice_node = node.slice
 253 |     if isinstance(slice_node, ast.Constant) and slice_node.value == 1:
 254 |         return id(node.value.value)
 255 |     return None
 256 | 
 257 | 
 258 | def _allowed_feature_symbols_data_ids(fn: ast.FunctionDef) -> set[int]:
 259 |     allowed: set[int] = set()
 260 |     for node in ast.walk(fn):
 261 |         if not (
 262 |             isinstance(node, ast.Call)
 263 |             and isinstance(node.func, ast.Name)
 264 |             and node.func.id == "feature_symbols"
 265 |             and len(node.args) == 1
 266 |         ):
 267 |             continue
 268 |         x_train_id = _x_train_shape_feature_arg_id(node.args[0])
 269 |         if x_train_id is not None:
 270 |             allowed.add(x_train_id)
 271 |     return allowed
 272 | 
 273 | 
 274 | def _validate_no_dataset_data_leak(fn: ast.FunctionDef, allowed_node_ids: set[int]) -> None:
 275 |     for node in ast.walk(fn):
 276 |         if (
 277 |             isinstance(node, ast.Name)
 278 |             and node.id in {"X_train", "y_train", "X_val", "y_val"}
 279 |             and id(node) not in allowed_node_ids
 280 |         ):
 281 |             raise ValueError(
 282 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: dataset array '{node.id}' may only "
 283 |                 "appear in feature_symbols(X_train.shape[1]) or as the canonical "
 284 |                 "evaluate_expression(expression, X_train, y_train, X_val, y_val, ...) "
 285 |                 "arguments. Do not use dataset values to choose expressions, mutate "
 286 |                 "splits, or tune constants/initial values."
 287 |             )
