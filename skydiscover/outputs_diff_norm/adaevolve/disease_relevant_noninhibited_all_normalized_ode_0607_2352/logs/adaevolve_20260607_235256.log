 821 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 822 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 823 |     raw_nmse_vals = [float(r["nmse_val"]) for r in per_dataset_results.values()]
 824 |     nmse_vals = [min(value, PER_DATASET_NMSE_CAP) for value in raw_nmse_vals]
 825 |     train_nmse_vals = [
 826 |         float(r["nmse_train"])
 827 |         for r in per_dataset_results.values()
 828 |         if np.isfinite(float(r.get("nmse_train", float("inf"))))
 829 |     ]
 830 |     complexity_vals = []
 831 |     for r in per_dataset_results.values():
 832 |         try:
 833 |             value = float(r.get("complexity", float("nan")))
 834 |         except (TypeError, ValueError):
 835 |             continue
 836 |         if np.isfinite(value):
 837 |             complexity_vals.append(value)
 838 |     aggregate_complexity = float(max(complexity_vals)) if complexity_vals else 0.0
 839 | 
 840 |     violation_errors = sorted(
 841 |         {
 842 |             str(r.get("error"))
 843 |             for r in per_dataset_results.values()
 844 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 845 |         }
 846 |     )
 847 |     failed_datasets = sorted(
 848 |         name
 849 |         for name, result in per_dataset_results.items()
 850 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 851 |     )
 852 |     templates = sorted(
 853 |         {
 854 |             str(r.get("equation_template"))
 855 |             for r in per_dataset_results.values()
 856 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 857 |         }
 858 |     )
 859 | 
 860 |     eq_template = ""
 861 |     for r in per_dataset_results.values():
 862 |         if r.get("equation"):
 863 |             eq_template = r["equation"]
 864 |             break
 865 | 
 866 |     hard_cases = [
 867 |         {"dataset": name, "nmse_val": float(result["nmse_val"])}
 868 |         for name, result in per_dataset_results.items()
 869 |         if np.isfinite(float(result.get("nmse_val", float("inf"))))
 870 |     ]
 871 |     hard_cases.sort(key=lambda item: item["nmse_val"], reverse=True)
 872 |     hard_cases = hard_cases[:5]
 873 |     hard_case_feedback = "; ".join(
 874 |         f"{case['dataset']} nmse={case['nmse_val']:.4g}" for case in hard_cases
 875 |     )
 876 |     hard_case_tail_nmse = (
 877 |         float(np.mean([case["nmse_val"] for case in hard_cases[:HARD_CASE_TAIL_COUNT]]))
 878 |         if hard_cases and HARD_CASE_TAIL_COUNT > 0
 879 |         else 0.0
 880 |     )
 881 | 
 882 |     violation_error = None
 883 |     if violation_errors:
 884 |         violation_error = violation_errors[0]
 885 |     elif failed_datasets:
 886 |         examples = ", ".join(failed_datasets[:3])
 887 |         violation_error = (
 888 |             "Single-equation violation: candidate failed on "
 889 |             f"{len(failed_datasets)}/{len(per_dataset_results)} datasets. "
 890 |             "Failed datasets are not dropped from the aggregate reward. "
 891 |             f"Examples: {examples}"
 892 |         )
 893 |     elif len(templates) > 1:
 894 |         examples = "; ".join(templates[:3])
 895 |         violation_error = (
 896 |             "Single-equation violation: evaluate_symbolic_candidate() produced "
 897 |             f"{len(templates)} distinct equation templates across datasets. "
 898 |             "The base equation must be identical for all datasets; only fitted "
 899 |             f"constants may vary. Example templates: {examples}"
 900 |         )
 901 | 
 902 |     if violation_error:
 903 |         agg_nmse = float("inf")
 904 |         mean_nmse = float("inf")
 905 |         agg_train_nmse = float("inf")
 906 |         agg_combined = 0.0
 907 |         n_successful = 0
 908 |     else:
 909 |         mean_nmse = float(np.mean(nmse_vals)) if nmse_vals else float("inf")
 910 |         raw_mean_nmse = float(np.mean(raw_nmse_vals)) if raw_nmse_vals else float("inf")
 911 |         agg_nmse = mean_nmse + HARD_CASE_TAIL_WEIGHT * hard_case_tail_nmse
 912 |         agg_train_nmse = float(np.mean(train_nmse_vals)) if train_nmse_vals else float("inf")
 913 |         raw_combined = (
 914 |             float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
 915 |         )
 916 |         parsimony_factor = _parsimony_penalty_factor(aggregate_complexity)
 917 |         agg_combined = raw_combined * parsimony_factor
 918 |         n_successful = sum(1 for value in nmse_vals if np.isfinite(value))
 919 | 
 920 |     aggregated = {
 921 |         "equation": eq_template,
 922 |         "nmse_train": agg_train_nmse,
 923 |         "nmse_val": agg_nmse,
 924 |         "mean_nmse_val": mean_nmse,
 925 |         "mean_raw_nmse_val": raw_mean_nmse if not violation_error else float("inf"),
 926 |         "combined_score": agg_combined,
 927 |         "fit_score": raw_combined if not violation_error else 0.0,
 928 |         "complexity": aggregate_complexity,
 929 |         "parsimony_weight": PARSIMONY_WEIGHT,
 930 |         "parsimony_penalty_factor": (
 931 |             _parsimony_penalty_factor(aggregate_complexity) if not violation_error else 1.0
 932 |         ),
 933 |         "n_datasets": len(per_dataset_results),
 934 |         "n_successful": n_successful,
 935 |         "eval_workers": NUM_WORKERS,
 936 |         "hard_cases": hard_cases,
 937 |         "hard_case_feedback": hard_case_feedback,
 938 |         "hard_case_tail_nmse": hard_case_tail_nmse,
 939 |         "hard_case_tail_weight": HARD_CASE_TAIL_WEIGHT,
 940 |         "per_dataset_nmse_cap": PER_DATASET_NMSE_CAP,
 941 |         "per_dataset": per_dataset_results,
 942 |     }
 943 |     if violation_error:
 944 |         aggregated["error"] = violation_error
 945 |     return aggregated
