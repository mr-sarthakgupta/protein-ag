 948 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 949 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 950 | 
 951 |     The subprocess loads every dataset, calls the candidate's
 952 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 953 |     constants each time) using parallel threads, and returns aggregated
 954 |     metrics.
 955 |     """
 956 |     validate_candidate_source(program_path)
 957 |     harness_root = str(BENCHMARK_ROOT)
 958 |     evaluator_path = str(Path(__file__).resolve())
 959 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
 960 |         script = f"""
 961 | import importlib.util
 962 | import os
 963 | import pickle
 964 | import sys
 965 | import traceback
 966 | from concurrent.futures import ThreadPoolExecutor, as_completed
 967 | 
 968 | os.environ.setdefault("OMP_NUM_THREADS", "1")
 969 | os.environ.setdefault("MKL_NUM_THREADS", "1")
 970 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
 971 | 
 972 | import numpy as np
 973 | 
 974 | sys.path.insert(0, {harness_root!r})
 975 | 
 976 | program_path = {program_path!r}
 977 | evaluator_path = {evaluator_path!r}
 978 | results_path = {temp_file.name + ".results"!r}
 979 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 980 | 
 981 | def _write_payload_and_exit(payload):
 982 |     with open(results_path, "wb") as f:
 983 |         pickle.dump(payload, f)
 984 |     sys.stdout.flush()
 985 |     sys.stderr.flush()
 986 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
 987 |     # interpreter shutdown. The parent only needs the pickle payload.
 988 |     os._exit(0)
 989 | 
 990 | try:
 991 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
 992 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
 993 |     evaluator_spec.loader.exec_module(evaluator)
 994 |     evaluator.validate_candidate_source(program_path)
 995 | 
 996 |     import pysr_harness.equation_session as equation_session
 997 |     equation_session.evaluate_expression = evaluator.evaluate_ode_expression
 998 |     equation_session.nmse = evaluator._nmse_with_gaussian_smoothed_target
 999 |     spec = importlib.util.spec_from_file_location("program", program_path)
1000 |     program = importlib.util.module_from_spec(spec)
1001 |     spec.loader.exec_module(program)
1002 |     from pysr_harness.equation_session import (
1003 |         single_equation_evaluation,
1004 |         validate_single_equation_result,
1005 |     )
1006 | 
1007 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1008 |         program, "run_discovery", None
1009 |     )
1010 |     if fn is None:
1011 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
1012 | 
1013 |     datasets = evaluator.load_all_datasets()
1014 | 
1015 |     def _eval_one(args):
1016 |         ds_name, X_train, X_val, y_train, y_val = args
1017 |         try:
1018 |             with single_equation_evaluation():
1019 |                 result = fn(X_train, y_train, X_val, y_val)
1020 |                 validate_single_equation_result(result)
1021 |             ds_nmse = float(result.get("nmse_val", float("inf")))
1022 |             ds_train_nmse = float(result.get("nmse_train", float("inf")))
1023 |             ds_combined = float(result.get("combined_score", 0.0))
1024 |             return ds_name, {{
1025 |                 "nmse_train": ds_train_nmse,
1026 |                 "nmse_val": ds_nmse,
1027 |                 "combined_score": ds_combined,
1028 |                 "complexity": float(result.get("complexity", 0.0)),
1029 |                 "equation": str(result.get("equation", "")),
1030 |                 "equation_template": str(result.get("equation_template", "")),
1031 |                 "constants": result.get("constants", {{}}),
1032 |             }}
1033 |         except Exception as exc:
1034 |             return ds_name, {{
1035 |                 "nmse_train": float("inf"),
1036 |                 "nmse_val": float("inf"),
1037 |                 "combined_score": 0.0,
1038 |                 "error": str(exc),
1039 |             }}
1040 | 
1041 |     per_dataset_results = {{}}
1042 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1043 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
1044 |         for future in as_completed(futures):
1045 |             ds_name, ds_result = future.result()
1046 |             per_dataset_results[ds_name] = ds_result
1047 | 
1048 |     aggregated = evaluator._aggregate_per_dataset_results(per_dataset_results)
1049 | 
1050 |     _write_payload_and_exit({{"result": aggregated}})
1051 | except Exception as exc:
1052 |     traceback.print_exc()
1053 |     _write_payload_and_exit({{"error": str(exc)}})
1054 | """
1055 |         temp_file.write(script.encode())
1056 |         temp_path = temp_file.name
1057 | 
1058 |     results_path = f"{temp_path}.results"
1059 |     try:
1060 |         process = subprocess.Popen(
1061 |             [sys.executable, temp_path],
1062 |             stdout=subprocess.PIPE,
1063 |             stderr=subprocess.PIPE,
1064 |         )
1065 |         stdout, stderr = process.communicate(timeout=timeout_seconds)
1066 |         if stdout:
1067 |             print(stdout.decode())
1068 |         if stderr:
1069 |             print(stderr.decode())
1070 |         if process.returncode != 0:
1071 |             raise RuntimeError(f"Subprocess exited with code {process.returncode}")
1072 |         if not os.path.exists(results_path):
1073 |             raise RuntimeError("Results file not found")
1074 |         with open(results_path, "rb") as f:
1075 |             payload = pickle.load(f)
1076 |         if "error" in payload:
1077 |             raise RuntimeError(payload["error"])
1078 |         return payload["result"]
1079 |     except subprocess.TimeoutExpired:
1080 |         process.kill()
1081 |         process.wait()
1082 |         raise TimeoutError(f"Program execution timed out after {timeout_seconds}s")
1083 |     finally:
1084 |         for path in (temp_path, results_path):
1085 |             if os.path.exists(path):
1086 |                 os.unlink(path)
