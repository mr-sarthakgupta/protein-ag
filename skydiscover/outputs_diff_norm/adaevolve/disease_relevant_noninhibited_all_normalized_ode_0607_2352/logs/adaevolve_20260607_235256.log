1203 | def evaluate_stage1(program_path: str) -> dict:
1204 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
1205 |     try:
1206 |         harness_root = str(BENCHMARK_ROOT)
1207 |         if harness_root not in sys.path:
1208 |             sys.path.insert(0, harness_root)
1209 | 
1210 |         all_datasets = load_all_datasets()
1211 |         rng = np.random.default_rng(RANDOM_STATE)
1212 |         if len(all_datasets) > 8:
1213 |             indices = rng.choice(len(all_datasets), size=8, replace=False)
1214 |             subset = [all_datasets[i] for i in sorted(indices)]
1215 |         else:
1216 |             subset = all_datasets
1217 | 
1218 |         work_items = [
1219 |             (name, X_train, X_val, y_train, y_val, program_path)
1220 |             for name, X_train, X_val, y_train, y_val in subset
1221 |         ]
1222 | 
1223 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1224 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
1225 |             worker_results = [future.result() for future in concurrent.futures.as_completed(futures)]
1226 | 
1227 |         combined_scores = [score for score, _error, _template in worker_results]
1228 |         successful_scores = [score for score in combined_scores if score > 0]
1229 |         errors = sorted({error for _score, error, _template in worker_results if error})
1230 |         violation_errors = sorted(
1231 |             {
1232 |                 error
1233 |                 for _score, error, _template in worker_results
1234 |                 if error and SINGLE_EQUATION_ERROR_PREFIX in error
1235 |             }
1236 |         )
1237 |         if violation_errors:
1238 |             return {
1239 |                 "combined_score": 0.0,
1240 |                 "n_stage1_datasets": len(subset),
1241 |                 "n_stage1_successful": len(successful_scores),
1242 |                 "eval_workers": NUM_WORKERS,
1243 |                 "error": violation_errors[0],
1244 |             }
1245 |         if errors:
1246 |             return {
1247 |                 "combined_score": 0.0,
1248 |                 "n_stage1_datasets": len(subset),
1249 |                 "n_stage1_successful": len(successful_scores),
1250 |                 "eval_workers": NUM_WORKERS,
1251 |                 "error": (
1252 |                     "Single-equation violation: stage 1 candidate failed on "
1253 |                     f"{len(errors)} dataset evaluations. Example: {errors[0]}"
1254 |                 ),
1255 |             }
1256 |         templates = sorted(
1257 |             {
1258 |                 template
1259 |                 for score, _error, template in worker_results
1260 |                 if score > 0 and template
1261 |             }
1262 |         )
1263 |         if len(templates) > 1:
1264 |             examples = "; ".join(templates[:3])
1265 |             return {
1266 |                 "combined_score": 0.0,
1267 |                 "n_stage1_datasets": len(subset),
1268 |                 "n_stage1_successful": len(successful_scores),
1269 |                 "eval_workers": NUM_WORKERS,
1270 |                 "error": (
1271 |                     "Single-equation violation: stage 1 produced "
1272 |                     f"{len(templates)} distinct equation templates across datasets. "
1273 |                     "The base equation must be identical for all datasets. "
1274 |                     f"Example templates: {examples}"
1275 |                 ),
1276 |             }
1277 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
1278 |         return {
1279 |             "combined_score": agg_combined,
1280 |             "n_stage1_datasets": len(subset),
1281 |             "n_stage1_successful": len(successful_scores),
1282 |             "eval_workers": NUM_WORKERS,
1283 |             "stage1_full_selected_datasets": 1.0,
1284 |         }
1285 |     except Exception as exc:
1286 |         print(f"Stage 1 evaluation failed: {exc}")
1287 |         return {"combined_score": 0.0, "error": str(exc)}
1288 | 
