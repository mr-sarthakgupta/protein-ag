 296 |     for node in tree.body:
 297 |         if _is_module_docstring(node) or _is_main_guard(node):
 298 |             continue
 299 |         if isinstance(node, ast.FunctionDef):
 300 |             _validate_top_level_function(node, postponed_annotations=postponed_annotations)
 301 |             continue
 302 |         if isinstance(node, ast.Import):
 303 |             for alias in node.names:
 304 |                 _validate_plain_import(alias)
 305 |         elif isinstance(node, ast.ImportFrom):
 306 |             module = node.module or ""
 307 |             if module not in _ALLOWED_FROM_IMPORTS:
 308 |                 raise ValueError(
 309 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: from-import '{module}' is not allowed."
 310 |                 )
 311 |             if module == "pysr_harness.equation_session":
 312 |                 aliased = [alias.name for alias in node.names if alias.asname]
 313 |                 if aliased:
 314 |                     raise ValueError(
 315 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: harness imports may not "
 316 |                         f"use aliases: {sorted(aliased)}."
 317 |                     )
 318 |                 imported = {alias.name for alias in node.names}
 319 |                 extra = imported - _ALLOWED_HARNESS_IMPORTS
 320 |                 if extra:
 321 |                     raise ValueError(
 322 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: unsupported harness imports "
 323 |                         f"{sorted(extra)}. Use only feature_symbols, constant_symbols, "
 324 |                         "and evaluate_expression."
 325 |                     )
 326 |         else:
 327 |             raise ValueError(
 328 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level executable code is not "
 329 |                 "allowed in candidate programs. Build and score the equation only "
 330 |                 "inside evaluate_symbolic_candidate()."
 331 |             )
 332 | 
 333 |     eval_fns = [
 334 |         node
 335 |         for node in tree.body
 336 |         if isinstance(node, ast.FunctionDef) and node.name == "evaluate_symbolic_candidate"
 337 |     ]
 338 |     if len(eval_fns) != 1:
 339 |         raise ValueError(
 340 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: program must define exactly one "
 341 |             "evaluate_symbolic_candidate() function."
 342 |         )
 343 |     fn = eval_fns[0]
 344 | 
 345 |     returns = [node for node in ast.walk(fn) if isinstance(node, ast.Return)]
 346 |     if len(returns) != 1:
 347 |         raise ValueError(
 348 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must have "
 349 |             "exactly one return statement."
 350 |         )
 351 |     return_value = returns[0].value
 352 |     if not (
 353 |         isinstance(return_value, ast.Call)
 354 |         and isinstance(return_value.func, ast.Name)
 355 |         and return_value.func.id == "evaluate_expression"
 356 |     ):
 357 |         raise ValueError(
 358 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must directly "
 359 |             "return evaluate_expression(...), with no wrapper or post-processing."
 360 |         )
 361 |     allowed_data_arg_ids = _validate_evaluate_expression_data_args(return_value)
 362 |     allowed_data_arg_ids.update(_allowed_feature_symbols_data_ids(fn))
 363 |     _validate_no_dataset_data_leak(fn, allowed_data_arg_ids)
 364 | 
 365 |     evaluate_calls = 0
 366 |     for node in ast.walk(fn):
 367 |         if isinstance(node, _DISALLOWED_CONTROL_NODES):
 368 |             raise ValueError(
 369 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: control flow, nested definitions, "
 370 |                 "comprehensions, and conditionals are not allowed inside "
 371 |                 "evaluate_symbolic_candidate(). Build one straight-line equation."
 372 |             )
 373 |         if isinstance(node, (ast.Import, ast.ImportFrom)):
 374 |             raise ValueError(
 375 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: imports are not allowed inside "
 376 |                 "evaluate_symbolic_candidate()."
 377 |             )
 378 |         if isinstance(node, (ast.Assign, ast.AnnAssign, ast.AugAssign)):
 379 |             targets = node.targets if isinstance(node, ast.Assign) else [node.target]
 380 |             assigned = set().union(*(_assigned_names(target) for target in targets))
 381 |             protected = assigned & _PROTECTED_NAMES
 382 |             if protected:
 383 |                 raise ValueError(
 384 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: cannot reassign protected scorer "
 385 |                     f"or harness names {sorted(protected)}."
 386 |                 )
 387 |         if isinstance(node, ast.Call):
 388 |             name = _call_name(node.func)
 389 |             if name == "evaluate_expression":
 390 |                 evaluate_calls += 1
 391 |             if name not in _ALLOWED_EVALUATE_CALLS:
 392 |                 raise ValueError(
 393 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: call '{name or type(node.func).__name__}' "
 394 |                     "is not allowed inside evaluate_symbolic_candidate(). Allowed calls "
 395 |                     "are the symbol helpers, evaluate_expression, and basic sp.* math."
 396 |                 )
 397 | 
 398 |     if evaluate_calls != 1:
 399 |         raise ValueError(
 400 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must call "
 401 |             f"evaluate_expression() exactly once; found {evaluate_calls} calls."
 402 |         )
 403 | 
 404 | 
 405 | def _parse_parameter_from_column(column_name: str) -> float | None:
 406 |     """Extract a monomer/protein concentration from a fit.tsv column header.
 407 | 
 408 |     Only concentration-like labels are accepted:
 409 |       - "... : 10uM"  or "10 uM"  → 10.0
 410 |       - "35uM" (bare, as in Abeta) → 35.0
 411 |       - "... : 3.95mM"             → 3950.0  (converted to uM)
 412 |       - "... : 0.3 mg/mL 22uM"    → 22.0    (prefer uM when both present)
 413 | 
 414 |     Seed percentages, pH values, ng/uL seed-material labels, and generic
 415 |     numeric fallbacks are intentionally ignored so x1 consistently represents
 416 |     the aggregating monomer/protein concentration when available.
 417 |     """
 418 |     text = column_name.strip()
 419 |     # Prefer the human-readable condition after the file-name prefix. Some
 420 |     # filenames contain seed concentrations that should not become x1.
 421 |     condition_text = text.rsplit(":", 1)[-1].strip().strip("\"'")
 422 | 
 423 |     # Prefer an explicit uM value
 424 |     m = re.search(r"(\d+(?:\.\d+)?)\s*uM", condition_text, re.IGNORECASE)
 425 |     if m:
 426 |         return float(m.group(1))
 427 | 
 428 |     # mM → convert to uM
 429 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mM", condition_text, re.IGNORECASE)
 430 |     if m:
 431 |         return float(m.group(1)) * 1000.0
 432 | 
 433 |     # mg/mL (take the number)
 434 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mg/mL", condition_text, re.IGNORECASE)
 435 |     if m:
 436 |         return float(m.group(1))
 437 | 
 438 |     return None
 439 | 
 440 | 
 441 | def _minmax_normalize(values: np.ndarray) -> np.ndarray:
 442 |     """Normalize one dataset column to 0..1, preserving constants as zeros."""
 443 |     values = np.asarray(values, dtype=float)
 444 |     v_min = float(np.min(values))
 445 |     v_max = float(np.max(values))
 446 |     scale = v_max - v_min
 447 |     if scale <= 0.0:
 448 |         return np.zeros_like(values, dtype=float)
 449 |     return (values - v_min) / scale
 450 | 
 451 | 
 452 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 453 |     """Load a wide fit.tsv and return X=[normalized time, raw parameter, c], y.
 454 | 
 455 |     The first column is always the time/measurement coordinate. Remaining
 456 |     columns are response curves. The varying parameter is extracted from
 457 |     concentration-like curve headers only; non-concentration columns are skipped.
 458 |     Time is min-max normalized to 0..1, but the parameter column is left in its
 459 |     parsed raw units. The response is normalized globally across the whole
 460 |     fit.tsv to 0..1. Files already rescaled to 0..1 keep that scale.
 461 |     """
 462 |     with data_file.open(newline="") as f:
 463 |         reader = csv.reader(f, delimiter="\t")
 464 |         header = next(reader)
 465 | 
 466 |         response_headers = header[1:]
 467 |         parsed_params = [_parse_parameter_from_column(h) for h in response_headers]
 468 | 
 469 |         features: list[list[float]] = []
 470 |         targets: list[float] = []
 471 |         for row in reader:
 472 |             if not row:
 473 |                 continue
 474 |             measurement_x = float(row[0])
 475 |             for param, value in zip(parsed_params, row[1:]):
 476 |                 if param is None:
 477 |                     continue
 478 |                 if value == "" or value.strip().lower() == "nan":
 479 |                     continue
 480 |                 features.append([measurement_x, param])
 481 |                 targets.append(float(value))
 482 | 
 483 |     if not features:
 484 |         raise ValueError(f"No regression samples loaded from {data_file}")
 485 | 
 486 |     X = np.asarray(features, dtype=float)
 487 |     y = np.asarray(targets, dtype=float)
 488 |     time_norm = _minmax_normalize(X[:, 0])
 489 |     parameter_raw = X[:, 1]
 490 |     y_norm = _minmax_normalize(y)
 491 | 
 492 |     # x2 is the concentration state c used by ODE RHS templates. During scoring
 493 |     # it is supplied from odeint's dynamic state, not read from candidate code.
 494 |     X_ode = np.column_stack([time_norm, parameter_raw, y_norm])
 495 |     return X_ode, y_norm
 496 | 
 497 | 
 498 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 499 |     """Recursively find all fit.tsv files and return (dataset_name, path) pairs."""
 500 |     datasets: list[tuple[str, Path]] = []
 501 |     for dirpath, _dirnames, filenames in os.walk(root):
 502 |         if "fit.tsv" in filenames:
 503 |             fit_path = Path(dirpath) / "fit.tsv"
 504 |             rel = fit_path.parent.relative_to(root)
 505 |             name = str(rel).replace(os.sep, "/")
 506 |             datasets.append((name, fit_path))
 507 |     datasets.sort(key=lambda x: x[0])
 508 |     return datasets
 509 | 
 510 | 
 511 | def _trajectory_preserving_split(
 512 |     X: np.ndarray,
 513 |     y: np.ndarray,
 514 | ) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 515 |     """Split by full parameter curves, using late-time holdout for <3 curves."""
 516 |     parameters = np.unique(X[:, 1])
 517 |     rng = np.random.default_rng(RANDOM_STATE)
 518 | 
 519 |     if len(parameters) >= 3:
 520 |         shuffled = parameters[rng.permutation(len(parameters))]
 521 |         n_val = min(max(1, int(round(len(parameters) * TEST_SIZE))), len(parameters) - 1)
 522 |         val_params = set(float(p) for p in shuffled[:n_val])
 523 |         val_mask = np.array([float(p) in val_params for p in X[:, 1]], dtype=bool)
 524 |         train_idx = np.flatnonzero(~val_mask)
 525 |         val_idx = np.flatnonzero(val_mask)
 526 |         return X[train_idx], X[val_idx], y[train_idx], y[val_idx]
 527 | 
 528 |     train_indices: list[int] = []
 529 |     val_indices: list[int] = []
 530 |     for parameter in parameters:
 531 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 532 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 533 |         if len(ordered_idx) == 1:
 534 |             train_indices.extend(ordered_idx.tolist())
 535 |             val_indices.extend(ordered_idx.tolist())
 536 |             continue
 537 | 
 538 |         split = int(round(len(ordered_idx) * (1.0 - TEST_SIZE)))
 539 |         split = min(max(split, 1), len(ordered_idx) - 1)
 540 |         train_indices.extend(ordered_idx[:split].tolist())
 541 |         # Include the last training point so validation integration starts from
 542 |         # the known boundary state before predicting the held-out late segment.
 543 |         val_indices.extend(ordered_idx[split - 1 :].tolist())
 544 | 
 545 |     train_idx = np.sort(np.asarray(train_indices, dtype=int))
 546 |     val_idx = np.sort(np.asarray(val_indices, dtype=int))
 547 |     return X[train_idx], X[val_idx], y[train_idx], y[val_idx]
 548 | 
 549 | 
 550 | def load_dataset(data_file: Path) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 551 |     """Load a single fit.tsv and return deterministic trajectory-preserving split."""
 552 |     X, y = _load_fit_table(data_file)
 553 |     return _trajectory_preserving_split(X, y)
 554 | 
 555 | 
 556 | def load_all_datasets(
 557 |     root: Path = DATA_ROOT,
 558 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 559 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 560 |     entries = discover_datasets(root)
 561 |     results = []
 562 |     for name, path in entries:
 563 |         try:
 564 |             X_train, X_val, y_train, y_val = load_dataset(path)
 565 |             results.append((name, X_train, X_val, y_train, y_val))
 566 |         except Exception as exc:
 567 |             print(f"Warning: skipping dataset {name}: {exc}")
 568 |     return results
