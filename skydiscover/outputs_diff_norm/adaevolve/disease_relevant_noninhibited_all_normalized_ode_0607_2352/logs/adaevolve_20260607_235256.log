exprs = {
    'current':      ((1-x2)*(c2+(c0+c1*x1)*x2),       [c0,c1,c2], [1.0,0.5,0.1]),
    # x1 scales primary nucleation only (swap roles)
    'x1_prim_only': ((1-x2)*(c2*x1+c0*x2),            [c0,c1,c2], [1.0,0.5,0.1]),
