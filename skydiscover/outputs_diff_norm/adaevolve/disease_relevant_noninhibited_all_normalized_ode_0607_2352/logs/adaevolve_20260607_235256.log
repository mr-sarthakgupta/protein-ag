import sys, numpy as np
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all_normalized_ode.evaluator import load_all_datasets, evaluate_ode_expression
from pysr_harness.equation_session import _complexity
import sympy as sp

datasets = load_all_datasets()
ds_map = {name: (X_train, X_val, y_train, y_val) for name, X_train, X_val, y_train, y_val in datasets}

x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2 = sp.symbols('c0 c1 c2')

hard = ['Alphasyn_Gaspar2017/03uM_seed all', 'insulin/Fits/Nielsen2001_seeded_sec',
        'serum amyloid/Ye2011/Fits/Ye2011_sec', 'Abeta/Meisl2014/Ab40_sec_IN_HOURS']

def score_hard(expr, consts, iv, label):
    nmses = []
    for name in hard:
        X_train, X_val, y_train, y_val = ds_map[name]
        r = evaluate_ode_expression(expr, X_train, y_train, X_val, y_val, constants=consts, initial_values=iv)
        nmses.append(r['nmse_val'])
    c = _complexity(expr)
    print(f'{label}(c={c}): hard={np.mean(nmses):.4f}  per={[f\"{v:.4f}\" for v in nmses]}')

# Baseline
score_hard((1-x2)*(c2+(c0+c1*x1)*x2), [c0,c1,c2], [1.0,0.5,0.1], 'current')

# Finke-Watzky: c0*(1-x2) + c1*x2*(1-x2) -- same as logistic with 2 terms
# But with x1 modulation of the autocatalytic term
score_hard(c0*(1-x2)+c1*(c2+x1)*x2*(1-x2), [c0,c1,c2], [0.1,1.0,0.5], 'FW_x1')

# What if we use x2^2 instead of x2 for autocatalysis (higher order)?
# c2*(1-x2) + (c0+c1*x1)*x2^2*(1-x2) -- complexity?
score_hard((1-x2)*(c2+(c0+c1*x1)*x2**2), [c0,c1,c2], [1.0,0.5,0.1], 'x2sq_autocatal')

# What if we try a different primary nucleation: c2*x2^0 = c2 vs c2*(1-x2)?
# Current already has c2*(1-x2) primary term. What about just c2 (no saturation on primary)?
score_hard(c2+(c0+c1*x1)*x2*(1-x2), [c0,c1,c2], [0.1,1.0,0.5], 'prim_no_sat')

# What about: (1-x2)^2 * (c2 + (c0+c1*x1)*x2) -- stronger saturation
score_hard((1-x2)**2*(c2+(c0+c1*x1)*x2), [c0,c1,c2], [1.0,0.5,0.1], 'sat_sq')

# Gompertz: c0*x2*(1-x2)*log(1+c1*x2) -- but log might be unstable
# Skip for now. Try: x2*(1-x2)*(c0+c1*x1) + c2*(1-x2)^2
score_hard(x2*(1-x2)*(c0+c1*x1)+c2*(1-x2)**2, [c0,c1,c2], [1.0,0.5,0.1], 'mixed_sat')
