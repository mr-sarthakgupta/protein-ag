1034 |     """Module-level worker for stage 1 parallel evaluation."""
1035 |     name, X_train, X_val, y_train, y_val, program_path = args
1036 |     harness_root = str(BENCHMARK_ROOT)
1037 |     if harness_root not in sys.path:
