# Histogram
bins = [0, 0.05, 0.1, 0.15, 0.2, 0.3, 0.5, 2.0]
counts, _ = np.histogram(nmses, bins=bins)
for i, cnt in enumerate(counts):
    print(f'  [{bins[i]:.2f},{bins[i+1]:.2f}): {cnt} datasets')
