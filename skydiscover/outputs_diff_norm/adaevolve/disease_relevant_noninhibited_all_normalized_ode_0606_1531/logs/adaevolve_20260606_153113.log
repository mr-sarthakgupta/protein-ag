print(f'All 42: mean={np.mean(nmses):.4f}')
excl = [v for v in nmses if v < 0.5]
print(f'Excl >0.5 ({len(nmses)-len(excl)} removed): mean={np.mean(excl):.4f}')
excl2 = [v for v in nmses if v < 0.3]
