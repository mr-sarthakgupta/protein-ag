1003 | def _eval_stage1_worker(args):
1004 |     """Module-level worker for stage 1 parallel evaluation."""
1005 |     name, X_train, X_val, y_train, y_val, program_path = args
1006 |     harness_root = str(BENCHMARK_ROOT)
1007 |     if harness_root not in sys.path:
1008 |         sys.path.insert(0, harness_root)
1009 |     validate_candidate_source(program_path)
1010 |     import pysr_harness.equation_session as equation_session
1011 |     equation_session.evaluate_expression = evaluate_ode_expression
1012 |     equation_session.nmse = _nmse_with_gaussian_smoothed_target
1013 |     spec = importlib.util.spec_from_file_location("program", program_path)
1014 |     program = importlib.util.module_from_spec(spec)
1015 |     spec.loader.exec_module(program)
1016 |     from pysr_harness.equation_session import (
1017 |         single_equation_evaluation,
1018 |         validate_single_equation_result,
1019 |     )
1020 | 
1021 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1022 |         program, "run_discovery", None
1023 |     )
1024 |     if fn is None:
1025 |         return 0.0, "missing evaluate_symbolic_candidate()", ""
1026 |     n = min(200, len(X_train))
1027 |     m = min(80, len(X_val))
1028 |     try:
1029 |         with single_equation_evaluation():
1030 |             result = fn(X_train[:n], y_train[:n], X_val[:m], y_val[:m])
1031 |             validate_single_equation_result(result)
1032 |         return float(result.get("combined_score", 0.0)), None, str(
1033 |             result.get("equation_template", "")
1034 |         )
1035 |     except Exception as exc:
1036 |         return 0.0, str(exc), ""
1037 | 
1038 | 
1039 | def evaluate_stage1(program_path: str) -> dict:
1040 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
1041 |     try:
1042 |         harness_root = str(BENCHMARK_ROOT)
1043 |         if harness_root not in sys.path:
1044 |             sys.path.insert(0, harness_root)
1045 | 
1046 |         all_datasets = load_all_datasets()
1047 |         rng = np.random.default_rng(RANDOM_STATE)
1048 |         if len(all_datasets) > 8:
1049 |             indices = rng.choice(len(all_datasets), size=8, replace=False)
1050 |             subset = [all_datasets[i] for i in sorted(indices)]
1051 |         else:
1052 |             subset = all_datasets
1053 | 
1054 |         work_items = [
1055 |             (name, X_train, X_val, y_train, y_val, program_path)
1056 |             for name, X_train, X_val, y_train, y_val in subset
1057 |         ]
1058 | 
1059 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1060 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
1061 |             worker_results = [future.result() for future in concurrent.futures.as_completed(futures)]
1062 | 
1063 |         combined_scores = [score for score, _error, _template in worker_results]
1064 |         successful_scores = [score for score in combined_scores if score > 0]
1065 |         errors = sorted({error for _score, error, _template in worker_results if error})
1066 |         violation_errors = sorted(
1067 |             {
