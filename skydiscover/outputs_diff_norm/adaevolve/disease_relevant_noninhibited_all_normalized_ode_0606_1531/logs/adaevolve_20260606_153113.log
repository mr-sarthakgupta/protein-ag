 803 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 804 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 805 | 
 806 |     The subprocess loads every dataset, calls the candidate's
 807 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 808 |     constants each time) using parallel threads, and returns aggregated
 809 |     metrics.
 810 |     """
 811 |     validate_candidate_source(program_path)
 812 |     harness_root = str(BENCHMARK_ROOT)
 813 |     evaluator_path = str(Path(__file__).resolve())
 814 |     with tempfile.NamedTemporaryFile(suffix=".py", delete=False) as temp_file:
 815 |         script = f"""
 816 | import importlib.util
 817 | import os
 818 | import pickle
 819 | import sys
 820 | import traceback
 821 | from concurrent.futures import ThreadPoolExecutor, as_completed
 822 | 
 823 | os.environ.setdefault("OMP_NUM_THREADS", "1")
 824 | os.environ.setdefault("MKL_NUM_THREADS", "1")
 825 | os.environ.setdefault("OPENBLAS_NUM_THREADS", "1")
 826 | 
 827 | import numpy as np
 828 | 
 829 | sys.path.insert(0, {harness_root!r})
 830 | 
 831 | program_path = {program_path!r}
 832 | evaluator_path = {evaluator_path!r}
 833 | results_path = {temp_file.name + ".results"!r}
 834 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 835 | 
 836 | def _write_payload_and_exit(payload):
 837 |     with open(results_path, "wb") as f:
 838 |         pickle.dump(payload, f)
 839 |     sys.stdout.flush()
 840 |     sys.stderr.flush()
 841 |     # PySR/PythonCall can leave Julia runtime threads/finalizers alive at
 842 |     # interpreter shutdown. The parent only needs the pickle payload.
 843 |     os._exit(0)
 844 | 
 845 | try:
 846 |     evaluator_spec = importlib.util.spec_from_file_location("benchmark_evaluator", evaluator_path)
 847 |     evaluator = importlib.util.module_from_spec(evaluator_spec)
 848 |     evaluator_spec.loader.exec_module(evaluator)
 849 |     evaluator.validate_candidate_source(program_path)
 850 | 
 851 |     import pysr_harness.equation_session as equation_session
 852 |     equation_session.evaluate_expression = evaluator.evaluate_ode_expression
 853 |     equation_session.nmse = evaluator._nmse_with_gaussian_smoothed_target
 854 |     spec = importlib.util.spec_from_file_location("program", program_path)
 855 |     program = importlib.util.module_from_spec(spec)
 856 |     spec.loader.exec_module(program)
 857 |     from pysr_harness.equation_session import (
 858 |         single_equation_evaluation,
 859 |         validate_single_equation_result,
 860 |     )
 861 | 
 862 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
 863 |         program, "run_discovery", None
 864 |     )
 865 |     if fn is None:
 866 |         raise AttributeError("Program must define evaluate_symbolic_candidate() or run_discovery()")
 867 | 
 868 |     datasets = evaluator.load_all_datasets()
 869 | 
 870 |     def _eval_one(args):
 871 |         ds_name, X_train, X_val, y_train, y_val = args
 872 |         try:
 873 |             with single_equation_evaluation():
 874 |                 result = fn(X_train, y_train, X_val, y_val)
 875 |                 validate_single_equation_result(result)
 876 |             ds_nmse = float(result.get("nmse_val", float("inf")))
 877 |             ds_combined = float(result.get("combined_score", 0.0))
 878 |             return ds_name, {{
 879 |                 "nmse_val": ds_nmse,
 880 |                 "combined_score": ds_combined,
 881 |                 "complexity": float(result.get("complexity", 0.0)),
 882 |                 "equation": str(result.get("equation", "")),
 883 |                 "equation_template": str(result.get("equation_template", "")),
 884 |                 "constants": result.get("constants", {{}}),
 885 |             }}
 886 |         except Exception as exc:
 887 |             return ds_name, {{
 888 |                 "nmse_val": float("inf"),
 889 |                 "combined_score": 0.0,
 890 |                 "error": str(exc),
 891 |             }}
 892 | 
 893 |     per_dataset_results = {{}}
 894 |     with ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
 895 |         futures = [executor.submit(_eval_one, dataset) for dataset in datasets]
 896 |         for future in as_completed(futures):
