1039 |     validate_candidate_source(program_path)
1040 |     import pysr_harness.equation_session as equation_session
1041 |     equation_session.evaluate_expression = evaluate_ode_expression
1042 |     equation_session.nmse = _nmse_with_gaussian_smoothed_target
1043 |     spec = importlib.util.spec_from_file_location("program", program_path)
1044 |     program = importlib.util.module_from_spec(spec)
1045 |     spec.loader.exec_module(program)
1046 |     from pysr_harness.equation_session import (
1047 |         single_equation_evaluation,
1048 |         validate_single_equation_result,
1049 |     )
1050 | 
1051 |     fn = getattr(program, "evaluate_symbolic_candidate", None) or getattr(
1052 |         program, "run_discovery", None
1053 |     )
1054 |     if fn is None:
1055 |         return 0.0, "missing evaluate_symbolic_candidate()", ""
1056 |     try:
1057 |         with single_equation_evaluation():
1058 |             result = fn(X_train, y_train, X_val, y_val)
1059 |             validate_single_equation_result(result)
1060 |         return float(result.get("combined_score", 0.0)), None, str(
1061 |             result.get("equation_template", "")
1062 |         )
