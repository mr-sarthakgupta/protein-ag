 305 |                 if aliased:
 306 |                     raise ValueError(
 307 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: harness imports may not "
 308 |                         f"use aliases: {sorted(aliased)}."
 309 |                     )
 310 |                 imported = {alias.name for alias in node.names}
 311 |                 extra = imported - _ALLOWED_HARNESS_IMPORTS
 312 |                 if extra:
 313 |                     raise ValueError(
 314 |                         f"{SINGLE_EQUATION_ERROR_PREFIX}: unsupported harness imports "
 315 |                         f"{sorted(extra)}. Use only feature_symbols, constant_symbols, "
 316 |                         "and evaluate_expression."
 317 |                     )
 318 |         else:
 319 |             raise ValueError(
 320 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: top-level executable code is not "
 321 |                 "allowed in candidate programs. Build and score the equation only "
 322 |                 "inside evaluate_symbolic_candidate()."
 323 |             )
 324 | 
 325 |     eval_fns = [
 326 |         node
 327 |         for node in tree.body
 328 |         if isinstance(node, ast.FunctionDef) and node.name == "evaluate_symbolic_candidate"
 329 |     ]
 330 |     if len(eval_fns) != 1:
 331 |         raise ValueError(
 332 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: program must define exactly one "
 333 |             "evaluate_symbolic_candidate() function."
 334 |         )
 335 |     fn = eval_fns[0]
 336 | 
 337 |     returns = [node for node in ast.walk(fn) if isinstance(node, ast.Return)]
 338 |     if len(returns) != 1:
 339 |         raise ValueError(
 340 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must have "
 341 |             "exactly one return statement."
 342 |         )
 343 |     return_value = returns[0].value
 344 |     if not (
 345 |         isinstance(return_value, ast.Call)
 346 |         and isinstance(return_value.func, ast.Name)
 347 |         and return_value.func.id == "evaluate_expression"
 348 |     ):
 349 |         raise ValueError(
 350 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must directly "
 351 |             "return evaluate_expression(...), with no wrapper or post-processing."
 352 |         )
 353 |     allowed_data_arg_ids = _validate_evaluate_expression_data_args(return_value)
 354 |     allowed_data_arg_ids.update(_allowed_feature_symbols_data_ids(fn))
 355 |     _validate_no_dataset_data_leak(fn, allowed_data_arg_ids)
 356 | 
 357 |     evaluate_calls = 0
 358 |     for node in ast.walk(fn):
 359 |         if isinstance(node, _DISALLOWED_CONTROL_NODES):
 360 |             raise ValueError(
 361 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: control flow, nested definitions, "
 362 |                 "comprehensions, and conditionals are not allowed inside "
 363 |                 "evaluate_symbolic_candidate(). Build one straight-line equation."
 364 |             )
 365 |         if isinstance(node, (ast.Import, ast.ImportFrom)):
 366 |             raise ValueError(
 367 |                 f"{SINGLE_EQUATION_ERROR_PREFIX}: imports are not allowed inside "
 368 |                 "evaluate_symbolic_candidate()."
 369 |             )
 370 |         if isinstance(node, (ast.Assign, ast.AnnAssign, ast.AugAssign)):
 371 |             targets = node.targets if isinstance(node, ast.Assign) else [node.target]
 372 |             assigned = set().union(*(_assigned_names(target) for target in targets))
 373 |             protected = assigned & _PROTECTED_NAMES
 374 |             if protected:
 375 |                 raise ValueError(
 376 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: cannot reassign protected scorer "
 377 |                     f"or harness names {sorted(protected)}."
 378 |                 )
 379 |         if isinstance(node, ast.Call):
 380 |             name = _call_name(node.func)
 381 |             if name == "evaluate_expression":
 382 |                 evaluate_calls += 1
 383 |             if name not in _ALLOWED_EVALUATE_CALLS:
 384 |                 raise ValueError(
 385 |                     f"{SINGLE_EQUATION_ERROR_PREFIX}: call '{name or type(node.func).__name__}' "
 386 |                     "is not allowed inside evaluate_symbolic_candidate(). Allowed calls "
 387 |                     "are the symbol helpers, evaluate_expression, and basic sp.* math."
 388 |                 )
 389 | 
 390 |     if evaluate_calls != 1:
 391 |         raise ValueError(
 392 |             f"{SINGLE_EQUATION_ERROR_PREFIX}: evaluate_symbolic_candidate() must call "
 393 |             f"evaluate_expression() exactly once; found {evaluate_calls} calls."
 394 |         )
 395 | 
 396 | 
 397 | def _parse_parameter_from_column(column_name: str) -> float | None:
 398 |     """Extract a numeric parameter value from a fit.tsv column header.
 399 | 
 400 |     Handles diverse header formats found across disease-relevant datasets:
 401 |       - "... : 10uM"  or "10 uM"  → 10.0
 402 |       - "35uM" (bare, as in Abeta) → 35.0
 403 |       - "... : 3.95mM"             → 3950.0  (converted to uM)
 404 |       - "... : 0.3 mg/mL 22uM"    → 22.0    (prefer uM when both present)
 405 |       - "... : pH 2.7"             → 2.7
 406 |       - "... : 5% seeds"           → 5.0
 407 |       - "20 ng/ul"                 → 20.0
 408 |       - Non-numeric labels (WT, C19S, acid 10min, ...) → None
 409 |     """
 410 |     text = column_name.strip()
 411 | 
 412 |     # Prefer an explicit uM value
 413 |     m = re.search(r"(\d+(?:\.\d+)?)\s*uM", text, re.IGNORECASE)
 414 |     if m:
 415 |         return float(m.group(1))
 416 | 
 417 |     # mM → convert to uM
 418 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mM", text, re.IGNORECASE)
 419 |     if m:
 420 |         return float(m.group(1)) * 1000.0
 421 | 
 422 |     # mg/mL (take the number)
 423 |     m = re.search(r"(\d+(?:\.\d+)?)\s*mg/mL", text, re.IGNORECASE)
 424 |     if m:
 425 |         return float(m.group(1))
 426 | 
 427 |     # ng/ul
 428 |     m = re.search(r"(\d+(?:\.\d+)?)\s*ng/ul", text, re.IGNORECASE)
 429 |     if m:
 430 |         return float(m.group(1))
 431 | 
 432 |     # pH value
 433 |     m = re.search(r"pH\s+(\d+(?:\.\d+)?)", text, re.IGNORECASE)
 434 |     if m:
 435 |         return float(m.group(1))
 436 | 
 437 |     # Percentage (e.g. "5% seeds")
 438 |     m = re.search(r"(\d+(?:\.\d+)?)\s*%", text)
 439 |     if m:
 440 |         return float(m.group(1))
 441 | 
 442 |     # Last resort: try to find any trailing number after colon/space
 443 |     m = re.search(r":\s*(\d+(?:\.\d+)?)\s*$", text)
 444 |     if m:
 445 |         return float(m.group(1))
 446 | 
 447 |     return None
 448 | 
 449 | 
 450 | def _minmax_normalize(values: np.ndarray) -> np.ndarray:
 451 |     """Normalize one dataset column to 0..1, preserving constants as zeros."""
 452 |     values = np.asarray(values, dtype=float)
 453 |     v_min = float(np.min(values))
 454 |     v_max = float(np.max(values))
 455 |     scale = v_max - v_min
 456 |     if scale <= 0.0:
 457 |         return np.zeros_like(values, dtype=float)
 458 |     return (values - v_min) / scale
 459 | 
 460 | 
 461 | def _load_fit_table(data_file: Path) -> tuple[np.ndarray, np.ndarray]:
 462 |     """Load a wide fit.tsv and return normalized X=[time, parameter, c], y.
 463 | 
 464 |     The first column is always the time/measurement coordinate. Remaining
 465 |     columns are response curves. The varying parameter (concentration, pH,
 466 |     etc.) is extracted from the header; if extraction fails, sequential
 467 |     indices 1, 2, 3, ... are used. Each dataset is then min-max normalized:
 468 |     time and parameter independently to 0..1, and the response globally across
 469 |     the whole fit.tsv to 0..1. Files already rescaled to 0..1 keep that scale.
 470 |     """
 471 |     with data_file.open(newline="") as f:
 472 |         reader = csv.reader(f, delimiter="\t")
 473 |         header = next(reader)
 474 | 
 475 |         response_headers = header[1:]
 476 |         parsed_params = [_parse_parameter_from_column(h) for h in response_headers]
 477 |         if all(p is not None for p in parsed_params):
 478 |             parameters = [float(p) for p in parsed_params]
 479 |         else:
 480 |             parameters = [float(i + 1) for i in range(len(response_headers))]
 481 | 
 482 |         features: list[list[float]] = []
 483 |         targets: list[float] = []
 484 |         for row in reader:
 485 |             if not row:
 486 |                 continue
 487 |             measurement_x = float(row[0])
 488 |             for param, value in zip(parameters, row[1:]):
 489 |                 if value == "" or value.strip().lower() == "nan":
 490 |                     continue
 491 |                 features.append([measurement_x, param])
 492 |                 targets.append(float(value))
 493 | 
 494 |     if not features:
 495 |         raise ValueError(f"No regression samples loaded from {data_file}")
 496 | 
 497 |     X = np.asarray(features, dtype=float)
 498 |     y = np.asarray(targets, dtype=float)
 499 |     X_norm = np.column_stack([_minmax_normalize(X[:, i]) for i in range(X.shape[1])])
 500 |     y_norm = _minmax_normalize(y)
 501 | 
 502 |     # x2 is the concentration state c used by ODE RHS templates. During scoring
 503 |     # it is supplied from odeint's dynamic state, not read from candidate code.
 504 |     X_ode = np.column_stack([X_norm, y_norm])
 505 |     return X_ode, y_norm
 506 | 
 507 | 
 508 | def discover_datasets(root: Path = DATA_ROOT) -> list[tuple[str, Path]]:
 509 |     """Recursively find all fit.tsv files and return (dataset_name, path) pairs."""
 510 |     datasets: list[tuple[str, Path]] = []
 511 |     for dirpath, _dirnames, filenames in os.walk(root):
 512 |         if "fit.tsv" in filenames:
 513 |             fit_path = Path(dirpath) / "fit.tsv"
 514 |             rel = fit_path.parent.relative_to(root)
 515 |             name = str(rel).replace(os.sep, "/")
 516 |             datasets.append((name, fit_path))
 517 |     datasets.sort(key=lambda x: x[0])
 518 |     return datasets
 519 | 
 520 | 
 521 | def load_dataset(data_file: Path) -> tuple[np.ndarray, np.ndarray, np.ndarray, np.ndarray]:
 522 |     """Load a single fit.tsv and return deterministic train/val split."""
 523 |     X, y = _load_fit_table(data_file)
 524 |     rng = np.random.default_rng(RANDOM_STATE)
 525 |     indices = rng.permutation(len(y))
 526 |     split = int(round(len(y) * (1.0 - TEST_SIZE)))
 527 |     train_idx = np.sort(indices[:split])
 528 |     val_idx = np.sort(indices[split:])
 529 |     return X[train_idx], X[val_idx], y[train_idx], y[val_idx]
 530 | 
 531 | 
 532 | def load_all_datasets(
 533 |     root: Path = DATA_ROOT,
 534 | ) -> list[tuple[str, np.ndarray, np.ndarray, np.ndarray, np.ndarray]]:
 535 |     """Load all datasets and return list of (name, X_train, X_val, y_train, y_val)."""
 536 |     entries = discover_datasets(root)
 537 |     results = []
 538 |     for name, path in entries:
 539 |         try:
 540 |             X_train, X_val, y_train, y_val = load_dataset(path)
 541 |             results.append((name, X_train, X_val, y_train, y_val))
 542 |         except Exception as exc:
 543 |             print(f"Warning: skipping dataset {name}: {exc}")
 544 |     return results
 545 | 
 546 | 
 547 | NUM_WORKERS = int(os.environ.get("SKYDISCOVER_EVAL_WORKERS", min(8, os.cpu_count() or 4)))
 548 | PARSIMONY_WEIGHT = float(os.environ.get("SKYDISCOVER_PARSIMONY_WEIGHT", "0.20"))
 549 | PARSIMONY_COMPLEXITY_SCALE = float(
 550 |     os.environ.get("SKYDISCOVER_PARSIMONY_COMPLEXITY_SCALE", "160")
 551 | )
 552 | 
 553 | 
 554 | def _parsimony_penalty_factor(complexity: float) -> float:
 555 |     """Bounded penalty factor for expression complexity."""
 556 |     if not np.isfinite(complexity) or PARSIMONY_COMPLEXITY_SCALE <= 0:
 557 |         return 1.0
 558 |     normalized = min(max(float(complexity), 0.0) / PARSIMONY_COMPLEXITY_SCALE, 1.0)
 559 |     return max(0.0, 1.0 - PARSIMONY_WEIGHT * normalized)
 560 | 
 561 | 
 562 | def _gaussian_smooth_1d(values: np.ndarray, sigma: float = GAUSSIAN_SMOOTH_SIGMA) -> np.ndarray:
 563 |     values = np.asarray(values, dtype=float).ravel()
 564 |     if values.size < 3 or sigma <= 0.0:
 565 |         return values
 566 |     radius = max(1, int(round(3.0 * sigma)))
 567 |     offsets = np.arange(-radius, radius + 1, dtype=float)
 568 |     kernel = np.exp(-0.5 * (offsets / sigma) ** 2)
 569 |     kernel /= np.sum(kernel)
 570 |     padded = np.pad(values, (radius, radius), mode="edge")
 571 |     return np.convolve(padded, kernel, mode="valid")
 572 | 
 573 | 
 574 | def _nmse_with_gaussian_smoothed_target(y_true: np.ndarray, y_pred: np.ndarray) -> float:
 575 |     raw_loss = _base_nmse(y_true, y_pred)
 576 |     smooth_loss = _base_nmse(_gaussian_smooth_1d(y_true), y_pred)
 577 |     return float((raw_loss + smooth_loss) / 2.0)
 578 | 
 579 | 
 580 | def _ode_predictions(
 581 |     rhs_fn: Any,
 582 |     X: np.ndarray,
 583 |     y_known: np.ndarray,
 584 |     theta: np.ndarray,
 585 | ) -> np.ndarray:
 586 |     """Integrate dc/dt=f(t, parameter, c) per parameter curve on one split."""
 587 |     from scipy.integrate import odeint
 588 | 
 589 |     X = np.asarray(X, dtype=float)
 590 |     y_known = np.asarray(y_known, dtype=float).reshape(-1)
 591 |     theta = np.asarray(theta, dtype=float).reshape(-1)
 592 |     predictions = np.full_like(y_known, np.nan, dtype=float)
 593 | 
 594 |     for parameter in np.unique(X[:, 1]):
 595 |         curve_idx = np.flatnonzero(X[:, 1] == parameter)
 596 |         ordered_idx = curve_idx[np.argsort(X[curve_idx, 0])]
 597 |         times = X[ordered_idx, 0]
 598 |         observed = y_known[ordered_idx]
 599 | 
 600 |         if len(ordered_idx) == 1 or float(times[-1] - times[0]) <= 0.0:
 601 |             predictions[ordered_idx] = observed[0]
 602 |             continue
 603 | 
 604 |         def dc_dt(c_state: np.ndarray, time_value: float) -> float:
 605 |             c_value = float(np.asarray(c_state, dtype=float).reshape(-1)[0])
 606 |             value = rhs_fn(float(time_value), float(parameter), c_value, *theta)
 607 |             value = float(np.asarray(value, dtype=float).reshape(-1)[0])
 608 |             if not np.isfinite(value):
 609 |                 raise FloatingPointError("non-finite ODE derivative")
 610 |             return value
 611 | 
 612 |         integrated = odeint(
 613 |             dc_dt,
 614 |             float(observed[0]),
 615 |             times,
 616 |             mxstep=1000,
 617 |         )
 618 |         curve_pred = np.asarray(integrated, dtype=float).reshape(-1)
 619 |         if curve_pred.shape != observed.shape or not np.all(np.isfinite(curve_pred)):
 620 |             raise FloatingPointError("non-finite ODE trajectory")
 621 |         predictions[ordered_idx] = curve_pred
 622 | 
 623 |     return predictions
 624 | 
 625 | 
 626 | def evaluate_ode_expression(
 627 |     expression: Any,
 628 |     X_train: np.ndarray,
 629 |     y_train: np.ndarray,
 630 |     X_val: np.ndarray,
 631 |     y_val: np.ndarray,
 632 |     *,
 633 |     constants: Any | None = None,
 634 |     initial_values: Any | None = None,
 635 |     max_nfev: int = 300,
 636 | ) -> dict[str, Any]:
 637 |     """Score a proposed ODE RHS by integrating predicted concentration curves."""
 638 |     import sympy as sp
 639 |     from pysr_harness import equation_session
 640 |     from scipy.optimize import least_squares
 641 | 
 642 |     X_train = np.asarray(X_train, dtype=float)
 643 |     y_train = np.asarray(y_train, dtype=float).reshape(-1)
 644 |     X_val = np.asarray(X_val, dtype=float)
 645 |     y_val = np.asarray(y_val, dtype=float).reshape(-1)
 646 |     feature_names = [f"x{i}" for i in range(X_train.shape[1])]
 647 |     template = equation_session._as_sympy_expr(expression, feature_names)
 648 |     equation_session._record_scored_template(template)
 649 | 
 650 |     if constants is None:
 651 |         feature_set = set(equation_session.feature_symbols(X_train.shape[1]))
 652 |         constants = sorted(template.free_symbols - feature_set, key=lambda s: s.name)
 653 |     constants = list(constants)
 654 |     equation_session._validate_expression_template(template, constants)
 655 | 
 656 |     if initial_values is None:
 657 |         x0 = np.ones(len(constants), dtype=float)
 658 |     else:
 659 |         x0 = np.asarray(initial_values, dtype=float).reshape(-1)
 660 |         if x0.size != len(constants):
 661 |             raise ValueError("initial_values must match the number of constants")
 662 | 
 663 |     feature_syms = equation_session.feature_symbols(X_train.shape[1])
 664 |     rhs_fn = sp.lambdify(feature_syms + constants, template, modules=["numpy"])
 665 | 
 666 |     def residual(theta: np.ndarray) -> np.ndarray:
 667 |         try:
 668 |             prediction = _ode_predictions(rhs_fn, X_train, y_train, theta)
 669 |         except Exception:
 670 |             return np.full_like(y_train, 1e12, dtype=float)
 671 |         if prediction.shape != y_train.shape or not np.all(np.isfinite(prediction)):
 672 |             return np.full_like(y_train, 1e12, dtype=float)
 673 |         return prediction - y_train
 674 | 
 675 |     import warnings
 676 | 
 677 |     with warnings.catch_warnings(), np.errstate(over="ignore", divide="ignore", invalid="ignore"):
 678 |         warnings.simplefilter("ignore", RuntimeWarning)
 679 |         fit = least_squares(
 680 |             residual,
 681 |             x0,
 682 |             loss="soft_l1",
 683 |             max_nfev=max_nfev,
 684 |         )
 685 | 
 686 |     fitted_constants = {
 687 |         str(symbol): float(value) for symbol, value in zip(constants, fit.x)
 688 |     }
 689 |     substitutions = dict(zip(constants, fit.x))
 690 |     fitted_expr = template.subs(substitutions)
 691 |     y_pred_train = _ode_predictions(rhs_fn, X_train, y_train, fit.x)
 692 |     y_pred_val = _ode_predictions(rhs_fn, X_val, y_val, fit.x)
 693 |     nmse_train = _nmse_with_gaussian_smoothed_target(y_train, y_pred_train)
 694 |     nmse_val = _nmse_with_gaussian_smoothed_target(y_val, y_pred_val)
 695 |     loss = float(np.mean((y_pred_train - y_train) ** 2))
 696 | 
 697 |     result = {
 698 |         "equation_template": f"d(c)/dt = {template}",
 699 |         "equation": f"d(c)/dt = {fitted_expr}",
 700 |         "constants": fitted_constants,
 701 |         "loss": loss,
 702 |         "complexity": equation_session._complexity(template),
 703 |         "nmse_train": nmse_train,
 704 |         "nmse_val": nmse_val,
 705 |         "combined_score": combined_score_from_nmse(nmse_val),
 706 |     }
 707 |     equation_session._record_scorer_result(result)
 708 |     return result
 709 | 
 710 | 
 711 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 712 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 713 |     nmse_vals = [r["nmse_val"] for r in per_dataset_results.values()]
 714 |     complexity_vals = []
 715 |     for r in per_dataset_results.values():
 716 |         try:
 717 |             value = float(r.get("complexity", float("nan")))
 718 |         except (TypeError, ValueError):
 719 |             continue
 720 |         if np.isfinite(value):
 721 |             complexity_vals.append(value)
 722 |     aggregate_complexity = float(max(complexity_vals)) if complexity_vals else 0.0
 723 | 
 724 |     violation_errors = sorted(
 725 |         {
 726 |             str(r.get("error"))
 727 |             for r in per_dataset_results.values()
 728 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 729 |         }
 730 |     )
 731 |     failed_datasets = sorted(
 732 |         name
 733 |         for name, result in per_dataset_results.items()
 734 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 735 |     )
 736 |     templates = sorted(
 737 |         {
 738 |             str(r.get("equation_template"))
 739 |             for r in per_dataset_results.values()
 740 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 741 |         }
 742 |     )
 743 | 
 744 |     eq_template = ""
 745 |     for r in per_dataset_results.values():
 746 |         if r.get("equation"):
 747 |             eq_template = r["equation"]
 748 |             break
 749 | 
 750 |     violation_error = None
 751 |     if violation_errors:
 752 |         violation_error = violation_errors[0]
 753 |     elif failed_datasets:
 754 |         examples = ", ".join(failed_datasets[:3])
 755 |         violation_error = (
 756 |             "Single-equation violation: candidate failed on "
 757 |             f"{len(failed_datasets)}/{len(per_dataset_results)} datasets. "
 758 |             "Failed datasets are not dropped from the aggregate reward. "
 759 |             f"Examples: {examples}"
 760 |         )
 761 |     elif len(templates) > 1:
 762 |         examples = "; ".join(templates[:3])
 763 |         violation_error = (
 764 |             "Single-equation violation: evaluate_symbolic_candidate() produced "
 765 |             f"{len(templates)} distinct equation templates across datasets. "
 766 |             "The base equation must be identical for all datasets; only fitted "
 767 |             f"constants may vary. Example templates: {examples}"
 768 |         )
 769 | 
 770 |     if violation_error:
 771 |         agg_nmse = float("inf")
 772 |         agg_combined = 0.0
 773 |         n_successful = 0
 774 |     else:
 775 |         agg_nmse = float(np.mean(nmse_vals)) if nmse_vals else float("inf")
 776 |         raw_combined = (
 777 |             float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
 778 |         )
 779 |         parsimony_factor = _parsimony_penalty_factor(aggregate_complexity)
 780 |         agg_combined = raw_combined * parsimony_factor
 781 |         n_successful = sum(1 for value in nmse_vals if np.isfinite(value))
 782 | 
 783 |     aggregated = {
 784 |         "equation": eq_template,
 785 |         "nmse_val": agg_nmse,
 786 |         "combined_score": agg_combined,
 787 |         "fit_score": raw_combined if not violation_error else 0.0,
 788 |         "complexity": aggregate_complexity,
 789 |         "parsimony_weight": PARSIMONY_WEIGHT,
 790 |         "parsimony_penalty_factor": (
 791 |             _parsimony_penalty_factor(aggregate_complexity) if not violation_error else 1.0
 792 |         ),
 793 |         "n_datasets": len(per_dataset_results),
 794 |         "n_successful": n_successful,
 795 |         "eval_workers": NUM_WORKERS,
 796 |         "per_dataset": per_dataset_results,
 797 |     }
 798 |     if violation_error:
 799 |         aggregated["error"] = violation_error
 800 |     return aggregated
 801 | 
 802 | 
 803 | def evaluate_candidate_with_timeout(program_path: str, timeout_seconds: int = 3000) -> dict:
 804 |     """Evaluate a candidate program across ALL datasets in a subprocess.
 805 | 
 806 |     The subprocess loads every dataset, calls the candidate's
 807 |     evaluate_symbolic_candidate() once per dataset (fitting independent
 808 |     constants each time) using parallel threads, and returns aggregated
 809 |     metrics.
 810 |     """
 811 |     validate_candidate_source(program_path)
 812 |     harness_root = str(BENCHMARK_ROOT)
 813 |     evaluator_path = str(Path(__file__).resolve())
