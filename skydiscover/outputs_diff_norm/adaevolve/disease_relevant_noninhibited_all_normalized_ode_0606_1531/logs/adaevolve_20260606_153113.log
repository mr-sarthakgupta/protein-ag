all_datasets = []
for dirpath, dirs, files in sorted([(str(d), dn, fn) for d, dn, fn in __import__('os').walk(root)]):
    if 'fit.tsv' in files:
        p = Path(dirpath) / 'fit.tsv'
        with open(p) as f:
            reader = csv.reader(f, delimiter='\t')
            header = next(reader)
            rows = [r for r in reader if r]
        name = str(Path(dirpath).relative_to(root))
        ncols = len(header) - 1
        nrows = len(rows)
        # sample first and last values of first data col
        try:
            v0 = float(rows[0][1])
            vend = float(rows[-1][1])
        except:
            v0, vend = 0, 0
        all_datasets.append((name, ncols, nrows, v0, vend))

print(f'Total: {len(all_datasets)} datasets')
print(f'name | ncurves | nrows | y_start | y_end')
for name, nc, nr, v0, ve in all_datasets[:30]:
    short = name[-40:]
    print(f'  {short:40s} | {nc:3d} | {nr:4d} | {v0:.4f} | {ve:.4f}')
