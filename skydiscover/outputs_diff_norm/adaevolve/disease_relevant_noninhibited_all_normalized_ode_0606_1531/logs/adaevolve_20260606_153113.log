1067 | def evaluate_stage1(program_path: str) -> dict:
1068 |     """Fast cascade stage: evaluate on a small subset of datasets with reduced data."""
1069 |     try:
1070 |         harness_root = str(BENCHMARK_ROOT)
1071 |         if harness_root not in sys.path:
1072 |             sys.path.insert(0, harness_root)
1073 | 
1074 |         all_datasets = load_all_datasets()
1075 |         rng = np.random.default_rng(RANDOM_STATE)
1076 |         if len(all_datasets) > 8:
1077 |             indices = rng.choice(len(all_datasets), size=8, replace=False)
1078 |             subset = [all_datasets[i] for i in sorted(indices)]
1079 |         else:
1080 |             subset = all_datasets
1081 | 
1082 |         work_items = [
1083 |             (name, X_train, X_val, y_train, y_val, program_path)
1084 |             for name, X_train, X_val, y_train, y_val in subset
1085 |         ]
1086 | 
1087 |         with concurrent.futures.ThreadPoolExecutor(max_workers=NUM_WORKERS) as executor:
1088 |             futures = [executor.submit(_eval_stage1_worker, item) for item in work_items]
1089 |             worker_results = [future.result() for future in concurrent.futures.as_completed(futures)]
1090 | 
1091 |         combined_scores = [score for score, _error, _template in worker_results]
1092 |         successful_scores = [score for score in combined_scores if score > 0]
1093 |         errors = sorted({error for _score, error, _template in worker_results if error})
1094 |         violation_errors = sorted(
1095 |             {
1096 |                 error
1097 |                 for _score, error, _template in worker_results
1098 |                 if error and SINGLE_EQUATION_ERROR_PREFIX in error
1099 |             }
1100 |         )
1101 |         if violation_errors:
1102 |             return {
1103 |                 "combined_score": 0.0,
1104 |                 "n_stage1_datasets": len(subset),
1105 |                 "n_stage1_successful": len(successful_scores),
1106 |                 "eval_workers": NUM_WORKERS,
1107 |                 "error": violation_errors[0],
1108 |             }
1109 |         if errors:
1110 |             return {
1111 |                 "combined_score": 0.0,
1112 |                 "n_stage1_datasets": len(subset),
1113 |                 "n_stage1_successful": len(successful_scores),
1114 |                 "eval_workers": NUM_WORKERS,
1115 |                 "error": (
1116 |                     "Single-equation violation: stage 1 candidate failed on "
1117 |                     f"{len(errors)} dataset evaluations. Example: {errors[0]}"
1118 |                 ),
1119 |             }
1120 |         templates = sorted(
1121 |             {
1122 |                 template
1123 |                 for score, _error, template in worker_results
1124 |                 if score > 0 and template
1125 |             }
1126 |         )
1127 |         if len(templates) > 1:
1128 |             examples = "; ".join(templates[:3])
1129 |             return {
1130 |                 "combined_score": 0.0,
1131 |                 "n_stage1_datasets": len(subset),
1132 |                 "n_stage1_successful": len(successful_scores),
1133 |                 "eval_workers": NUM_WORKERS,
1134 |                 "error": (
1135 |                     "Single-equation violation: stage 1 produced "
1136 |                     f"{len(templates)} distinct equation templates across datasets. "
1137 |                     "The base equation must be identical for all datasets. "
1138 |                     f"Example templates: {examples}"
1139 |                 ),
1140 |             }
1141 |         agg_combined = float(np.mean(combined_scores)) if combined_scores else 0.0
1142 |         return {
1143 |             "combined_score": agg_combined,
1144 |             "n_stage1_datasets": len(subset),
1145 |             "n_stage1_successful": len(successful_scores),
1146 |             "eval_workers": NUM_WORKERS,
1147 |             "stage1_full_selected_datasets": 1.0,
1148 |         }
1149 |     except Exception as exc:
1150 |         print(f"Stage 1 evaluation failed: {exc}")
1151 |         return {"combined_score": 0.0, "error": str(exc)}
