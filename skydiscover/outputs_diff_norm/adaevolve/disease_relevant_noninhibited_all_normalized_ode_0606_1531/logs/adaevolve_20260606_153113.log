from disease_relevant_noninhibited_all_normalized_ode.evaluator import load_all_datasets, evaluate_ode_expression
import pysr_harness.equation_session as eq
eq.evaluate_expression = evaluate_ode_expression
import sympy as sp
import numpy as np

datasets = load_all_datasets()

x = eq.feature_symbols(3)
c = eq.constant_symbols(3)
concentration = x[2]
parameter = x[1]
expression = (c[0] + c[1]*parameter) * (1 - concentration) * (1 + c[2]*concentration)

# Test on hard datasets
hard = ['insulin/Fits/Nielsen2001_seeded_sec', 'htt/Kakkar2016', 'serum amyloid/Ye2011']
for name, X_train, X_val, y_train, y_val in datasets:
    if any(h in name for h in hard):
        x1_vals = np.unique(X_train[:,1])
        # Check shape of data
        for x1v in x1_vals[:2]:
            mask = X_train[:,1] == x1v
            t = X_train[mask,0]
            y = y_train[mask]
            order = np.argsort(t)
            t, y = t[order], y[order]
            print(f'{name} x1={x1v:.2f}: y0={y[0]:.3f} ymax={y.max():.3f} ymid={y[len(y)//2]:.3f} npts={len(y)}')
        print()
