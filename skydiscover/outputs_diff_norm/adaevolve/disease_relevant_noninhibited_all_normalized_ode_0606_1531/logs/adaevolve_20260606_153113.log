    if 'Nielsen' in name:
        mask = X_train[:,1] == 0.0
        t = X_train[mask,0]
        y = y_train[mask]
        order = np.argsort(t)
        t, y = t[order], y[order]
        print(f'{name}')
        print(f'  n_pts: {len(t)}, n_x1: {len(np.unique(X_train[:,1]))}')
        print(f'  First 10 pts: t={t[:10].round(3)}, y={y[:10].round(4)}')
