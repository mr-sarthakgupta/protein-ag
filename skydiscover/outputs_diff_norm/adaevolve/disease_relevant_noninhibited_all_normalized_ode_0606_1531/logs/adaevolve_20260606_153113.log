import sys
sys.path.insert(0, '.')
from disease_relevant_noninhibited_all_normalized_ode.evaluator import load_all_datasets, evaluate_ode_expression
import pysr_harness.equation_session as eq
eq.evaluate_expression = evaluate_ode_expression
import sympy as sp
import numpy as np

datasets = load_all_datasets()
x = eq.feature_symbols(3)
c = eq.constant_symbols(3)
xc = x[2]
x1 = x[1]

# Test 3 candidate structures on hard datasets only
hard_names = ['htt', 'serum amyloid', 'Abeta/Meisl', 'Kar2011']
hard_ds = [(n, Xt, Xv, yt, yv) for n, Xt, Xv, yt, yv in datasets if any(h in n for h in hard_names)]

candidates = {
    'current': (c[0] + c[1]*x1) * (1 - xc) * (1 + c[2]*xc),
    'x1_autocatal': c[0] * (1 - xc) * (1 + c[1]*x1*xc + c[2]*xc),
    'x1_both': (c[0] + c[1]*x1) * (1 - xc) * (1 + c[2]*x1*xc),
}

for cname, expr in candidates.items():
    nmses = []
    for name, X_train, X_val, y_train, y_val in hard_ds:
        from pysr_harness.equation_session import single_equation_evaluation, validate_single_equation_result
        with single_equation_evaluation():
            r = evaluate_ode_expression(expr, X_train, y_train, X_val, y_val, constants=c, initial_values=[0.5, 1.0, 2.0])
            validate_single_equation_result(r)
        nmses.append(r['nmse_val'])
    print(f'{cname}: mean_nmse={np.mean(nmses):.4f}  ({len(nmses)} datasets)')
