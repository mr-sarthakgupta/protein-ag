import csv, numpy as np, re
from pathlib import Path
from scipy.integrate import odeint
from scipy.optimize import least_squares

root = Path('/home/mrsar/protein-ag/past-published-data/disease-relevant non-inhibited')

def load_normalized(p):
    with open(p) as f:
        reader = csv.reader(f, delimiter='\t')
        header = next(reader)
        rows = [r for r in reader if r]
    all_vals = []
    for r in rows:
        for v in r[1:]:
            try: all_vals.append(float(v))
            except: pass
    vmin, vmax = min(all_vals), max(all_vals)
    scale = vmax - vmin if vmax > vmin else 1.0
    params_raw = []
    for h in header[1:]:
        m = re.search(r'(\d+(?:\.\d+)?)\s*uM', h, re.IGNORECASE)
        if m: params_raw.append(float(m.group(1))); continue
        m = re.search(r'(\d+(?:\.\d+)?)\s*mM', h, re.IGNORECASE)
        if m: params_raw.append(float(m.group(1))*1000); continue
        params_raw.append(None)
    if all(p is not None for p in params_raw):
        params = [float(p) for p in params_raw]
    else:
        params = [float(i+1) for i in range(len(header)-1)]
    pmin, pmax = min(params), max(params)
    pscale = pmax - pmin if pmax > pmin else 1.0
    times = [float(r[0]) for r in rows]
    tmin, tmax = min(times), max(times)
    tscale = tmax - tmin if tmax > tmin else 1.0
    X, y = [], []
    for r in rows:
        t_n = (float(r[0]) - tmin) / tscale
        for j, param in enumerate(params):
            if j+1 < len(r) and r[j+1].strip():
                try:
                    val = float(r[j+1])
                    y_n = (val - vmin) / scale
                    p_n = (param - pmin) / pscale
                    X.append([t_n, p_n, y_n]); y.append(y_n)
                except: pass
    return np.array(X), np.array(y)

def test_model(X, y, model_fn, x0):
    curves = {}
    for param in np.unique(X[:, 1]):
        idx = np.flatnonzero(X[:, 1] == param)
        idx_s = idx[np.argsort(X[idx, 0])]
        curves[param] = (X[idx_s, 0], y[idx_s])
    def resid(params):
        preds, trues = [], []
        for param, (t, obs) in curves.items():
            ic = obs[0]
            try:
                sol = odeint(model_fn, ic, t, args=(param,)+tuple(params), mxstep=2000)
                preds.extend(sol.ravel())
            except: preds.extend([1e6]*len(t))
            trues.extend(obs)
        return np.array(preds) - np.array(trues)
    fit = least_squares(resid, x0, loss='soft_l1', max_nfev=400)
    r = resid(fit.x)
    nmse = np.mean(r**2) / np.var(y) if np.var(y) > 0 else float('inf')
    return nmse, fit.x

# Models to compare
# B: dc/dt = k0*(1-c) + k1*(1+k2*x1)*c*(1-c)
def modelB(c, t, x1, k0, k1, k2):
    return k0*(1-c) + k1*(1+k2*x1)*c*(1-c)

# C: dc/dt = (k0 + k1*x1)*(1-c)*(1 + k2*c)  -- factored form
def modelC(c, t, x1, k0, k1, k2):
    return (k0 + k1*x1)*(1-c)*(1 + k2*c)

# D: dc/dt = k0*(1-c) + k1*x1*c*(1-c)  -- simpler, 3 params
def modelD(c, t, x1, k0, k1):
    return k0*(1-c) + k1*x1*c*(1-c)

# E: dc/dt = (k0 + k1*c)*(1-c)  -- no x1 dependence, simplest
def modelE(c, t, x1, k0, k1):
    return (k0 + k1*c)*(1-c)

all_paths = []
for dirpath, dirs, files in sorted([(str(d), dn, fn) for d, dn, fn in __import__('os').walk(root)]):
    if 'fit.tsv' in files:
        all_paths.append(Path(dirpath) / 'fit.tsv')

total = {n: [] for n in ['B','C','D','E']}
for pth in all_paths[:15]:
    X, y = load_normalized(pth)
    name = str(pth.parent.relative_to(root))[-30:]
    nmseB, _ = test_model(X, y, modelB, [0.1, 5.0, 0.5])
    nmseC, _ = test_model(X, y, modelC, [0.1, 5.0, 1.0])
    nmseD, _ = test_model(X, y, modelD, [0.1, 5.0])
    nmseE, _ = test_model(X, y, modelE, [0.1, 5.0])
    total['B'].append(nmseB); total['C'].append(nmseC)
    total['D'].append(nmseD); total['E'].append(nmseE)
    print(f'{name:30s}: B={nmseB:.4f} C={nmseC:.4f} D={nmseD:.4f} E={nmseE:.4f}')

print()
for n in ['B','C','D','E']:
    vals = [v for v in total[n] if np.isfinite(v)]
    print(f'Model {n} mean NMSE: {np.mean(vals):.4f}')
