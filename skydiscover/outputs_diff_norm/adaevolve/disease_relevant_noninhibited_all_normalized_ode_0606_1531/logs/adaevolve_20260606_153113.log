 711 | def _aggregate_per_dataset_results(per_dataset_results: dict[str, dict[str, Any]]) -> dict[str, Any]:
 712 |     """Aggregate per-dataset metrics without letting failed datasets disappear."""
 713 |     nmse_vals = [r["nmse_val"] for r in per_dataset_results.values()]
 714 |     train_nmse_vals = [
 715 |         float(r["nmse_train"])
 716 |         for r in per_dataset_results.values()
 717 |         if np.isfinite(float(r.get("nmse_train", float("inf"))))
 718 |     ]
 719 |     complexity_vals = []
 720 |     for r in per_dataset_results.values():
 721 |         try:
 722 |             value = float(r.get("complexity", float("nan")))
 723 |         except (TypeError, ValueError):
 724 |             continue
 725 |         if np.isfinite(value):
 726 |             complexity_vals.append(value)
 727 |     aggregate_complexity = float(max(complexity_vals)) if complexity_vals else 0.0
 728 | 
 729 |     violation_errors = sorted(
 730 |         {
 731 |             str(r.get("error"))
 732 |             for r in per_dataset_results.values()
 733 |             if r.get("error") and SINGLE_EQUATION_ERROR_PREFIX in str(r.get("error"))
 734 |         }
 735 |     )
 736 |     failed_datasets = sorted(
 737 |         name
 738 |         for name, result in per_dataset_results.items()
 739 |         if result.get("error") or not np.isfinite(float(result.get("nmse_val", float("inf"))))
 740 |     )
 741 |     templates = sorted(
 742 |         {
 743 |             str(r.get("equation_template"))
 744 |             for r in per_dataset_results.values()
 745 |             if r.get("combined_score", 0.0) > 0 and r.get("equation_template")
 746 |         }
 747 |     )
 748 | 
 749 |     eq_template = ""
 750 |     for r in per_dataset_results.values():
 751 |         if r.get("equation"):
 752 |             eq_template = r["equation"]
 753 |             break
 754 | 
 755 |     hard_cases = [
 756 |         {"dataset": name, "nmse_val": float(result["nmse_val"])}
 757 |         for name, result in per_dataset_results.items()
 758 |         if np.isfinite(float(result.get("nmse_val", float("inf"))))
 759 |     ]
 760 |     hard_cases.sort(key=lambda item: item["nmse_val"], reverse=True)
 761 |     hard_cases = hard_cases[:5]
 762 |     hard_case_feedback = "; ".join(
 763 |         f"{case['dataset']} nmse={case['nmse_val']:.4g}" for case in hard_cases
 764 |     )
 765 | 
 766 |     violation_error = None
 767 |     if violation_errors:
 768 |         violation_error = violation_errors[0]
 769 |     elif failed_datasets:
 770 |         examples = ", ".join(failed_datasets[:3])
 771 |         violation_error = (
 772 |             "Single-equation violation: candidate failed on "
 773 |             f"{len(failed_datasets)}/{len(per_dataset_results)} datasets. "
 774 |             "Failed datasets are not dropped from the aggregate reward. "
 775 |             f"Examples: {examples}"
 776 |         )
 777 |     elif len(templates) > 1:
 778 |         examples = "; ".join(templates[:3])
 779 |         violation_error = (
 780 |             "Single-equation violation: evaluate_symbolic_candidate() produced "
 781 |             f"{len(templates)} distinct equation templates across datasets. "
 782 |             "The base equation must be identical for all datasets; only fitted "
 783 |             f"constants may vary. Example templates: {examples}"
 784 |         )
 785 | 
 786 |     if violation_error:
 787 |         agg_nmse = float("inf")
 788 |         agg_train_nmse = float("inf")
 789 |         agg_combined = 0.0
 790 |         n_successful = 0
 791 |     else:
 792 |         agg_nmse = float(np.mean(nmse_vals)) if nmse_vals else float("inf")
 793 |         agg_train_nmse = float(np.mean(train_nmse_vals)) if train_nmse_vals else float("inf")
 794 |         raw_combined = (
 795 |             float(1.0 / (1.0 + max(agg_nmse, 0.0))) if np.isfinite(agg_nmse) else 0.0
 796 |         )
 797 |         parsimony_factor = _parsimony_penalty_factor(aggregate_complexity)
 798 |         agg_combined = raw_combined * parsimony_factor
 799 |         n_successful = sum(1 for value in nmse_vals if np.isfinite(value))
 800 | 
 801 |     aggregated = {
 802 |         "equation": eq_template,
 803 |         "nmse_train": agg_train_nmse,
 804 |         "nmse_val": agg_nmse,
 805 |         "combined_score": agg_combined,
 806 |         "fit_score": raw_combined if not violation_error else 0.0,
 807 |         "complexity": aggregate_complexity,
 808 |         "parsimony_weight": PARSIMONY_WEIGHT,
 809 |         "parsimony_penalty_factor": (
 810 |             _parsimony_penalty_factor(aggregate_complexity) if not violation_error else 1.0
 811 |         ),
 812 |         "n_datasets": len(per_dataset_results),
 813 |         "n_successful": n_successful,
 814 |         "eval_workers": NUM_WORKERS,
 815 |         "hard_cases": hard_cases,
 816 |         "hard_case_feedback": hard_case_feedback,
 817 |         "per_dataset": per_dataset_results,
 818 |     }
 819 |     if violation_error:
 820 |         aggregated["error"] = violation_error
 821 |     return aggregated
