import sys
sys.path.insert(0, '.')
import sympy as sp

# Check complexity of Model C
x0, x1, x2 = sp.symbols('x0 x1 x2')
c0, c1, c2 = sp.symbols('c0 c1 c2')

# Model C: (c0 + c1*x1)*(1-x2)*(1 + c2*x2)
expr_C = (c0 + c1*x1)*(1 - x2)*(1 + c2*x2)
print('Model C:', expr_C)
print('Expanded:', sp.expand(expr_C))

# Count nodes manually
def count_nodes(expr):
    return sum(1 for _ in sp.preorder_traversal(expr))

print('Node count C:', count_nodes(expr_C))

# Also check simpler variants
# Model B: c0*(1-x2) + c1*(1+c2*x1)*x2*(1-x2)
expr_B = c0*(1-x2) + c1*(1+c2*x1)*x2*(1-x2)
print('Model B nodes:', count_nodes(expr_B))

