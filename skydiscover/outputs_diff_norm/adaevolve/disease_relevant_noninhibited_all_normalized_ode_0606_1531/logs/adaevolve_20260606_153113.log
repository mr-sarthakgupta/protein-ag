 965 | def _metrics_from_result(result: dict, eval_time: float) -> dict:
 966 |     """Normalize aggregated harness output into SkyDiscover evaluator metrics."""
 967 |     nmse_val = float(result.get("nmse_val", float("inf")))
 968 |     combined = float(result.get("combined_score", combined_score_from_nmse(nmse_val)))
 969 |     if not np.isfinite(combined):
 970 |         combined = 0.0
 971 | 
 972 |     return {
 973 |         "equation": str(result.get("equation", "")),
 974 |         "loss": nmse_val,
 975 |         "complexity": float(result.get("complexity", 0.0)),
 976 |         "nmse_train": float(result.get("nmse_train", float("inf"))),
 977 |         "nmse_val": nmse_val,
 978 |         "combined_score": combined,
 979 |         "fit_score": float(result.get("fit_score", combined)),
 980 |         "parsimony_weight": float(result.get("parsimony_weight", PARSIMONY_WEIGHT)),
 981 |         "parsimony_penalty_factor": float(result.get("parsimony_penalty_factor", 1.0)),
 982 |         "eval_time": float(eval_time),
 983 |         "n_datasets": result.get("n_datasets", 0),
 984 |         "n_successful": result.get("n_successful", 0),
 985 |         "eval_workers": result.get("eval_workers", NUM_WORKERS),
 986 |         "hard_cases": result.get("hard_cases", []),
 987 |         "hard_case_feedback": str(result.get("hard_case_feedback", "")),
 988 |         "per_dataset": result.get("per_dataset", {}),
 989 |         "error": str(result.get("error", "")),
 990 |     }
 991 | 
 992 | 
 993 | def evaluate(program_path: str) -> dict:
 994 |     """Evaluate one evolved symbolic-equation candidate across all datasets."""
 995 |     try:
 996 |         start = time.time()
 997 |         result = evaluate_candidate_with_timeout(program_path, timeout_seconds=3000)
 998 |         metrics = _metrics_from_result(result, time.time() - start)
 999 |         print(
1000 |             "Evaluation: "
1001 |             f"nmse_val={metrics['nmse_val']:.6f}, "
1002 |             f"combined_score={metrics['combined_score']:.6f}, "
1003 |             f"n_datasets={metrics['n_datasets']}, "
1004 |             f"n_successful={metrics['n_successful']}, "
1005 |             f"time={metrics['eval_time']:.2f}s"
1006 |         )
1007 |         print(f"Equation template: {metrics['equation']}")
1008 |         if metrics.get("hard_case_feedback"):
1009 |             print(f"Hard-case feedback: {metrics['hard_case_feedback']}")
1010 |         if metrics.get("error"):
1011 |             print(f"Evaluator feedback: {metrics['error']}")
1012 |         return metrics
1013 |     except Exception as exc:
1014 |         print(f"Evaluation failed: {exc}")
1015 |         traceback.print_exc()
1016 |         return {
1017 |             "equation": "",
1018 |             "loss": float("inf"),
1019 |             "complexity": 0.0,
1020 |             "nmse_train": float("inf"),
1021 |             "nmse_val": float("inf"),
1022 |             "combined_score": 0.0,
1023 |             "eval_time": 0.0,
1024 |             "n_datasets": 0,
1025 |             "n_successful": 0,
1026 |             "hard_cases": [],
1027 |             "hard_case_feedback": "",
1028 |             "per_dataset": {},
1029 |             "error": str(exc),
1030 |         }
