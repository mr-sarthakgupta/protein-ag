# protein-ag workspace environment (sourced by run scripts and supervisor services)

PROTEINA_COMPLEXA_ROOT=/workspace/protein-ag/Proteina-Complexa
LOCAL_CODE_PATH=/workspace/protein-ag/Proteina-Complexa
CKPT_PATH=/workspace/protein-ag/Proteina-Complexa/ckpts
COMMUNITY_MODELS_PATH=/workspace/protein-ag/Proteina-Complexa/community_models
AF2_DIR=/workspace/protein-ag/Proteina-Complexa/community_models/ckpts/AF2
ESM_DIR=/workspace/protein-ag/Proteina-Complexa/community_models/ckpts/ESM2
RF3_DIR=/workspace/protein-ag/Proteina-Complexa/community_models/ckpts/RF3
RF3_CKPT_PATH=/workspace/protein-ag/Proteina-Complexa/community_models/ckpts/RF3/rf3_foundry_01_24_latest_remapped.ckpt
RF3_EXEC_PATH=/workspace/protein-ag/Proteina-Complexa/.venv/bin/rf3
DATA_PATH=/workspace/protein-ag/Proteina-Complexa/data
PROTEINA_PYTHON=/workspace/protein-ag/Proteina-Complexa/.venv/bin/python
PYTHONPATH=/workspace/protein-ag/Proteina-Complexa/src
HF_HOME=/workspace/protein-ag/Proteina-Complexa/community_models/ckpts/ESM2

# 24 GB GPU memory limits for Proteina binder-design evals (override if you have more VRAM)
SKYDISCOVER_BINDER_STAGE2_BATCH_SIZE=2
SKYDISCOVER_BINDER_STAGE2_NUM_LENGTH_SAMPLES=2
SKYDISCOVER_BINDER_STAGE2_REPLICAS=2
SKYDISCOVER_BINDER_MAX_BATCH_SIZE=4
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
